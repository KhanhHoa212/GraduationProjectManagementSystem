@model GPMS.Web.ViewModels.SubmissionsViewModel
@{
    ViewData["Title"] = "Documentation Submission";
    Layout = "_Layout";
}

<div class="p-8 space-y-10 animate-in fade-in slide-in-from-bottom-4 duration-1000">
    <!-- Header Section -->
    <div class="flex flex-col gap-1">
        <div class="flex items-center gap-2 text-[#64748b] text-[13px] font-medium mb-1">
            <span>Student Portal</span>
            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
            <span class="text-[#2563eb]">Submissions</span>
        </div>
        <h1 class="text-[36px] font-black text-[#0f172a] tracking-tight leading-tight">Documentation Submission</h1>
        <p class="text-[#64748b] text-[16px] max-w-2xl">Manage and upload your project deliverables for each review stage. Ensure all documents meet the required format before submission.</p>
    </div>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="htmx-notification-trigger" class="hidden" data-message="@TempData["SuccessMessage"]" data-type="success"></div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div id="htmx-notification-trigger" class="hidden" data-message="@TempData["ErrorMessage"]" data-type="error"></div>
    }


    <!-- Tabs Navigation (Segmented Control Style) -->
    <div class="inline-flex p-1.5 bg-[#f1f5f9] rounded-2xl border border-[#e2e8f0]">
        @foreach (var round in Model.ReviewRounds.OrderBy(r => r.RoundNumber))
        {
            var isActive = round.RoundNumber == Model.ActiveRoundNumber;
            <button onclick="switchRound(@round.RoundNumber)" 
                    id="tab-round-@round.RoundNumber"
                    class="group relative px-8 py-3 text-[14px] font-bold rounded-xl transition-all duration-300
                           @(isActive ? "bg-white text-[#2563eb] shadow-sm ring-1 ring-[#e2e8f0]" : "text-[#64748b] hover:text-[#0f172a] hover:bg-white/50")">
                <div class="flex items-center gap-2.5">
                    @if (round.Status == GPMS.Domain.Enums.RoundStatus.Completed)
                    {
                        <span class="material-symbols-outlined text-[20px] text-[#16a34a]">check_circle</span>
                    }
                    else if (round.Status == GPMS.Domain.Enums.RoundStatus.Ongoing)
                    {
                        <span class="material-symbols-outlined text-[20px] text-[#2563eb] animate-spin-slow">sync</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-[20px] text-[#94a3b8]">lock</span>
                    }
                    Round @round.RoundNumber
                </div>
            </button>
        }
    </div>

    @foreach (var round in Model.ReviewRounds)
    {
        var isActive = round.RoundNumber == Model.ActiveRoundNumber;
        var roundSubmissions = Model.Submissions.Where(s => s.RoundNumber == round.RoundNumber).ToList();
        var submittedCount = roundSubmissions.Count(s => s.IsSubmitted);
        var totalCount = roundSubmissions.Count;
        
        <div id="content-round-@round.RoundNumber" class="space-y-6 @(isActive ? "" : "hidden") round-content-panel">
            
            <!-- Round Status Banner -->
            @if (round.Status == GPMS.Domain.Enums.RoundStatus.Ongoing)
            {
                var daysLeft = (round.EndDate - DateTime.Now).Days;
                <div class="relative overflow-hidden p-6 bg-gradient-to-r from-[#eff6ff] to-[#f8faff] border border-[#dbeafe] rounded-2xl shadow-sm group">
                    <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-[80px]">auto_awesome</span>
                    </div>
                    <div class="flex items-center justify-between gap-6 relative z-10">
                        <div class="flex items-center gap-5">
                            <div class="size-14 rounded-2xl bg-white flex items-center justify-center text-[#2563eb] shadow-md border border-[#dbeafe]">
                                <span class="material-symbols-outlined text-[28px]">event_upcoming</span>
                            </div>
                            <div>
                                <h4 class="text-[15px] font-black text-[#1e40af] uppercase tracking-wider mb-0.5">Deadline approaching</h4>
                                <p class="text-[14px] text-[#3b82f6] font-medium">Round @round.RoundNumber ends on <span class="text-[#1e40af] font-bold">@round.EndDate.ToString("MMMM dd, yyyy")</span> · @(daysLeft > 0 ? $" {daysLeft} days remaining" : "Ending today")</p>
                            </div>
                        </div>
                        <div class="flex flex-col items-end gap-2">
                            <div class="px-4 py-1.5 bg-[#2563eb] text-white text-[13px] font-bold rounded-full shadow-lg shadow-blue-500/20">
                                @submittedCount / @totalCount Completed
                            </div>
                            @{
                                var progress = (double)submittedCount / totalCount * 100;
                            }
                            <div class="w-32 h-1.5 bg-[#dbeafe] rounded-full overflow-hidden">
                                <div class="h-full bg-[#2563eb] rounded-full transition-all duration-1000" style="width: @(progress)%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Deliverables List -->
            <div class="grid gap-6">
                @if (!roundSubmissions.Any())
                {
                    <div class="text-center py-12 bg-[#f8fafc] border-2 border-dashed border-[#e2e8f0] rounded-2xl">
                        <p class="text-[#64748b]">No requirements defined for this round.</p>
                    </div>
                }
                else
                {
                    foreach (var sub in roundSubmissions)
                    {
                        var isOverdue = !sub.IsSubmitted && sub.IsLate;
                        
                        <div class="group relative bg-white border @(isOverdue ? "border-red-200" : "border-[#e2e8f0]") rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:-translate-y-0.5">
                            <!-- Status Accent Bar -->
                            <div class="absolute left-0 top-0 bottom-0 w-1.5 
                                        @(sub.IsSubmitted ? "bg-[#22c55e]" : (isOverdue ? "bg-[#ef4444]" : "bg-[#f59e0b]"))"></div>
                            
                            <div class="p-7">
                                <div class="flex items-start justify-between gap-6">
                                    <div class="flex items-start gap-5 flex-1">
                                        <div class="size-14 rounded-2xl flex items-center justify-center flex-shrink-0 mt-0.5 shadow-sm
                                                    @(sub.IsSubmitted ? "bg-[#f0fdf4] text-[#16a34a] border border-[#dcfce7]" : (isOverdue ? "bg-[#fef2f2] text-[#dc2626] border border-[#fee2e2]" : "bg-[#fffbeb] text-[#d97706] border border-[#fef3c7]"))">
                                            <span class="material-symbols-outlined text-[30px]">
                                                @(sub.IsSubmitted ? "verified" : (isOverdue ? "emergency_home" : "pending_actions"))
                                            </span>
                                        </div>
                                        <div class="space-y-2 flex-1">
                                            <div class="flex items-center gap-3">
                                                <h3 class="text-[19px] font-black text-[#0f172a] tracking-tight">@sub.DocumentName</h3>
                                                @if (sub.IsSubmitted) {
                                                    <span class="px-2.5 py-0.5 bg-[#f0fdf4] text-[#16a34a] text-[11px] font-bold rounded-md uppercase tracking-wider border border-[#dcfce7]">Submitted</span>
                                                } else if (isOverdue) {
                                                    <span class="px-2.5 py-0.5 bg-[#fef2f2] text-[#dc2626] text-[11px] font-bold rounded-md uppercase tracking-wider border border-[#fee2e2]">Overdue</span>
                                                }
                                            </div>

                                            @if (isOverdue)
                                            {
                                                <p class="text-[14px] font-medium text-[#ef4444] flex items-center gap-2">
                                                    <span class="material-symbols-outlined text-[18px]">info</span>
                                                    Deadline passed — A late submission will be recorded.
                                                </p>
                                            }
                                            else if (!sub.IsSubmitted)
                                            {
                                                <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[13px] text-[#64748b]">
                                                    <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px]">file_present</span> @(string.IsNullOrEmpty(sub.AllowedFormats) ? "Any format" : sub.AllowedFormats.ToUpper())</span>
                                                    <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px]">database</span> Max @(sub.MaxFileSizeMB ?? 50)MB</span>
                                                    <span class="flex items-center gap-1.5 text-[#d97706] font-bold bg-[#fffbeb] px-2 py-0.5 rounded">
                                                        <span class="material-symbols-outlined text-[16px]">timer</span>
                                                        @( (sub.Deadline - DateTime.Now).Days > 0 ? $"{(sub.Deadline - DateTime.Now).Days} days left" : "Due today" )
                                                    </span>
                                                </div>
                                            }
                                            else
                                            {
                                                <p class="text-[14px] text-[#64748b] font-medium">Verified deliverable received by the system.</p>
                                            }

                                            @if (sub.IsSubmitted)
                                            {
                                                <div class="mt-6 p-4 bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl flex items-center justify-between group/file hover:border-[#ccd5e0] transition-colors">
                                                    <div class="flex items-center gap-4">
                                                        <div class="size-12 rounded-xl bg-white flex items-center justify-center text-[#2563eb] shadow-sm border border-[#e2e8f0]">
                                                            <span class="material-symbols-outlined text-[24px]">description</span>
                                                        </div>
                                                        <div>
                                                            <p class="text-[14px] font-bold text-[#0f172a]">@sub.FileName</p>
                                                            <p class="text-[12px] text-[#94a3b8] font-medium">@sub.SubmittedAt?.ToString("MMM dd, yyyy · HH:mm")</p>
                                                        </div>
                                                    </div>
                                                    <div class="flex items-center gap-2">
                                                        @{
                                                            var extension = System.IO.Path.GetExtension(sub.FileName)?.ToLower();
                                                            var canView = extension != ".zip" && extension != ".rar" && extension != ".7z";
                                                        }
                                                        @if (canView)
                                                        {
                                                            <a href="@sub.FileUrl" target="_blank" hx-boost="false" data-no-load class="px-4 py-2 text-[13px] font-bold text-[#475569] hover:bg-white rounded-xl transition-all flex items-center gap-2 border border-transparent hover:border-[#e2e8f0]">
                                                                Preview
                                                                <span class="material-symbols-outlined text-[18px]">visibility</span>
                                                            </a>
                                                        }
                                                        <a asp-action="DownloadSubmission" asp-route-id="@sub.SubmissionID" hx-boost="false" data-no-load class="no-spinner px-4 py-2 text-[13px] font-bold text-[#2563eb] hover:bg-blue-50 rounded-xl transition-all flex items-center gap-2 border border-transparent hover:border-blue-100">
                                                            Download
                                                            <span class="material-symbols-outlined text-[18px]">cloud_download</span>
                                                        </a>
                                                        <button onclick="toggleResubmit(@sub.RequirementID)" class="ml-2 px-5 py-2 text-[13px] font-bold bg-[#0f172a] text-white hover:bg-[#1e293b] rounded-xl transition-all shadow-md active:scale-95">Re-submit</button>
                                                    </div>
                                                </div>
                                                
                                                <!-- Hidden Resubmit Form -->
                                                <div id="resubmit-form-@sub.RequirementID" class="hidden mt-6 animate-in fade-in slide-in-from-top-4 duration-300">
                                                    <form asp-action="SubmitWork" method="post" enctype="multipart/form-data" class="space-y-4">
                                                        <input type="hidden" name="requirementId" value="@sub.RequirementID" />
                                                        <input type="hidden" name="roundNumber" value="@round.RoundNumber" />
                                                        <div class="group/dropzone border-2 border-dashed border-[#e2e8f0] rounded-2xl p-10 bg-[#f8fafc]/50 flex flex-col items-center justify-center gap-4 hover:border-[#2563eb] hover:bg-[#eff6ff] transition-all cursor-pointer relative">
                                                            <input type="file" name="file" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="updateFileName(this, @sub.RequirementID, '@sub.AllowedFormats')" accept="@sub.AllowedFormats" />
                                                            <div class="size-16 rounded-full bg-white flex items-center justify-center text-[#94a3b8] group-hover/dropzone:text-[#2563eb] group-hover/dropzone:scale-110 transition-all shadow-md">
                                                                <span class="material-symbols-outlined text-[36px]">upload</span>
                                                            </div>
                                                            <div class="text-center">
                                                                <p class="text-[15px] font-bold text-[#0f172a]" id="fileName-@sub.RequirementID">Upload a newer version</p>
                                                                <p class="text-[13px] text-[#64748b] font-medium mt-1" id="formatInfo-@sub.RequirementID">This will increment submission to <span class="text-[#2563eb]">Version @((sub.Version ?? 0) + 1)</span></p>
                                                                <p class="hidden text-[13px] font-bold text-red-500 mt-2" id="error-@sub.RequirementID"></p>
                                                            </div>
                                                        </div>
                                                        <div class="flex justify-end gap-3">
                                                            <button type="button" onclick="toggleResubmit(@sub.RequirementID)" class="px-6 py-2.5 text-[14px] font-bold text-[#64748b] hover:bg-[#f1f5f9] rounded-xl transition-all">Discard</button>
                                                            <button type="submit" id="resubmitBtn-@sub.RequirementID" class="hidden px-10 py-2.5 bg-[#2563eb] text-white text-[14px] font-black rounded-xl hover:bg-[#1d4ed8] transition-all shadow-lg shadow-blue-500/25 active:scale-[0.98]">Push New Version</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            }
                                            else
                                            {
                                                <form asp-action="SubmitWork" method="post" enctype="multipart/form-data" class="mt-6">
                                                    <input type="hidden" name="requirementId" value="@sub.RequirementID" />
                                                    <input type="hidden" name="roundNumber" value="@round.RoundNumber" />
                                                    <div class="border-2 border-dashed border-[#e2e8f0] rounded-2xl p-10 bg-[#f8fafc] flex flex-col items-center justify-center gap-4 group/dropzone hover:border-[#2563eb] hover:bg-[#eff6ff] transition-all cursor-pointer relative overflow-hidden">
                                                        <div class="absolute inset-0 bg-blue-50 opacity-0 group-hover/dropzone:opacity-30 transition-opacity"></div>
                                                        <input type="file" name="file" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20" onchange="updateFileName(this, @sub.RequirementID, '@sub.AllowedFormats')" required accept="@sub.AllowedFormats" />
                                                        <div class="size-16 rounded-full bg-white flex items-center justify-center text-[#94a3b8] group-hover/dropzone:text-[#2563eb] group-hover/dropzone:scale-110 transition-all shadow-md z-10">
                                                            <span class="material-symbols-outlined text-[36px]">cloud_upload</span>
                                                        </div>
                                                        <div class="text-center z-10">
                                                            <p class="text-[16px] font-black text-[#0f172a]" id="fileName-@sub.RequirementID">Drag and drop file or click to browse</p>
                                                            <p class="text-[13px] text-[#64748b] font-medium mt-1" id="formatInfo-@sub.RequirementID">Allowed: @(string.IsNullOrEmpty(sub.AllowedFormats) ? "All files" : sub.AllowedFormats.Replace(".", "").Replace(",", ", ").ToUpper())</p>
                                                            <p class="hidden text-[13px] font-bold text-[#dc2626] mt-2 bg-red-50 px-3 py-1 rounded-lg" id="error-@sub.RequirementID"></p>
                                                        </div>
                                                    </div>
                                                    <div class="mt-5 flex justify-end">
                                                        <button type="submit" id="submitBtn-@sub.RequirementID" class="hidden px-12 py-3 bg-[#2563eb] text-white text-[15px] font-black rounded-xl hover:bg-[#1d4ed8] hover:shadow-xl hover:shadow-blue-500/25 transition-all active:scale-[0.98]">Complete Submission</button>
                                                    </div>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

<script>
    function switchRound(roundNumber) {
        // Hide all panels
        document.querySelectorAll('.round-content-panel').forEach(panel => {
            panel.classList.add('hidden');
        });

        // Show selected panel
        document.getElementById('content-round-' + roundNumber).classList.remove('hidden');

        // Update tab styles
        document.querySelectorAll('[id^="tab-round-"]').forEach(tab => {
            tab.classList.remove('bg-white', 'text-[#2563eb]', 'shadow-sm', 'ring-1', 'ring-[#e2e8f0]');
            tab.classList.add('text-[#64748b]', 'hover:text-[#0f172a]', 'hover:bg-white/50');
        });

        const activeTab = document.getElementById('tab-round-' + roundNumber);
        activeTab.classList.remove('text-[#64748b]', 'hover:text-[#0f172a]', 'hover:bg-white/50');
        activeTab.classList.add('bg-white', 'text-[#2563eb]', 'shadow-sm', 'ring-1', 'ring-[#e2e8f0]');
    }

    function updateFileName(input, requirementId, allowedFormats) {
        const fileNameDisplay = document.getElementById('fileName-' + requirementId);
        const formatInfo = document.getElementById('formatInfo-' + requirementId);
        const errorMessage = document.getElementById('error-' + requirementId);
        const submitBtn = document.getElementById('submitBtn-' + requirementId);
        const resubmitBtn = document.getElementById('resubmitBtn-' + requirementId);
        
        if (input.files && input.files.length > 0) {
            const fileName = input.files[0].name;
            const extension = "." + fileName.split('.').pop().toLowerCase();
            const allowedList = allowedFormats ? allowedFormats.toLowerCase().split(',').map(f => f.trim()) : [];
            
            const isValid = !allowedFormats || allowedList.includes(extension) || allowedList.length === 0;
            
            if (isValid) {
                fileNameDisplay.innerText = "Selected: " + fileName;
                fileNameDisplay.classList.remove('text-red-500');
                fileNameDisplay.classList.add('text-[#2563eb]');
                if (formatInfo) formatInfo.classList.remove('hidden');
                if (errorMessage) errorMessage.classList.add('hidden');
                if (submitBtn) submitBtn.classList.remove('hidden');
                if (resubmitBtn) resubmitBtn.classList.remove('hidden');
            } else {
                fileNameDisplay.innerText = "Invalid Format";
                fileNameDisplay.classList.remove('text-[#2563eb]');
                fileNameDisplay.classList.add('text-red-500');
                if (formatInfo) formatInfo.classList.add('hidden');
                if (errorMessage) {
                    errorMessage.innerText = "Please select a supported format: " + allowedFormats.toUpperCase();
                    errorMessage.classList.remove('hidden');
                }
                if (submitBtn) submitBtn.classList.add('hidden');
                if (resubmitBtn) resubmitBtn.classList.add('hidden');
                
                // Clear input
                input.value = "";
            }
        } else {
            fileNameDisplay.innerText = "Drag and drop file or click to select";
            fileNameDisplay.classList.remove('text-[#2563eb]', 'text-red-500');
            if (formatInfo) formatInfo.classList.remove('hidden');
            if (errorMessage) errorMessage.classList.add('hidden');
            if (submitBtn) submitBtn.classList.add('hidden');
            if (resubmitBtn) resubmitBtn.classList.add('hidden');
        }
    }

    function toggleResubmit(requirementId) {
        const form = document.getElementById('resubmit-form-' + requirementId);
        form.classList.toggle('hidden');
    }
</script>

@model GPMS.Application.DTOs.ProjectDefenseScheduleDto
@{
    ViewData["Title"] = "Project Defense Schedule";
    Layout = "_StudentLayout";
}

<div class="p-6 lg:p-10 max-w-7xl mx-auto animate-fadeIn">
    <!-- Header Section -->
    <div class="mb-10">
        <h1 class="text-4xl font-black text-[#1e3a5f] dark:text-white tracking-tight leading-none mb-3">Defense Schedule</h1>
        <p class="text-slate-500 dark:text-dark-300 text-lg font-medium">Detailed information about the official project defense session</p>
    </div>

    @if (Model == null)
    {
        <!-- Empty State UI -->
        <div class="bg-white dark:bg-dark-800 rounded-3xl p-12 shadow-2xl shadow-slate-200/50 dark:shadow-none border border-slate-100 dark:border-dark-700 text-center max-w-2xl mx-auto">
            <div class="w-24 h-24 bg-slate-50 dark:bg-dark-700 rounded-full flex items-center justify-center mx-auto mb-8">
                <span class="material-symbols-outlined text-5xl text-slate-400">calendar_today</span>
            </div>
            <h2 class="text-2xl font-bold text-slate-800 dark:text-white mb-4">No defense schedule yet</h2>
            <p class="text-slate-500 dark:text-dark-400 mb-8 leading-relaxed">
                Currently, your group hasn't been scheduled for an official defense session. 
                Please check back later or contact the Office of Academic Affairs for any inquiries.
            </p>
            <a asp-action="Index" class="inline-flex items-center gap-2 px-8 py-4 bg-primary-500 hover:bg-primary-600 text-white font-bold rounded-2xl transition-all duration-300 shadow-lg shadow-primary-500/30">
                <span class="material-symbols-outlined">arrow_back</span>
                Back to Dashboard
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Left Column: Main Info -->
            <div class="lg:col-span-8 space-y-8">
                
                <!-- Announcement Banner -->
                <div class="bg-blue-50/80 dark:bg-blue-900/10 border border-blue-100 dark:border-blue-900/30 rounded-3xl p-6 flex gap-5 items-start backdrop-blur-sm">
                    <div class="w-12 h-12 bg-white dark:bg-dark-800 rounded-2xl shadow-sm flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-blue-500">campaign</span>
                    </div>
                    <div>
                        <p class="text-blue-900 dark:text-blue-300 font-bold mb-1 leading-snug">
                            📅 The defense schedule has been announced. Please read the information carefully and prepare all necessary documents before the scheduled date.
                        </p>
                    </div>
                </div>

                <!-- Session Info Card -->
                <div class="bg-white dark:bg-dark-800 rounded-[2.5rem] shadow-xl shadow-slate-200/40 dark:shadow-none border border-slate-100 dark:border-dark-700 overflow-hidden transform transition-all duration-500 hover:shadow-2xl">
                    <div class="px-8 py-6 border-b border-slate-50 dark:border-dark-700 flex items-center gap-3">
                        <span class="material-symbols-outlined text-[#F37021] filled">calendar_month</span>
                        <h2 class="text-sm font-black text-slate-400 dark:text-dark-400 uppercase tracking-[0.15em]">Session Information</h2>
                    </div>
                    
                    <div class="p-10">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                            <!-- Time & Location -->
                            <div class="space-y-8">
                                <div>
                                    <span class="block text-[10px] font-bold text-slate-400 dark:text-dark-500 uppercase tracking-widest mb-3">Time</span>
                                    <div class="space-y-1">
                                        <div class="text-3xl font-black text-slate-800 dark:text-white tracking-tight">
                                            @Model.ScheduledAt.ToString("dd/MM/yyyy")
                                        </div>
                                        <div class="text-xl font-bold text-slate-500 dark:text-dark-300">
                                            @Model.ScheduledAt.ToString("HH:mm") - @Model.ScheduledAt.AddHours(1).ToString("HH:mm")
                                        </div>
                                    </div>
                                </div>

                                <div>
                                    <span class="block text-[10px] font-bold text-slate-400 dark:text-dark-500 uppercase tracking-widest mb-3">Location</span>
                                    <div class="space-y-1">
                                        <div class="text-2xl font-black text-slate-800 dark:text-white tracking-tight">
                                            Room @Model.RoomName, @Model.Building
                                        </div>
                                        <div class="text-sm font-medium text-slate-400 dark:text-dark-400 italic">
                                            @Model.LocationDetails
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Format & Note -->
                            <div class="space-y-8">
                                <div>
                                    <span class="block text-[10px] font-bold text-slate-400 dark:text-dark-500 uppercase tracking-widest mb-3">Format</span>
                                    <span class="inline-flex px-4 py-2 bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 text-xs font-black rounded-xl border border-emerald-100 dark:border-emerald-500/20 uppercase tracking-widest">
                                        @(string.IsNullOrEmpty(Model.MeetLink) ? "Offline" : "Online")
                                    </span>
                                </div>

                                <div>
                                    <span class="block text-[10px] font-bold text-slate-400 dark:text-dark-500 uppercase tracking-widest mb-3">Note</span>
                                    <p class="text-sm font-medium text-slate-500 dark:text-dark-300 leading-relaxed italic">
                                        @(string.IsNullOrEmpty(Model.Notes) ? "Candidates must wear uniforms and be present 15 minutes early to prepare technical equipment." : Model.Notes)
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Committee Card -->
                <div class="bg-white dark:bg-dark-800 rounded-[2.5rem] shadow-xl shadow-slate-200/40 dark:shadow-none border border-slate-100 dark:border-dark-700 overflow-hidden transform transition-all duration-500 hover:shadow-2xl">
                    <div class="px-8 py-6 border-b border-slate-50 dark:border-dark-700 flex items-center gap-3">
                        <span class="material-symbols-outlined text-[#F37021] filled">groups</span>
                        <h2 class="text-sm font-black text-slate-400 dark:text-dark-400 uppercase tracking-[0.15em]">Examination Committee</h2>
                    </div>
                    
                    <div class="divide-y divide-slate-50 dark:divide-dark-700">
                        @foreach (var member in Model.CommitteeMembers)
                        {
                            <div class="p-6 md:p-8 flex items-center justify-between group hover:bg-slate-50/50 dark:hover:bg-dark-700/30 transition-colors duration-300">
                                <div class="flex items-center gap-5">
                                    <div class="w-14 h-14 bg-gradient-to-br from-slate-100 to-slate-200 dark:from-dark-700 dark:to-dark-600 rounded-2xl flex items-center justify-center text-slate-400 dark:text-dark-300 shadow-inner group-hover:scale-105 transition-transform duration-500 overflow-hidden">
                                        @if (!string.IsNullOrEmpty(member.AvatarUrl))
                                        {
                                            <img src="@member.AvatarUrl" alt="@member.FullName" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-3xl font-bold">person</span>
                                        }
                                    </div>
                                    <div>
                                        <div class="text-lg font-black text-slate-800 dark:text-white mb-1 group-hover:text-primary-500 transition-colors">@member.FullName</div>
                                        <div class="text-[11px] font-bold text-slate-400 dark:text-dark-500 uppercase tracking-widest">LECTURER ID: @member.UserID</div>
                                    </div>
                                </div>
                                <span class="px-5 py-2 bg-slate-50 dark:bg-dark-700 text-slate-500 dark:text-dark-300 text-[10px] font-black rounded-xl border border-slate-100 dark:border-dark-600 uppercase tracking-widest group-hover:bg-[#F37021]/10 group-hover:text-[#F37021] group-hover:border-[#F37021]/20 transition-all duration-300">
                                    @member.Role
                                </span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right Column: Sidebar Actions -->
            <div class="lg:col-span-4 space-y-8">
                <!-- Countdown Card -->
                <div class="bg-[#1e3a5f] rounded-[2.5rem] p-8 text-white shadow-2xl shadow-blue-900/40 relative overflow-hidden group">
                    <div class="absolute -right-10 -top-10 w-40 h-40 bg-white/5 rounded-full blur-3xl group-hover:bg-white/10 transition-colors duration-700"></div>
                    
                    <div class="relative z-10">
                        <div class="text-center mb-8">
                            <span class="text-[10px] font-black uppercase tracking-[0.2em] text-blue-200 opacity-60">Countdown Timer</span>
                        </div>
                        
                        <div id="countdown-timer" class="grid grid-cols-4 gap-3 mb-10" data-target="@Model.ScheduledAt.ToString("yyyy-MM-ddTHH:mm:ss")">
                            <div class="text-center">
                                <div class="bg-white/10 backdrop-blur-md rounded-2xl py-3 border border-white/10 mb-2">
                                    <span id="days" class="text-2xl font-black leading-none">00</span>
                                </div>
                                <span class="text-[8px] font-bold uppercase tracking-widest text-blue-200/50">Days</span>
                            </div>
                            <div class="text-center">
                                <div class="bg-white/10 backdrop-blur-md rounded-2xl py-3 border border-white/10 mb-2">
                                    <span id="hours" class="text-2xl font-black leading-none">00</span>
                                </div>
                                <span class="text-[8px] font-bold uppercase tracking-widest text-blue-200/50">Hours</span>
                            </div>
                            <div class="text-center">
                                <div class="bg-white/10 backdrop-blur-md rounded-2xl py-3 border border-white/10 mb-2">
                                    <span id="minutes" class="text-2xl font-black leading-none">00</span>
                                </div>
                                <span class="text-[8px] font-bold uppercase tracking-widest text-blue-200/50">Mins</span>
                            </div>
                            <div class="text-center">
                                <div class="bg-white/10 backdrop-blur-md rounded-2xl py-3 border border-white/10 mb-2">
                                    <span id="seconds" class="text-2xl font-black leading-none">00</span>
                                </div>
                                <span class="text-[8px] font-bold uppercase tracking-widest text-blue-200/50">Secs</span>
                            </div>
                        </div>

                        <button class="w-full py-5 bg-[#F37021] hover:bg-[#F37021]/90 rounded-[1.25rem] font-black text-sm uppercase tracking-widest flex items-center justify-center gap-3 transition-all duration-300 shadow-xl shadow-orange-900/30 active:scale-[0.98]">
                            <span class="material-symbols-outlined filled">calendar_add_on</span>
                            Add to Google Calendar
                        </button>
                    </div>
                </div>

            </div>
        </div>
    }
</div>

<style>
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fadeIn {
        animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const timerContainer = document.getElementById('countdown-timer');
        if (!timerContainer) return;

        const targetDate = new Date(timerContainer.dataset.target).getTime();

        function updateCountdown() {
            const now = new Date().getTime();
            const distance = targetDate - now;

            if (distance < 0) {
                document.getElementById('days').innerText = "00";
                document.getElementById('hours').innerText = "00";
                document.getElementById('minutes').innerText = "00";
                document.getElementById('seconds').innerText = "00";
                
                // Optional: Change header text if expired
                const headerSpan = timerContainer.previousElementSibling.querySelector('span');
                if (headerSpan) headerSpan.innerText = "SESSION STARTED / FINISHED";
                
                return;
            }

            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);

            document.getElementById('days').innerText = String(days).padStart(2, '0');
            document.getElementById('hours').innerText = String(hours).padStart(2, '0');
            document.getElementById('minutes').innerText = String(minutes).padStart(2, '0');
            document.getElementById('seconds').innerText = String(seconds).padStart(2, '0');
        }

        // Run once immediately
        updateCountdown();
        
        // Update every second
        const x = setInterval(updateCountdown, 1000);
    });
</script>

@model GPMS.Web.ViewModels.StudentFeedbackHistoryViewModel
@{
    ViewData["Title"] = "Feedback History";
}

<div class="row">
    @if (Model.Feedbacks.Any())
    {
        @foreach (var fb in Model.Feedbacks)
        {
            <div class="col-12 col-xl-6 mb-4">
                <div class="card h-100">
                    <div class="card-header pb-0 p-3">
                        <div class="row">
                            <div class="col-md-8 d-flex align-items-center">
                                <h6 class="mb-0">@fb.ProjectName - @fb.RoundName</h6>
                            </div>
                            <div class="col-md-4 text-end">
                                <span class="badge bg-gradient-success">Released @fb.SubmittedAt.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-3">
                        <p class="text-sm">
                            <strong>Reviewer:</strong> @fb.ReviewerName
                        </p>
                        <hr class="horizontal gray-light my-2">
                        <p class="text-sm font-weight-bold mb-1">General Feedback:</p>
                        <p class="text-sm text-secondary mb-3">@fb.Content</p>

                        <div class="table-responsive">
                            <table class="table align-items-center mb-0">
                                <thead>
                                    <tr>
                                        <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 px-2" style="width:15%">Code</th>
                                        <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 px-2" style="width:65%">Criteria</th>
                                        <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 text-center px-2" style="width:20%">Assessment</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var item in fb.Items)
                                    {
                                        <tr>
                                            <td class="px-2"><span class="text-xs font-weight-bold">@item.ItemCode</span></td>
                                            <td class="px-2 text-wrap"><span class="text-xs text-secondary">@item.ItemContent</span></td>
                                            <td class="text-center px-2"><span class="text-xs font-weight-bold">@item.Assessment</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="card">
                <div class="card-body p-5 text-center">
                    <p class="text-lg mb-0 text-muted">No feedback has been released for your group yet.</p>
                </div>
            </div>
        </div>
    }
</div>

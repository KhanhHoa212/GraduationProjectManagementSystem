@model IEnumerable<GPMS.Web.ViewModels.MajorViewModel>
@{
    ViewData["Title"] = "Major Management";

    ViewData["BreadcrumbTitle"] = "Majors";

    Layout = "_Layout";
}

<div class="max-w-7xl mx-auto">
    <!-- Page Header -->
    <div class="flex flex-wrap justify-between items-start gap-6 mb-8">
        <div>
            <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight">Major Management</h1>
            <p class="text-slate-500 text-sm mt-1">Manage academic majors and their associated faculties.</p>
        </div>
        <a asp-action="Create"
            class="flex items-center gap-2 rounded-xl bg-primary hover:bg-orange-600 text-black px-5 py-2.5 text-sm font-bold transition-all shadow-lg shadow-primary/25 no-underline">
            <span class="material-symbols-outlined text-[18px]">add_circle</span>
            <span>Create New Major</span>
        </a>
    </div>

    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)

    {
        <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl flex items-center gap-3">
            <span class="material-symbols-outlined text-green-500">check_circle</span>
            <p class="text-sm text-green-700 font-medium">@TempData["SuccessMessage"]</p>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)

    {
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl flex items-center gap-3">
            <span class="material-symbols-outlined text-red-500">error</span>
            <p class="text-sm text-red-700 font-medium">@TempData["ErrorMessage"]</p>
        </div>
    }

    <!-- Table -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-200">
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Major Code</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Major Name</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Faculty</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">
                            Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var m in Model)

                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4 font-bold text-slate-900">@m.MajorCode</td>
                            <td class="px-6 py-4 text-sm text-slate-600">@m.MajorName</td>
                            <td class="px-6 py-4 text-sm text-slate-600">@m.FacultyName</td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end gap-1">
                                    <a asp-action="Edit" asp-route-id="@m.MajorID"
                                        class="p-2 text-slate-400 hover:text-primary hover:bg-primary/10 rounded-lg transition-all no-underline">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@m.MajorID" method="post"
                                        onsubmit="return confirm('Are you sure you want to delete this major?');"
                                        style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                            class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all border-none bg-transparent">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

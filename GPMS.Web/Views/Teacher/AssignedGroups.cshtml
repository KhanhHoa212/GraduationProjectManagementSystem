@model GPMS.Web.ViewModels.ReviewerDashboardViewModel
@{
    ViewData["Title"] = "Assigned Groups for Review";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header pb-0">
                    <h6>Assigned Review Groups</h6>
                </div>
                <div class="card-body px-0 pt-0 pb-2">
                    <div class="table-responsive p-0">
                        <table class="table align-items-center mb-0">
                            <thead>
                                <tr>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Project</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 ps-2">Round</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Type</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Scheduled</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Location / Link</th>
                                    <th class="text-secondary opacity-7"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.AssignedGroups.Any())
                                {
                                    @foreach (var item in Model.AssignedGroups)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex px-2 py-1">
                                                    <div class="d-flex flex-column justify-content-center">
                                                        <h6 class="mb-0 text-sm">@item.ProjectName</h6>
                                                        <p class="text-xs text-secondary mb-0">Group: @item.GroupName</p>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <p class="text-xs font-weight-bold mb-0">Round @item.RoundNumber</p>
                                                <p class="text-xs text-secondary mb-0">@item.StartDate.ToString("dd/MM/yyyy")</p>
                                            </td>
                                            <td class="align-middle text-center text-sm">
                                                @if (item.RoundType == GPMS.Domain.Enums.RoundType.Online)
                                                {
                                                    <span class="badge badge-sm bg-gradient-info">Online</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-sm bg-gradient-primary">Offline</span>
                                                }
                                            </td>
                                            <td class="align-middle text-center">
                                                <span class="text-secondary text-xs font-weight-bold">
                                                    @(item.ScheduledAt.HasValue ? item.ScheduledAt.Value.ToString("dd/MM/yyyy HH:mm") : "TBD")
                                                </span>
                                            </td>
                                            <td class="align-middle text-center">
                                                @if (item.RoundType == GPMS.Domain.Enums.RoundType.Online && !string.IsNullOrEmpty(item.MeetLink))
                                                {
                                                    <a href="@item.MeetLink" target="_blank" class="text-secondary text-xs font-weight-bold text-info"><i class="fas fa-video me-1"></i> Join Meet</a>
                                                }
                                                else if (item.RoundType == GPMS.Domain.Enums.RoundType.Offline && !string.IsNullOrEmpty(item.RoomCode))
                                                {
                                                    <span class="text-secondary text-xs font-weight-bold"><i class="fas fa-map-marker-alt me-1"></i> Room @item.RoomCode</span>
                                                }
                                                else
                                                {
                                                    <span class="text-secondary text-xs">Not specified</span>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                <a href="@Url.Action("EvaluationForm", "Teacher", new { roundId = item.ReviewRoundID, groupId = item.GroupID })" class="text-secondary font-weight-bold text-xs bg-gradient-success p-2 text-white rounded" data-toggle="tooltip" data-original-title="Evaluate">
                                                    Evaluate
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center p-4">
                                            <p class="text-sm mb-0">You have no assigned groups to review at the moment.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

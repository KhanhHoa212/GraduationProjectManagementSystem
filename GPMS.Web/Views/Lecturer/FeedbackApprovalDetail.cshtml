@using System
@using System.Linq
@using GPMS.Domain.Enums
@model GPMS.Web.ViewModels.Lecturer.FeedbackApprovalDetailViewModel
@{
    ViewData["Title"] = "Feedback Approval Detail";
    Layout = "_Layout";
    var isGradeRound = Model.Scores.Any(s => s.ItemType == "Grade");
    var groupedScores = Model.Scores
        .Select((score, index) => new { score, index })
        .GroupBy(x => x.score.Section ?? "Checklist");
}

<div class="page-header d-flex justify-content-between align-items-center mb-4 pb-3">
    <div>
        <h1 class="page-title">Mentor Review Approval</h1>
        <p class="page-subtitle text-muted mb-0">@Model.GroupName - Round @Model.CurrentRoundIndex (@Model.ReviewRoundName)</p>
    </div>
    <div class="d-flex gap-2">
        <span class="badge @(Model.ApprovalStatus == ApprovalStatus.Pending ? "bg-warning-subtle text-warning" : Model.ApprovalStatus == ApprovalStatus.Approved ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") px-3 py-2">
            @Model.ApprovalStatus
        </span>
        <span class="badge @(Model.MentorGateStatus == MentorGateStatus.Approved ? "bg-success-subtle text-success" : Model.MentorGateStatus == MentorGateStatus.Rejected ? "bg-danger-subtle text-danger" : "bg-secondary-subtle text-secondary") px-3 py-2">
            Gate: @Model.MentorGateStatus
        </span>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.MentorGateComment))
{
    <div class="alert alert-info border-0 mb-4">
        <div class="fw-semibold mb-1">Pre-review mentor comment</div>
        <div style="font-size:13px;">@Model.MentorGateComment</div>
    </div>
}

<form asp-action="ApproveFeedback" asp-controller="Lecturer" method="post" id="feedbackActionForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="FeedbackID" />
    <input type="hidden" name="decision" id="decisionInput" value="" />
    <input type="hidden" name="comments" id="commentsInput" value="" />

    <div class="row g-4">
        <div class="col-xl-8 d-flex flex-column gap-section">
            @if (isGradeRound)
            {
                <div class="card-panel border p-0 overflow-hidden shadow-sm mb-0">
                    <div class="p-3 border-bottom d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined" style="color:var(--fpt-orange)">grading</span>
                        <h2 class="section-title mb-0">Round 3 Review Table</h2>
                    </div>
                    <div class="table-responsive">
                        <table class="table mb-0 align-middle">
                            <thead>
                                <tr class="bg-light">
                                    <th style="min-width:80px;">Code</th>
                                    <th style="min-width:180px;">Name</th>
                                    <th style="min-width:240px;">Criteria</th>
                                    <th style="min-width:150px;">Grade Level</th>
                                    <th style="min-width:220px;">Grade</th>
                                    <th style="min-width:220px;">Mentor Comment</th>
                                    <th style="min-width:220px;">Reviewer Comment</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < Model.Scores.Count; i++)
                                {
                                    var score = Model.Scores[i];
                                    <tr>
                                        <td>
                                            <input type="hidden" asp-for="Scores[@i].ItemID" value="@score.ItemID" />
                                            @score.ItemCode
                                        </td>
                                        <td>@score.ItemName</td>
                                        <td>
                                            <div style="white-space:pre-line; font-size:13px;">@score.ItemContent</div>
                                        </td>
                                        <td><span class="badge bg-light text-body border">@score.Assessment</span></td>
                                        <td>
                                            <div class="small text-muted">@score.GradeDescription</div>
                                            <details class="mt-2">
                                                <summary class="text-primary" style="cursor:pointer; font-size:12px;">Rubric reference</summary>
                                                <div class="small text-muted mt-2">
                                                    <div><strong>Excellent:</strong> @score.RubricDescriptions.FirstOrDefault(r => r.GradeLevel == "Excellent")?.Description</div>
                                                    <div class="mt-1"><strong>Good:</strong> @score.RubricDescriptions.FirstOrDefault(r => r.GradeLevel == "Good")?.Description</div>
                                                    <div class="mt-1"><strong>Acceptable:</strong> @score.RubricDescriptions.FirstOrDefault(r => r.GradeLevel == "Acceptable")?.Description</div>
                                                    <div class="mt-1"><strong>Fail:</strong> @score.RubricDescriptions.FirstOrDefault(r => r.GradeLevel == "Fail")?.Description</div>
                                                </div>
                                            </details>
                                        </td>
                                        <td><textarea asp-for="Scores[@i].MentorComment" class="form-control" rows="4" placeholder="Mentor comment"></textarea></td>
                                        <td><textarea class="form-control" rows="4" readonly>@score.ReviewerComment</textarea></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="card-panel border shadow-sm mb-0">
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <span class="material-symbols-outlined" style="color:var(--fpt-orange)">rule_settings</span>
                        <h2 class="section-title mb-0">Reviewer Checklist Submission</h2>
                    </div>

                    @foreach (var sectionGroup in groupedScores)
                    {
                        <div class="mb-4">
                            <div class="fw-bold mb-3" style="font-size:15px;">@sectionGroup.Key</div>
                            <div class="table-responsive">
                                <table class="table align-middle mb-0">
                                    <thead>
                                        <tr class="bg-light">
                                            <th style="min-width:320px;">Question</th>
                                            <th style="min-width:110px;">Priority</th>
                                            <th style="min-width:130px;">Assessment</th>
                                            <th style="min-width:220px;">Mentor Comment</th>
                                            <th style="min-width:220px;">Reviewer Comment</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in sectionGroup)
                                        {
                                            var score = row.score;
                                            var i = row.index;
                                            <tr>
                                                <td>
                                                    <input type="hidden" asp-for="Scores[@i].ItemID" value="@score.ItemID" />
                                                    <div class="fw-medium">@score.ItemContent</div>
                                                </td>

                                                <td><span class="badge bg-light text-body border">@score.Assessment</span></td>
                                                <td><textarea asp-for="Scores[@i].MentorComment" class="form-control" rows="3" placeholder="Mentor comment"></textarea></td>
                                                <td><textarea class="form-control" rows="3" readonly>@score.ReviewerComment</textarea></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="card-panel border shadow-sm mb-0">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="section-title mb-0">Overall Feedback to Student Group</h2>
                    <span class="small text-muted">Submitted: @Model.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</span>
                </div>
                <textarea asp-for="FeedbackContent" class="form-control" rows="8" id="editedFeedbackInput"></textarea>
            </div>
        </div>

        <div class="col-xl-4 d-flex flex-column gap-section">
            <div class="card-panel border shadow-sm mb-0">
                <div class="fw-semibold mb-2">Review Meta</div>
                <div class="small text-muted mb-1">Reviewer: @Model.ReviewerName</div>
                <div class="small text-muted mb-1">Round: @Model.CurrentRoundIndex / @Model.TotalRounds</div>

                <div class="small text-muted">Latest supervisor note: @(string.IsNullOrWhiteSpace(Model.SupervisorComment) ? "None" : Model.SupervisorComment)</div>
            </div>

            <div class="card-panel border shadow-sm mb-0">
                <h2 class="section-title mb-3">Decision Panel</h2>
                <button type="button" class="btn btn-primary w-100 mb-3" onclick="prepareDecision('Approve')" data-bs-toggle="modal" data-bs-target="#confirmApproveModal">Approve</button>
                <button type="button" class="btn btn-secondary w-100 mb-3" onclick="prepareDecision('ApproveWithEdits')" data-bs-toggle="modal" data-bs-target="#confirmApproveEditsModal">Approve with Edits</button>
                <button type="button" class="btn btn-danger w-100" onclick="prepareDecision('Reject')" data-bs-toggle="modal" data-bs-target="#confirmRejectModal">Reject</button>
            </div>
        </div>
    </div>
</form>

<div class="modal fade" id="confirmApproveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Approve Feedback</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">This will approve the review and make it available for student release according to the auto-release rule.</div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitApproval()">Confirm</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmApproveEditsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Approve With Edits</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">Your edited overall feedback and mentor comments will be saved before approval.</div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitApproval()">Confirm</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmRejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold text-danger">Reject Feedback</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Rejection Reason</label>
                <textarea class="form-control" rows="4" id="rejectReasonInput" placeholder="Explain what the reviewer needs to revise."></textarea>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="submitApproval()">Reject</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function prepareDecision(decision) {
            document.getElementById('decisionInput').value = decision;
        }

        function submitApproval() {
            const decision = document.getElementById('decisionInput').value;
            const commentsInput = document.getElementById('commentsInput');
            commentsInput.value = decision === 'Reject'
                ? document.getElementById('rejectReasonInput').value
                : '';
            document.getElementById('feedbackActionForm').submit();
        }
    </script>
}

@using GPMS.Web.ViewModels.Lecturer
@model LecturerDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_LecturerLayout";
}

<div class="alert border-0 mb-4" style="background:#FFF7F2; color:var(--text-body);">
    <div class="d-flex align-items-start gap-2">
        <span class="material-symbols-outlined" style="color:var(--fpt-orange)">tips_and_updates</span>
        <div>
            <div class="fw-semibold mb-1">What needs your attention</div>
            <div style="font-size:13px;">@Model.GuidanceMessage</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="card-panel h-100 d-flex flex-column justify-content-center">
            <div class="text-muted fw-bold mb-1" style="font-size:11px; letter-spacing:1px;">GROUPS MENTORING</div>
            <div class="d-flex justify-content-between align-items-center">
                <div class="fw-bold" style="font-size:32px; letter-spacing:-1px;">@Model.MentoringGroupsCount</div>
                <div class="rounded p-2" style="background:#FFF7F2; color:var(--fpt-orange)">
                    <span class="material-symbols-outlined">people</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card-panel h-100 d-flex flex-column justify-content-center">
            <div class="text-muted fw-bold mb-1" style="font-size:11px; letter-spacing:1px;">PENDING APPROVALS</div>
            <div class="d-flex justify-content-between align-items-center">
                <div class="fw-bold" style="font-size:32px; letter-spacing:-1px;">@Model.PendingApprovalsCount</div>
                <div class="rounded p-2" style="background:#FFF7F2; color:var(--fpt-orange)">
                    <span class="material-symbols-outlined">fact_check</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card-panel h-100 d-flex flex-column justify-content-center">
            <div class="text-muted fw-bold mb-1" style="font-size:11px; letter-spacing:1px;">ASSIGNED REVIEWS</div>
            <div class="d-flex justify-content-between align-items-center">
                <div class="fw-bold" style="font-size:32px; letter-spacing:-1px;">@Model.AssignedReviewsCount</div>
                <div class="rounded p-2" style="background:#FFF7F2; color:var(--fpt-orange)">
                    <span class="material-symbols-outlined">assignment</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card-panel h-100 d-flex flex-column justify-content-center border-0" style="border-left: 4px solid var(--error-text) !important;">
            <div class="text-muted fw-bold mb-1" style="font-size:11px; letter-spacing:1px;">UPCOMING DEADLINES</div>
            <div class="d-flex justify-content-between align-items-center">
                <div class="fw-bold text-danger" style="font-size:32px; letter-spacing:-1px;">@Model.UpcomingDeadlinesCount</div>
                <div class="rounded p-2" style="background:var(--error-bg); color:var(--error-text)">
                    <span class="material-symbols-outlined">event_busy</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card-panel h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="section-title mb-0">Recent Activity</h2>
                <a href="@Url.Action("History", "Lecturer")" class="text-decoration-none fw-semibold" style="font-size:13px; color:var(--fpt-orange)">View History</a>
            </div>

            @if (!Model.RecentActivities.Any())
            {
                <p class="text-muted text-center py-4">No recent activity.</p>
            }
            else
            {
                <div class="d-flex flex-column gap-4">
                    @foreach (var item in Model.RecentActivities)
                    {
                        <div class="d-flex gap-3">
                            <div class="flex-shrink-0 mt-1">
                                <div class="d-flex align-items-center justify-content-center text-white rounded-circle" style="width:36px; height:36px; background:@item.IconBgColor">
                                    <span class="material-symbols-outlined" style="font-size:18px;">@item.Icon</span>
                                </div>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <h6 class="mb-0 fw-bold" style="font-size:14px;">@item.Title</h6>
                                    <span class="text-muted" style="font-size:12px;" title="@item.Timestamp.ToString("g")">
                                        @{
                                            var diff = DateTime.Now - item.Timestamp;
                                            var ago = diff.TotalHours < 1
                                                ? $"{(int)diff.TotalMinutes}m ago"
                                                : diff.TotalDays < 1
                                                    ? $"{(int)diff.TotalHours}h ago"
                                                    : item.Timestamp.ToString("MMM dd");
                                        }
                                        @ago
                                    </span>
                                </div>
                                <p class="text-muted mb-2" style="font-size:13px;">@item.Description</p>
                                @if (!string.IsNullOrEmpty(item.ActionUrl))
                                {
                                    <a href="@item.ActionUrl" class="btn btn-primary py-1 px-3 d-inline-flex" style="font-size:12px;">@item.ActionText</a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="col-lg-4 d-flex flex-column gap-section">
        <div class="card-panel mb-0 flex-grow-1">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="section-title d-flex align-items-center gap-2 mb-0">
                    <span class="material-symbols-outlined" style="color:var(--fpt-orange); font-size: 20px;">calendar_today</span>
                    Upcoming Schedule
                </h2>
                <a href="@Url.Action("Schedule", "Lecturer")" class="text-decoration-none" style="font-size:12px; color:var(--fpt-orange)">Full schedule</a>
            </div>

            @if (!Model.TodaysSchedule.Any())
            {
                <p class="text-muted text-center py-4">No upcoming sessions found.</p>
            }
            else
            {
                <div class="d-flex flex-column gap-3 mt-4">
                    @foreach (var session in Model.TodaysSchedule)
                    {
                        var borderColor = session.IsHighlight ? "var(--fpt-orange)" : "#D1D5DB";
                        var bgColor = session.IsHighlight ? "#FFF7F2" : "#F9FAFB";
                        var timeColor = session.IsHighlight ? "var(--fpt-orange)" : "inherit";
                        <div class="p-3 border rounded border-start border-4" style="border-left-color: @borderColor !important; background:@bgColor;">
                            <div class="d-flex gap-3">
                                <div class="text-center" style="color:@timeColor; min-width: 56px;">
                                    <div class="fw-bold" style="font-size:14px;">@session.StartTime.ToString("dd MMM")</div>
                                    <div style="font-size:11px; font-weight:600;">@session.StartTime.ToString("HH:mm")</div>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-bold mb-1" style="font-size:13px;">@session.Title</div>
                                    <div class="text-muted" style="font-size:12px;">@session.Location - @session.DurationMinutes min</div>
                                    <div class="d-flex gap-2 mt-2">
                                        @if (!string.IsNullOrWhiteSpace(session.MeetLink))
                                        {
                                            <a href="@session.MeetLink" target="_blank" class="btn btn-sm btn-primary">Join Meet</a>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(session.ActionUrl))
                                        {
                                            <a href="@session.ActionUrl" class="btn btn-sm btn-outline-secondary">Open</a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="card-panel mb-0">
            <h2 class="section-title">Quick Actions</h2>
            <div class="row g-3">
                <div class="col-6">
                    <a href="@Url.Action("ReviewAssignments", "Lecturer")" class="btn btn-secondary w-100 d-flex flex-column align-items-center justify-content-center py-3 text-decoration-none border-0" style="background:#F9FAFB;">
                        <span class="material-symbols-outlined mb-2" style="color:var(--fpt-orange)">edit_document</span>
                        <span class="fw-bold" style="font-size:10px; letter-spacing:1px; color:var(--text-body);">GRADING</span>
                    </a>
                </div>
                <div class="col-6">
                    <a href="@Url.Action("FeedbackApprovals", "Lecturer")" class="btn btn-secondary w-100 d-flex flex-column align-items-center justify-content-center py-3 text-decoration-none border-0" style="background:#F9FAFB;">
                        <span class="material-symbols-outlined mb-2" style="color:var(--fpt-orange)">fact_check</span>
                        <span class="fw-bold" style="font-size:10px; letter-spacing:1px; color:var(--text-body);">APPROVALS</span>
                    </a>
                </div>
                <div class="col-6">
                    <a href="@Url.Action("Projects", "Lecturer")" class="btn btn-secondary w-100 d-flex flex-column align-items-center justify-content-center py-3 text-decoration-none border-0" style="background:#F9FAFB;">
                        <span class="material-symbols-outlined mb-2" style="color:var(--fpt-orange)">folder_open</span>
                        <span class="fw-bold" style="font-size:10px; letter-spacing:1px; color:var(--text-body);">PROJECTS</span>
                    </a>
                </div>
                <div class="col-6">
                    <a href="@Url.Action("Schedule", "Lecturer")" class="btn btn-secondary w-100 d-flex flex-column align-items-center justify-content-center py-3 text-decoration-none border-0" style="background:#F9FAFB;">
                        <span class="material-symbols-outlined mb-2" style="color:var(--fpt-orange)">calendar_month</span>
                        <span class="fw-bold" style="font-size:10px; letter-spacing:1px; color:var(--text-body);">SCHEDULE</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

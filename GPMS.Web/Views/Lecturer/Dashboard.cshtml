@using GPMS.Web.ViewModels.Lecturer
@model LecturerDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

<!-- Guidance Alert -->
<div class="bg-[#FFF7F2] dark:bg-primary-900/20 border border-primary-100 dark:border-primary-800 rounded-xl p-4 mb-6 flex items-start gap-4">
    <div class="mt-0.5 bg-primary-100 dark:bg-primary-900/50 p-2 rounded-lg text-primary-500">
        <span class="material-symbols-outlined">tips_and_updates</span>
    </div>
    <div class="flex-1">
        <h4 class="text-dark-900 dark:text-dark-100 font-bold text-sm mb-1">What needs your attention</h4>
        <p class="text-dark-500 dark:text-dark-400 text-sm leading-relaxed">@Model.GuidanceMessage</p>
    </div>
</div>

<!-- Key Metrics Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
    <!-- Groups Mentoring -->
    <div class="bg-white dark:bg-dark-800 rounded-2xl p-6 shadow-sm border border-slate-100 dark:border-dark-700 flex flex-col justify-center transition-all hover:shadow-md hover:border-primary-100 dark:hover:border-primary-900 group">
        <div class="text-[11px] font-bold text-slate-400 dark:text-slate-500 tracking-widest uppercase mb-3">Groups Mentoring</div>
        <div class="flex justify-between items-center">
            <div class="text-4xl font-black text-dark-900 dark:text-white tracking-tight">@Model.MentoringGroupsCount</div>
            <div class="w-12 h-12 rounded-xl bg-slate-50 dark:bg-dark-700 flex items-center justify-center text-primary-500 group-hover:bg-[#FFF7F2] group-hover:scale-110 transition-all">
                <span class="material-symbols-outlined text-[28px] filled">people</span>
            </div>
        </div>
    </div>

    <!-- Pending Approvals -->
    <div class="bg-white dark:bg-dark-800 rounded-2xl p-6 shadow-sm border border-slate-100 dark:border-dark-700 flex flex-col justify-center transition-all hover:shadow-md hover:border-primary-100 dark:hover:border-primary-900 group">
        <div class="text-[11px] font-bold text-slate-400 dark:text-slate-500 tracking-widest uppercase mb-3">Pending Approvals</div>
        <div class="flex justify-between items-center">
            <div class="text-4xl font-black text-dark-900 dark:text-white tracking-tight">@Model.PendingApprovalsCount</div>
            <div class="w-12 h-12 rounded-xl bg-slate-50 dark:bg-dark-700 flex items-center justify-center text-primary-500 group-hover:bg-[#FFF7F2] group-hover:scale-110 transition-all">
                <span class="material-symbols-outlined text-[28px] filled">fact_check</span>
            </div>
        </div>
    </div>

    <!-- Assigned Reviews -->
    <div class="bg-white dark:bg-dark-800 rounded-2xl p-6 shadow-sm border border-slate-100 dark:border-dark-700 flex flex-col justify-center transition-all hover:shadow-md hover:border-primary-100 dark:hover:border-primary-900 group">
        <div class="text-[11px] font-bold text-slate-400 dark:text-slate-500 tracking-widest uppercase mb-3">Assigned Reviews</div>
        <div class="flex justify-between items-center">
            <div class="text-4xl font-black text-dark-900 dark:text-white tracking-tight">@Model.AssignedReviewsCount</div>
            <div class="w-12 h-12 rounded-xl bg-slate-50 dark:bg-dark-700 flex items-center justify-center text-primary-500 group-hover:bg-[#FFF7F2] group-hover:scale-110 transition-all">
                <span class="material-symbols-outlined text-[28px] filled">assignment</span>
            </div>
        </div>
    </div>

    <!-- Upcoming Deadlines -->
    <div class="bg-white dark:bg-dark-800 rounded-2xl p-6 shadow-sm border border-slate-100 dark:border-dark-700 border-l-4 border-l-red-500 flex flex-col justify-center transition-all hover:shadow-md group">
        <div class="text-[11px] font-bold text-slate-400 dark:text-slate-500 tracking-widest uppercase mb-3">Upcoming Deadlines</div>
        <div class="flex justify-between items-center">
            <div class="text-4xl font-black text-red-500 tracking-tight">@Model.UpcomingDeadlinesCount</div>
            <div class="w-12 h-12 rounded-xl bg-red-50 dark:bg-red-900/20 flex items-center justify-center text-red-500 group-hover:scale-110 transition-all">
                <span class="material-symbols-outlined text-[28px] filled">event_busy</span>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Recent Activity -->
    <div class="lg:col-span-2 space-y-6 flex flex-col">
        <div class="bg-white dark:bg-dark-800 rounded-2xl p-6 lg:p-8 shadow-sm border border-slate-100 dark:border-dark-700 flex-1">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-lg font-bold text-dark-900 dark:text-white">Recent Activity</h2>
                <a href="@Url.Action("History", "Lecturer")" class="text-sm font-semibold text-primary-500 hover:text-primary-600 transition-colors">View History</a>
            </div>

            @if (!Model.RecentActivities.Any())
            {
                <div class="flex flex-col items-center justify-center py-10 text-slate-400 dark:text-slate-500">
                    <span class="material-symbols-outlined text-4xl mb-3 opacity-50">history</span>
                    <p>No recent activity.</p>
                </div>
            }
            else
            {
                <div class="space-y-6">
                    @foreach (var item in Model.RecentActivities)
                    {
                        <div class="flex gap-4 group">
                            <!-- Icon -->
                            <div class="shrink-0 pt-0.5">
                                <div class="w-10 h-10 rounded-full flex items-center justify-center text-white shadow-sm" style="background-color: @item.IconBgColor">
                                    <span class="material-symbols-outlined text-[20px]">@item.Icon</span>
                                </div>
                            </div>
                            <!-- Content -->
                            <div class="flex-1 pb-6 border-b border-slate-100 dark:border-dark-700 group-last:border-0 group-last:pb-2">
                                <div class="flex justify-between items-start mb-1 gap-2">
                                    <h6 class="text-sm font-bold text-dark-900 dark:text-white">@item.Title</h6>
                                    <span class="shrink-0 text-[12px] text-slate-400 dark:text-slate-500" title="@item.Timestamp.ToString("g")">
                                        @{
                                            var diff = DateTime.Now - item.Timestamp;
                                            var ago = diff.TotalHours < 1
                                                ? $"{(int)diff.TotalMinutes}m ago"
                                                : diff.TotalDays < 1
                                                    ? $"{(int)diff.TotalHours}h ago"
                                                    : item.Timestamp.ToString("MMM dd");
                                        }
                                        @ago
                                    </span>
                                </div>
                                <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">@item.Description</p>
                                @if (!string.IsNullOrEmpty(item.ActionUrl))
                                {
                                    <a href="@item.ActionUrl" class="inline-flex items-center justify-center px-4 py-1.5 text-xs font-semibold rounded-lg bg-primary-50 text-primary-600 hover:bg-primary-100 transition-colors border border-primary-100">
                                        @item.ActionText
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Upcoming Schedule & Quick Actions -->
    <div class="space-y-6 flex flex-col">
        <!-- Upcoming Schedule -->
        <div class="bg-white dark:bg-dark-800 rounded-2xl p-6 shadow-sm border border-slate-100 dark:border-dark-700 flex-1">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-lg font-bold text-dark-900 dark:text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary-500">calendar_today</span>
                    Upcoming Schedule
                </h2>
                <a href="@Url.Action("Schedule", "Lecturer")" class="text-xs font-semibold text-primary-500 hover:text-primary-600 transition-colors">Full schedule</a>
            </div>

            @if (!Model.TodaysSchedule.Any())
            {
                <div class="flex flex-col items-center justify-center py-8 text-slate-400 dark:text-slate-500">
                    <span class="material-symbols-outlined text-4xl mb-3 opacity-50">event_busy</span>
                    <p class="text-sm">No upcoming sessions found.</p>
                </div>
            }
            else
            {
                <div class="space-y-4">
                    @foreach (var session in Model.TodaysSchedule)
                    {
                        var borderColorClass = session.IsHighlight ? "border-l-primary-500" : "border-l-slate-300 dark:border-l-slate-600";
                        var bgColorClass = session.IsHighlight ? "bg-primary-50/50 dark:bg-primary-900/10" : "bg-slate-50 dark:bg-dark-700";
                        var timeColorClass = session.IsHighlight ? "text-primary-600 dark:text-primary-400" : "text-slate-600 dark:text-slate-400";
                        
                        <div class="p-4 rounded-xl border border-slate-100 dark:border-dark-600 border-l-4 @borderColorClass @bgColorClass transition-colors hover:shadow-sm">
                            <div class="flex gap-4">
                                <!-- Time Column -->
                                <div class="text-center min-w-[56px] @timeColorClass shrink-0 pt-0.5">
                                    <div class="text-sm font-bold">@session.StartTime.ToString("MMM dd")</div>
                                    <div class="text-xs font-bold mt-0.5">@session.StartTime.ToString("HH:mm")</div>
                                </div>
                                <!-- Details Column -->
                                <div class="flex-1 min-w-0">
                                    <div class="text-sm font-bold text-dark-900 dark:text-white mb-1 truncate">@session.Title</div>
                                    <div class="text-xs text-slate-500 dark:text-slate-400 mb-3 truncate flex items-center gap-1.5">
                                        <span class="material-symbols-outlined text-[14px]">location_on</span>
                                        @session.Location • @session.DurationMinutes min
                                    </div>
                                    <div class="flex gap-2">

                                        @if (!string.IsNullOrWhiteSpace(session.ActionUrl))
                                        {
                                            <a href="@session.ActionUrl" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white dark:bg-dark-800 border border-slate-200 dark:border-dark-600 text-dark-700 dark:text-dark-200 hover:bg-slate-50 dark:hover:bg-dark-700 text-xs font-semibold rounded-lg transition-colors">
                                                Open <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                                            </a>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(session.MeetLink))
                                        {
                                            <a href="@session.MeetLink" target="_blank" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-800 dark:bg-slate-700 text-white hover:bg-slate-900 dark:hover:bg-slate-600 text-xs font-semibold rounded-lg transition-colors">
                                                Join Meet <span class="material-symbols-outlined text-[14px]">videocam</span>
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Quick Actions -->
        <div class="bg-white dark:bg-dark-800 rounded-2xl p-6 shadow-sm border border-slate-100 dark:border-dark-700">
            <h2 class="text-lg font-bold text-dark-900 dark:text-white mb-4">Quick Actions</h2>
            <div class="grid grid-cols-2 gap-3">
                <a href="@Url.Action("ReviewAssignments", "Lecturer")" class="flex flex-col items-center justify-center p-4 rounded-xl bg-slate-50 dark:bg-dark-700 hover:bg-primary-50 dark:hover:bg-primary-900/20 text-slate-600 dark:text-slate-300 hover:text-primary-600 border border-transparent hover:border-primary-100 dark:hover:border-primary-800 transition-all group">
                    <span class="material-symbols-outlined mb-2 text-primary-500 group-hover:scale-110 transition-transform">edit_document</span>
                    <span class="text-[10px] font-bold tracking-widest uppercase">Grading</span>
                </a>
                <a href="@Url.Action("FeedbackApprovals", "Lecturer")" class="flex flex-col items-center justify-center p-4 rounded-xl bg-slate-50 dark:bg-dark-700 hover:bg-primary-50 dark:hover:bg-primary-900/20 text-slate-600 dark:text-slate-300 hover:text-primary-600 border border-transparent hover:border-primary-100 dark:hover:border-primary-800 transition-all group">
                    <span class="material-symbols-outlined mb-2 text-primary-500 group-hover:scale-110 transition-transform">fact_check</span>
                    <span class="text-[10px] font-bold tracking-widest uppercase">Approvals</span>
                </a>
                <a href="@Url.Action("Projects", "Lecturer")" class="flex flex-col items-center justify-center p-4 rounded-xl bg-slate-50 dark:bg-dark-700 hover:bg-primary-50 dark:hover:bg-primary-900/20 text-slate-600 dark:text-slate-300 hover:text-primary-600 border border-transparent hover:border-primary-100 dark:hover:border-primary-800 transition-all group">
                    <span class="material-symbols-outlined mb-2 text-primary-500 group-hover:scale-110 transition-transform">folder_open</span>
                    <span class="text-[10px] font-bold tracking-widest uppercase">Projects</span>
                </a>
                <a href="@Url.Action("Schedule", "Lecturer")" class="flex flex-col items-center justify-center p-4 rounded-xl bg-slate-50 dark:bg-dark-700 hover:bg-primary-50 dark:hover:bg-primary-900/20 text-slate-600 dark:text-slate-300 hover:text-primary-600 border border-transparent hover:border-primary-100 dark:hover:border-primary-800 transition-all group">
                    <span class="material-symbols-outlined mb-2 text-primary-500 group-hover:scale-110 transition-transform">calendar_month</span>
                    <span class="text-[10px] font-bold tracking-widest uppercase">Schedule</span>
                </a>
            </div>
        </div>
    </div>
</div>

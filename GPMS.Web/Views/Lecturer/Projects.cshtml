@using GPMS.Web.ViewModels.Lecturer
@model MentoredProjectsViewModel
@{
    ViewData["Title"] = "My Projects";
    Layout = "_Layout";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-6 pb-4 border-b border-slate-200 dark:border-dark-700 gap-4">
    <div>
        <h1 class="text-2xl font-black text-dark-900 dark:text-white tracking-tight mb-1">My Projects</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 font-medium">All groups you are supervising, their next meeting, and current feedback state.</p>
    </div>
</div>

<div class="bg-white dark:bg-dark-800 rounded-2xl shadow-sm border border-slate-100 dark:border-dark-700 overflow-hidden">
    <div class="p-5 border-b border-slate-100 dark:border-dark-700 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <h2 class="text-lg font-bold text-dark-900 dark:text-white">Mentored Groups</h2>
        <div class="relative w-full md:w-72">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3">
                <span class="material-symbols-outlined text-slate-400 text-lg">search</span>
            </span>
            <input type="text" id="groupSearch" class="block w-full rounded-xl border-slate-200 dark:border-dark-600 bg-slate-50 dark:bg-dark-900 pl-10 text-sm focus:border-primary-500 focus:ring-primary-500 shadow-sm transition-colors text-dark-900 dark:text-white placeholder-slate-400" placeholder="Search group or project...">
        </div>
    </div>

    @if (!Model.Groups.Any())
    {
        <div class="flex flex-col items-center justify-center py-12 text-slate-400 dark:text-slate-500">
            <span class="material-symbols-outlined text-5xl mb-4 opacity-50">folder_off</span>
            <p class="text-sm font-medium">No groups assigned to you this semester.</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-sm whitespace-nowrap md:whitespace-normal" id="projectsTable">
                <thead>
                    <tr class="bg-slate-50 dark:bg-dark-700 border-b border-slate-200 dark:border-dark-600">
                        <th class="px-5 py-3 font-bold text-slate-500 dark:text-slate-400">GROUP</th>
                        <th class="px-5 py-3 font-bold text-slate-500 dark:text-slate-400">PROJECT</th>
                        <th class="px-5 py-3 font-bold text-slate-500 dark:text-slate-400">MEMBERS</th>
                        <th class="px-5 py-3 font-bold text-slate-500 dark:text-slate-400">NEXT SESSION</th>
                        <th class="px-5 py-3 font-bold text-slate-500 dark:text-slate-400">ROUND</th>
                        <th class="px-5 py-3 font-bold text-slate-500 dark:text-slate-400">STATUS</th>
                        <th class="px-5 py-3 font-bold text-slate-500 dark:text-slate-400 text-right">ACTIONS</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-dark-700">
                    @foreach (var g in Model.Groups)
                    {
                        var statusClass = g.Status.Contains("Awaiting") ? "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400"
                            : g.Status.Contains("revision") ? "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400"
                            : "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400";

                        <tr class="hover:bg-slate-50/50 dark:hover:bg-dark-700/30 transition-colors align-middle">
                            <td class="px-5 py-4">
                                <div class="font-bold text-dark-900 dark:text-white">@g.GroupName</div>
                            </td>
                            <td class="px-5 py-4">
                                <div class="font-medium text-dark-900 dark:text-white mb-0.5 truncate max-w-[200px]">@g.ProjectName</div>
                                <div class="text-xs text-slate-500 dark:text-slate-400">@g.ProjectCode &middot; @g.Semester</div>
                            </td>
                            <td class="px-5 py-4">
                                <div class="flex items-center -space-x-2">
                                    @foreach (var name in g.MemberNames.Take(3))
                                    {
                                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(name)&background=E5E7EB&color=374151"
                                             title="@name" class="w-7 h-7 rounded-full border-2 border-white dark:border-dark-800 shadow-sm" alt="@name" />
                                    }
                                    @if (g.MemberNames.Count > 3)
                                    {
                                        <span class="w-7 h-7 rounded-full border-2 border-white dark:border-dark-800 bg-slate-100 dark:bg-dark-600 text-slate-600 dark:text-slate-300 flex items-center justify-center text-[10px] font-bold shadow-sm z-10">
                                            +@(g.MemberNames.Count - 3)
                                        </span>
                                    }
                                </div>
                            </td>
                            <td class="px-5 py-4">
                                @if (g.NextSessionAt.HasValue)
                                {
                                    <div class="font-medium text-dark-900 dark:text-white mb-0.5 text-sm">@g.NextSessionAt.Value.ToString("MMM dd, HH:mm")</div>
                                    <div class="text-xs text-slate-500 dark:text-slate-400 truncate max-w-[150px]">@g.NextSessionLocation</div>
                                }
                                else
                                {
                                    <span class="text-xs text-slate-400 dark:text-slate-500">No meeting scheduled</span>
                                }
                            </td>
                            <td class="px-5 py-4">
                                <span class="px-2.5 py-1 text-xs font-semibold rounded-lg border border-slate-200 dark:border-dark-600 bg-slate-50 dark:bg-dark-900 text-slate-600 dark:text-slate-300">@g.RoundType</span>
                            </td>
                            <td class="px-5 py-4">
                                <span class="px-3 py-1.5 text-xs font-semibold rounded-lg @statusClass inline-block">@g.Status</span>
                                @if (g.PendingFeedbackCount > 0)
                                {
                                    <div class="text-xs text-amber-600 dark:text-amber-400 font-medium mt-2">@g.PendingFeedbackCount pending approval</div>
                                }
                            </td>
                            <td class="px-5 py-4 text-right">
                                <a href="@Url.Action("ProjectGroupDetail", "Lecturer", new { id = g.GroupID })" class="inline-flex items-center justify-center px-4 py-2 border border-slate-200 dark:border-dark-600 text-slate-700 dark:text-slate-300 bg-white dark:bg-dark-800 hover:bg-slate-50 dark:hover:bg-dark-700 rounded-xl text-sm font-semibold transition-colors shadow-sm">
                                    View Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

    <script>
        document.getElementById('groupSearch')?.addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#projectsTable tbody tr').forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(q) ? '' : 'none';
            });
        });
    </script>

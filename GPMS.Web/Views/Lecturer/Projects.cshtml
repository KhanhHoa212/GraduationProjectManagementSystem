@{
    ViewData["Title"] = "My Projects";
    Layout = "_LecturerLayout";
}

<!-- Page Header -->
<div class="page-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="page-title">My Projects</h1>
        <p class="page-subtitle text-muted mb-0">Oversee and manage your mentored student groups, track project milestones, and monitor student progress across semesters.</p>
    </div>
    <div class="d-none d-md-block">
        <button type="button" class="btn btn-primary shadow-sm" style="background-color: var(--fpt-orange); border-color: var(--fpt-orange);">
            <span class="material-symbols-outlined fs-5">add</span>
            Propose New Project
        </button>
    </div>
</div>

<!-- Filters Bar -->
<div class="card-panel py-3 px-4 mb-4">
    <form class="row g-3 align-items-end" method="get">
        <div class="col-md-3">
            <label class="form-label" style="font-size: 11px; text-transform: uppercase; font-weight: 600; color: var(--text-muted); letter-spacing: 0.5px;">Semester</label>
            <div class="position-relative">
                <select class="form-select bg-white pe-5 shadow-none" name="semesterId" style="height: 42px;">
                    <option value="fall2024">Fall 2024</option>
                    <option value="summer2024">Summer 2024</option>
                    <option value="spring2024">Spring 2024</option>
                </select>
            </div>
        </div>
        <div class="col-md-7">
            <label class="form-label" style="font-size: 11px; text-transform: uppercase; font-weight: 600; color: var(--text-muted); letter-spacing: 0.5px;">Search</label>
            <div class="position-relative">
                <span class="material-symbols-outlined position-absolute top-50 start-0 translate-middle-y ms-3 text-muted">search</span>
                <input type="text" class="form-control ps-5 shadow-none" name="query" placeholder="Search by project name or group..." style="height: 42px;" />
            </div>
        </div>
        <div class="col-md-2 d-flex justify-content-md-end">
            <button type="button" class="btn btn-light border d-flex align-items-center gap-2 w-100 justify-content-center shadow-none" style="height: 42px; background: #F9FAFB;">
                <span class="material-symbols-outlined fs-6">tune</span>
                More Filters
            </button>
        </div>
    </form>
</div>

<!-- Projects Table -->
<div class="card-panel p-0 mb-4 overflow-hidden border">
    <div class="table-responsive">
        <table class="table mb-0 align-middle text-nowrap">
            <thead>
                <tr>
                    <th scope="col" style="width: 30%;">PROJECT NAME</th>
                    <th scope="col" style="width: 15%;">GROUP NAME</th>
                    <th scope="col" style="width: 20%;">STUDENT COUNT</th>
                    <th scope="col" style="width: 15%;">CURRENT ROUND</th>
                    <th scope="col" style="width: 15%;">STATUS</th>
                    <th scope="col" class="text-end" style="width: 5%;">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                <!-- Row 1 -->
                <tr>
                    <td>
                        <div class="fw-bold mb-1" style="color: var(--text-heading); font-size: 14px; white-space: normal;">AI-Powered Campus Navigation</div>
                        <div class="text-muted" style="font-size: 12px;">Computer Science • Mobile App</div>
                    </td>
                    <td>
                        <div class="fw-bold" style="font-size: 13px;">Alpha Squad</div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="d-flex align-items-center me-1">
                                <img src="https://ui-avatars.com/api/?name=St1&background=E5E7EB&color=374151" class="rounded-circle border border-white" width="28" height="28" style="margin-right: -8px; position: relative; z-index: 3;" />
                                <img src="https://ui-avatars.com/api/?name=St2&background=D1D5DB&color=374151" class="rounded-circle border border-white" width="28" height="28" style="margin-right: -8px; position: relative; z-index: 2;" />
                                <div class="rounded-circle border border-white bg-secondary text-white d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 10px; position: relative; z-index: 1;">+2</div>
                            </div>
                            <span class="text-muted" style="font-size: 13px;">4 Students</span>
                        </div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge text-orange-600 border border-orange-200" style="background: #FFF7F2; color: var(--fpt-orange); font-size: 10px; padding: 4px 6px;">ROUND 03</span>
                            <span style="font-size: 13px;">Final Presentation</span>
                        </div>
                    </td>
                    <td>
                        <span class="status-badge approved">
                            <span class="d-inline-block rounded-circle bg-success me-1" style="width: 6px; height: 6px;"></span>
                            Active
                        </span>
                    </td>
                    <td class="text-end">
                        <div class="table-action-icons d-inline-flex">
                            <a href="@Url.Action("ProjectGroupDetail", "Lecturer", new { id = "GRP-01" })" class="btn btn-sm btn-link text-muted p-1 hover-primary text-decoration-none">
                                <span class="material-symbols-outlined fs-5">more_vert</span>
                            </a>
                        </div>
                    </td>
                </tr>

                <!-- Row 2 -->
                <tr>
                    <td>
                        <div class="fw-bold mb-1" style="color: var(--text-heading); font-size: 14px; white-space: normal;">Blockchain Student Records</div>
                        <div class="text-muted" style="font-size: 12px;">Software Engineering • Web3</div>
                    </td>
                    <td>
                        <div class="fw-bold" style="font-size: 13px;">Chain Reaction</div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="d-flex align-items-center me-1">
                                <img src="https://ui-avatars.com/api/?name=A&background=E5E7EB&color=374151" class="rounded-circle border border-white" width="28" height="28" style="margin-right: -8px; position: relative; z-index: 3;" />
                                <img src="https://ui-avatars.com/api/?name=B&background=D1D5DB&color=374151" class="rounded-circle border border-white" width="28" height="28" style="margin-right: -8px; position: relative; z-index: 2;" />
                                <img src="https://ui-avatars.com/api/?name=C&background=9CA3AF&color=ffffff" class="rounded-circle border border-white" width="28" height="28" style="position: relative; z-index: 1;" />
                            </div>
                            <span class="text-muted" style="font-size: 13px;">3 Students</span>
                        </div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-secondary text-white" style="font-size: 10px; padding: 4px 6px;">COMPLETED</span>
                            <span style="font-size: 13px;">Post-Review</span>
                        </div>
                    </td>
                    <td>
                        <span class="status-badge draft">
                            Completed
                        </span>
                    </td>
                    <td class="text-end">
                         <div class="table-action-icons d-inline-flex">
                            <a href="@Url.Action("ProjectGroupDetail", "Lecturer", new { id = "GRP-02" })" class="btn btn-sm btn-link text-muted p-1 hover-primary text-decoration-none">
                                <span class="material-symbols-outlined fs-5">more_vert</span>
                            </a>
                        </div>
                    </td>
                </tr>
                
                <!-- Row 3 -->
                <tr class="problem-row">
                    <td>
                        <div class="fw-bold mb-1 text-danger" style="font-size: 14px; white-space: normal;">Predictive Health Analysis</div>
                        <div class="text-muted" style="font-size: 12px;">Data Science • Python</div>
                    </td>
                    <td>
                        <div class="fw-bold" style="font-size: 13px;">VitalStats</div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="d-flex align-items-center me-1">
                                <img src="https://ui-avatars.com/api/?name=A&background=E5E7EB&color=374151" class="rounded-circle border border-white" width="28" height="28" style="margin-right: -8px; position: relative; z-index: 2;" />
                                <img src="https://ui-avatars.com/api/?name=B&background=D1D5DB&color=374151" class="rounded-circle border border-white" width="28" height="28" style="position: relative; z-index: 1;" />
                            </div>
                            <span class="text-muted" style="font-size: 13px;">2 Students</span>
                        </div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge text-warning-emphasis bg-warning-subtle" style="font-size: 10px; padding: 4px 6px;">ON HOLD</span>
                            <span style="font-size: 13px;">Awaiting Assets</span>
                        </div>
                    </td>
                    <td>
                        <span class="status-badge pending">
                            <span class="d-inline-block rounded-circle bg-warning me-1" style="width: 6px; height: 6px;"></span>
                            Pending
                        </span>
                    </td>
                    <td class="text-end">
                         <div class="table-action-icons d-inline-flex" style="opacity: 1;"> <!-- Force show on problem row -->
                            <a href="@Url.Action("ProjectGroupDetail", "Lecturer", new { id = "GRP-03" })" class="btn btn-sm btn-link text-muted p-1 text-decoration-none">
                                <span class="material-symbols-outlined fs-5">more_vert</span>
                            </a>
                        </div>
                    </td>
                </tr>

            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="p-3 border-top d-flex align-items-center justify-content-between bg-white">
        <div class="text-muted" style="font-size: 13px;">
            Showing <span class="fw-bold text-body">1 - 3</span> of <span class="fw-bold text-body">12</span> projects
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0 outline-none shadow-none">
                <li class="page-item disabled">
                    <a class="page-link text-muted border-0 bg-transparent" href="#" tabindex="-1" aria-disabled="true">
                        <span class="material-symbols-outlined fs-6 align-middle">chevron_left</span>
                    </a>
                </li>
                <li class="page-item active"><a class="page-link text-white border-0" href="#" style="background-color: var(--fpt-orange);">1</a></li>
                <li class="page-item"><a class="page-link text-muted border-0 bg-transparent" href="#">2</a></li>
                <li class="page-item"><a class="page-link text-muted border-0 bg-transparent" href="#">3</a></li>
                <li class="page-item">
                    <a class="page-link text-muted border-0 bg-transparent" href="#">
                        <span class="material-symbols-outlined fs-6 align-middle">chevron_right</span>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<!-- Bottom Metric Cards -->
<div class="row g-4 mt-2">
    <div class="col-md-4">
        <div class="card-panel h-100 mb-0 d-flex flex-column justify-content-center pt-4 pb-4 position-relative overflow-hidden text-white border-0" style="background-color: var(--fpt-orange);">
            <div class="position-absolute end-0 bottom-0 ms-5 mb-n4 me-n2 opacity-25" style="transform: scale(2.5);">
                <span class="material-symbols-outlined" style="font-size: 64px;">group</span>
            </div>
            <div class="position-relative z-1">
                <div class="fw-bold mb-1" style="font-size: 11px; letter-spacing: 1px;">TOTAL STUDENTS MENTORED</div>
                <div class="fw-bold mb-2" style="font-size: 36px; letter-spacing: -1px; line-height: 1;">42</div>
                <div class="d-flex align-items-center gap-1" style="font-size: 12px; font-weight: 500;">
                    <span class="material-symbols-outlined fs-6">trending_up</span>
                    <span>+12% from last semester</span>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card-panel h-100 mb-0 d-flex flex-column justify-content-center border pt-4 pb-4">
            <div class="text-muted fw-bold mb-1" style="font-size: 11px; letter-spacing: 1px;">AVERAGE COMPLETION RATE</div>
            <div class="fw-bold mb-3" style="font-size: 36px; letter-spacing: -1px; line-height: 1;">88%</div>
            <div class="progress" style="height: 6px;">
                <div class="progress-bar" role="progressbar" style="width: 88%; background-color: var(--fpt-orange);" aria-valuenow="88" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card-panel h-100 mb-0 d-flex flex-column justify-content-center border pt-4 pb-4">
            <div class="text-muted fw-bold mb-1" style="font-size: 11px; letter-spacing: 1px;">PENDING ASSESSMENTS</div>
            <div class="fw-bold mb-3" style="font-size: 36px; letter-spacing: -1px; line-height: 1;">05</div>
            <div class="d-flex align-items-center gap-1 text-orange-600 fw-medium" style="font-size: 12px; color: var(--fpt-orange);">
                <span class="material-symbols-outlined fs-6" style="font-size: 14px !important;">schedule</span>
                <span>Due in 4 days</span>
            </div>
        </div>
    </div>
</div>

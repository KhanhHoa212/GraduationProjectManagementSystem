@using GPMS.Application.DTOs.Lecturer
@model LecturerEvaluationFormViewModel
@{
    ViewData["Title"] = "Evaluation Form";
    Layout = "_LecturerLayout";
    var isReadOnly = !string.IsNullOrEmpty(Model.Status) && Model.Status == "Submitted";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4 pb-3">
    <div>
        <h1 class="page-title">Evaluation Form</h1>
        <p class="page-subtitle text-muted mb-0">@Model.GroupName — Round @Model.ReviewRoundName</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <span class="badge @(isReadOnly ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning") py-2 px-3" style="font-size:13px;">
            @Model.Status
        </span>
    </div>
</div>

<form asp-action="SubmitEvaluation" asp-controller="Lecturer" method="post" id="evaluationForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="EvaluationId" value="@Model.EvaluationId" />
    <input type="hidden" name="AssignmentId" value="@Model.AssignmentId" />
    <input type="hidden" name="GroupId" value="@Model.GroupId" />

    <div class="row g-4">
        <!-- Left Panel (65%): Checklist / Rubric -->
        <div class="col-lg-8 order-lg-first d-flex flex-column gap-section">

            <!-- Checklist Table -->
            <div class="card-panel border p-0 overflow-hidden mb-0 shadow-sm">
                <div class="p-3 border-bottom d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined" style="color:var(--fpt-orange)">checklist</span>
                    <h2 class="section-title mb-0">@(string.IsNullOrEmpty(Model.ChecklistTitle) ? "Evaluation Criteria" : Model.ChecklistTitle)</h2>
                </div>
                <table class="table mb-0 align-middle">
                    <thead>
                        <tr class="bg-light">
                            <th class="px-4" style="width:50%;">CRITERIA</th>
                            <th style="width:15%; text-align:center;">MAX</th>
                            <th style="width:35%;">SCORE</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Criteria.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">No evaluation criteria found for this round.</td>
                            </tr>
                        }
                        @foreach (var criterion in Model.Criteria)
                        {
                            var existingScore = Model.Scores.ContainsKey(criterion.Id) ? Model.Scores[criterion.Id] : (decimal?)null;
                            <tr class="criterion-row">
                                <td class="px-4">
                                    <div class="fw-medium text-body" style="font-size:14px;">@criterion.Name</div>
                                    @if (!string.IsNullOrEmpty(criterion.Description))
                                    {
                                        <div class="text-muted" style="font-size:12px;">@criterion.Description</div>
                                    }
                                </td>
                                <td class="text-center text-muted fw-bold">@criterion.MaxScore</td>
                                <td>
                                    <input type="number" 
                                           class="form-control score-input" 
                                           name="Scores[@criterion.Id]"
                                           min="0" max="@criterion.MaxScore" step="0.5"
                                           value="@(existingScore?.ToString("F1") ?? "")"
                                           placeholder="0–@criterion.MaxScore"
                                           data-max="@criterion.MaxScore"
                                           @(isReadOnly ? "readonly" : "")
                                           required />
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr style="background:#FFF7F2;">
                            <td class="px-4 fw-bold text-body" colspan="2">Total Score</td>
                            <td class="fw-bold" style="color:var(--fpt-orange); font-size:16px;" id="totalScoreDisplay">— / @Model.Criteria.Sum(c => c.MaxScore)</td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <!-- Overall Feedback -->
            <div class="card-panel border mb-0 shadow-sm">
                <h2 class="section-title mb-3">Overall Comments</h2>
                <textarea name="OverallFeedback" class="form-control" rows="6"
                          placeholder="Write your overall feedback for this group..."
                          @(isReadOnly ? "readonly" : "")>@Model.OverallFeedback</textarea>
            </div>

            <!-- Submit -->
            @if (!isReadOnly)
            {
                <div class="d-flex justify-content-end gap-3">
                    <button type="submit" name="saveAction" value="draft" class="btn btn-outline-secondary px-4">
                        <span class="material-symbols-outlined align-middle me-1" style="font-size:18px;">save</span>
                        Save Draft
                    </button>
                    <button type="submit" name="saveAction" value="submit" class="btn btn-primary px-4">
                        <span class="material-symbols-outlined align-middle me-1" style="font-size:18px;">send</span>
                        Submit Evaluation
                    </button>
                </div>
            }
        </div>

        <!-- Right Panel (35%): Group Info & Documents -->
        <div class="col-lg-4 order-lg-last d-flex flex-column gap-section">

            <!-- Group Info Card -->
            <div class="card-panel mb-0 border shadow-sm" style="border-top-width: 4px !important; border-top-color: var(--fpt-orange) !important;">
                <div class="text-muted mb-3" style="font-size: 11px; text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px;">GROUP INFO</div>
                <h4 class="fw-bold text-body mb-1" style="font-size: 16px;">@Model.GroupName</h4>
                <p class="text-muted mb-3" style="font-size: 13px;">@Model.ProjectName</p>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex gap-2 align-items-start">
                        <span class="material-symbols-outlined text-muted" style="font-size: 16px; margin-top: 1px;">person</span>
                        <div>
                            <div class="text-muted" style="font-size: 11px; letter-spacing: 0.5px;">SUPERVISOR</div>
                            <div class="fw-medium text-body" style="font-size: 13px;">@Model.SupervisorName</div>
                        </div>
                    </div>
                    @if (Model.DefenseDate != default)
                    {
                        <div class="d-flex gap-2 align-items-start">
                            <span class="material-symbols-outlined text-muted" style="font-size: 16px; margin-top: 1px;">event</span>
                            <div>
                                <div class="text-muted" style="font-size: 11px; letter-spacing: 0.5px;">SCHEDULED DATE</div>
                                <div class="fw-medium text-body" style="font-size: 13px;">@Model.DefenseDate.ToString("MMM dd, yyyy HH:mm")</div>
                            </div>
                        </div>
                    }
                </div>
                <hr class="my-3 text-muted" style="opacity: 0.2;">
                <div class="text-muted mb-2" style="font-size: 11px; text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px;">MEMBERS</div>
                <div class="d-flex flex-column gap-2">
                    @foreach (var m in Model.Members)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <img src="@m.AvatarUrl" class="rounded-circle" width="28" height="28" />
                            <div>
                                <div class="fw-medium text-body" style="font-size: 13px;">@m.FullName</div>
                                <div class="text-muted" style="font-size: 11px;">@m.RoleInGroup</div>
                            </div>
                        </div>
                    }
                    @if (!Model.Members.Any())
                    {
                        <p class="text-muted mb-0" style="font-size:12px;">No member info available.</p>
                    }
                </div>
            </div>

            <!-- Project Documents -->
            <div class="card-panel mb-0 border shadow-sm">
                <div class="text-muted mb-3" style="font-size: 11px; text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px;">PROJECT DOCUMENTS</div>
                @if (!Model.Documents.Any())
                {
                    <p class="text-muted mb-0" style="font-size:13px;">No documents submitted yet.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var doc in Model.Documents)
                        {
                            <a href="@doc.Url" target="_blank" class="d-flex align-items-center gap-3 p-2 rounded hover-bg-light border text-decoration-none text-body">
                                <div class="rounded p-2" style="background: #FFF7F2;">
                                    <span class="material-symbols-outlined" style="color:var(--fpt-orange); font-size:18px;">description</span>
                                </div>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="fw-medium text-truncate" style="font-size: 13px;">@doc.FileName</div>
                                    <div class="text-muted" style="font-size: 11px;">@doc.DocumentType · @(doc.SizeInBytes / 1024)KB</div>
                                </div>
                                <span class="material-symbols-outlined text-muted" style="font-size:18px;">download</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const scoreInputs = document.querySelectorAll('.score-input');
        const totalDisplay = document.getElementById('totalScoreDisplay');
        const maxTotal = @Model.Criteria.Sum(c => c.MaxScore);

        function updateTotal() {
            let total = 0;
            let allFilled = true;
            scoreInputs.forEach(input => {
                const val = parseFloat(input.value);
                if (isNaN(val)) { allFilled = false; return; }
                const max = parseFloat(input.dataset.max);
                if (val > max) input.value = max;
                if (val < 0) input.value = 0;
                total += parseFloat(input.value) || 0;
            });
            if (totalDisplay) {
                totalDisplay.textContent = allFilled ? `${total.toFixed(1)} / ${maxTotal}` : `– / ${maxTotal}`;
            }
        }
        scoreInputs.forEach(i => i.addEventListener('input', updateTotal));
        updateTotal();
    </script>
}

@using GPMS.Web.ViewModels.Lecturer
@model ReviewAssignmentsViewModel
@{
    ViewData["Title"] = "Review Assignments";
    Layout = "_LecturerLayout";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">My Review Assignments</h1>
        <p class="page-subtitle text-muted mb-0">Groups you have been assigned to evaluate, including Meet links or offline room details.</p>
    </div>
</div>

<!-- Stats Bar -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card-panel text-center py-3">
            <div class="fw-bold" style="font-size:28px;">@Model.PendingEvaluationsCount</div>
            <div class="text-muted" style="font-size:12px;">PENDING</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card-panel text-center py-3">
            <div class="fw-bold" style="font-size:28px;">@Model.ScheduledTodayCount</div>
            <div class="text-muted" style="font-size:12px;">SCHEDULED TODAY</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card-panel text-center py-3">
            <div class="fw-bold" style="font-size:28px;">@Model.CompletedReviewsCount</div>
            <div class="text-muted" style="font-size:12px;">COMPLETED</div>
        </div>
    </div>
</div>

<div class="card-panel border p-0 overflow-hidden shadow-sm">
    <div class="p-4 border-bottom">
        <h2 class="section-title mb-0">Assignments</h2>
    </div>

    @if (!Model.Assignments.Any())
    {
        <div class="text-center py-5 text-muted">
            <span class="material-symbols-outlined fs-1 d-block mb-2">assignment</span>
            <p>No review assignments at this time.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-0">
            @foreach (var a in Model.Assignments)
            {
                var isCompleted = a.HasEvaluation;
                var borderColor = isCompleted ? "#22C55E" : "var(--fpt-orange)";
                <div class="p-4 border-bottom d-flex align-items-center gap-4" style="border-left: 4px solid @borderColor;">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <h6 class="mb-0 fw-bold" style="font-size:15px;">@a.GroupName</h6>
                            <span class="text-muted">·</span>
                            <span class="text-muted" style="font-size:13px;">@a.ProjectName</span>
                        </div>
                        <div class="d-flex gap-3 text-muted" style="font-size:12px;">
                            <span><span class="material-symbols-outlined align-middle" style="font-size:14px;">layers</span> Round @a.RoundNumber (@a.RoundType)</span>
                            @if (a.ScheduledAt.HasValue)
                            {
                                <span><span class="material-symbols-outlined align-middle" style="font-size:14px;">calendar_today</span> @a.ScheduledAt.Value.ToString("MMM dd, HH:mm")</span>
                            }
                            @if (!string.IsNullOrEmpty(a.Location))
                            {
                                <span><span class="material-symbols-outlined align-middle" style="font-size:14px;">location_on</span> @a.Location</span>
                            }
                            @if (a.MeetLink != null)
                            {
                                <a href="@a.MeetLink" target="_blank" class="text-decoration-none" style="color:var(--fpt-orange);">
                                    <span class="material-symbols-outlined align-middle" style="font-size:14px;">videocam</span> Join Meeting
                                </a>
                            }
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <span class="badge @a.StatusBadgeClass">@a.StatusLabel</span>
                        @if (!isCompleted)
                        {
                            <a href="@Url.Action("EvaluationForm", "Lecturer", new { id = a.AssignmentID })"
                               class="btn btn-primary btn-sm d-flex align-items-center gap-1">
                                <span class="material-symbols-outlined" style="font-size:16px;">edit</span>
                                @a.PrimaryActionLabel
                            </a>
                        }
                        else if (a.EvaluationID.HasValue)
                        {
                            <a href="@Url.Action("EvaluationForm", "Lecturer", new { id = a.AssignmentID })"
                               class="btn btn-outline-secondary btn-sm">
                                View
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

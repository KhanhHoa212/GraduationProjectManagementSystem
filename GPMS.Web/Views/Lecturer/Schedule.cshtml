@using GPMS.Web.ViewModels.Lecturer
@model LecturerScheduleViewModel
@{
    ViewData["Title"] = "Schedule";
    Layout = "_Layout";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-6 pb-4 border-b border-slate-200 dark:border-dark-700 gap-4">
    <div>
        <h1 class="text-2xl font-black text-dark-900 dark:text-white tracking-tight mb-1">Detailed Schedule</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 font-medium">Review sessions, mentoring meetings, online Meet links, and offline room information.</p>
    </div>
</div>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-8">
    <div class="bg-white dark:bg-dark-800 rounded-3xl border border-slate-200 dark:border-dark-700 p-6 text-center shadow-sm">
        <div class="text-3xl font-black text-dark-900 dark:text-white mb-1">@Model.TodaySessionsCount</div>
        <div class="text-[11px] font-bold text-primary-500 uppercase tracking-widest">TODAY</div>
    </div>
    <div class="bg-white dark:bg-dark-800 rounded-3xl border border-slate-200 dark:border-dark-700 p-6 text-center shadow-sm">
        <div class="text-3xl font-black text-dark-900 dark:text-white mb-1">@Model.OnlineSessionsCount</div>
        <div class="text-[11px] font-bold text-blue-500 uppercase tracking-widest">ONLINE</div>
    </div>
    <div class="bg-white dark:bg-dark-800 rounded-3xl border border-slate-200 dark:border-dark-700 p-6 text-center shadow-sm">
        <div class="text-3xl font-black text-dark-900 dark:text-white mb-1">@Model.OfflineSessionsCount</div>
        <div class="text-[11px] font-bold text-slate-500 uppercase tracking-widest">OFFLINE</div>
    </div>
    <div class="bg-white dark:bg-dark-800 rounded-3xl border border-slate-200 dark:border-dark-700 p-6 text-center shadow-sm">
        <div class="text-3xl font-black text-dark-900 dark:text-white mb-1">@Model.UpcomingDeadlinesCount</div>
        <div class="text-[11px] font-bold text-red-500 uppercase tracking-widest">DEADLINES</div>
    </div>
</div>

<div class="flex flex-col lg:flex-row gap-6">
    <div class="w-full lg:w-2/3">
        <div class="bg-white dark:bg-dark-800 rounded-3xl border border-slate-200 dark:border-dark-700 shadow-sm p-6 lg:p-8">
            <h2 class="text-xl font-bold text-dark-900 dark:text-white mb-6">Sessions</h2>
            @if (!Model.Entries.Any())
            {
                <div class="bg-slate-50 dark:bg-dark-900/50 rounded-2xl border border-dashed border-slate-200 dark:border-dark-600 p-8 text-center text-slate-500 dark:text-slate-400">
                    <p class="m-0 font-medium">No schedule entries available.</p>
                </div>
            }
            else
            {
                <div class="flex flex-col gap-4">
                    @foreach (var entry in Model.Entries)
                    {
                        <div class="border border-slate-200 dark:border-dark-600 hover:border-primary-200 dark:hover:border-primary-900/50 rounded-2xl p-5 lg:p-6 bg-white dark:bg-dark-800 transition-colors shadow-sm relative overflow-hidden group">
                            <!-- Left Accent line -->
                            <div class="absolute left-0 top-0 bottom-0 w-1 bg-slate-200 dark:bg-dark-600 group-hover:bg-primary-400 transition-colors"></div>
                            
                            <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-4 pl-2">
                                <div>
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="px-2.5 py-1 text-[10px] uppercase font-bold tracking-wider rounded border border-slate-200 dark:border-dark-600 bg-slate-50 dark:bg-dark-900 text-slate-600 dark:text-slate-300">@entry.RoleLabel</span>
                                        <span class="px-2.5 py-1 text-[10px] uppercase font-bold tracking-wider rounded @(entry.IsOnline ? "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400" : "bg-slate-100 text-slate-700 dark:bg-dark-700 dark:text-slate-300")">@(entry.IsOnline ? "Online" : "Offline")</span>
                                    </div>
                                    <h3 class="text-lg font-bold text-dark-900 dark:text-white mb-1">@entry.GroupName - @entry.ProjectName</h3>
                                    <div class="text-sm font-medium text-slate-500 dark:text-slate-400">Round @entry.RoundNumber (@entry.RoundType)</div>
                                </div>
                                <div class="sm:text-right shrink-0">
                                    <div class="text-lg font-bold text-dark-900 dark:text-white">@entry.ScheduledAt.ToString("MMM dd, yyyy")</div>
                                    <div class="text-sm font-bold text-primary-500">@entry.ScheduledAt.ToString("HH:mm")</div>
                                </div>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end pl-2">
                                <div class="md:col-span-7">
                                    <div class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1.5">Location / Link</div>
                                    <div class="font-medium text-dark-900 dark:text-white">@entry.Location</div>
                                    @if (!string.IsNullOrWhiteSpace(entry.Guidance))
                                    {
                                        <div class="text-sm text-slate-600 dark:text-slate-400 mt-2 bg-slate-50 dark:bg-dark-900/50 p-2.5 rounded-xl border border-slate-100 dark:border-dark-700 italic">@entry.Guidance</div>
                                    }
                                </div>
                                <div class="md:col-span-5 flex justify-start md:justify-end gap-3 flex-wrap">
                                    @if (!string.IsNullOrWhiteSpace(entry.MeetLink))
                                    {
                                        <a href="@entry.MeetLink" target="_blank" class="inline-flex items-center justify-center px-4 py-2 bg-primary-500 hover:bg-primary-600 text-white text-sm font-bold rounded-xl shadow-sm transition-colors">Open Meet</a>
                                    }
                                    <a href="@entry.ActionUrl" class="inline-flex items-center justify-center px-4 py-2 bg-white dark:bg-dark-800 border border-slate-200 dark:border-dark-600 text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-dark-700 text-sm font-bold rounded-xl shadow-sm transition-colors">Open related page</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="w-full lg:w-1/3">
        <div class="bg-white dark:bg-dark-800 rounded-3xl border border-slate-200 dark:border-dark-700 shadow-sm p-6 lg:p-8 sticky top-24">
            <h2 class="text-xl font-bold text-dark-900 dark:text-white mb-6">Upcoming Deadlines</h2>
            @if (!Model.Deadlines.Any())
            {
                <div class="bg-slate-50 dark:bg-dark-900/50 rounded-2xl p-6 text-center text-slate-500 dark:text-slate-400">
                    <p class="m-0 text-sm font-medium">No upcoming deadlines.</p>
                </div>
            }
            else
            {
                <div class="flex flex-col gap-4">
                    @foreach (var deadline in Model.Deadlines)
                    {
                        var badgeClass = deadline.Severity == "danger" ? "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400" : deadline.Severity == "warning" ? "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400" : "bg-slate-100 text-slate-700 dark:bg-dark-700 dark:text-slate-300";
                        <div class="border border-slate-100 dark:border-dark-700 bg-slate-50/50 dark:bg-dark-900/30 rounded-2xl p-5 shadow-sm">
                            <div class="flex justify-between items-start gap-3 mb-2">
                                <div class="font-bold text-dark-900 dark:text-white">@deadline.Title</div>
                                <span class="px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider rounded-lg shrink-0 @badgeClass">@deadline.DueAt.ToString("MMM dd")</span>
                            </div>
                            <div class="text-sm text-slate-600 dark:text-slate-400 mb-4 leading-relaxed">@deadline.Description</div>
                            <a href="@deadline.ActionUrl" class="inline-flex w-full items-center justify-center px-4 py-2 border border-slate-200 dark:border-dark-600 bg-white dark:bg-dark-800 text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-dark-700 text-sm font-bold rounded-xl shadow-sm transition-colors">@deadline.ActionText</a>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@using System.Security.Claims
@using GPMS.Domain.Enums
@inject GPMS.Application.Interfaces.Repositories.INotificationRepository NotificationRepository
@{
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var notifications = string.IsNullOrWhiteSpace(currentUserId)
        ? Enumerable.Empty<GPMS.Domain.Entities.Notification>()
        : await NotificationRepository.GetRecentByRecipientAsync(currentUserId, 5);
    var unreadCount = notifications.Count(n => !n.IsRead);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GPMS Portal</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <!-- Material Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    
    <!-- Custom Design System styles -->
    <link rel="stylesheet" href="~/css/lecturer-portal.css" asp-append-version="true" />
</head>
<body>
    <div class="portal-wrapper">
        
        <!-- Fixed Sidebar -->
        <partial name="_LecturerSidebar" />
        
        <!-- Main Area -->
        <main class="portal-main">
            
            <!-- Fixed Topbar -->
            <header class="portal-topbar">
                <!-- Breadcrumbs -->
                <nav aria-label="breadcrumb" class="d-flex align-items-center">
                    <ol class="breadcrumb mb-0" style="font-size: 13px;">
                        <li class="breadcrumb-item"><a href="#" class="text-decoration-none" style="color: var(--text-muted);">Portal</a></li>
                        <li class="breadcrumb-item active" aria-current="page" style="color: var(--text-body); font-weight: 500;">
                            @ViewData["Title"]
                        </li>
                    </ol>
                </nav>

                <!-- Topbar Actions -->
                <div class="d-flex align-items-center gap-3">
                    <div class="position-relative">
                        <button id="notificationToggle" class="btn btn-link text-muted p-1 border-0" style="color: #6B7280;">
                            <span class="material-symbols-outlined">notifications</span>
                            @if (unreadCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle" style="width: 8px; height: 8px; margin-top: 8px; margin-left: -8px;"></span>
                            }
                        </button>
                        
                        <!-- Notification Dropdown -->
                        <div id="notificationDropdown" class="d-none position-absolute bg-white rounded shadow-sm border" style="top: 100%; right: 0; width: 320px; z-index: 1000;">
                            <div class="p-3 border-bottom d-flex align-items-center justify-content-between">
                                <h6 class="mb-0 fw-bold" style="font-size: 14px;">Notifications</h6>
                                <a href="@Url.Action("History", "Lecturer")" class="text-decoration-none" style="font-size: 12px; color: var(--fpt-orange)">Open history</a>
                            </div>
                            <div style="max-height: 300px; overflow-y: auto;">
                                @if (!notifications.Any())
                                {
                                    <div class="px-3 py-4 text-center text-muted" style="font-size: 12px;">No notifications yet.</div>
                                }
                                else
                                {
                                    @foreach (var notification in notifications)
                                    {
                                        var icon = notification.Type switch
                                        {
                                            NotificationType.Feedback => "chat",
                                            NotificationType.Schedule => "calendar_today",
                                            NotificationType.Deadline => "event_busy",
                                            NotificationType.Review => "assignment",
                                            _ => "notifications"
                                        };
                                        <div class="px-3 py-2 border-bottom text-body hover-bg-light cursor-pointer">
                                            <div class="d-flex gap-2">
                                                <div class="mt-1"><span class="material-symbols-outlined fs-6" style="color: var(--fpt-orange)">@icon</span></div>
                                                <div>
                                                    <p class="mb-1 fw-medium" style="font-size: 13px;">@notification.Title</p>
                                                    <p class="mb-1 text-muted" style="font-size: 12px;">@notification.Content</p>
                                                    <small class="text-muted" style="font-size: 11px;">@notification.CreatedAt.ToString("MMM dd, HH:mm")</small>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="p-2 text-center border-top">
                                <a href="@Url.Action("History", "Lecturer")" class="text-decoration-none text-muted" style="font-size: 12px;">View all</a>
                            </div>
                        </div>
                    </div>
                    
                    <div style="width: 1px; height: 24px; background-color: var(--border-color);"></div>
                    
                    <div class="dropdown">
                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(User.Identity?.Name ?? "Admin")&background=E5E7EB&color=374151" alt="Profile" class="rounded-circle cursor-pointer" data-bs-toggle="dropdown" aria-expanded="false" width="32" height="32" />
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border mt-2">
                            <li><h6 class="dropdown-header">@User.Identity?.Name</h6></li>
                            <li><a class="dropdown-item" href="#">Profile Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0 p-0">
                                    <button type="submit" class="dropdown-item text-danger d-flex align-items-center gap-2">
                                        <span class="material-symbols-outlined" style="font-size: 18px;">logout</span>
                                        Log out
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Scrollable Content -->
            <div class="portal-content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 bg-success-subtle text-success" role="alert" style="border-radius: 8px;">
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-5">check_circle</span>
                            <span class="fw-medium" style="font-size: 14px;">@TempData["SuccessMessage"]</span>
                        </div>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show border-0 bg-danger-subtle text-danger" role="alert" style="border-radius: 8px;">
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-5">error</span>
                            <span class="fw-medium" style="font-size: 14px;">@TempData["ErrorMessage"]</span>
                        </div>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @RenderBody()
            </div>

        </main>
    </div>

    <!-- Bootstrap & Custom JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/lecturer-portal.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

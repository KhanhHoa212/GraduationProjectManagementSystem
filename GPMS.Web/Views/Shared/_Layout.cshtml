        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const sidebar = document.getElementById('main-sidebar');
                const overlay = document.getElementById('sidebar-overlay');
                const mobileBtn = document.getElementById('mobile-menu-btn');
                const loadingOverlay = document.getElementById('loading-overlay');

                if (mobileBtn) {
                    mobileBtn.addEventListener('click', () => {
                        sidebar.classList.remove('-translate-x-full');
                        overlay.classList.remove('hidden');
                    });
                }

                if (overlay) {
                    overlay.addEventListener('click', () => {
                        sidebar.classList.add('-translate-x-full');
                        overlay.classList.add('hidden');
                    });
                }

                // Global Loading Overlay hook
                document.querySelectorAll('form').forEach(form => {
                    form.addEventListener('submit', function () {
                        if (this.checkValidity() && !this.classList.contains('no-spinner')) {
                            loadingOverlay.classList.add('active');
                        }
                    });
                });

                document.querySelectorAll('a:not([target="_blank"]):not([href^="#"]):not([href^="javascript:"]):not([data-no-load])').forEach(link => {
                    link.addEventListener('click', function (e) {
                        const href = this.getAttribute('href');
                        if (href && !e.ctrlKey && !e.shiftKey && !e.metaKey && !this.classList.contains('no-spinner')) {
                            setTimeout(() => loadingOverlay.classList.add('active'), 50);
                        }
                    });
                });

                window.addEventListener('pageshow', () => {
                    loadingOverlay.classList.remove('active');
                });
            });


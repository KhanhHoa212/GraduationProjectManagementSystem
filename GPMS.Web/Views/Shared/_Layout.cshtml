<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GPMS Admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        
        /* Loading Spinner Overlay Styles */
        #loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.7);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            visibility: hidden;
            opacity: 0;
            transition: visibility 0s, opacity 0.2s linear;
        }
        .dark #loading-overlay {
            background: rgba(16, 22, 34, 0.7);
        }
        #loading-overlay.active {
            visibility: visible;
            opacity: 1;
        }
        .spinner-border.text-orange { color: #F27123; width: 3rem; height: 3rem; }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark min-h-screen flex flex-col transition-colors duration-200">
    <!-- Loading Overlay -->
    <div id="loading-overlay">
        <div class="flex flex-col items-center gap-4">
            <div class="spinner-border text-orange" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-primary font-bold animate-pulse text-lg tracking-wide uppercase">Processing...</p>
        </div>
    </div>

    <!-- Top Navigation Bar -->
    <header class="sticky top-0 z-50 w-full border-b border-[#e7ebf3] dark:border-gray-800 bg-white dark:bg-[#1a2230] px-6 lg:px-10 py-3 shadow-sm">
        <div class="flex items-center justify-between whitespace-nowrap">
            <div class="flex items-center gap-4 text-[#0d121b] dark:text-white">
                @if (User.IsInRole("Admin") || User.IsInRole("HeadOfDept"))
                {
                    <a asp-controller="Admin" asp-action="Dashboard" class="flex items-center gap-4 no-underline text-inherit hover:opacity-80 transition-opacity">
                        <div class="size-8 flex items-center justify-center rounded-lg bg-primary/10 text-primary">
                            <span class="material-symbols-outlined text-2xl font-bold">school</span>
                        </div>
                        <h2 class="text-lg font-extrabold leading-tight tracking-[-0.015em]">GPMS</h2>
                    </a>
                }
                else
                {
                    <a asp-controller="Home" asp-action="Index" class="flex items-center gap-4 no-underline text-inherit hover:opacity-80 transition-opacity">
                        <div class="size-8 flex items-center justify-center rounded-lg bg-primary/10 text-primary">
                            <span class="material-symbols-outlined text-2xl font-bold">school</span>
                        </div>
                        <h2 class="text-lg font-extrabold leading-tight tracking-[-0.015em]">GPMS</h2>
                    </a>
                }
            </div>
            
            <div class="flex flex-1 justify-end gap-8">
                <div class="hidden md:flex items-center gap-8">
                    <a class="text-sm font-medium transition-colors no-underline @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "text-primary font-bold" : "text-[#4c669a] dark:text-gray-400 hover:text-primary")" asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                    
                    @if (User.IsInRole("Admin") || User.IsInRole("HeadOfDept"))
                    {
                        <a class="text-sm font-medium transition-colors no-underline @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "text-primary font-bold" : "text-[#4c669a] dark:text-gray-400 hover:text-primary")" asp-controller="Admin" asp-action="Index">Users</a>
                    }
                    
                    <a class="text-[#4c669a] dark:text-gray-400 hover:text-primary dark:hover:text-primary text-sm font-medium transition-colors no-underline" href="#">Projects</a>
                    <a class="text-[#4c669a] dark:text-gray-400 hover:text-primary dark:hover:text-primary text-sm font-medium transition-colors no-underline" href="#">Reports</a>
                </div>

                <div class="flex items-center gap-4">
                    <button class="flex items-center justify-center text-[#4c669a] dark:text-gray-400 hover:text-primary">
                        <span class="material-symbols-outlined">notifications</span>
                    </button>
                    
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="flex items-center gap-3 pl-4 border-l border-gray-200 dark:border-gray-700">
                             <div class="flex flex-col items-end hidden sm:flex">
                                <span class="text-xs font-bold text-[#0d121b] dark:text-white">@User.Identity.Name</span>
                                <div class="flex items-center gap-2">
                                    @if (!User.IsInRole("Admin"))
                                    {
                                        <a asp-controller="Profile" asp-action="Index" class="text-[10px] text-primary hover:underline font-bold uppercase tracking-wider no-underline">Profile</a>
                                        <span class="text-[10px] text-slate-300">|</span>
                                    }
                                    <a asp-controller="Auth" asp-action="Logout" class="text-[10px] text-red-500 hover:underline font-bold uppercase tracking-wider no-underline">Logout</a>
                                </div>
                            </div>
                            @if (!User.IsInRole("Admin"))
                            {
                                <a asp-controller="Profile" asp-action="Index" class="bg-primary/10 hover:bg-primary/20 transition-colors flex items-center justify-center rounded-full size-9 border-2 border-white dark:border-gray-700 shadow-sm text-primary no-underline">
                                    <span class="material-symbols-outlined">person</span>
                                </a>
                            }
                            else
                            {
                                <div class="bg-primary/10 flex items-center justify-center rounded-full size-9 border-2 border-white dark:border-gray-700 shadow-sm text-primary">
                                    <span class="material-symbols-outlined">person</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                         <a asp-controller="Auth" asp-action="Login" class="rounded-lg bg-primary hover:bg-[#d95d12] text-white h-9 px-4 flex items-center text-sm font-bold transition-all no-underline">
                            Sign In
                         </a>
                    }
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content Container -->
    <main class="flex-1 w-full max-w-[1440px] mx-auto">
        @RenderBody()
    </main>

    <footer class="w-full max-w-[1440px] mx-auto px-10 py-8 border-t border-slate-200 dark:border-slate-800">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-500 dark:text-slate-400">
            <div class="flex items-center gap-4">
                <span>© 2026 GPMS. All rights reserved.</span>
                <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-800 rounded font-mono">v2.4.0</span>
            </div>
            <div class="flex gap-6">
                <a class="hover:text-primary transition-colors no-underline" href="#">Privacy Policy</a>
                <a class="hover:text-primary transition-colors no-underline" href="#">Terms of Service</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const overlay = document.getElementById('loading-overlay');
            
            // Show spinner on form submission
            document.querySelectorAll('form').forEach(form => {
                form.addEventListener('submit', function() {
                    // Check if form is valid if it has validation
                    if (this.checkValidity()) {
                        overlay.classList.add('active');
                    }
                });
            });

            // Show spinner on navigation links
            document.querySelectorAll('a:not([target="_blank"]):not([href^="#"]):not([href^="javascript:"])').forEach(link => {
                link.addEventListener('click', function(e) {
                    const href = this.getAttribute('href');
                    if (href && !e.ctrlKey && !e.shiftKey && !e.metaKey) {
                        setTimeout(() => overlay.classList.add('active'), 50);
                    }
                });
            });

            // Ensure spinner is hidden on back/forward
            window.addEventListener('pageshow', function(event) {
                overlay.classList.remove('active');
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

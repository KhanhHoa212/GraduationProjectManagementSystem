@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!-- Sidebar Navigation -->
<div class="flex flex-col h-full bg-[#1e3a5f] dark:bg-dark-800 border-r border-dark-200 dark:border-dark-700 transition-all duration-300 shadow-xl lg:shadow-none">
    <!-- Logo Section -->
    <div class="h-16 px-6 flex items-center border-b border-dark-200 dark:border-dark-700 shrink-0 bg-dark-900/20 backdrop-blur-sm">
        <a asp-controller="HOD" asp-action="Index" class="flex items-center gap-3 w-full group">
            <div class="w-9 h-9 bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl shadow-lg shadow-primary-500/30 flex items-center justify-center text-white group-hover:scale-105 transition-transform duration-300">
                <span class="material-symbols-outlined text-[20px] font-bold">school</span>
            </div>
            <div class="flex flex-col">
                <span class="font-black text-white text-lg tracking-wide leading-none">GPMS</span>
                <span class="text-primary-300 text-[9px] uppercase tracking-[0.15em] font-bold mt-1 leading-none">HOD PORTAL</span>
            </div>
        </a>
    </div>

    <!-- Navigation Menu -->
    <nav class="flex-1 px-3 py-6 space-y-1 overflow-y-auto custom-scrollbar">
        
        <span class="px-3 text-[10px] font-bold text-dark-400 uppercase tracking-widest mb-2 block">Dashboards</span>

        <a asp-controller="HOD" asp-action="Index" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "Index" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "Index" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">dashboard</span>
            <span class="text-sm font-semibold tracking-wide">Dashboard</span>
            
        </a>

        <a asp-controller="HOD" asp-action="Projects" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "Projects" || currentAction == "CreateProject" || currentAction == "ProjectDetails" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "Projects" || currentAction == "CreateProject" || currentAction == "ProjectDetails" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">folder_open</span>
            <span class="text-sm font-semibold tracking-wide">Projects</span>
            
        </a>


        <span class="px-3 text-[10px] font-bold text-dark-400 uppercase tracking-widest mt-6 mb-2 block">Management</span>

        <a asp-controller="HOD" asp-action="AssignSupervisor" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "AssignSupervisor" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "AssignSupervisor" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">person_check</span>
            <span class="text-sm font-semibold tracking-wide">Supervisor Assign</span>
            
        </a>

        <a asp-controller="HOD" asp-action="ReviewRounds" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "ReviewRounds" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "ReviewRounds" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">update</span>
            <span class="text-sm font-semibold tracking-wide">Review Rounds</span>
            
        </a>

        <a asp-controller="HOD" asp-action="Checklists" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "Checklists" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "Checklists" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">fact_check</span>
            <span class="text-sm font-semibold tracking-wide">Checklists</span>
            
        </a>

        <a asp-controller="HOD" asp-action="AssignReviewer" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "AssignReviewer" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "AssignReviewer" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">assignment_ind</span>
            <span class="text-sm font-semibold tracking-wide">Reviewer Assign</span>
            
        </a>

        <a asp-controller="HOD" asp-action="DefenseSchedule" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "DefenseSchedule" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "DefenseSchedule" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">calendar_month</span>
            <span class="text-sm font-semibold tracking-wide">Defense Schedule</span>
            
        </a>

        <span class="px-3 text-[10px] font-bold text-dark-400 uppercase tracking-widest mt-6 mb-2 block">Monitoring</span>

        <a asp-controller="HOD" asp-action="Progress" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "Progress" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "Progress" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">trending_up</span>
            <span class="text-sm font-semibold tracking-wide">Progress</span>
            
        </a>

        <a asp-controller="HOD" asp-action="Reports" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "Reports" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "Reports" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">bar_chart</span>
            <span class="text-sm font-semibold tracking-wide">Reports</span>
            
        </a>
    </nav>

    <!-- Sign Out -->
    <div class="px-4 py-4 border-t border-dark-200 dark:border-dark-700 bg-dark-900/20 backdrop-blur-sm mt-auto">
        <a asp-controller="Auth" asp-action="Logout" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-slate-300 hover:bg-red-500/10 hover:text-red-400 transition-all duration-300 group">
            <span class="material-symbols-outlined group-hover:scale-110 transition-transform duration-300">logout</span>
            <span class="text-sm font-semibold tracking-wide">Sign Out</span>
        </a>
    </div>
</div>

<style>
/* Custom Scrollbar for sidebar */
.custom-scrollbar::-webkit-scrollbar {
    width: 5px;
}
.custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
}
.custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: theme('colors.dark.600');
    border-radius: 20px;
}
.custom-scrollbar:hover::-webkit-scrollbar-thumb {
    background-color: theme('colors.dark.500');
}
</style>




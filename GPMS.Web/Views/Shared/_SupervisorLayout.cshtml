<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GPMS Supervisor</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-[#f8f9fa] min-h-screen transition-colors duration-200 flex">

    <!-- Fixed Sidebar -->
    <aside class="w-64 flex-shrink-0 bg-white border-r border-[#e7ebf3] flex flex-col fixed h-full z-40 top-0 left-0">
        <!-- Logo -->
        <div class="h-[72px] flex items-center px-6 border-b border-[#e7ebf3]">
            <a asp-controller="Teacher" asp-action="Index" class="flex items-center gap-3 no-underline text-inherit hover:opacity-80 transition-opacity">
                <div class="size-8 flex items-center justify-center rounded-lg bg-blue-50 text-[#0d9488]">
                    <span class="material-symbols-outlined text-xl">shield_person</span>
                </div>
                <div>
                    <h2 class="text-[15px] font-bold leading-tight text-gray-900">GPMS Supervisor</h2>
                    <p class="text-[11px] text-gray-500 font-medium">FPT University</p>
                </div>
            </a>
        </div>

        <!-- Navigation Menu -->
        <nav class="flex-1 px-4 py-6 flex flex-col gap-2 overflow-y-auto">
            <a asp-controller="Teacher" asp-action="Index" 
               class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-semibold transition-colors no-underline @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "bg-[#fff3eb] text-[#f97316]" : "text-gray-600 hover:bg-gray-50")">
                <span class="material-symbols-outlined text-lg">dashboard</span>
                Dashboard
            </a>
            <a asp-controller="Teacher" asp-action="AssignedGroups" 
               class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-semibold transition-colors no-underline text-gray-600 hover:bg-gray-50 @(ViewContext.RouteData.Values["action"]?.ToString() == "AssignedGroups" ? "bg-gray-100 text-gray-900" : "")">
                <span class="material-symbols-outlined text-lg">group</span>
                My Groups
            </a>
            <a asp-controller="Teacher" asp-action="Schedule" 
               class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-semibold transition-colors no-underline text-gray-600 hover:bg-gray-50 @(ViewContext.RouteData.Values["action"]?.ToString() == "Schedule" ? "bg-gray-100 text-gray-900" : "")">
                <span class="material-symbols-outlined text-lg">calendar_month</span>
                Schedule
            </a>
            <a asp-controller="Teacher" asp-action="FeedbackApprovals" 
               class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-semibold transition-colors no-underline text-gray-600 hover:bg-gray-50 @(ViewContext.RouteData.Values["action"]?.ToString() == "FeedbackApprovals" ? "bg-gray-100 text-gray-900" : "")">
                <span class="material-symbols-outlined text-lg">assignment</span>
                Reports
            </a>
            <a href="#" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-semibold transition-colors no-underline text-gray-600 hover:bg-gray-50 mt-2">
                <span class="material-symbols-outlined text-lg">settings</span>
                Settings
            </a>
        </nav>

        <!-- User Profile (Bottom of sidebar) -->
        <div class="border-t border-[#e7ebf3] p-4">
             <div class="flex items-center gap-3">
                 <div class="size-10 rounded-full bg-orange-100 flex items-center justify-center overflow-hidden border border-orange-200">
                     <!-- Dummy Avatar -->
                     <img src="https://ui-avatars.com/api/?name=Prof+Anderson&background=fed7aa&color=c2410c&bold=true" alt="Avatar" class="w-full h-full object-cover"/>
                 </div>
                 <div class="flex-1 truncate">
                    <p class="text-sm font-bold text-gray-900 truncate">@User.Identity?.Name</p>
                    <p class="text-[11px] text-gray-500 font-medium">Supervisor</p>
                 </div>
                 <a asp-controller="Auth" asp-action="Logout" class="text-gray-400 hover:text-red-500 transition-colors" title="Logout">
                     <span class="material-symbols-outlined text-lg">logout</span>
                 </a>
             </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div class="flex-1 flex flex-col w-full ml-64 bg-[#f8f9fa] min-h-screen">
        
        <!-- Top Nav (Search & Notifications) -->
        <header class="h-[72px] sticky top-0 z-30 bg-[#f8f9fa] px-8 flex items-center justify-between border-b border-gray-200/60">
            <h1 class="text-lg font-bold text-gray-900">@ViewData["Title"]</h1>
            
            <div class="flex items-center gap-6">
                <!-- Search Bar -->
                <div class="relative w-80">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-gray-400 text-sm">search</span>
                    </div>
                    <input type="text" 
                           class="block w-full pl-9 pr-3 py-2 border-0 rounded-lg text-sm bg-gray-100 text-gray-900 placeholder-gray-500 focus:ring-1 focus:ring-indigo-500 focus:bg-white transition-colors" 
                           placeholder="Search groups, students...">
                </div>

                <!-- Icons -->
                <div class="flex items-center gap-4 text-gray-500">
                    <button class="hover:text-gray-900 transition-colors relative">
                        <span class="material-symbols-outlined text-[20px]">notifications</span>
                        <span class="absolute top-0 right-0 size-2 bg-red-500 rounded-full border border-white"></span>
                    </button>
                    <button class="hover:text-gray-900 transition-colors">
                        <span class="material-symbols-outlined text-[20px]">chat</span>
                    </button>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="flex-1 p-8">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

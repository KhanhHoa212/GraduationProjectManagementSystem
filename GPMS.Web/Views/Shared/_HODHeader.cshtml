@{
    var currentSemester = "SP25 - 2024-2025"; 
}
<!-- Header Navigation -->
<header class="bg-white border-b border-slate-200 h-[72px] shrink-0 flex items-center shadow-sm z-30 transition-colors duration-300">
    <div class="px-6 lg:px-8 w-full flex items-center justify-between">
        <!-- Breadcrumb & Mobile Menu -->
        <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2.5 -ml-3 text-dark-500 dark:text-dark-400 hover:bg-dark-100 dark:hover:bg-dark-700 rounded-xl transition-colors">
                <span class="material-symbols-outlined">menu</span>
            </button>
            <div class="hidden sm:flex items-center gap-2.5 text-sm text-dark-500 dark:text-dark-400 font-medium">
                <span class="hover:text-primary-500 cursor-pointer transition-colors">GPMS</span>
                <span class="material-symbols-outlined text-sm">chevron_right</span>
                <span class="text-dark-900 font-bold">@(ViewData["Title"] ?? "Dashboard")</span>
            </div>
        </div>

        <!-- Right Section: Actions & Profile -->
        <div class="flex items-center gap-3 md:gap-5">
            <!-- Semester Selector -->
            <div class="hidden md:flex items-center gap-3 bg-white border rounded-xl border-slate-200 px-4 py-1.5">
                <span class="text-xs font-bold text-dark-500 dark:text-dark-400 uppercase tracking-widest">Há»ŒC Ká»²</span>
                <div class="w-px h-4 bg-dark-300 dark:bg-dark-600"></div>
                <div class="relative group cursor-pointer">
                    <select class="bg-transparent text-sm font-bold text-primary-600 dark:text-primary-400 outline-none appearance-none pr-6 cursor-pointer group-hover:text-primary-500 transition-colors z-10 relative">
                        <option>SP25 - 2024-2025</option>
                        <option>FA24 - 2024-2025</option>
                        <option>SU24 - 2023-2024</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-0 top-1/2 -translate-y-1/2 pointer-events-none text-primary-500 text-base transition-transform group-hover:translate-y-[-40%]">arrow_drop_down</span>
                </div>
            </div>

            <div class="h-8 w-px bg-dark-200 dark:bg-dark-700 hidden sm:block mx-1"></div>

            <!-- Notifications -->
            <button class="relative p-2.5 text-dark-500 dark:text-dark-400 hover:text-primary-500 dark:hover:text-primary-400 hover:bg-primary-50 dark:hover:bg-dark-700 rounded-xl transition-all group">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">notifications</span>
                <span class="absolute top-2 right-2.5 w-2 h-2 bg-red-500 rounded-full shadow-[0_0_0_2px_#ffffff] dark:shadow-[0_0_0_2px_#1E293B] animate-pulse"></span>
            </button>

            <!-- User Profile -->
            <div class="flex items-center gap-3 pl-2 sm:pl-3 cursor-pointer group hover:bg-dark-50 dark:hover:bg-dark-700/50 p-1.5 pr-3 rounded-xl transition-colors">
                <div class="text-right hidden sm:block">
                    <div class="text-sm font-bold text-dark-900 dark:text-white group-hover:text-primary-500 transition-colors">@(User.Identity?.Name ?? "SP25 Portal")</div>
                    <div class="text-[11px] font-medium text-dark-500 dark:text-dark-400 tracking-wide mt-0.5">Admin User</div>
                </div>
                <div class="w-10 h-10 bg-gradient-to-br from-primary-400 to-primary-600 rounded-full flex items-center justify-center shadow-md border-2 border-white dark:border-dark-700 group-hover:shadow-primary-500/30 group-hover:scale-105 transition-all duration-300">
                    <span class="text-white font-bold text-base">A</span>
                </div>
            </div>
        </div>
    </div>
</header>



@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!-- Sidebar Navigation -->
<div class="flex flex-col h-full bg-[#1e3a5f] dark:bg-dark-800 border-r border-dark-200 dark:border-dark-700 transition-all duration-300 shadow-xl lg:shadow-none">
    <!-- Logo Section -->
    <div class="h-16 px-6 flex items-center border-b border-dark-200 dark:border-dark-700 shrink-0 bg-dark-900/20 backdrop-blur-sm">
        <a asp-controller="Student" asp-action="Index" class="flex items-center gap-3 w-full group">
            <div class="w-9 h-9 bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl shadow-lg shadow-primary-500/30 flex items-center justify-center text-white group-hover:scale-105 transition-transform duration-300">
                <span class="material-symbols-outlined text-[20px] font-bold">school</span>
            </div>
            <div class="flex flex-col">
                <span class="font-black text-white text-lg tracking-wide leading-none">GPMS</span>
                <span class="text-primary-300 text-[9px] uppercase tracking-[0.15em] font-bold mt-1 leading-none">MY WORKSPACE</span>
            </div>
        </a>
    </div>

    <!-- Navigation Menu -->
    <nav class="flex-1 px-3 py-6 space-y-1 overflow-y-auto custom-scrollbar">
        
        <span class="px-3 text-[10px] font-bold text-dark-400 uppercase tracking-widest mb-2 block">My Workspace</span>

        <a asp-controller="Student" asp-action="Index" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "Index" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "Index" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">folder_open</span>
            <span class="text-sm font-semibold tracking-wide">My Project</span>
        </a>

        <a asp-action="Submissions" asp-controller="Student" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "Submissions" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "Submissions" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">description</span>
            <span class="text-sm font-semibold tracking-wide">Submissions</span>
        </a>

        <a asp-action="Feedback" asp-controller="Student" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "Feedback" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "Feedback" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">rate_review</span>
            <span class="text-sm font-semibold tracking-wide">Feedback</span>
        </a>

        <a asp-action="Schedule" asp-controller="Student" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "Schedule" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "Schedule" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">event</span>
            <span class="text-sm font-semibold tracking-wide">Project Defense Schedule</span>
        </a>


        <a asp-action="Notifications" asp-controller="Student" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-300 group @(currentAction == "Notifications" ? "bg-[#F37021] text-white shadow-md" : "text-slate-300 hover:bg-dark-700/60 hover:text-white")">
            <span class="material-symbols-outlined @(currentAction == "Notifications" ? "filled" : "") group-hover:scale-110 transition-transform duration-300">notifications</span>
            <span class="text-sm font-semibold tracking-wide">Notifications</span>
        </a>
    </nav>

    <!-- Sign Out -->
    <div class="px-4 py-4 border-t border-dark-200 dark:border-dark-700 bg-dark-900/20 backdrop-blur-sm mt-auto">
        <a asp-controller="Auth" asp-action="Logout" 
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-slate-300 hover:bg-red-500/10 hover:text-red-400 transition-all duration-300 group">
            <span class="material-symbols-outlined group-hover:scale-110 transition-transform duration-300">logout</span>
            <span class="text-sm font-semibold tracking-wide">Sign Out</span>
        </a>
    </div>
</div>

<style>
/* Custom Scrollbar for sidebar */
.custom-scrollbar::-webkit-scrollbar {
    width: 5px;
}
.custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
}
.custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: theme('colors.dark.600');
    border-radius: 20px;
}
.custom-scrollbar:hover::-webkit-scrollbar-thumb {
    background-color: theme('colors.dark.500');
}
</style>

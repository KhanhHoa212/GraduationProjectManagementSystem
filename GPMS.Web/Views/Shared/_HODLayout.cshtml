<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GPMS HOD</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .material-symbols-outlined.filled { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }

        #hod-sidebar {
            width: 256px;
            min-width: 256px;
            height: 100vh;
            position: fixed;
            top: 0; left: 0;
            z-index: 100;
            display: flex;
            flex-direction: column;
            background: #1a2236;
            border-right: 1px solid rgba(255,255,255,0.06);
            transition: transform 0.3s ease;
        }

        #hod-main {
            margin-left: 256px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .sidebar-nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
            color: #94a3b8;
            transition: all 0.2s ease;
            margin-bottom: 2px;
        }

        .sidebar-nav-item:hover {
            background: rgba(255,255,255,0.07);
            color: #ffffff;
            text-decoration: none;
        }

        .sidebar-nav-item.active {
            background: rgba(243, 112, 33, 0.1);
            color: #F37021;
            font-weight: 600;
            border-left: 3px solid #F37021;
            border-top-left-radius: 0;
            border-bottom-left-radius: 0;
        }

        .sidebar-nav-item.active .material-symbols-outlined {
            font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24;
        }

        .sidebar-section-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: rgba(100, 116, 139, 0.8);
            padding: 0 14px;
            margin: 16px 0 6px 0;
        }

        .main-content-area::-webkit-scrollbar { width: 6px; }
        .main-content-area::-webkit-scrollbar-track { background: #f0f2f5; }
        .main-content-area::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 6px; }

        @@media (max-width: 768px) {
            #hod-sidebar { transform: translateX(-100%); }
            #hod-sidebar.open { transform: translateX(0); }
            #hod-main { margin-left: 0; }
        }
    </style>
</head>
<body class="bg-[#f0f2f5] text-slate-900">
    <div class="flex">
        <!-- Sidebar -->
        <aside id="hod-sidebar">
            <div class="px-5 py-5 border-b border-white/5">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 no-underline">
                    <div class="size-9 rounded-xl bg-[#F37021] flex items-center justify-center shadow-lg shadow-primary/30 flex-shrink-0">
                        <span class="material-symbols-outlined text-white text-xl filled">domain</span>
                    </div>
                    <div>
                        <h1 class="text-white text-lg font-extrabold tracking-tight leading-tight">GPMS</h1>
                        <p class="text-[10px] text-slate-400 uppercase tracking-widest font-semibold">HOD Portal</p>
                    </div>
                </a>
            </div>

            <nav class="flex-1 overflow-y-auto px-3 py-3">
                <span class="sidebar-section-label">Overview</span>
                <a asp-controller="HOD" asp-action="Index" class="sidebar-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span>Dashboard</span>
                </a>

                <span class="sidebar-section-label">Management</span>
                <a asp-controller="HOD" asp-action="Projects" class="sidebar-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Projects" || ViewContext.RouteData.Values["action"]?.ToString() == "ProjectDetails" ? "active" : "")">
                    <span class="material-symbols-outlined">account_tree</span>
                    <span>Projects</span>
                </a>
                <a asp-controller="HOD" asp-action="Groups" class="sidebar-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Groups" ? "active" : "")">
                    <span class="material-symbols-outlined">group</span>
                    <span>Groups</span>
                </a>

                <span class="sidebar-section-label">Actions</span>
                <a asp-controller="HOD" asp-action="AssignSupervisor" class="sidebar-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "AssignSupervisor" ? "active" : "")">
                    <span class="material-symbols-outlined">person_add</span>
                    <span>Assign Supervisor</span>
                </a>
                <a asp-controller="HOD" asp-action="Import" class="sidebar-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Import" ? "active" : "")">
                    <span class="material-symbols-outlined">cloud_upload</span>
                    <span>Import Data</span>
                </a>
            </nav>

            <div class="px-4 py-3 mx-3 mb-3 bg-white/5 rounded-xl border border-white/5 text-[10px]">
                <p class="text-slate-500 uppercase tracking-widest font-bold mb-1">Active Semester</p>
                <p class="text-[#F37021] font-extrabold text-sm">Spring 2025 (SP25)</p>
            </div>

            <div class="border-t border-white/5 p-3">
                <div class="flex items-center gap-3 p-2 rounded-xl hover:bg-white/5 transition-colors cursor-pointer">
                    <div class="size-9 rounded-full bg-[#F37021]/20 flex items-center justify-center text-[#F37021] border-2 border-[#F37021]/30 flex-shrink-0">
                        <span class="material-symbols-outlined text-base">person</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold text-white truncate">@User.Identity?.Name</p>
                        <p class="text-[11px] text-slate-400">Head of Dept</p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main -->
        <div id="hod-main" class="flex-1">
            <header class="sticky top-0 z-50 h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 shadow-sm">
                <button id="sidebar-toggle" class="md:hidden p-2 text-slate-500 hover:bg-slate-100 rounded-lg">
                    <span class="material-symbols-outlined">menu</span>
                </button>

                <div class="flex items-center gap-2 text-slate-500 text-sm">
                    <span class="font-medium">HOD Portal</span>
                    <span class="material-symbols-outlined text-slate-300 text-xs">chevron_right</span>
                    <span class="text-slate-900 font-semibold">@ViewData["Title"]</span>
                </div>

                <div class="flex items-center gap-3">
                    <div class="flex items-center gap-2 pl-3 border-l border-slate-200">
                        <div class="text-right hidden sm:block">
                            <p class="text-xs font-bold text-slate-900">Academic Office</p>
                            <p class="text-[10px] text-slate-500 uppercase">Campus Resource</p>
                        </div>
                        <div class="size-9 rounded-full bg-[#F37021]/10 flex items-center justify-center text-[#F37021] border-2 border-[#F37021]/20">
                            <span class="text-[10px] font-bold">FPT</span>
                        </div>
                    </div>
                </div>
            </header>

            <main class="flex-1 p-8 main-content-area overflow-y-auto">
                @RenderBody()
            </main>
        </div>
    </div>

    <script>
        document.getElementById('sidebar-toggle')?.addEventListener('click', () => {
            const sidebar = document.getElementById('hod-sidebar');
            sidebar.classList.toggle('open');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GPMS Reviewer Portal</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-[#f8f9fa] min-h-screen flex flex-col transition-colors duration-200">

    <!-- Top Navigation Bar -->
    <header class="sticky top-0 z-50 w-full border-b border-[#e7ebf3] bg-white px-8 py-3 shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)]">
        <div class="flex items-center justify-between">
            
            <!-- Logo area -->
            <div class="flex items-center gap-3 text-gray-900">
                <a asp-controller="Teacher" asp-action="AssignedGroups" class="flex items-center gap-3 no-underline text-inherit hover:opacity-80 transition-opacity">
                    <div class="size-8 flex items-center justify-center rounded-lg bg-orange-100/50 text-orange-500 border border-orange-100">
                        <span class="material-symbols-outlined text-[18px]">verified</span>
                    </div>
                    <div class="flex items-baseline gap-2">
                        <h2 class="text-sm font-extrabold tracking-tight">GPMS</h2>
                        <span class="text-[13px] text-gray-400 font-medium">Reviewer Portal</span>
                    </div>
                </a>
            </div>
            
            <!-- Center Navigation -->
            <div class="hidden md:flex items-center gap-6">
                <a href="#" class="text-[13px] font-semibold transition-colors no-underline text-gray-500 hover:text-gray-900">Dashboard</a>
                <a asp-controller="Teacher" asp-action="AssignedGroups" class="text-[13px] font-bold transition-colors no-underline text-orange-500 border-b-2 border-orange-500 pb-1 -mb-1">Reviews</a>
                <a href="#" class="text-[13px] font-semibold transition-colors no-underline text-gray-500 hover:text-gray-900">Schedule</a>
            </div>

            <!-- Profile Info -->
            <div class="flex items-center gap-4">
                <div class="flex flex-col items-end hidden sm:flex">
                    <span class="text-[13px] font-bold text-gray-900 leading-tight">@User.Identity?.Name</span>
                    <span class="text-[11px] text-gray-400 font-medium">Lecturer</span>
                </div>
                <!-- Profile Avatar -->
                <div class="size-9 rounded-full bg-blue-50 flex items-center justify-center overflow-hidden border-2 border-white shadow-sm ring-1 ring-gray-100">
                     <img src="https://ui-avatars.com/api/?name=Dr+Alan+Smith&background=f8fafc&color=0f172a&bold=true" alt="Avatar" class="w-full h-full object-cover"/>
                </div>
            </div>

        </div>
    </header>

    <!-- Main Content Container -->
    <main class="flex-1 w-full max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

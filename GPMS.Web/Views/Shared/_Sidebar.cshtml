@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    // Helper function for active state
    bool IsActive(string controller, string action)
    {
        if (!currentController.Equals(controller, StringComparison.OrdinalIgnoreCase)) return false;

        // Special handling for HOD Projects
        if (controller.Equals("HOD", StringComparison.OrdinalIgnoreCase) && action.Equals("Projects",
        StringComparison.OrdinalIgnoreCase))
        {
            return currentAction.Equals("Projects", StringComparison.OrdinalIgnoreCase) ||
            currentAction.Equals("CreateProject", StringComparison.OrdinalIgnoreCase) ||
            currentAction.Equals("ProjectDetails", StringComparison.OrdinalIgnoreCase);
        }

        // Special handling for HOD Review Rounds
        if (controller.Equals("HOD", StringComparison.OrdinalIgnoreCase) && action.Equals("ReviewRounds",
        StringComparison.OrdinalIgnoreCase))
        {
            return currentAction.Equals("ReviewRounds", StringComparison.OrdinalIgnoreCase) ||
            currentAction.Equals("CreateReviewRound", StringComparison.OrdinalIgnoreCase) ||
            currentAction.Equals("EditReviewRound", StringComparison.OrdinalIgnoreCase);
        }

        return currentAction.Equals(action, StringComparison.OrdinalIgnoreCase);
    }

    string GetActiveClasses(string controller, string action)
    {
        return IsActive(controller, action)
        ? "border-[#f4741c] bg-[#f4741c]/10 text-[#f4741c] font-semibold"
        : "border-transparent text-slate-400 font-medium hover:text-white hover:bg-white/5";
    }

    string GetIconClasses(string controller, string action)
    {
        return IsActive(controller, action) ? "filled" : "";
    }
}

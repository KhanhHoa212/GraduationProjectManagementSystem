@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? ViewBag.Title) - GPMS Student Portal</title>
    
    <!-- Google Fonts - Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
        
    <!-- Material Symbols Outlined -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
        
    <!-- Tailwind CSS v3 -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        primary: {
                            50: '#FEF5F1',
                            100: '#FDE9E1',
                            200: '#FBD3C3',
                            300: '#F8BDA5',
                            400: '#F59980',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#933A0F',
                            900: '#762E0A',
                        },
                        dark: {
                            50: '#F8FAFC',
                            100: '#F1F5F9',
                            200: '#E2E8F0',
                            300: '#CBD5E1',
                            400: '#94A3B8',
                            500: '#64748B',
                            600: '#475569',
                            700: '#334155',
                            800: '#1E293B',
                            900: '#0F172A',
                        },
                        sidebar: '#1e3a5f',
                    },
                }
            }
        }
    </script>
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }
        
        body {
            @@apply bg-white dark:bg-dark-900 text-dark-900 dark:text-white transition-colors duration-300;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .material-symbols-outlined.filled {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .sidebar {
            @@apply bg-sidebar dark:bg-dark-800 text-white;
        }

        .card {
            @@apply bg-white dark:bg-dark-800 rounded-[12px] shadow-[0_4px_12px_rgba(0,0,0,0.05)] border border-transparent dark:border-dark-700 transition-all duration-300;
        }

        .stat-card {
            @@apply card p-6 flex items-center justify-between;
        }

        .btn-primary {
            @@apply bg-primary-500 hover:bg-primary-600 text-white font-medium px-4 py-2 rounded-lg transition-colors duration-200 inline-flex items-center gap-2;
        }

        .btn-secondary {
            @@apply bg-dark-100 dark:bg-dark-700 hover:bg-dark-200 dark:hover:bg-dark-600 text-dark-900 dark:text-white font-medium px-4 py-2 rounded-lg transition-colors duration-200 inline-flex items-center gap-2;
        }

        .btn-icon {
            @@apply p-2 hover:bg-dark-100 dark:hover:bg-dark-700 rounded-lg transition-colors duration-200;
        }

        /* Loading overlay */
        #loading-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(255,255,255,0.7);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            visibility: hidden;
            opacity: 0;
            transition: visibility 0s, opacity 0.2s linear;
        }
        .dark #loading-overlay {
            background: rgba(15, 23, 42, 0.7);
        }
        #loading-overlay.active {
            visibility: visible;
            opacity: 1;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-[#F5F7FA] dark:bg-dark-900 antialiased selection:bg-primary-500 selection:text-white">
    
    <!-- Loading Overlay -->
    <div id="loading-overlay">
        <div class="flex flex-col items-center gap-4 bg-white dark:bg-dark-800 p-6 rounded-2xl shadow-xl border border-dark-100 dark:border-dark-700">
            <div class="w-12 h-12 border-4 border-primary-500/30 border-t-primary-500 rounded-full animate-spin"></div>
            <p class="text-primary-500 font-bold animate-pulse text-sm tracking-widest uppercase">Processing...</p>
        </div>
    </div>

    <!-- Main Layout wrapper -->
    <div class="flex h-screen overflow-hidden">
        
        <!-- Sidebar -->
        <div id="main-sidebar" class="z-50 transition-transform duration-300 w-64 shrink-0 shadow-2xl lg:shadow-[2px_0_10px_rgba(0,0,0,0.1)] lg:relative absolute top-0 left-0 bg-sidebar dark:bg-dark-800 h-full -translate-x-full lg:translate-x-0">
            @await Html.PartialAsync("_StudentSidebar")
        </div>
        
        <!-- Mobile Sidebar Overlay -->
        <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 backdrop-blur-[2px] z-40 hidden lg:hidden transition-opacity"></div>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-hidden w-full relative">
            
            <!-- Header -->
            @await Html.PartialAsync("_StudentHeader")
            
            <!-- Page Content -->
            <main class="flex-1 overflow-auto bg-[#F5F7FA] dark:bg-dark-900 custom-main-scroll">
                <div class="w-full min-h-full p-4 lg:p-6 pb-20 lg:pb-24 text-dark-900 dark:text-dark-100">
                    @RenderBody()
                </div>
            </main>            
            <div id="chatbot-container">
                <iframe id="chatbot-iframe"
                        src="https://gpms-bot-supporter-fe.onrender.com/"
                        style="position: fixed;
                               bottom: 0;
                               right: 0;
                               width: 60px;
                               height: 60px;
                               border: none;
                               z-index: 9999;
                               border-radius: 50%;
                               overflow: hidden;">
                </iframe>
            </div>
        </div>
    </div>

    <!-- Scrollbar Styling for Main Content -->
    <style>
        .custom-main-scroll::-webkit-scrollbar { width: 8px; height: 8px; }
        .custom-main-scroll::-webkit-scrollbar-track { background: transparent; }
        .custom-main-scroll::-webkit-scrollbar-thumb { 
            background-color: theme('colors.dark.300'); 
            border-radius: 10px; 
            border: 2px solid theme('colors.dark.50'); 
        }
        .dark .custom-main-scroll::-webkit-scrollbar-thumb { 
            background-color: theme('colors.dark.600'); 
            border: 2px solid theme('colors.dark.900');
        }
        .custom-main-scroll::-webkit-scrollbar-thumb:hover { background-color: theme('colors.dark.400'); }
        .dark .custom-main-scroll::-webkit-scrollbar-thumb:hover { background-color: theme('colors.dark.500'); }
    </style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const sidebar = document.getElementById('main-sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            const mobileBtn = document.getElementById('mobile-menu-btn');
            const loadingOverlay = document.getElementById('loading-overlay');

            if(mobileBtn) {
                mobileBtn.addEventListener('click', () => {
                    sidebar.classList.remove('-translate-x-full');
                    overlay.classList.remove('hidden');
        window.addEventListener("message", function (event) {
            if (!event.data || typeof event.data !== "object") return;
            const iframe = document.getElementById("chatbot-iframe");
            if (!iframe) return;
            if (event.data.type === "chatbot-open") {
                iframe.style.width = "400px";
                iframe.style.height = "500px";
                iframe.style.borderRadius = "12px";
            } else if (event.data.type === "chatbot-close") {
                iframe.style.width = "60px";
                iframe.style.height = "60px";
                iframe.style.borderRadius = "50%";
            }
        }, false);
        document.addEventListener('DOMContentLoaded', function () {
            const overlay = document.getElementById('loading-overlay');
            const sidebar = document.getElementById('student-sidebar');
            const sidebarToggle = document.getElementById('sidebar-toggle');
            const sidebarOverlay = document.getElementById('sidebar-overlay');

            // Mobile sidebar toggle
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', function () {
                    sidebar.classList.toggle('open');
                    sidebarOverlay.classList.toggle('hidden');
                });
            }

            if(overlay) {
                overlay.addEventListener('click', () => {
                    sidebar.classList.add('-translate-x-full');
                    overlay.classList.add('hidden');
                });
            }

            document.querySelectorAll('form').forEach(form => {
                form.addEventListener('submit', function () {
                    if (this.checkValidity()) {
                        loadingOverlay.classList.add('active');
                    }
                });
            });

            document.querySelectorAll('a:not([target="_blank"]):not([href^="#"]):not([href^="javascript:"]):not([data-no-load])').forEach(link => {
                link.addEventListener('click', function (e) {
                    const href = this.getAttribute('href');
                    if (href && !e.ctrlKey && !e.shiftKey && !e.metaKey) {
                        setTimeout(() => loadingOverlay.classList.add('active'), 50);
                    }
                });
            });

            window.addEventListener('pageshow', () => {
                loadingOverlay.classList.remove('active');
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

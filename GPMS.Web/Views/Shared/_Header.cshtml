@using GPMS.Application.Interfaces.Services
@inject ISemesterService SemesterService
@{
    var semesters = await SemesterService.GetAllSemestersAsync();
    var activeSemester = semesters.FirstOrDefault(s => s.Status == GPMS.Domain.Enums.SemesterStatus.Active);
}
<!-- Header Navigation -->
<header class="bg-white border-b border-slate-200 h-[72px] shrink-0 flex items-center shadow-sm z-30 transition-colors duration-300">
    <div class="px-6 lg:px-8 w-full flex items-center justify-between">
        <!-- Breadcrumb & Mobile Menu -->
        <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2.5 -ml-3 text-dark-500 hover:bg-dark-100 rounded-xl transition-colors">
                <span class="material-symbols-outlined">menu</span>
            </button>
            <div class="hidden sm:flex items-center gap-2.5 text-sm text-dark-500 font-medium">
                <span class="hover:text-primary-500 cursor-pointer transition-colors">
                    @if (User.IsInRole("Admin")) { <text>Admin Portal</text> }
                    else if (User.IsInRole("HeadOfDept")) { <text>HOD Portal</text> }
                    else if (User.IsInRole("Lecturer")) { <text>Lecturer Panel</text> }

                    else { <text>GPMS</text> }
                </span>
                <span class="material-symbols-outlined text-sm">chevron_right</span>
                <span class="text-dark-900 font-bold">@(ViewData["BreadcrumbTitle"] ?? ViewData["Title"] ?? "Dashboard")</span>
            </div>
        </div>

        <!-- Right Section: Actions & Profile -->
        <div class="flex items-center gap-3 md:gap-5">
            <!-- Semester Selector (Custom Premium Dropdown) - Only for Admin & HOD -->
            @if (User.IsInRole("Admin") || User.IsInRole("HeadOfDept"))
            {
                <div class="relative hidden md:block" id="semester-dropdown">
                    <button type="button" 
                            id="semester-btn"
                            class="flex items-center gap-3 bg-white border border-slate-200 rounded-xl px-4 py-2.5 hover:border-primary-400 hover:shadow-md transition-all duration-200 group">
                        <div class="flex items-center gap-3 h-full">
                            <span class="text-[11px] font-black text-slate-400 uppercase tracking-widest border-r border-slate-200 pr-3">Học Kỳ</span>
                            <div class="flex items-center gap-1.5">
                                <span class="text-sm font-bold text-primary-600">
                                    @(activeSemester?.SemesterCode ?? "N/A") - @(activeSemester?.AcademicYear ?? "N/A")
                                </span>
                                <span class="material-symbols-outlined text-primary-500 text-lg transition-transform duration-300 group-hover:rotate-180">expand_more</span>
                            </div>
                        </div>
                    </button>

                    <!-- Dropdown Menu -->
                    <div id="semester-menu" 
                         class="absolute top-[calc(100%+8px)] right-0 w-72 bg-white rounded-2xl shadow-2xl border border-slate-100 py-3 hidden z-50 origin-top-right transform transition-all duration-200">
                        
                        <div class="px-5 py-2 mb-2 border-b border-slate-50">
                            <span class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">Chọn học kỳ làm việc</span>
                        </div>

                        <div class="max-h-[240px] overflow-y-auto px-2 custom-scrollbar">
                            @foreach (var sem in semesters.OrderByDescending(s => s.StartDate))
                            {
                                <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-slate-50 transition-all group/item @(sem.Status == GPMS.Domain.Enums.SemesterStatus.Active ? "bg-primary-50/50" : "")">
                                    <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0 @(sem.Status == GPMS.Domain.Enums.SemesterStatus.Active ? "bg-primary-500 text-white" : "bg-slate-100 text-slate-400")">
                                        <span class="material-symbols-outlined text-[20px]">calendar_today</span>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center justify-between">
                                            <span class="text-sm font-bold text-slate-700 group-hover/item:text-primary-600 truncate">@sem.SemesterCode - @sem.AcademicYear</span>
                                            @if (sem.Status == GPMS.Domain.Enums.SemesterStatus.Active)
                                            {
                                                <span class="flex h-2 w-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></span>
                                            }
                                        </div>
                                        <div class="flex items-center gap-2 mt-0.5">
                                            <span class="text-[11px] text-slate-400 font-medium">@sem.StartDate.ToString("dd/MM/yyyy")</span>
                                            <span class="text-[10px] text-slate-300">•</span>
                                            <span class="text-[11px] text-slate-400 font-medium">@sem.EndDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>

                        <div class="mt-3 px-4 pt-3 border-t border-slate-50 flex items-center justify-center">
                            <a href="#" class="text-[11px] font-bold text-primary-600 hover:text-primary-700 flex items-center gap-1.5 group/manage">
                                Quản lý học kỳ
                                <span class="material-symbols-outlined text-sm group-hover/manage:translate-x-0.5 transition-transform">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                </div>

                <script>
                    document.addEventListener('DOMContentLoaded', () => {
                        const btn = document.getElementById('semester-btn');
                        const menu = document.getElementById('semester-menu');
                        const dropdown = document.getElementById('semester-dropdown');

                        if (btn && menu) {
                            btn.addEventListener('click', (e) => {
                                e.stopPropagation();
                                const isHidden = menu.classList.contains('hidden');
                                
                                if (isHidden) {
                                    menu.classList.remove('hidden', 'animate-out', 'fade-out', 'zoom-out-95');
                                    menu.classList.add('animate-in', 'fade-in', 'zoom-in-95');
                                } else {
                                    menu.classList.add('hidden');
                                    menu.classList.remove('animate-in', 'fade-in', 'zoom-in-95');
                                }
                            });

                            document.addEventListener('click', (e) => {
                                if (!dropdown.contains(e.target)) {
                                    menu.classList.add('hidden');
                                    menu.classList.remove('animate-in', 'fade-in', 'zoom-in-95');
                                }
                            });
                        }
                    });
                </script>
            }

            <style>
                #semester-menu.animate-in {
                    display: block !important;
                    animation: enter 0.2s ease-out;
                }
                @@keyframes enter {
                    from { opacity: 0; transform: translateY(-10px) scale(0.95); }
                    to { opacity: 1; transform: translateY(0) scale(1); }
                }

                .custom-scrollbar::-webkit-scrollbar { width: 4px; }
                .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
                .custom-scrollbar::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 10px; }
                .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #CBD5E1; }
            </style>

            <div class="h-8 w-px bg-dark-200 dark:bg-dark-700 hidden sm:block mx-1"></div>

            <!-- Notifications (Common) -->
            @await Component.InvokeAsync("NotificationDropdown")

            <!-- User Profile Dropdown (Common) -->
            <div class="relative" id="profile-dropdown">
                <button type="button" id="profile-btn" class="flex items-center gap-3 pl-2 sm:pl-3 cursor-pointer group hover:bg-dark-50 p-1.5 pr-3 rounded-xl transition-colors">
                    <div class="text-right hidden sm:block">
                        <div class="text-sm font-bold text-dark-900 group-hover:text-primary-500 transition-colors">@(User.Identity?.Name ?? "User")</div>
                        <div class="text-[11px] font-medium text-dark-500 tracking-wide mt-0.5">
                            @if (User.IsInRole("Admin")) { <text>System Administrator</text> }
                            else if (User.IsInRole("HeadOfDept")) { <text>Head of Department</text> }
                            else if (User.IsInRole("Lecturer")) { <text>Senior Lecturer</text> }

                            else { <text>Student</text> }
                        </div>
                    </div>
                    <div class="w-10 h-10 bg-gradient-to-br from-primary-400 to-primary-600 rounded-full flex items-center justify-center shadow-md border-2 border-white dark:border-dark-700 group-hover:shadow-primary-500/30 group-hover:scale-105 transition-all duration-300">
                        <span class="text-white font-bold text-base">@(string.IsNullOrEmpty(User.Identity?.Name) ? "A" : User.Identity.Name.Substring(0, 1).ToUpper())</span>
                    </div>
                    <span class="material-symbols-outlined text-dark-400 text-sm transition-transform duration-300 group-hover:rotate-180">expand_more</span>
                </button>

                <!-- Profile Menu -->
                <div id="profile-menu" class="absolute top-[calc(100%+8px)] right-0 w-48 bg-white rounded-2xl shadow-2xl border border-slate-100 py-2 hidden z-50 origin-top-right transform transition-all duration-200">
                    <a href="#" class="flex items-center gap-3 px-4 py-2.5 hover:bg-slate-50 text-slate-700 hover:text-primary-600 transition-colors">
                        <span class="material-symbols-outlined text-[20px]">person</span>
                        <span class="text-sm font-medium">Hồ sơ cá nhân</span>
                    </a>
                    <div class="h-px bg-slate-100 my-1 mx-4"></div>
                    <a asp-controller="Auth" asp-action="Logout" class="flex items-center gap-3 px-4 py-2.5 hover:bg-red-50 text-red-600 transition-colors group/logout">
                        <span class="material-symbols-outlined text-[20px] group-hover/logout:translate-x-1 transition-transform">logout</span>
                        <span class="text-sm font-medium">Đăng xuất</span>
                    </a>
                </div>
            </div>

            <script>
                document.addEventListener('DOMContentLoaded', () => {
                    const profileBtn = document.getElementById('profile-btn');
                    const profileMenu = document.getElementById('profile-menu');
                    const profileDropdown = document.getElementById('profile-dropdown');

                    if (profileBtn && profileMenu) {
                        profileBtn.addEventListener('click', (e) => {
                            e.stopPropagation();
                            const isHidden = profileMenu.classList.contains('hidden');
                            
                            if (isHidden) {
                                profileMenu.classList.remove('hidden', 'animate-out', 'fade-out', 'zoom-out-95');
                                profileMenu.classList.add('animate-in', 'fade-in', 'zoom-in-95');
                            } else {
                                profileMenu.classList.add('hidden');
                                profileMenu.classList.remove('animate-in', 'fade-in', 'zoom-in-95');
                            }
                        });

                        document.addEventListener('click', (e) => {
                            if (profileDropdown && !profileDropdown.contains(e.target)) {
                                profileMenu.classList.add('hidden');
                                profileMenu.classList.remove('animate-in', 'fade-in', 'zoom-in-95');
                            }
                        });
                    }
                });
            </script>

            <style>
                #profile-menu.animate-in {
                    display: block !important;
                    animation: enterProfile 0.2s ease-out;
                }
                @@keyframes enterProfile {
                    from { opacity: 0; transform: translateY(-10px) scale(0.95); }
                    to { opacity: 1; transform: translateY(0) scale(1); }
                }
            </style>
        </div>
    </div>
</header>

@model GPMS.Web.ViewModels.ResetPasswordViewModel
@{
    Layout = null; 
    ViewData["Title"] = "Reset Password - GPMS";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#F27123",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .form-input-custom {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid #e5e7eb;
            border-radius: 0.5rem;
            background-color: #f9fafb;
            transition: all 0.2s;
        }
        .form-input-custom:focus {
            outline: none;
            border-color: #F27123;
            background-color: white;
            box-shadow: 0 0 0 3px rgba(242, 113, 35, 0.1);
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark min-h-screen flex items-center justify-center p-0 m-0 overflow-hidden font-display text-[#1f2937] dark:text-gray-100">
    <div class="flex w-full h-screen">
        <!-- Split Layout - Left Side -->
        <div class="hidden lg:flex lg:w-1/2 xl:w-7/12 relative bg-primary flex-col justify-end p-12 lg:p-16 text-white overflow-hidden">
            <div class="absolute inset-0 z-0">
                <img alt="Modern university" class="w-full h-full object-cover opacity-90 grayscale-[20%] mix-blend-overlay" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA5_2IouiSrJLbBxrrWT90KXIfcyK_AhlsR1DKCSJcGfdEj1DFlev4ruQbDEV09Y-wki2OghtEZG6FaLirupBHlpyL_Ccs9LzjkRV5H-0u6XlPTV4gRQklhRZC7Nt9NgulPa1bbE4ZWeZDTTYbAyM6GIt0hEbkPVrwS0mn3tgNXUnlg4bRk8Bgls5UntbbTXhQyo2_kv1kxJ_dS9-7ANAF5VBkWRMvurZzq--TmtcKi14KlmID2lWKqt5NqF9Rla1AKRi01e7ZUabs" />
                <div class="absolute inset-0 bg-[#F27123]/80 mix-blend-multiply"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-[#F27123]/90 via-[#F27123]/40 to-transparent"></div>
            </div>
            <div class="relative z-10 max-w-2xl text-left">
                <div class="mb-8 flex items-center gap-3">
                    <div class="p-2 bg-white/10 rounded-lg backdrop-blur-sm border border-white/20">
                        <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                            <path d="M42.4379 44C42.4379 44 36.0744 33.9038 41.1692 24C46.8624 12.9336 42.2078 4 42.2078 4L7.01134 4C7.01134 4 11.6577 12.932 5.96912 23.9969C0.876273 33.9029 7.27094 44 7.27094 44L42.4379 44Z" fill="currentColor"></path>
                        </svg>
                    </div>
                    <span class="text-xl font-bold tracking-tight text-white/90">FPT University GPMS</span>
                </div>
                <h1 class="text-4xl lg:text-5xl font-bold leading-tight tracking-tight mb-6 text-white text-left">
                    Set a new password
                </h1>
                <p class="text-lg text-white/80 font-medium leading-relaxed max-w-lg text-left">
                    Secure your account with a strong, unique password.
                </p>
            </div>
        </div>

        <!-- Right Side: Reset Panel -->
        <div class="w-full lg:w-1/2 xl:w-5/12 h-full flex flex-col relative bg-background-light dark:bg-background-dark overflow-y-auto">
            <div class="flex-1 flex flex-col justify-center px-8 sm:px-12 lg:px-20 xl:px-24 pb-20 mt-10">
                <div class="space-y-2 mb-8 text-left">
                    <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white text-left">Reset Password</h2>
                    <p class="text-base text-gray-500 dark:text-gray-400 text-left">Please enter your new password below.</p>
                </div>

                <div class="flex flex-col gap-5">
                    <form asp-action="ResetPassword" asp-controller="Auth" method="post" class="space-y-4">
                        <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 p-3 rounded-md mb-2"></div>
                        
                        <!-- Hidden Token Field -->
                        <input type="hidden" asp-for="Token" />

                        <div class="space-y-1.5 text-left">
                            <label asp-for="NewPassword" class="text-sm font-semibold text-gray-700 dark:text-gray-300 text-left">New Password</label>
                            <input asp-for="NewPassword" type="password" class="form-input-custom" placeholder="••••••••" />
                            <span asp-validation-for="NewPassword" class="text-xs text-red-600"></span>
                        </div>

                        <div class="space-y-1.5 text-left">
                            <label asp-for="ConfirmPassword" class="text-sm font-semibold text-gray-700 dark:text-gray-300 text-left">Confirm New Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-input-custom" placeholder="••••••••" />
                            <span asp-validation-for="ConfirmPassword" class="text-xs text-red-600"></span>
                        </div>

                        <button type="submit" class="relative flex items-center justify-center w-full h-12 bg-primary hover:bg-primary/90 text-white rounded-lg font-bold text-base transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 group overflow-hidden mt-6">
                            <div class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/10 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
                            <span class="material-symbols-outlined mr-2.5 text-[22px]">lock_reset</span>
                            <span>Update Password</span>
                        </button>
                    </form>
                </div>

                <div class="mt-auto pt-10 text-center sm:text-left">
                    <p class="text-xs text-gray-400 dark:text-gray-600 mt-4 text-center sm:text-left">
                        © 2026 FPT University. All rights reserved.
                    </p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

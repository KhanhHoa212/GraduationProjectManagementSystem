@model GPMS.Web.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "FPT University GPMS - Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#F27123",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .form-input-custom {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid #e5e7eb;
            border-radius: 0.5rem;
            background-color: #f9fafb;
            transition: all 0.2s;
        }
        .form-input-custom:focus {
            outline: none;
            border-color: #F27123;
            background-color: white;
            box-shadow: 0 0 0 3px rgba(242, 113, 35, 0.1);
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark min-h-screen flex items-center justify-center p-0 m-0 overflow-hidden font-display text-[#1f2937] dark:text-gray-100">
    <div class="flex w-full h-screen">
        <!-- Left Side: Branding Panel -->
        <div class="hidden lg:flex lg:w-1/2 xl:w-7/12 relative bg-primary flex-col justify-end p-12 lg:p-16 text-white overflow-hidden">
            <!-- Background Image -->
            <div class="absolute inset-0 z-0">
                <img alt="Modern university" class="w-full h-full object-cover opacity-90 grayscale-[20%] mix-blend-overlay" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA5_2IouiSrJLbBxrrWT90KXIfcyK_AhlsR1DKCSJcGfdEj1DFlev4ruQbDEV09Y-wki2OghtEZG6FaLirupBHlpyL_Ccs9LzjkRV5H-0u6XlPTV4gRQklhRZC7Nt9NgulPa1bbE4ZWeZDTTYbAyM6GIt0hEbkPVrwS0mn3tgNXUnlg4bRk8Bgls5UntbbTXhQyo2_kv1kxJ_dS9-7ANAF5VBkWRMvurZzq--TmtcKi14KlmID2lWKqt5NqF9Rla1AKRi01e7ZUabs" />
                <div class="absolute inset-0 bg-[#F27123]/80 mix-blend-multiply"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-[#F27123]/90 via-[#F27123]/40 to-transparent"></div>
            </div>
            <!-- Content -->
            <div class="relative z-10 max-w-2xl text-left">
                <div class="mb-8 flex items-center gap-3">
                    <div class="p-2 bg-white/10 rounded-lg backdrop-blur-sm border border-white/20">
                        <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                            <path d="M42.4379 44C42.4379 44 36.0744 33.9038 41.1692 24C46.8624 12.9336 42.2078 4 42.2078 4L7.01134 4C7.01134 4 11.6577 12.932 5.96912 23.9969C0.876273 33.9029 7.27094 44 7.27094 44L42.4379 44Z" fill="currentColor"></path>
                        </svg>
                    </div>
                    <span class="text-xl font-bold tracking-tight text-white/90">FPT University GPMS</span>
                </div>
                <h1 class="text-4xl lg:text-5xl font-bold leading-tight tracking-tight mb-6 text-white text-left">
                    Empowering the next generation of innovators
                </h1>
                <p class="text-lg text-white/80 font-medium leading-relaxed max-w-lg text-left">
                    Manage your graduation projects, connect with mentors, and track your academic milestones all in one centralized hub.
                </p>
                <div class="mt-12 flex gap-4">
                    <div class="flex -space-x-3 overflow-hidden">
                        <img alt="Student 1" class="inline-block h-10 w-10 rounded-full ring-2 bg-gray-300 ring-[#F27123]" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBlvrBoUc8REc3z5iJUWD6f83Uob4c1q5ET1hHgEEte5WQ0tCo34lOphYgtBBLfatX4tn6MInIvpuKdvrKUT-ba-OhPcGsg7RuVroHRW8gbUNy_k_zuCX_Um1c8wExO3SQkDH8f2Aet6ejlya-OL0ssOJknvkZe9ZGX0umr4WozrCLJBJ4_utrCpjOqsACc4cSvaSXIT5wTtCMytvv7vTGt9rbCtQFWGkkmNwDBNeaXp1Rr5TRDub9Ob7oZ5AZMfTESg8bwe7GrtWA" />
                        <img alt="Student 2" class="inline-block h-10 w-10 rounded-full ring-2 bg-gray-300 ring-[#F27123]" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBi4BtDsw9fcXtqd6LlqvExRCPxnPA4pCfAOzxs4FmVun8xGoufXqkqZ1K-yrZ88VYxuaPyBCdu47k8e49NaOqV3xc9naRXHGITzY1GATxouWCKSzQw7QOxQy_l0Y8aCVaZSGYOJU8zDkgw6r8TpgArQe88TGJ_va-8GyPJlKzND9zzkCoxhgXpFRN3Wi3UDwvz6qPp6ZDqFKpzKr21GJqiWDg6-uxwFn_LX6o-G56g5dse44WSJjxJuIl9tjqditd4Ti89Wi4Sjjo" />
                        <img alt="Student 3" class="inline-block h-10 w-10 rounded-full ring-2 bg-gray-300 ring-[#F27123]" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCuszg87Zb7C7hjYf-m0WkY1ING9lbo9eqhDWlpa19jjUNunSJw00WFvmeuiyy8Uis4oQELeEw8bkgoqjZe92ng6JrbZnDAMeA-rgrZLnTtXnD1xB5byDLr1S_w3g63sKVpk719zZ5D0YIpDrYHKLX_scVhJ8JHhxAj8Ngk_Ax4oqW7sJ0BVv0CErxYFx5M17OHNZsNpkNgeM1kUxC7CP0ICQWAiwHt66wCgnIjWsu_Mri1OMKVKBjouH0stslS8NGpalMKYmbFh78" />
                    </div>
                    <div class="flex flex-col justify-center items-start text-left">
                        <span class="text-sm font-semibold text-white">Joined by 12k+ Students</span>
                        <span class="text-xs text-white/70 text-left">Across 5 Campuses</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Login Panel -->
        <div class="w-full lg:w-1/2 xl:w-5/12 h-full flex flex-col relative bg-background-light dark:bg-background-dark overflow-y-auto">
            <!-- Mobile Header/Brand -->
            <div class="lg:hidden flex items-center justify-between p-6 border-b border-primary/10 bg-white dark:bg-gray-900">
                <div class="flex items-center gap-2">
                    <div class="p-1 bg-primary/10 rounded">
                         <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                            <path d="M42.4379 44C42.4379 44 36.0744 33.9038 41.1692 24C46.8624 12.9336 42.2078 4 42.2078 4L7.01134 4C7.01134 4 11.6577 12.932 5.96912 23.9969C0.876273 33.9029 7.27094 44 7.27094 44L42.4379 44Z" fill="currentColor"></path>
                        </svg>
                    </div>
                    <span class="font-bold text-lg text-gray-900 dark:text-white">GPMS</span>
                </div>
            </div>

            <!-- Campus Selector -->
            <div class="flex justify-end p-6 lg:p-8">
                <div class="relative group">
                    <button class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-sm font-semibold text-gray-700 dark:text-gray-200 hover:border-primary hover:text-primary transition-all shadow-sm">
                        <span class="material-symbols-outlined text-[20px] text-gray-400 group-hover:text-primary">language</span>
                        <span>Select Campus</span>
                        <span class="material-symbols-outlined text-[18px] text-gray-400 ml-1">expand_more</span>
                    </button>
                </div>
            </div>

            <!-- Main Form Container -->
            <div class="flex-1 flex flex-col justify-center px-8 sm:px-12 lg:px-20 xl:px-24 pb-20">
                <div class="space-y-2 mb-8 text-left">
                    <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white text-left">Welcome back</h2>
                    <p class="text-base text-gray-500 dark:text-gray-400 text-left">Sign in to access your graduation project dashboard.</p>
                </div>

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg flex items-start gap-3">
                        <span class="material-symbols-outlined text-red-500 text-xl">error</span>
                        <p class="text-sm text-red-700 font-medium text-left">@TempData["ErrorMessage"]</p>
                    </div>
                }

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg flex items-start gap-3">
                        <span class="material-symbols-outlined text-green-500 text-xl">check_circle</span>
                        <p class="text-sm text-green-700 font-medium text-left">@TempData["SuccessMessage"]</p>
                    </div>
                }

                <div class="flex flex-col gap-5">
                    <!-- Login Form -->
                    <form asp-action="Login" asp-controller="Auth" method="post" class="space-y-4">
                        <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 p-3 rounded-md mb-2"></div>
                        
                        <div class="space-y-1.5 text-left">
                            <label asp-for="Identifier" class="text-sm font-semibold text-gray-700 dark:text-gray-300 text-left">Email or Username</label>
                            <input asp-for="Identifier" class="form-input-custom" placeholder="name@fpt.edu.vn" autocomplete="username" />
                            <span asp-validation-for="Identifier" class="text-xs text-red-600"></span>
                        </div>

                        <div class="space-y-1.5 text-left">
                            <input asp-for="Password" type="password" class="form-input-custom" placeholder="••••••••" autocomplete="current-password" />
                            <span asp-validation-for="Password" class="text-xs text-red-600"></span>
                        </div>

                        <button type="submit" class="relative flex items-center justify-center w-full h-12 bg-primary hover:bg-primary/90 text-white rounded-lg font-bold text-base transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 group overflow-hidden mt-2">
                            <div class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/10 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
                            <span class="material-symbols-outlined mr-2.5 text-[22px]">login</span>
                            <span>Sign In</span>
                        </button>
                    </form>

                    <div class="relative flex items-center py-2">
                        <div class="flex-grow border-t border-gray-200 dark:border-gray-700"></div>
                        <span class="flex-shrink-0 mx-4 text-gray-400 text-xs uppercase font-semibold tracking-wider">Or continue with</span>
                        <div class="flex-grow border-t border-gray-200 dark:border-gray-700"></div>
                    </div>

                    <!-- Google Login Button -->
                    <a href="@Url.Action("GoogleLogin", "Auth")" class="flex items-center justify-center w-full h-12 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-200 border border-gray-200 dark:border-gray-700 rounded-lg font-semibold text-sm transition-all hover:bg-gray-50 dark:hover:bg-gray-700 hover:border-gray-300 dark:hover:border-gray-600 shadow-sm no-underline">
                        <svg aria-hidden="true" class="mr-3 h-5 w-5" viewBox="0 0 488 512" xmlns="http://www.w3.org/2000/svg">
                            <path d="M488 261.8C488 403.3 391.1 504 248 504 110.8 504 0 393.2 0 256S110.8 8 248 8c66.8 0 123 24.5 166.3 64.9l-67.5 64.9C258.5 52.6 94.3 116.6 94.3 256c0 86.5 69.1 156.6 153.7 156.6 98.2 0 135-70.4 140.8-106.9H248v-85.3h236.1c2.3 12.7 3.9 24.9 3.9 41.4z" fill="currentColor"></path>
                        </svg>
                        Sign in with Google
                    </a>
                </div>

                <div class="mt-8 pt-6 border-t border-dashed border-gray-200 dark:border-gray-700">
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
                        <a class="text-sm font-medium text-primary hover:text-primary/80 hover:underline flex items-center group no-underline" href="@Url.Action("ForgotPassword", "Auth")">
                            <span class="material-symbols-outlined text-[18px] mr-1.5 transition-transform group-hover:rotate-12">help</span>
                            Trouble signing in?
                        </a>
                        <span class="text-xs text-gray-400 dark:text-gray-500">v2.4.0 • Secure Server</span>
                    </div>
                </div>

                <!-- Footer Links -->
                <div class="mt-auto pt-10 text-center sm:text-left">
                    <div class="flex flex-wrap justify-center sm:justify-start gap-x-6 gap-y-2 text-xs text-gray-400 dark:text-gray-500">
                        <a class="hover:text-primary transition-colors no-underline" href="#">Privacy Policy</a>
                        <a class="hover:text-primary transition-colors no-underline" href="#">Terms of Service</a>
                        <a class="hover:text-primary transition-colors no-underline" href="#">Contact IT Support</a>
                    </div>
                    <p class="text-xs text-gray-400 dark:text-gray-600 mt-4 text-center sm:text-left">
                        © 2026 FPT University. All rights reserved.
                    </p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

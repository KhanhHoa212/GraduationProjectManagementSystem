@model GPMS.Web.ViewModels.EditSemesterViewModel
@{
    ViewData["Title"] = "Create Semester";
    ViewData["BreadcrumbTitle"] = "Create New Semester";
    Layout = "_AdminLayout";
}

<div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center gap-3 mb-1">
            <a asp-action="Index" class="p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-colors no-underline">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            </a>
            <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight">Create New Semester</h1>
        </div>
        <p class="text-slate-500 text-sm ml-11">Fill in the details to set up a new academic term.</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-xl overflow-hidden">
        <div class="p-8">
            <form asp-action="Create" method="post" class="space-y-6">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="p-4 text-sm text-red-700 bg-red-50 border border-red-200 rounded-xl"></div>

                <div>
                    <label asp-for="SemesterCode" class="block text-sm font-bold text-slate-700 mb-2">Semester Code</label>
                    <input asp-for="SemesterCode" placeholder="e.g., SP25" 
                           class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" />
                    <p class="text-[11px] text-slate-400 mt-1.5 font-medium">Short identifier used across the system (e.g. FA24, SP25)</p>
                    <span asp-validation-for="SemesterCode" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="AcademicYear" class="block text-sm font-bold text-slate-700 mb-2">Academic Year</label>
                    <input asp-for="AcademicYear" placeholder="e.g., 2024-2025" 
                           class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" />
                    <span asp-validation-for="AcademicYear" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="StartDate" class="block text-sm font-bold text-slate-700 mb-2">Start Date</label>
                        <div class="relative">
                            <input asp-for="StartDate" type="date" 
                                   class="w-full pl-4 pr-10 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" />
                        </div>
                        <span asp-validation-for="StartDate" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="EndDate" class="block text-sm font-bold text-slate-700 mb-2">End Date</label>
                        <div class="relative">
                            <input asp-for="EndDate" type="date" 
                                   class="w-full pl-4 pr-10 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" />
                        </div>
                        <span asp-validation-for="EndDate" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                </div>

                <div class="p-3 bg-blue-50/50 border border-blue-100 rounded-xl flex items-center gap-3">
                    <span class="material-symbols-outlined text-blue-500 text-[18px]">info</span>
                    <p class="text-[11px] text-blue-700 font-semibold">End date must be after start date</p>
                </div>

                <div>
                    <label asp-for="Status" class="block text-sm font-bold text-slate-700 mb-2">Status</label>
                    <select asp-for="Status" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all appearance-none"
                            asp-items="Html.GetEnumSelectList<GPMS.Domain.Enums.SemesterStatus>()">
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Description</label>
                    <textarea asp-for="Description" rows="4" placeholder="Briefly describe the purpose or notes for this term..." 
                              class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all"></textarea>
                </div>

                <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
                    <a asp-action="Index" class="px-6 py-3 text-sm font-bold text-slate-600 hover:bg-slate-50 rounded-xl transition-all no-underline">Cancel</a>
                    <button type="submit" class="px-8 py-3 bg-primary hover:bg-orange-600 text-white text-sm font-bold rounded-xl shadow-lg shadow-primary/30 transition-all">
                        Create Semester
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@model IEnumerable<GPMS.Web.ViewModels.SemesterViewModel>
@{
    ViewData["Title"] = "Semester Management";
    ViewData["BreadcrumbTitle"] = "Semesters";
    Layout = "_AdminLayout";
}

<div class="max-w-7xl mx-auto">
    <!-- Page Header -->
    <div class="flex flex-wrap justify-between items-start gap-6 mb-8">
        <div>
            <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight">Semester Management</h1>
            <p class="text-slate-500 text-sm mt-1">Manage academic periods, schedules and project allocations.</p>
        </div>
        <a asp-action="Create"
           class="flex items-center gap-2 rounded-xl bg-primary hover:bg-orange-600 text-white px-5 py-2.5 text-sm font-bold transition-all shadow-lg shadow-primary/25 no-underline">
            <span class="material-symbols-outlined text-[18px]">add_circle</span>
            <span>Create New Semester</span>
        </a>
    </div>

    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl flex items-center gap-3">
            <span class="material-symbols-outlined text-green-500">check_circle</span>
            <p class="text-sm text-green-700 font-medium">@TempData["SuccessMessage"]</p>
        </div>
    }

    <!-- Search & Filters -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 mb-6">
        <div class="flex flex-col md:flex-row gap-4 items-center">
            <div class="relative flex-1 w-full">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                <input type="text" placeholder="Search by semester code (e.g. FA24)" 
                       class="w-full pl-10 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/30 text-sm" />
            </div>
            <div class="flex items-center gap-2 p-1 bg-slate-50 rounded-xl overflow-x-auto">
                <button class="px-4 py-1.5 rounded-lg text-sm font-bold bg-white shadow-sm text-primary">All</button>
                <button class="px-4 py-1.5 rounded-lg text-sm font-medium text-slate-500 hover:text-slate-700 transition-colors">Upcoming</button>
                <button class="px-4 py-1.5 rounded-lg text-sm font-medium text-slate-500 hover:text-slate-700 transition-colors">Active</button>
                <button class="px-4 py-1.5 rounded-lg text-sm font-medium text-slate-500 hover:text-slate-700 transition-colors">Closed</button>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-200">
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Semester Code</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Start Date</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">End Date</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Projects Count</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var s in Model)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4 font-bold text-slate-900">@s.SemesterCode</td>
                            <td class="px-6 py-4 text-sm text-slate-600">@s.StartDate.ToString("yyyy-MM-dd")</td>
                            <td class="px-6 py-4 text-sm text-slate-600">@s.EndDate.ToString("yyyy-MM-dd")</td>
                            <td class="px-6 py-4">
                                @{
                                    var statusClass = s.Status switch {
                                        GPMS.Domain.Enums.SemesterStatus.Active => "bg-orange-100 text-orange-600 border-orange-200",
                                        GPMS.Domain.Enums.SemesterStatus.Closed => "bg-green-100 text-green-600 border-green-200",
                                        GPMS.Domain.Enums.SemesterStatus.Upcoming => "bg-blue-100 text-blue-600 border-blue-200",
                                        _ => "bg-slate-100 text-slate-500 border-slate-200"
                                    };
                                }
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold border @statusClass">
                                    @s.Status
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <span class="text-sm font-semibold text-slate-700">@s.ProjectsCount projects</span>
                                    <div class="w-20 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                        @{
                                            var progress = Math.Min(100, (s.ProjectsCount * 100) / 200); // Dummy for visualization
                                            var progressColor = s.Status == GPMS.Domain.Enums.SemesterStatus.Active ? "bg-primary" : "bg-green-500";
                                        }
                                        <div class="@progressColor h-full" style="width: @(progress)%"></div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end gap-1">
                                    <a asp-action="Edit" asp-route-id="@s.SemesterID" 
                                       class="p-2 text-slate-400 hover:text-primary hover:bg-primary/10 rounded-lg transition-all no-underline">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </a>
                                    <button class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-all">
                                        <span class="material-symbols-outlined text-[20px]">more_vert</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <div class="px-6 py-4 bg-slate-50/50 border-t border-slate-200 flex items-center justify-between">
            <span class="text-xs text-slate-500 font-medium">
                Showing <span class="text-slate-900 font-bold">1-@Model.Count()</span> of <span class="text-slate-900 font-bold">@Model.Count()</span> semesters
            </span>
            <div class="flex gap-2">
                <button class="px-4 py-1.5 bg-white border border-slate-200 rounded-lg text-xs font-bold text-slate-400 cursor-not-allowed">Previous</button>
                <button class="px-4 py-1.5 bg-white border border-slate-200 rounded-lg text-xs font-bold text-slate-700 hover:bg-slate-50">Next</button>
            </div>
        </div>
    </div>
</div>

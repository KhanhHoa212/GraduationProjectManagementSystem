@using GPMS.Application.DTOs
@model ChecklistDto
@{
    ViewData["Title"] = "Checklist Details";
    Layout = "_Layout";
    var isRubric = Model.Items.Any(i => i.ItemType == "Rubric");
    var sections = Model.Items.GroupBy(i => i.Section ?? "General").OrderBy(g => g.Key);
}

<div class="p-6 max-w-5xl mx-auto">
    <!-- Breadcrumb & Header -->
    <div class="mb-6">
        <nav class="flex mb-4 text-sm text-gray-500">
            <a href="/HOD/Checklists" class="hover:text-orange-500 flex items-center gap-1">
                <i class="ri-arrow-left-line"></i>
                Back to list
            </a>
        </nav>
        <div class="flex justify-between items-end">
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <h1 class="text-2xl font-bold text-gray-800">@Model.Title</h1>
                    <span class="px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">
                        @(isRubric ? "Rubric ⭐" : "Yes/No")
                    </span>
                </div>
                <p class="text-gray-500">
                    <i class="ri-information-line"></i> 
                    @Model.ReviewRoundTitle · @Model.Items.Count items · @sections.Count() sections
                </p>
            </div>
            <a href="/HOD/EditChecklist/@Model.ReviewRoundID" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center gap-2">
                <i class="ri-edit-line"></i>
                Edit
            </a>
        </div>
    </div>

    @if (isRubric)
    {
        <!-- Rubric Grade Scale Card -->
        <div class="bg-indigo-900 text-white rounded-xl p-6 mb-8 shadow-lg">
            <h3 class="font-bold mb-4 flex items-center gap-2 text-indigo-200 uppercase tracking-wider text-sm">
                <i class="ri-bar-chart-2-line"></i>
                Qualitative Grading (Grade Scale)
            </h3>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                <div class="flex items-center gap-3">
                    <span class="w-3 h-3 rounded-full bg-green-500"></span>
                    <div>
                        <div class="font-bold text-green-400">Excellent</div>
                        <div class="text-[10px] text-indigo-300">8.0 – 10.0</div>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="w-3 h-3 rounded-full bg-blue-500"></span>
                    <div>
                        <div class="font-bold text-blue-400">Good</div>
                        <div class="text-[10px] text-indigo-300">6.0 – 8.0</div>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
                    <div>
                        <div class="font-bold text-yellow-400">Acceptable</div>
                        <div class="text-[10px] text-indigo-300">4.0 – 6.0</div>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="w-3 h-3 rounded-full bg-red-500"></span>
                    <div>
                        <div class="font-bold text-red-400">Fail</div>
                        <div class="text-[10px] text-indigo-300">0.0 – 4.0</div>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="w-3 h-3 rounded-full bg-gray-400"></span>
                    <div>
                        <div class="font-bold text-gray-400">N/A</div>
                        <div class="text-[10px] text-indigo-300">Not Applicable</div>
                    </div>
                </div>
            </div>
            <p class="mt-4 text-xs text-indigo-300 italic border-t border-indigo-800 pt-3">
                <i class="ri-information-line"></i> This is a qualitative evaluation for student feedback – the final score is determined independently by the Committee.
            </p>
        </div>

        <!-- Rubric Content -->
        @foreach (var group in sections)
        {
            <div class="mb-8">
                <h2 class="text-sm font-bold text-indigo-600 uppercase tracking-widest mb-4 flex items-center gap-2">
                    <i class="ri-bookmark-3-line"></i>
                    Group: @group.Key
                    <span class="h-px bg-indigo-100 flex-grow ml-2"></span>
                </h2>
                <div class="grid gap-6">
                    @foreach (var item in group.OrderBy(i => i.OrderIndex))
                    {
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                            <div class="p-5 border-b border-gray-50 bg-gray-50/50 flex justify-between items-start">
                                <div>
                                    <span class="text-[10px] font-bold text-indigo-500 uppercase">@item.ItemCode</span>
                                    <h4 class="font-bold text-gray-800 mt-0.5">@item.ItemName</h4>
                                </div>
                                <button onclick="toggleRubric('@item.ItemID')" class="text-indigo-600 text-xs font-bold hover:underline flex items-center gap-1">
                                    <i class="ri-expand-up-down-line"></i>
                                    Rubric Details
                                </button>
                            </div>
                            <div class="p-5">
                                <div class="text-sm text-gray-600 whitespace-pre-line leading-relaxed">
                                    @item.ItemContent
                                </div>
                                
                                <div id="rubric-@item.ItemID" class="mt-4 grid grid-cols-1 md:grid-cols-4 gap-3 hidden animate-fadeIn">
                                    @foreach (var level in new[] { "Excellent", "Good", "Acceptable", "Fail" })
                                    {
                                        var rubric = item.Rubrics.FirstOrDefault(r => r.GradeLevel == level);
                                        var colorClass = level switch { 
                                            "Excellent" => "bg-green-50 text-green-700 border-green-100",
                                            "Good" => "bg-blue-50 text-blue-700 border-blue-100",
                                            "Acceptable" => "bg-yellow-50 text-yellow-700 border-yellow-100",
                                            _ => "bg-red-50 text-red-700 border-red-100"
                                        };
                                        <div class="p-3 rounded-lg border @colorClass text-xs">
                                            <div class="font-bold mb-1 uppercase tracking-tighter">@level</div>
                                            <p class="leading-normal opacity-90">@(rubric?.Description ?? "Content not configured.")</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <!-- Yes/No Content -->
        <div class="space-y-6">
            @foreach (var group in sections)
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <button onclick="toggleGroup('@group.Key.Replace(" ", "-")')" class="w-full p-4 flex justify-between items-center bg-gray-50/50 hover:bg-gray-50 transition-colors">
                        <div class="flex items-center gap-3">
                            <span class="w-8 h-8 rounded bg-white border flex items-center justify-center font-bold text-gray-400 text-xs shadow-sm">
                                @group.Key.Split('-')[0]
                            </span>
                            <span class="font-bold text-gray-700">@group.Key</span>
                            <span class="text-xs text-gray-400">(@group.Count() items)</span>
                        </div>
                        <i id="icon-@group.Key.Replace(" ", "-")" class="ri-arrow-down-s-line text-xl text-gray-400 transition-transform"></i>
                    </button>
                    <div id="group-@group.Key.Replace(" ", "-")" class="p-4 bg-white">
                        <div class="divide-y border-t border-gray-50">
                            @foreach (var item in group.OrderBy(i => i.OrderIndex))
                            {
                                <div class="py-4 flex gap-4 items-start group">
                                    <div class="text-gray-300 font-mono text-xs pt-1 group-hover:text-blue-400 transition-colors">@item.ItemCode</div>
                                    <div class="flex-grow">
                                        <p class="text-gray-700 leading-relaxed">@item.ItemContent</p>
                                    </div>
                                    <div class="flex gap-1">
                                        <span class="w-6 h-6 rounded border border-gray-100 bg-gray-50 text-[10px] flex items-center justify-center text-gray-300">Y</span>
                                        <span class="w-6 h-6 rounded border border-gray-100 bg-gray-50 text-[10px] flex items-center justify-center text-gray-300">N</span>
                                        <span class="w-6 h-6 rounded border border-gray-100 bg-gray-50 text-[10px] flex items-center justify-center text-gray-300">NA</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Overall Comments Info -->
    <div class="mt-8 p-6 bg-gray-100 rounded-xl border-2 border-dashed border-gray-200">
        <h4 class="font-bold text-gray-500 mb-2 flex items-center gap-2">
            <i class="ri-chat-smile-2-line"></i>
            Comments (Optional)
        </h4>
        <p class="text-sm text-gray-400 italic">
            The reviewer can add general comments here during the evaluation. This field will be automatically displayed to the reviewer.
        </p>
    </div>
</div>

<script>
    function toggleRubric(itemId) {
        const el = document.getElementById('rubric-' + itemId);
        el.classList.toggle('hidden');
    }

    function toggleGroup(groupId) {
        const el = document.getElementById('group-' + groupId);
        const icon = document.getElementById('icon-' + groupId);
        el.classList.toggle('hidden');
        icon.classList.toggle('rotate-180');
    }
</script>

<style>
    .animate-fadeIn {
        animation: fadeIn 0.3s ease-in-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-5px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

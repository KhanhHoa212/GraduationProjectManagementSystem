@{
    ViewData["Title"] = "Import Data Wizard";
    Layout = "_HODLayout";
}

<div class="max-w-4xl mx-auto space-y-16 animate-in slide-in-from-bottom duration-700 pb-20">
    <div class="text-center space-y-4">
        <h1 class="text-3xl font-bold text-slate-800 tracking-tight uppercase tracking-widest">Bulk Import Wizard</h1>
        <p class="text-slate-400 text-xs font-bold uppercase tracking-[2px] mt-2 italic px-12 italic border-b border-slate-100 pb-4">Seamlessly upload graduation project portfolios and member rosters using our smart validation engine.</p>
    </div>

    <!-- Smart Stepper (Refined) -->
    <div class="flex items-center justify-between relative px-20">
        <div class="absolute top-1/2 left-0 w-full h-1 bg-slate-100 -z-10 -translate-y-1/2 rounded-full"></div>
        <div class="absolute top-1/2 left-0 w-1/3 h-1 bg-[#F37021] -z-10 -translate-y-1/2 rounded-full shadow-lg shadow-orange-500/20"></div>
        
        <div class="flex flex-col items-center gap-2">
            <div class="w-10 h-10 rounded-full bg-[#1a2236] text-white flex items-center justify-center font-bold shadow-lg ring-8 ring-slate-100">1</div>
            <span class="text-[9px] font-bold text-[#1a2236] uppercase tracking-widest mt-1">UPLOAD</span>
        </div>
        <div class="flex flex-col items-center gap-2 opacity-30">
            <div class="w-10 h-10 rounded-full bg-white border-4 border-slate-100 text-slate-400 flex items-center justify-center font-bold shadow-sm ring-8 ring-slate-100">2</div>
            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-1">VALIDATE</span>
        </div>
        <div class="flex flex-col items-center gap-2 opacity-30">
            <div class="w-10 h-10 rounded-full bg-white border-4 border-slate-100 text-slate-400 flex items-center justify-center font-bold shadow-sm ring-8 ring-slate-100">3</div>
            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-1">RESULTS</span>
        </div>
    </div>

    <!-- Drop Zone (Refined) -->
    <div class="bg-white rounded-xl border-2 border-dashed border-slate-100 p-20 text-center transition-all hover:bg-orange-50/20 hover:border-orange-200 group shadow-sm flex flex-col items-center justify-center cursor-pointer">
        <div class="w-20 h-20 bg-slate-50 rounded-xl flex items-center justify-center mb-8 transition-transform group-hover:scale-110 shadow-inner group-hover:rotate-3">
            <span class="material-symbols-outlined text-4xl text-slate-300 group-hover:text-orange-500 transition-colors">cloud_upload</span>
        </div>
        
        <h3 class="text-xl font-bold text-slate-800 tracking-tight uppercase tracking-widest">Transmit Source File</h3>
        <p class="text-slate-400 text-[10px] font-bold uppercase mt-4 tracking-widest">Supported formats: <span class="text-[#F37021]">.xlsx, .csv</span> (Max Payload 10MB)</p>
        
        <div class="mt-12">
            <button class="px-10 py-3 bg-white border border-slate-200 rounded-xl text-[10px] font-black text-slate-700 hover:bg-[#F37021] hover:text-white hover:border-[#F37021] shadow-xl transition-all uppercase tracking-[3px]">Locate Payload Files</button>
        </div>

        <div class="mt-16 pt-12 border-t-2 border-dashed border-slate-50 w-full flex justify-center">
            <a href="#" class="inline-flex items-center gap-2 text-[10px] font-black text-[#F37021] hover:bg-orange-50 px-6 py-3 rounded-2xl transition-all uppercase no-underline tracking-widest shadow-sm">
                 <span class="material-symbols-outlined text-sm">download</span>
                 Legacy Template (.xlsx)
            </a>
        </div>
    </div>
</div>

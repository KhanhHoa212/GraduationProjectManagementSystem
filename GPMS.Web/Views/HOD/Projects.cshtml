@{
    ViewData["Title"] = "Projects";
    Layout = "_HODLayout";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-slate-900">Project Portfolio</h1>
        <div class="flex gap-2">
            <button class="flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 shadow-sm transition-all"><span class="material-symbols-outlined text-sm">filter_list</span>Filter</button>
            <a asp-action="ProjectDetails" class="px-4 py-2 bg-[#F37021] text-white rounded-lg text-sm font-semibold hover:bg-orange-600 shadow-lg shadow-orange-500/20 no-underline transition-all ring-offset-2 focus:ring-2 focus:ring-orange-500">+ Add Project</a>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="p-4 border-b border-slate-100 flex items-center justify-between gap-4">
             <div class="relative w-full max-w-sm group">
                <span class="absolute left-3 top-2.5 text-slate-400 group-focus-within:text-[#F37021] transition-colors"><span class="material-symbols-outlined text-xl">search</span></span>
                <input class="w-full pl-10 pr-4 py-2 text-sm border-2 border-slate-100 rounded-xl focus:ring-0 focus:border-[#F37021] bg-slate-50 transition-all font-medium" placeholder="Search projects..." type="text"/>
            </div>
            <div class="flex gap-2 shrink-0">
                <button class="px-3 py-1.5 bg-slate-50 text-slate-500 rounded-lg text-xs font-bold hover:bg-slate-100 transition-all">Export PDF</button>
            </div>
        </div>

        <table class="w-full text-left">
            <thead class="bg-slate-50 text-slate-500 font-semibold text-xs border-b border-slate-100">
                <tr>
                    <th class="px-6 py-4 w-10"><input class="rounded border-slate-200 text-[#F37021] focus:ring-[#F37021]" type="checkbox"/></th>
                    <th class="px-6 py-4">ID</th>
                    <th class="px-6 py-4">Title</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4">Supervisor</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50/50">
                    <td class="px-6 py-4"><input class="rounded border-slate-200" type="checkbox"/></td>
                    <td class="px-6 py-4 text-sm font-medium text-slate-400">#GP001</td>
                    <td class="px-6 py-4">
                        <p class="text-sm font-bold text-slate-700">Smart Campus IoT System</p>
                        <p class="text-[10px] text-slate-400 font-bold uppercase mt-1">Embedded Systems</p>
                    </td>
                    <td class="px-6 py-4">
                        <span class="px-3 py-1 rounded-full text-[10px] font-bold bg-green-50 text-green-700 border border-green-100">Approved</span>
                    </td>
                    <td class="px-6 py-4">
                         <div class="flex items-center gap-2">
                             <div class="w-6 h-6 rounded-full bg-slate-100 flex items-center justify-center font-bold text-[10px] text-[#F37021]">LT</div>
                             <span class="text-xs font-semibold text-slate-600">Lê Minh Trung</span>
                         </div>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex justify-end gap-2">
                            <a asp-action="ProjectDetails" class="p-1.5 bg-white border border-slate-200 rounded-lg text-slate-400 hover:text-[#F37021] transition-all"><span class="material-symbols-outlined text-sm">edit</span></a>
                            <button class="p-1.5 bg-white border border-slate-200 rounded-lg text-slate-400 hover:text-red-500 transition-all"><span class="material-symbols-outlined text-sm">delete</span></button>
                        </div>
                    </td>
                </tr>
                <!-- More rows similarly -->
            </tbody>
        </table>

        <div class="p-6 border-t border-slate-100 flex items-center justify-between text-xs font-semibold text-slate-400 uppercase">
            <p>Showing 1 to 1 of 48 total projects</p>
            <div class="flex gap-1">
                <button class="px-3 py-1 bg-slate-50 border border-slate-100 rounded-lg text-slate-300 disabled:opacity-50" disabled>PREV</button>
                <button class="px-3 py-1 bg-[#F37021] text-white rounded-lg shadow-sm">1</button>
                <button class="px-3 py-1 bg-white border border-slate-100 rounded-lg hover:bg-slate-50 transition-all">2</button>
                <button class="px-3 py-1 bg-white border border-slate-100 rounded-lg hover:bg-slate-50 transition-all">NEXT</button>
            </div>
        </div>
    </div>
</div>

@{
    ViewBag.Title = "Projects";
    ViewBag.CurrentPage = "Projects";
    ViewBag.BreadcrumbSection = "Project";
    Layout = "~/Views/Shared/_HODLayout.cshtml";
}

<!-- Projects List Content -->
<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Danh sách Đề tài</h1>
            <p class="text-slate-500 text-sm mt-1">Quản lý toàn bộ đề tài trong học kỳ SP25</p>
        </div>
        <div class="flex gap-3">
            <button class="bg-[#F37021] hover:bg-orange-600 text-white flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold transition shadow-sm border border-orange-600">
                <span class="material-symbols-outlined text-[20px]">add</span>
                <span>Import Excel</span>
            </button>
            <a href="/HOD/CreateProject" class="bg-[#1E3A5F] hover:bg-slate-800 text-white flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold transition shadow-sm no-underline">
                <span class="material-symbols-outlined text-[20px]">add</span>
                <span>Tạo đề tài mới</span>
            </a>
        </div>
    </div>

    <!-- Filters Card -->
    <div class="bg-white border border-slate-200 rounded-xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Semester Filter -->
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">HỌC KỲ</label>
                <select class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-700 font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 hover:bg-white transition-colors appearance-none outline-none">
                    <option>SP25</option>
                    <option>FA24</option>
                    <option>SP24</option>
                </select>
            </div>

            <!-- Specialization Filter -->
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">CHUYÊN NGÀNH</label>
                <select class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-700 font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 hover:bg-white transition-colors appearance-none outline-none">
                    <option>Tất cả</option>
                    <option>Công nghệ thông tin</option>
                    <option>Kỹ thuật phần mềm</option>
                    <option>An toàn thông tin</option>
                </select>
            </div>

            <!-- Status Filter -->
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">TRẠNG THÁI</label>
                <select class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-slate-700 font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 hover:bg-white transition-colors appearance-none outline-none">
                    <option>Tất cả trạng thái</option>
                    <option>Active</option>
                    <option>Draft</option>
                    <option>Completed</option>
                </select>
            </div>

            <!-- Search -->
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">TÌM KIẾM</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                    <input type="text" placeholder="Mã đề tài, tên đề tài..." 
                           class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-2.5 pl-10 text-sm text-slate-700 font-medium placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 hover:bg-white transition-colors outline-none" />
                </div>
            </div>
        </div>
    </div>

    <!-- Projects Table -->
    <div class="bg-white border border-slate-200 rounded-xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] overflow-hidden flex flex-col">
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-white border-b border-slate-200">
                    <tr>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">MÃ ĐỀ TÀI</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider w-1/3">TÊN ĐỀ TÀI</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">CHUYÊN NGÀNH</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center">SỐ NHÓM</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">TRẠNG THÁI</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">NGÀY TẠO</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <!-- Row 1 -->
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-5 font-bold text-slate-800">PRJ001</td>
                        <td class="px-6 py-5">
                            <span class="font-semibold text-slate-700 line-clamp-2 leading-relaxed">Hệ thống quản lý chuỗi cung ứng Blockchain</span>
                        </td>
                        <td class="px-6 py-5">
                            <span class="text-slate-600 font-medium">Kỹ thuật phần mềm</span>
                        </td>
                        <td class="px-6 py-5 text-center">
                            <span class="font-bold text-slate-800">04</span>
                        </td>
                        <td class="px-6 py-5">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold text-emerald-700 bg-emerald-50 border border-emerald-100">Active</span>
                        </td>
                        <td class="px-6 py-5 text-slate-500 font-medium">12/01/2025</td>
                        <td class="px-6 py-5 text-center">
                            <div class="flex items-center justify-center gap-2">
                                <button class="p-1.5 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-md transition" title="View">
                                    <span class="material-symbols-outlined text-[20px]">visibility</span>
                                </button>
                                <button class="p-1.5 text-slate-400 hover:text-slate-800 hover:bg-slate-100 rounded-md transition" title="Edit">
                                    <span class="material-symbols-outlined text-[20px]">edit</span>
                                </button>
                                <button class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition" title="Delete">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 2 -->
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-5 font-bold text-slate-800">PRJ002</td>
                        <td class="px-6 py-5">
                            <span class="font-semibold text-slate-700 line-clamp-2 leading-relaxed">Ứng dụng AI trong chẩn đoán y khoa</span>
                        </td>
                        <td class="px-6 py-5">
                            <span class="text-slate-600 font-medium whitespace-nowrap">Hệ thống thông tin</span>
                        </td>
                        <td class="px-6 py-5 text-center">
                            <span class="font-bold text-slate-800">02</span>
                        </td>
                        <td class="px-6 py-5">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold text-amber-700 bg-amber-50 border border-amber-100">Draft</span>
                        </td>
                        <td class="px-6 py-5 text-slate-500 font-medium">10/01/2025</td>
                        <td class="px-6 py-5 text-center">
                            <div class="flex items-center justify-center gap-2">
                                <button class="p-1.5 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-md transition" title="View">
                                    <span class="material-symbols-outlined text-[20px]">visibility</span>
                                </button>
                                <button class="p-1.5 text-slate-400 hover:text-slate-800 hover:bg-slate-100 rounded-md transition" title="Edit">
                                    <span class="material-symbols-outlined text-[20px]">edit</span>
                                </button>
                                <button class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition" title="Delete">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 3 -->
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-5 font-bold text-slate-800">PRJ003</td>
                        <td class="px-6 py-5">
                            <span class="font-semibold text-slate-700 line-clamp-2 leading-relaxed">Phát triển Mobile Game với Unity</span>
                        </td>
                        <td class="px-6 py-5">
                            <span class="text-slate-600 font-medium">Kỹ thuật phần mềm</span>
                        </td>
                        <td class="px-6 py-5 text-center">
                            <span class="font-bold text-slate-800">05</span>
                        </td>
                        <td class="px-6 py-5">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold text-blue-700 bg-blue-50 border border-blue-100">Completed</span>
                        </td>
                        <td class="px-6 py-5 text-slate-500 font-medium">20/12/2024</td>
                        <td class="px-6 py-5 text-center">
                            <div class="flex items-center justify-center gap-2">
                                <button class="p-1.5 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-md transition" title="View">
                                    <span class="material-symbols-outlined text-[20px]">visibility</span>
                                </button>
                                <button class="p-1.5 text-slate-400 hover:text-slate-800 hover:bg-slate-100 rounded-md transition" title="Edit">
                                    <span class="material-symbols-outlined text-[20px]">edit</span>
                                </button>
                                <button class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition" title="Delete">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 4 -->
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-5 font-bold text-slate-800">PRJ004</td>
                        <td class="px-6 py-5">
                            <span class="font-semibold text-slate-700 line-clamp-2 leading-relaxed">Bảo mật IoT với mã hóa đầu cuối</span>
                        </td>
                        <td class="px-6 py-5">
                            <span class="text-slate-600 font-medium whitespace-nowrap">An toàn thông tin</span>
                        </td>
                        <td class="px-6 py-5 text-center">
                            <span class="font-bold text-slate-800">03</span>
                        </td>
                        <td class="px-6 py-5">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold text-emerald-700 bg-emerald-50 border border-emerald-100">Active</span>
                        </td>
                        <td class="px-6 py-5 text-slate-500 font-medium">15/01/2025</td>
                        <td class="px-6 py-5 text-center">
                            <div class="flex items-center justify-center gap-2">
                                <button class="p-1.5 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-md transition" title="View">
                                    <span class="material-symbols-outlined text-[20px]">visibility</span>
                                </button>
                                <button class="p-1.5 text-slate-400 hover:text-slate-800 hover:bg-slate-100 rounded-md transition" title="Edit">
                                    <span class="material-symbols-outlined text-[20px]">edit</span>
                                </button>
                                <button class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition" title="Delete">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex items-center justify-between">
            <div class="text-sm font-medium text-slate-500">
                Đang hiển thị 1 đến 4 trong tổng số 24 đề tài
            </div>
            <div class="flex items-center gap-1">
                <button class="w-8 h-8 flex items-center justify-center rounded-md border border-slate-200 text-slate-500 bg-white hover:bg-slate-50 transition">
                    <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                </button>
                <button class="w-8 h-8 flex items-center justify-center rounded-md bg-[#1E3A5F] text-white font-bold shadow-sm">1</button>
                <button class="w-8 h-8 flex items-center justify-center rounded-md border border-slate-200 text-slate-600 bg-white hover:bg-slate-50 hover:text-blue-600 font-bold transition">2</button>
                <button class="w-8 h-8 flex items-center justify-center rounded-md border border-slate-200 text-slate-600 bg-white hover:bg-slate-50 hover:text-blue-600 font-bold transition">3</button>
                <span class="w-8 h-8 flex items-center justify-center text-slate-400 font-bold">...</span>
                <button class="w-8 h-8 flex items-center justify-center rounded-md border border-slate-200 text-slate-600 bg-white hover:bg-slate-50 hover:text-blue-600 font-bold transition">6</button>
                <button class="w-8 h-8 flex items-center justify-center rounded-md border border-slate-200 text-slate-500 bg-white hover:bg-slate-50 transition">
                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                </button>
            </div>
        </div>
    </div>
</div>

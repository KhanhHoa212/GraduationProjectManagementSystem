@{
    ViewData["Title"] = "Groups Management";
    Layout = "_HODLayout";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-slate-900">Department Formation</h1>
        <button class="px-5 py-2.5 bg-[#F37021] text-white rounded-xl text-xs font-semibold hover:bg-orange-600 shadow-xl shadow-orange-500/20 transition-all uppercase ring-offset-2 focus:ring-2 focus:ring-orange-500">Auto-Generate Groups</button>
    </div>

    <!-- Warning Message (Refined) -->
    <div class="p-4 bg-orange-50 border border-orange-100 rounded-xl flex items-center justify-between group">
        <div class="flex items-center gap-3 text-orange-700">
            <span class="material-symbols-outlined text-orange-500 text-xl font-bold">warning</span>
            <span class="text-xs font-semibold uppercase tracking-widest">Action Required: 2 groups are missing main supervisors.</span>
        </div>
        <a asp-action="AssignSupervisor" class="px-4 py-1.5 bg-[#F37021] text-white rounded-lg text-[10px] font-bold uppercase tracking-widest no-underline shadow-sm hover:bg-orange-600 transition-all transition-all ring-offset-2">Assign Now</a>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <table class="w-full text-left">
            <thead class="bg-slate-50 text-slate-500 font-semibold text-xs border-b border-slate-100 uppercase tracking-widest">
                <tr>
                    <th class="px-6 py-4">Group #</th>
                    <th class="px-6 py-4">Project ID</th>
                    <th class="px-6 py-4">Members</th>
                    <th class="px-6 py-4">Supervisor</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50/50">
                    <td class="px-6 py-4 font-bold text-slate-700 text-lg tracking-tighter uppercase">G01</td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-1 bg-slate-50 border border-slate-200 rounded text-[10px] font-black tracking-widest text-[#1a2236]">#GP-SE-001</span>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <span class="text-[10px] font-bold text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full uppercase">5 / 5 CAP</span>
                            <div class="flex -space-x-1 border border-white rounded-full">
                                <div class="w-6 h-6 rounded-full bg-slate-200 border border-white flex items-center justify-center text-[8px] font-bold">SV</div>
                                <div class="w-6 h-6 rounded-full bg-slate-300 border border-white flex items-center justify-center text-[8px] font-bold">SV</div>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 font-bold text-slate-700 text-xs">
                        <div class="flex items-center gap-2">
                             <div class="w-2 h-2 rounded-full bg-green-500"></div>
                             <span>Lê Minh Trung</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-right">
                         <a asp-action="ProjectDetails" class="text-[#F37021] font-bold text-xs hover:underline no-underline uppercase tracking-widest">Manage</a>
                    </td>
                </tr>
                <tr class="hover:bg-orange-50/20 bg-orange-50/5 transition-all">
                    <td class="px-6 py-4 font-bold text-red-500 text-lg tracking-tighter uppercase">G02</td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-1 bg-white border border-red-100 rounded text-[10px] font-bold text-red-400">#GP-SE-002</span>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <span class="text-[10px] font-bold text-red-500 bg-red-50 px-2 py-0.5 rounded-full uppercase">3 / 5 MIN</span>
                            <span class="text-[10px] text-red-500 font-bold ml-1 uppercase animate-pulse">UNDER CAPACITY</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-red-500 font-bold text-xs">
                         <div class="flex items-center gap-2">
                             <div class="w-2 h-2 rounded-full bg-red-500 animate-ping"></div>
                             <span>NOT ASSIGNED</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-right">
                         <a asp-action="ProjectDetails" class="px-4 py-2 bg-white border border-red-200 rounded-lg text-[10px] font-bold text-red-500 hover:bg-red-500 hover:text-white no-underline transition-all">Enroll members</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

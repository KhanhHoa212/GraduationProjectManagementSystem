@using GPMS.Application.DTOs
@model IEnumerable<ProjectGroupDto>
@{
    ViewData["Title"] = "Student Project Groups";
    Layout = "~/Views/Shared/_HodLayout.cshtml";
}

<!-- Main Content -->
<div class="space-y-6">
    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-800 mb-2">Student Project Groups</h1>
        <p class="text-slate-500 text-sm">Manage and monitor current semester's research groups and thesis projects.</p>
    </div>

    <!-- Controls Section -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] p-6 mb-6">
        <form asp-action="Groups" method="get" class="flex flex-col md:flex-row md:items-center gap-4">
            <!-- Search Box -->
            <div class="flex-1 relative">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                <input 
                    type="text" 
                    name="search"
                    value="@ViewData["Search"]"
                    placeholder="Search groups, topics or student names..." 
                    class="w-full pl-12 pr-4 py-3 border border-slate-200 rounded-lg bg-slate-50 text-slate-800 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors font-medium hover:bg-white"
                />
            </div>

            <!-- Filter Buttons -->
            <div class="flex gap-3">
                <div class="relative inline-block w-[140px]">
                    <select name="status" class="w-full appearance-none px-4 py-3 pr-10 border border-slate-200 rounded-lg bg-slate-50 text-slate-700 font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors hover:bg-white cursor-pointer text-sm outline-none">
                        <!option value="All Projects" @(ViewData["Status"]?.ToString() == "All Projects" ? "selected" : "")>All Projects</!option>
                        @foreach (var s in Enum.GetNames(typeof(GPMS.Domain.Enums.ProjectStatus)))
                        {
                            <!option value="@s" @(ViewData["Status"]?.ToString() == s ? "selected" : "")>@s</!option>
                        }
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-lg">expand_more</span>
                </div>

                <div class="relative inline-block w-[180px]">
                    <select name="supervisor" class="w-full appearance-none px-4 py-3 pr-10 border border-slate-200 rounded-lg bg-slate-50 text-slate-700 font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors hover:bg-white cursor-pointer text-sm outline-none">
                        <!option value="All Supervisors" @(ViewData["Supervisor"]?.ToString() == "All Supervisors" ? "selected" : "")>All Supervisors</!option>
                        @if (ViewData["AllSupervisors"] != null)
                        {
                            @foreach (var sup in (IEnumerable<string>)ViewData["AllSupervisors"]!)
                            {
                                <!option value="@sup" @(ViewData["Supervisor"]?.ToString() == sup ? "selected" : "")>@sup</!option>
                            }
                        }
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-lg">expand_more</span>
                </div>

                <button type="submit" class="px-5 py-3 bg-[#1E3A5F] text-white rounded-lg hover:bg-slate-800 transition shadow-sm flex items-center gap-2 font-bold text-sm">
                    <span class="material-symbols-outlined text-[18px]">filter_list</span>
                    Apply Filters
                </button>
                
                @if (ViewData["Search"] != null || ViewData["Status"] != null || ViewData["Supervisor"] != null)
                {
                    <a asp-action="Groups" class="px-4 py-3 bg-slate-100 text-slate-600 rounded-lg hover:bg-slate-200 transition flex items-center gap-2 font-bold text-sm">
                        Clear
                    </a>
                }
            </div>
        </form>
    </div>


    <!-- Table Section -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-slate-200 bg-white">
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">GROUP NAME</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">RESEARCH TOPIC</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">MEMBERS</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">SUPERVISOR</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">REVIEW PHASE</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">STATUS</th>
                        <th class="px-6 py-4 text-center text-xs font-bold text-slate-500 uppercase tracking-wider">ACTIONS</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-6 py-5">
                                    <div>
                                        <a asp-action="GroupDetails" asp-route-id="@item.GroupID" class="font-bold text-slate-800 hover:text-blue-600 cursor-pointer no-underline">@item.GroupName</a>
                                        <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mt-1">@item.ProjectCode</p>
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    <p class="text-sm text-slate-700 font-semibold line-clamp-2">@item.ProjectName</p>
                                </td>
                                <td class="px-6 py-5">
                                    <div class="flex -space-x-2">
                                        @{
                                            var memberColors = new[] { "bg-blue-100 text-blue-700", "bg-purple-100 text-purple-700", "bg-pink-100 text-pink-700", "bg-emerald-100 text-emerald-700", "bg-amber-100 text-amber-700" };
                                            int colorIdx = 0;
                                        }
                                        @foreach (var name in item.MemberNames)
                                        {
                                            <div class="w-8 h-8 rounded-full @memberColors[colorIdx % memberColors.Length] flex items-center justify-center text-xs font-bold border-2 border-white shadow-sm" style="z-index: @(30 - colorIdx)">
                                                @name.Substring(0, 1).ToUpper()
                                            </div>
                                            colorIdx++;
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    <div class="inline-flex items-center gap-3 px-3 py-1.5 bg-slate-50 border border-slate-200 rounded-full">
                                        <div class="w-6 h-6 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 text-[10px] font-bold">
                                            @(item.SupervisorName != "Not Assigned" ? item.SupervisorName.Substring(0, 1) : "NA")
                                        </div>
                                        <span class="text-sm text-slate-700 font-bold pr-1">@item.SupervisorName</span>
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    <div class="flex items-center gap-3">
                                        <div class="w-16 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                            <div class="bg-[#1E3A5F] w-1/3 h-full rounded-full"></div>
                                        </div>
                                        <span class="text-[11px] font-extrabold text-[#1E3A5F]">@item.CurrentReviewPhase</span>
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    @{
                                        var statusClass = item.ProjectStatus switch
                                        {
                                            GPMS.Domain.Enums.ProjectStatus.Active => "bg-emerald-50 text-emerald-700 border-emerald-100",
                                            GPMS.Domain.Enums.ProjectStatus.Draft => "bg-amber-50 text-amber-700 border-amber-100",
                                            GPMS.Domain.Enums.ProjectStatus.Completed => "bg-blue-50 text-blue-700 border-blue-100",
                                            _ => "bg-slate-50 text-slate-700 border-slate-100"
                                        };
                                    }
                                    <span class="inline-flex items-center px-3 py-1 @statusClass text-[11px] font-bold rounded-full border">
                                        @item.ProjectStatus
                                    </span>
                                </td>
                                <td class="px-6 py-5 text-center">
                                    <button class="p-1.5 text-slate-400 hover:text-slate-800 hover:bg-slate-100 rounded-md transition" title="More Options">
                                        <span class="material-symbols-outlined text-[20px]">more_vert</span>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="px-6 py-10 text-center text-slate-500 font-medium">
                                No groups found for the current semester.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between bg-white">
            <p class="text-sm font-medium text-slate-500">Showing 1 to @(Model?.Count() ?? 0) of @(Model?.Count() ?? 0) groups</p>
            <div class="flex items-center gap-1">
                <button class="px-3 py-1.5 text-sm font-bold text-slate-500 hover:text-slate-800 transition">Previous</button>
                <div class="flex items-center gap-1 mx-2">
                    <button class="w-8 h-8 flex items-center justify-center rounded-md bg-[#1E3A5F] text-white font-bold shadow-sm">1</button>
                </div>
                <button class="px-3 py-1.5 text-sm font-bold text-slate-500 hover:text-slate-800 transition">Next</button>
            </div>
        </div>
    </div>
</div>


@{
    ViewData["Title"] = "Student Project Groups";
    Layout = "~/Views/Shared/_HodLayout.cshtml";
}

<!-- Main Content -->
<div class="space-y-6">
    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-800 mb-2">Student Project Groups</h1>
        <p class="text-slate-500 text-sm">Manage and monitor current semester's research groups and thesis projects.</p>
    </div>

    <!-- Controls Section -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] p-6 mb-6">
        <div class="flex flex-col md:flex-row md:items-center gap-4">
            <!-- Search Box -->
            <div class="flex-1 relative">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                <input 
                    type="text" 
                    placeholder="Search groups, topics or student names..." 
                    class="w-full pl-12 pr-4 py-3 border border-slate-200 rounded-lg bg-slate-50 text-slate-800 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors font-medium hover:bg-white"
                />
            </div>

            <!-- Filter Buttons -->
            <div class="flex gap-3">
                <div class="relative inline-block w-[140px]">
                    <select class="w-full appearance-none px-4 py-3 pr-10 border border-slate-200 rounded-lg bg-slate-50 text-slate-700 font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors hover:bg-white cursor-pointer text-sm outline-none">
                        <option>All Projects</option>
                        <option>Active</option>
                        <option>Pending</option>
                        <option>Completed</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-lg">expand_more</span>
                </div>

                <div class="relative inline-block w-[140px]">
                    <select class="w-full appearance-none px-4 py-3 pr-10 border border-slate-200 rounded-lg bg-slate-50 text-slate-700 font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors hover:bg-white cursor-pointer text-sm outline-none">
                        <option>All Statuses</option>
                        <option>Active</option>
                        <option>Pending</option>
                        <option>On Hold</option>
                        <option>Completed</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-lg">expand_more</span>
                </div>

                <div class="relative inline-block w-[160px]">
                    <select class="w-full appearance-none px-4 py-3 pr-10 border border-slate-200 rounded-lg bg-slate-50 text-slate-700 font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors hover:bg-white cursor-pointer text-sm outline-none">
                        <option>All Supervisors</option>
                        <option>TS. Nguyễn Văn A</option>
                        <option>ThS. Trần Hoàng B</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-lg">expand_more</span>
                </div>

                <button class="px-5 py-3 bg-[#1E3A5F] text-white rounded-lg hover:bg-slate-800 transition shadow-sm flex items-center gap-2 font-bold text-sm">
                    <span class="material-symbols-outlined text-[18px]">filter_list</span>
                    Apply Filters
                </button>
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-slate-200 bg-white">
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">GROUP NAME</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">RESEARCH TOPIC</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">MEMBERS</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">SUPERVISOR</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">REVIEW PHASE</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">STATUS</th>
                        <th class="px-6 py-4 text-center text-xs font-bold text-slate-500 uppercase tracking-wider">ACTIONS</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <!-- Row 1 -->
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-5">
                            <div>
                                <a href="/HOD/GroupDetails" class="font-bold text-slate-800 hover:text-blue-600 cursor-pointer no-underline">G-01-2024</a>
                                <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mt-1">CS Department</p>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <p class="text-sm text-slate-700 font-semibold line-clamp-2">Machine Learning in Urban Traffic Prediction</p>
                        </td>
                        <td class="px-6 py-5">
                            <div class="flex -space-x-2">
                                <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 text-xs font-bold border-2 border-white shadow-sm z-30">A</div>
                                <div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center text-purple-700 text-xs font-bold border-2 border-white shadow-sm z-20">B</div>
                                <div class="w-8 h-8 rounded-full bg-pink-100 flex items-center justify-center text-pink-700 text-xs font-bold border-2 border-white shadow-sm z-10">C</div>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <div class="inline-flex items-center gap-3 px-3 py-1.5 bg-slate-50 border border-slate-200 rounded-full">
                                <div class="w-6 h-6 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 text-[10px] font-bold">JC</div>
                                <span class="text-sm text-slate-700 font-bold pr-1">Dr. Jane Cooper</span>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <div class="flex items-center gap-3">
                                <div class="w-16 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                    <div class="bg-[#1E3A5F] w-1/2 h-full rounded-full"></div>
                                </div>
                                <span class="text-[11px] font-extrabold text-[#1E3A5F]">REVIEW #2</span>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <span class="inline-flex items-center px-3 py-1 bg-emerald-50 text-emerald-700 text-[11px] font-bold rounded-full border border-emerald-100">Active</span>
                        </td>
                        <td class="px-6 py-5 text-center">
                            <button class="p-1.5 text-slate-400 hover:text-slate-800 hover:bg-slate-100 rounded-md transition" title="More Options">
                                <span class="material-symbols-outlined text-[20px]">more_vert</span>
                            </button>
                        </td>
                    </tr>

                    <!-- Row 2 -->
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-5">
                            <div>
                                <p class="font-bold text-slate-800 cursor-pointer hover:text-blue-600 transition">G-02-2024</p>
                                <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mt-1">IS Department</p>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <p class="text-sm text-slate-700 font-semibold line-clamp-2">Blockchain for Decentralized Health Records</p>
                        </td>
                        <td class="px-6 py-5">
                            <div class="flex -space-x-2">
                                <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-700 text-xs font-bold border-2 border-white shadow-sm z-30">D</div>
                                <div class="w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center text-amber-700 text-xs font-bold border-2 border-white shadow-sm z-20">E</div>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <div class="inline-flex items-center gap-3 px-3 py-1.5 bg-slate-50 border border-slate-200 rounded-full">
                                <div class="w-6 h-6 rounded-full bg-slate-200 flex items-center justify-center text-slate-700 text-[10px] font-bold">JS</div>
                                <span class="text-sm text-slate-700 font-bold pr-1">Prof. John Smith</span>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <div class="flex items-center gap-3">
                                <div class="w-16 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                    <div class="bg-[#1E3A5F] w-1/4 h-full rounded-full"></div>
                                </div>
                                <span class="text-[11px] font-extrabold text-[#1E3A5F]">REVIEW #1</span>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <span class="inline-flex items-center px-3 py-1 bg-amber-50 text-amber-700 text-[11px] font-bold rounded-full border border-amber-100">Pending</span>
                        </td>
                        <td class="px-6 py-5 text-center">
                            <button class="p-1.5 text-slate-400 hover:text-slate-800 hover:bg-slate-100 rounded-md transition" title="More Options">
                                <span class="material-symbols-outlined text-[20px]">more_vert</span>
                            </button>
                        </td>
                    </tr>

                    <!-- Row 3 -->
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-5">
                            <div>
                                <p class="font-bold text-slate-800 cursor-pointer hover:text-blue-600 transition">G-03-2024</p>
                                <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mt-1">CS Department</p>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <p class="text-sm text-slate-700 font-semibold line-clamp-2">AR Application for Historical Landmarks</p>
                        </td>
                        <td class="px-6 py-5">
                            <div class="flex -space-x-2">
                                <div class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center text-red-700 text-xs font-bold border-2 border-white shadow-sm z-30">F</div>
                                <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 text-xs font-bold border-2 border-white shadow-sm z-20">G</div>
                                <div class="w-8 h-8 rounded-full bg-cyan-100 flex items-center justify-center text-cyan-700 text-xs font-bold border-2 border-white shadow-sm z-10">H</div>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <div class="inline-flex items-center gap-3 px-3 py-1.5 bg-slate-50 border border-slate-200 rounded-full">
                                <div class="w-6 h-6 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 text-[10px] font-bold">AW</div>
                                <span class="text-sm text-slate-700 font-bold pr-1">Dr. Alan Walker</span>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <div class="flex items-center gap-3">
                                <div class="w-16 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                    <div class="bg-[#1E3A5F] w-[90%] h-full rounded-full"></div>
                                </div>
                                <span class="text-[11px] font-extrabold text-[#1E3A5F]">REVIEW #3</span>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <span class="inline-flex items-center px-3 py-1 bg-blue-50 text-blue-700 text-[11px] font-bold rounded-full border border-blue-100">Completed</span>
                        </td>
                        <td class="px-6 py-5 text-center">
                            <button class="p-1.5 text-slate-400 hover:text-slate-800 hover:bg-slate-100 rounded-md transition" title="More Options">
                                <span class="material-symbols-outlined text-[20px]">more_vert</span>
                            </button>
                        </td>
                    </tr>

                    <!-- Row 4 -->
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-5">
                            <div>
                                <p class="font-bold text-slate-800 cursor-pointer hover:text-blue-600 transition">G-04-2024</p>
                                <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mt-1">IS Department</p>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <p class="text-sm text-slate-700 font-semibold line-clamp-2">Cyber-Security Framework for SME</p>
                        </td>
                        <td class="px-6 py-5">
                            <div class="flex -space-x-2">
                                <div class="w-8 h-8 rounded-full bg-orange-100 flex items-center justify-center text-orange-700 text-xs font-bold border-2 border-white shadow-sm z-30">I</div>
                                <div class="w-8 h-8 rounded-full bg-teal-100 flex items-center justify-center text-teal-700 text-xs font-bold border-2 border-white shadow-sm z-20">J</div>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <div class="inline-flex items-center gap-3 px-3 py-1.5 bg-slate-50 border border-slate-200 rounded-full">
                                <div class="w-6 h-6 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 text-[10px] font-bold">JC</div>
                                <span class="text-sm text-slate-700 font-bold pr-1">Dr. Jane Cooper</span>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <div class="flex items-center gap-3">
                                <div class="w-16 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                    <div class="bg-[#1E3A5F] w-1/4 h-full rounded-full"></div>
                                </div>
                                <span class="text-[11px] font-extrabold text-[#1E3A5F]">REVIEW #1</span>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <span class="inline-flex items-center px-3 py-1 bg-red-50 text-red-700 text-[11px] font-bold rounded-full border border-red-100">On Hold</span>
                        </td>
                        <td class="px-6 py-5 text-center">
                            <button class="p-1.5 text-slate-400 hover:text-slate-800 hover:bg-slate-100 rounded-md transition" title="More Options">
                                <span class="material-symbols-outlined text-[20px]">more_vert</span>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between bg-white">
            <p class="text-sm font-medium text-slate-500">Showing 1 to 4 of 24 groups</p>
            <div class="flex items-center gap-1">
                <button class="px-3 py-1.5 text-sm font-bold text-slate-500 hover:text-slate-800 transition">Previous</button>
                <div class="flex items-center gap-1 mx-2">
                    <button class="w-8 h-8 flex items-center justify-center rounded-md bg-[#1E3A5F] text-white font-bold shadow-sm">1</button>
                    <button class="w-8 h-8 flex items-center justify-center rounded-md text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 transition font-bold">2</button>
                    <button class="w-8 h-8 flex items-center justify-center rounded-md text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 transition font-bold">3</button>
                </div>
                <button class="px-3 py-1.5 text-sm font-bold text-slate-500 hover:text-slate-800 transition">Next</button>
            </div>
        </div>
    </div>
</div>

@using GPMS.Web.ViewModels
@model HODProgressViewModel
@{
    ViewData["Title"] = "Project Progress Tracking";
    Layout = "_Layout";
}

<div class="space-y-6">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
        <div>
            <nav class="flex items-center gap-2 text-sm text-slate-500 font-medium mb-4">
                <a href="/HOD/Dashboard" class="hover:text-slate-800 transition-colors no-underline">GPMS</a>
                <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                <span class="text-slate-800">Theo dõi tiến độ</span>
            </nav>
            <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Giám sát Tiến độ Đồ án</h1>
            <p class="text-slate-600 mt-1">Theo dõi các chặng đường từ Round 1 đến Bảo vệ chính thức của @Model.Groups.Count nhóm.</p>
        </div>
        
        <div class="flex flex-wrap items-center gap-3">
             <form method="get" id="filterForm" class="flex items-center gap-3">
                <select name="semesterId" class="bg-white border border-slate-200 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 shadow-sm focus:border-orange-500 outline-none" onchange="this.form.submit()">
                    <option value="-1">Tất cả học kỳ</option>
                    @foreach(var sem in Model.Semesters) {
                        <option value="@sem.SemesterID" selected="@(ViewBag.SelectedSemesterId == sem.SemesterID)">@sem.SemesterCode</option>
                    }
                </select>

                <select name="majorName" class="bg-white border border-slate-200 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 shadow-sm focus:border-orange-500 outline-none" onchange="this.form.submit()">
                    <option value="">Tất cả chuyên ngành</option>
                    @foreach(var major in Model.Majors) {
                        <option value="@major.MajorName" selected="@(ViewBag.CurrentMajor == major.MajorName)">@major.MajorName</option>
                    }
                </select>
            </form>
        </div>
    </div>

    <!-- Progress Grid Table -->
    <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="p-6 text-left text-xs font-bold text-slate-400 uppercase tracking-widest w-64">Thông tin nhóm</th>
                        <th class="p-6 text-left text-xs font-bold text-slate-400 uppercase tracking-widest">Tiến trình các vòng Review</th>
                        <th class="p-6 text-center text-xs font-bold text-slate-400 uppercase tracking-widest w-40">Trạng thái cuối</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (!Model.Groups.Any()) {
                        <tr>
                            <td colspan="3" class="p-20 text-center">
                                <div class="flex flex-col items-center gap-4">
                                    <span class="material-symbols-outlined text-slate-200 text-6xl">visibility_off</span>
                                    <p class="text-slate-400 font-medium">Không tìm thấy dữ liệu nhóm nào phù hợp</p>
                                </div>
                            </td>
                        </tr>
                    }

                    @foreach (var group in Model.Groups) {
                        <tr class="hover:bg-slate-50/30 transition-colors group">
                            <td class="p-6">
                                <div class="flex flex-col">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="px-2 py-0.5 bg-orange-50 text-[#F37021] text-[10px] font-bold rounded-full uppercase tracking-tighter">@group.ProjectCode</span>
                                        <h3 class="text-sm font-bold text-slate-900">@group.GroupName</h3>
                                    </div>
                                    <p class="text-xs text-slate-500 line-clamp-1 mb-2">@group.ProjectName</p>
                                    <div class="flex items-center gap-3 text-[10px] font-medium text-slate-400">
                                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">person</span> @group.SupervisorName</span>
                                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">school</span> @group.MajorName</span>
                                    </div>
                                </div>
                            </td>
                            <td class="p-6">
                                <div class="flex items-center justify-between relative max-w-2xl">
                                    <!-- Progress Line Background -->
                                    <div class="absolute top-1/2 left-0 w-full h-0.5 bg-slate-100 -translate-y-1/2 z-0"></div>
                                    
                                    @for (int i = 0; i < Model.Rounds.Count; i++) {
                                        var round = Model.Rounds[i];
                                        // Mock status check (In real env, check against group progress)
                                        bool isPast = (i < 2); // Example logic
                                        bool isCurrent = (i == 2); 

                                        <div class="relative z-10 flex flex-col items-center gap-2">
                                            <div class="w-8 h-8 rounded-full flex items-center justify-center border-4 border-white shadow-sm @(isPast ? "bg-emerald-500 text-white" : isCurrent ? "bg-[#F37021] text-white animate-pulse" : "bg-slate-200 text-slate-500")">
                                                @if (isPast) {
                                                    <span class="material-symbols-outlined text-[16px] font-bold">check</span>
                                                } else {
                                                    <span class="text-[11px] font-black">R@(round.RoundNumber)</span>
                                                }
                                            </div>
                                            <span class="text-[10px] font-bold @(isPast ? "text-emerald-600" : isCurrent ? "text-orange-500" : "text-slate-400") uppercase">
                                                @(i == Model.Rounds.Count - 1 ? "Bảo vệ" : "Round " + round.RoundNumber)
                                            </span>
                                        </div>
                                    }
                                </div>
                            </td>
                            <td class="p-6 text-center">
                                <span class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full bg-slate-100 text-slate-600 text-[11px] font-bold">
                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                                    ĐANG THỰC HIỆN
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

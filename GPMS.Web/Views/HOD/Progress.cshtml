@using GPMS.Web.ViewModels
@model HODProgressViewModel
@{
    ViewData["Title"] = "Project Progress Tracking";
    Layout = "_Layout";

    // Calculate Stats
    var totalGroups = Model.Groups.Count;
    var completedGroups = Model.Groups.Count(g => g.RoundStatuses.All(rs => rs.IsEvaluated));
    var warningGroups = Model.Groups.Count(g => g.RoundStatuses.Any(rs => !rs.IsSubmitted && rs.RoundNumber < Model.Rounds.Max(r => r.RoundNumber)));
}

<div class="space-y-8 pb-20 animate-in fade-in duration-700">
    <!-- Header Section -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6">
        <div class="space-y-2">
            <nav class="flex items-center gap-2 text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
                <a href="/HOD/Dashboard" class="hover:text-orange-500 transition-colors no-underline">GPMS Portal</a>
                <span class="material-symbols-outlined text-[14px]">chevron_right</span>
                <span class="text-slate-600">Progress Monitoring</span>
            </nav>
            <h1 class="text-4xl font-black text-slate-900 tracking-tight">
                Project <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-rose-500">Progress</span>
            </h1>
            <p class="text-slate-500 max-w-2xl text-lg font-medium leading-relaxed">
                Monitor the completion process of @totalGroups student groups across defense rounds.
            </p>
        </div>
        
        <!-- Filters -->
        <div class="bg-white/60 backdrop-blur-xl border border-white p-2 rounded-2xl shadow-sm flex items-center gap-2">
            <form method="get" id="filterForm" class="flex flex-wrap items-center gap-2">
                <div class="relative group">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 text-lg group-focus-within:text-orange-500 transition-colors">calendar_month</span>
                    <select name="semesterId" class="bg-slate-50/50 border border-slate-100 rounded-xl pl-10 pr-4 py-2.5 text-sm font-bold text-slate-700 shadow-inner focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 outline-none transition-all appearance-none cursor-pointer" onchange="this.form.submit()">
                        <option value="-1">All Semesters</option>
                        @foreach(var sem in Model.Semesters) {
                            <option value="@sem.SemesterID" selected="@(ViewBag.SelectedSemesterId == sem.SemesterID)">@sem.SemesterCode</option>
                        }
                    </select>
                </div>

                <div class="relative group">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 text-lg group-focus-within:text-orange-500 transition-colors">school</span>
                    <select name="majorName" class="bg-slate-50/50 border border-slate-100 rounded-xl pl-10 pr-10 py-2.5 text-sm font-bold text-slate-700 shadow-inner focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 outline-none transition-all appearance-none cursor-pointer" onchange="this.form.submit()">
                        <option value="">All Majors</option>
                        @foreach(var major in Model.Majors) {
                            <option value="@major.MajorName" selected="@(ViewBag.CurrentMajor == major.MajorName)">@major.MajorName</option>
                        }
                    </select>
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-300 pointer-events-none">expand_more</span>
                </div>
            </form>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow group">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 rounded-2xl bg-orange-50 flex items-center justify-center text-orange-500 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-3xl font-bold">groups</span>
                </div>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Total Groups</span>
            </div>
            <div class="text-3xl font-black text-slate-900">@totalGroups</div>
            <div class="mt-2 text-xs font-semibold text-slate-400">Active this semester</div>
        </div>

        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow group">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 rounded-2xl bg-emerald-50 flex items-center justify-center text-emerald-500 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-3xl font-bold">verified</span>
                </div>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Completed</span>
            </div>
            <div class="text-3xl font-black text-slate-900">@completedGroups</div>
            <div class="mt-2 text-xs font-semibold text-emerald-600 flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                Defenses finished
            </div>
        </div>

        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow group">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 rounded-2xl bg-amber-50 flex items-center justify-center text-amber-500 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-3xl font-bold">pending</span>
                </div>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-tighter">In Progress</span>
            </div>
            <div class="text-3xl font-black text-slate-900">@(totalGroups - completedGroups)</div>
            <div class="mt-2 text-xs font-semibold text-amber-600">Currently in review process</div>
        </div>

        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow group">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 rounded-2xl bg-rose-50 flex items-center justify-center text-rose-500 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-3xl font-bold">warning</span>
                </div>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Attention Needed</span>
            </div>
            <div class="text-3xl font-black text-slate-900">@warningGroups</div>
            <div class="mt-2 text-xs font-semibold text-rose-600">Behind schedule or needs support</div>
        </div>
    </div>

    <!-- Main Content Table -->
    <div class="bg-white rounded-[2rem] border border-slate-100 shadow-xl shadow-slate-200/50 overflow-hidden">
        <div class="overflow-x-auto min-h-[400px]">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="bg-slate-50/80 border-b border-slate-100">
                        <th class="p-8 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] w-[350px]">Project Information</th>
                        <th class="p-8 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Rounds Status</th>
                        <th class="p-8 text-center text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] w-48">Overall Progress</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @if (!Model.Groups.Any()) {
                        <tr>
                            <td colspan="3" class="p-32 text-center text-slate-300">
                                <div class="flex flex-col items-center gap-6">
                                    <div class="w-24 h-24 rounded-full bg-slate-50 flex items-center justify-center">
                                        <span class="material-symbols-outlined text-6xl">inventory_2</span>
                                    </div>
                                    <p class="text-xl font-bold text-slate-400">No data available for this semester</p>
                                </div>
                            </td>
                        </tr>
                    }

                    @foreach (var group in Model.Groups.OrderByDescending(g => g.ProjectCode)) {
                        var completedCount = group.RoundStatuses.Count(s => s.IsEvaluated);
                        var totalRounds = Model.Rounds.Count;
                        var progressPercent = (totalRounds > 0) ? (completedCount * 100 / totalRounds) : 0;
                        var isFinished = completedCount == totalRounds;

                        <tr class="hover:bg-slate-50/50 transition-all duration-300 group/row">
                            <td class="p-8 border-r border-slate-50/50">
                                <div class="space-y-4">
                                    <div class="flex items-start gap-4">
                                        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-slate-100 to-slate-200 flex-shrink-0 flex items-center justify-center text-slate-500 font-bold shadow-sm">
                                            @group.ProjectCode.Substring(Math.Max(0, group.ProjectCode.Length - 2))
                                        </div>
                                        <div class="min-w-0">
                                            <div class="flex items-center gap-2 mb-1">
                                                <span class="px-2 py-0.5 bg-orange-50 text-orange-600 text-[10px] font-black rounded-lg uppercase tracking-tight">@group.ProjectCode</span>
                                                <h3 class="text-base font-black text-slate-800 truncate">@group.GroupName</h3>
                                            </div>
                                            <p class="text-sm font-semibold text-slate-500 line-clamp-2 leading-snug">@group.ProjectName</p>
                                        </div>
                                    </div>
                                    
                                    <div class="flex flex-wrap gap-2 pt-2">
                                        <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-100 text-slate-500 text-[11px] font-bold">
                                            <span class="material-symbols-outlined text-lg">person</span>
                                            @group.SupervisorName
                                        </div>
                                        <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-100 text-slate-500 text-[11px] font-bold">
                                            <span class="material-symbols-outlined text-lg">school</span>
                                            @group.MajorName
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="p-8">
                                <div class="flex items-center justify-between relative max-w-[500px] h-20">
                                    <!-- Dynamic Progress Background -->
                                    <div class="absolute top-1/2 left-0 w-full h-1 bg-slate-100 -translate-y-1/2 rounded-full overflow-hidden">
                                        <div class="h-full bg-gradient-to-r from-orange-500 to-emerald-500 transition-all duration-1000" style="width: @progressPercent%"></div>
                                    </div>
                                    
                                    @for (int i = 0; i < Model.Rounds.Count; i++) {
                                        var round = Model.Rounds[i];
                                        var status = group.RoundStatuses.FirstOrDefault(rs => rs.RoundNumber == round.RoundNumber);
                                        
                                        bool isPast = status?.IsEvaluated ?? false;
                                        bool isCurrent = !isPast && (status?.IsSubmitted ?? false);
                                        bool isPending = !isPast && !isCurrent;
                                        
                                        <div class="relative z-10 group/step @(i == 0 ? "self-start" : i == Model.Rounds.Count - 1 ? "self-end" : "")">
                                            <!-- Step Bubble -->
                                            <div class="w-10 h-10 rounded-2xl flex items-center justify-center border-4 border-white shadow-xl transition-all duration-500 
                                                @(isPast ? "bg-emerald-500 text-white scale-110" : 
                                                  isCurrent ? "bg-orange-500 text-white animate-bounce shadow-orange-500/40" : 
                                                  "bg-white text-slate-400 ring-1 ring-slate-100")">
                                                
                                                @if (isPast) {
                                                    <span class="material-symbols-outlined text-xl font-black">check_circle</span>
                                                } else if (isCurrent) {
                                                    <span class="material-symbols-outlined text-xl animate-pulse">rocket_launch</span>
                                                } else {
                                                    <span class="text-xs font-black">R@(round.RoundNumber)</span>
                                                }
                                            </div>

                                            <!-- Step Label -->
                                            <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 whitespace-nowrap text-center">
                                                <div class="text-[10px] font-black uppercase tracking-widest @(isPast ? "text-emerald-600" : isCurrent ? "text-orange-500" : "text-slate-400")">
                                                    @(i == Model.Rounds.Count - 1 ? "FINAL" : $"ROUND {round.RoundNumber}")
                                                </div>
                                                <div class="text-[9px] font-bold text-slate-300 mt-0.5">
                                                    @(isPast ? "COMPLETED" : isCurrent ? "GRADING" : "PENDING")
                                                </div>
                                            </div>

                                            <!-- Tooltip -->
                                            <div class="absolute -top-12 left-1/2 -translate-x-1/2 bg-slate-900 text-white text-[10px] px-3 py-1.5 rounded-lg opacity-0 group-hover/step:opacity-100 transition-opacity pointer-events-none whitespace-nowrap font-bold shadow-2xl">
                                                @if (status != null) {
                                                    <ul class="text-left space-y-1">
                                                        <li class="flex items-center gap-1">@(status.IsSubmitted ? "✅" : "❌") File Submitted</li>
                                                        <li class="flex items-center gap-1">@(status.IsApproved ? "✅" : "❌") Mentor Approved</li>
                                                        <li class="flex items-center gap-1">@(status.IsEvaluated ? "✅" : "❌") Evaluated</li>
                                                    </ul>
                                                } else {
                                                    <span>No data available</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </td>
                            <td class="p-8 text-center border-l border-slate-50/50">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="relative w-16 h-16">
                                        <svg class="w-full h-full -rotate-90" viewBox="0 0 36 36">
                                            <circle cx="18" cy="18" r="16" fill="none" class="stroke-slate-100" stroke-width="4"></circle>
                                            <circle cx="18" cy="18" r="16" fill="none" class="@(isFinished ? "stroke-emerald-500" : "stroke-orange-500") transition-all duration-1000" 
                                                    stroke-width="4" stroke-dasharray="100" stroke-dashoffset="@(100 - progressPercent)" 
                                                    stroke-linecap="round"></circle>
                                        </svg>
                                        <div class="absolute inset-0 flex items-center justify-center">
                                            <span class="text-xs font-black text-slate-700">@progressPercent%</span>
                                        </div>
                                    </div>
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-tighter
                                        @(isFinished ? "bg-emerald-50 text-emerald-600 border border-emerald-100" : "bg-orange-50 text-orange-600 border border-orange-100")">
                                        <span class="w-1.5 h-1.5 rounded-full @(isFinished ? "bg-emerald-500" : "bg-orange-500 animate-pulse")"></span>
                                        @(isFinished ? "Done" : "Ongoing")
                                    </span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
    
    body {
        font-family: 'Inter', sans-serif;
        background-color: #f8fafc;
    }

    .material-symbols-outlined {
        font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    table {
        border-spacing: 0;
    }

    tr:last-child {
        border-bottom: none;
    }

    .tracking-tighter {
        letter-spacing: -0.05em;
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }
    ::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }
    ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }
    ::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
    }
</style>

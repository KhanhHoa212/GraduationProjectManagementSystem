@{
    ViewBag.Title = "Quản lý Vòng Review";
    ViewBag.CurrentPage = "ReviewRounds";
    ViewBag.BreadcrumbSection = "Vòng Review";
    Layout = "~/Views/Shared/_HODLayout.cshtml";
}

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div>
            <nav class="flex items-center gap-2 text-sm text-slate-500 font-medium mb-4">
                <a href="/HOD/Dashboard" class="hover:text-slate-800 transition-colors no-underline">GPMS</a>
                <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                <span class="text-slate-800 font-bold">Vòng Review</span>
            </nav>
            <h1 class="text-2xl font-bold text-slate-800">Quản lý Vòng Review</h1>
            <p class="text-slate-500 text-sm mt-1 font-medium">Thiết lập và theo dõi các giai đoạn đánh giá đồ án trong học kỳ.</p>
        </div>
        <div class="flex items-end">
            <button class="bg-[#1E3A5F] hover:bg-slate-800 text-white flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-bold transition shadow-sm border border-slate-700">
                <span class="material-symbols-outlined text-[18px]">add_circle</span>
                Tạo vòng review mới
            </button>
        </div>
    </div>

    <!-- Timeline Overview (Top Card) -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] pt-12 pb-10 px-6 overflow-hidden">
        <div class="relative flex justify-between items-start w-full max-w-4xl mx-auto">
            <!-- Background line -->
            <div class="absolute top-[18px] left-0 w-full h-[3px] bg-slate-100 rounded-full z-0"></div>
            <!-- Progress line -->
            <div class="absolute top-[18px] left-0 w-[40%] h-[3px] bg-[#F37021] rounded-full z-0"></div>
            
            <!-- Step 1: Ongoing -->
            <div class="relative z-10 flex flex-col items-center flex-1 text-center group cursor-pointer -ml-8">
                <div class="w-10 h-10 rounded-full bg-[#F37021] text-white flex items-center justify-center shadow-lg ring-4 ring-white transition-transform group-hover:scale-110 mb-4 border border-orange-500">
                    <span class="material-symbols-outlined text-[20px] font-bold">check</span>
                </div>
                <h3 class="text-[15px] font-bold text-slate-800">Vòng 1: Proposal Review</h3>
                <span class="inline-block mt-2 mb-2 px-2.5 py-0.5 bg-orange-50 text-[#F37021] text-[10px] font-extrabold rounded-full border border-orange-100 uppercase tracking-wider">Đang diễn ra</span>
                <p class="text-[11px] text-slate-500 font-bold flex items-center justify-center gap-1.5"><span class="material-symbols-outlined text-[14px]">calendar_today</span> 10/01 - 25/01</p>
            </div>

            <!-- Step 2: Planned -->
            <div class="relative z-10 flex flex-col items-center flex-1 text-center group cursor-pointer">
                <div class="w-10 h-10 rounded-full bg-slate-50 text-slate-400 flex items-center justify-center ring-4 ring-white border border-slate-200 transition-transform group-hover:scale-110 mb-4 shadow-sm">
                    <span class="material-symbols-outlined text-[20px]">more_horiz</span>
                </div>
                <h3 class="text-[15px] font-bold text-slate-500 group-hover:text-slate-700 transition-colors">Vòng 2: Mid-term Progress</h3>
                <span class="inline-block mt-2 mb-2 px-2.5 py-0.5 bg-slate-50 text-slate-400 text-[10px] font-extrabold rounded-full border border-slate-200 uppercase tracking-wider">Dự kiến</span>
                <p class="text-[11px] text-slate-400 font-bold flex items-center justify-center gap-1.5"><span class="material-symbols-outlined text-[14px]">calendar_today</span> 01/03 - 15/03</p>
            </div>

            <!-- Step 3: Planned -->
            <div class="relative z-10 flex flex-col items-center flex-1 text-center group cursor-pointer -mr-8">
                <div class="w-10 h-10 rounded-full bg-slate-50 text-slate-400 flex items-center justify-center ring-4 ring-white border border-slate-200 transition-transform group-hover:scale-110 mb-4 shadow-sm">
                    <span class="material-symbols-outlined text-[20px]">event</span>
                </div>
                <h3 class="text-[15px] font-bold text-slate-500 group-hover:text-slate-700 transition-colors">Vòng 3: Final Defense</h3>
                <span class="inline-block mt-2 mb-2 px-2.5 py-0.5 bg-slate-50 text-slate-400 text-[10px] font-extrabold rounded-full border border-slate-200 uppercase tracking-wider">Dự kiến</span>
                <p class="text-[11px] text-slate-400 font-bold flex items-center justify-center gap-1.5"><span class="material-symbols-outlined text-[14px]">calendar_today</span> 20/05 - 30/06</p>
            </div>
        </div>
    </div>

    <!-- Data Table Section -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] overflow-hidden">
        <div class="p-5 border-b border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-[#1E3A5F]">list_alt</span>
                <h2 class="text-[15px] font-bold text-slate-800">Danh sách các Vòng Review</h2>
            </div>
            <div class="relative min-w-[300px]">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                <input type="text" placeholder="Tìm kiếm vòng..." class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-lg bg-slate-50 text-sm font-medium text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-colors shadow-sm" />
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-white border-b border-slate-200">
                        <th class="px-6 py-5 text-[11px] font-extrabold text-slate-400 uppercase tracking-wider w-[35%]">TÊN VÒNG</th>
                        <th class="px-6 py-5 text-[11px] font-extrabold text-slate-400 uppercase tracking-wider">HỌC KỲ</th>
                        <th class="px-6 py-5 text-[11px] font-extrabold text-slate-400 uppercase tracking-wider w-[20%]">THỜI GIAN (BĐ - KT)</th>
                        <th class="px-6 py-5 text-[11px] font-extrabold text-slate-400 uppercase tracking-wider">DEADLINE NỘP</th>
                        <th class="px-6 py-5 text-[11px] font-extrabold text-slate-400 uppercase tracking-wider">TRẠNG THÁI</th>
                        <th class="px-6 py-5 text-center text-[11px] font-extrabold text-slate-400 uppercase tracking-wider">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <!-- R1: Proposal Review -->
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-6">
                            <div class="flex items-start gap-4">
                                <div class="w-10 h-10 rounded-xl bg-orange-50 border border-orange-100 flex flex-col items-center justify-center flex-shrink-0 text-[#F37021] shadow-sm">
                                    <span class="font-extrabold text-sm leading-none m-0 p-0 block">R</span>
                                    <span class="font-bold text-[10px] leading-none m-0 p-0 block mt-0.5">1</span>
                                </div>
                                <div class="pt-0.5">
                                    <p class="font-bold text-slate-800 text-[15px] leading-snug">Proposal Review</p>
                                    <p class="text-xs text-slate-500 font-medium mt-1 leading-snug tracking-wide">Vòng đánh giá đề cương chi tiết</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-6">
                            <span class="font-extrabold text-slate-800 text-sm">SP25</span>
                        </td>
                        <td class="px-6 py-6">
                            <p class="font-bold text-slate-700 text-[13px] tracking-wide">10/01/2025 - 25/01/2025</p>
                            <p class="text-[9px] text-slate-400 font-extrabold uppercase tracking-widest mt-1.5">15 NGÀY THỰC HIỆN</p>
                        </td>
                        <td class="px-6 py-6">
                            <span class="font-bold text-red-500 text-sm">20/01/2025</span>
                        </td>
                        <td class="px-6 py-6">
                            <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-orange-50 border border-orange-200 text-[#F37021] rounded-full shadow-sm">
                                <span class="w-1.5 h-1.5 rounded-full bg-[#F37021]"></span>
                                <span class="text-[10px] font-extrabold uppercase tracking-widest mt-px">Ongoing</span>
                            </div>
                        </td>
                        <td class="px-6 py-6 text-center">
                            <div class="flex items-center justify-center gap-1.5">
                                <button class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition" title="Edit Stage">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </button>
                                <button class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition" title="Manage Checklist">
                                    <span class="material-symbols-outlined text-[18px]">fact_check</span>
                                </button>
                                <button class="p-2 text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 rounded-lg transition" title="Assign Reviewers">
                                    <span class="material-symbols-outlined text-[18px]">manage_accounts</span>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- R2: Mid-term Progress -->
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-6">
                            <div class="flex items-start gap-4">
                                <div class="w-10 h-10 rounded-xl bg-blue-50 border border-blue-100 flex flex-col items-center justify-center flex-shrink-0 text-blue-600 shadow-sm">
                                    <span class="font-extrabold text-sm leading-none m-0 p-0 block">R</span>
                                    <span class="font-bold text-[10px] leading-none m-0 p-0 block mt-0.5">2</span>
                                </div>
                                <div class="pt-0.5">
                                    <p class="font-bold text-slate-800 text-[15px] leading-snug">Mid-term Progress</p>
                                    <p class="text-xs text-slate-500 font-medium mt-1 leading-snug tracking-wide">Đánh giá tiến độ giữa kỳ</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-6">
                            <span class="font-extrabold text-slate-800 text-sm">SP25</span>
                        </td>
                        <td class="px-6 py-6">
                            <p class="font-bold text-slate-700 text-[13px] tracking-wide">01/03/2025 - 15/03/2025</p>
                            <p class="text-[9px] text-slate-400 font-extrabold uppercase tracking-widest mt-1.5">14 NGÀY THỰC HIỆN</p>
                        </td>
                        <td class="px-6 py-6">
                            <span class="font-bold text-slate-800 text-sm">10/03/2025</span>
                        </td>
                        <td class="px-6 py-6">
                            <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-50 border border-blue-100 text-blue-600 rounded-full shadow-sm">
                                <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                                <span class="text-[10px] font-extrabold uppercase tracking-widest mt-px">Planned</span>
                            </div>
                        </td>
                        <td class="px-6 py-6 text-center">
                            <div class="flex items-center justify-center gap-1.5">
                                <button class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition" title="Edit Stage">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </button>
                                <button class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition" title="Manage Checklist">
                                    <span class="material-symbols-outlined text-[18px]">fact_check</span>
                                </button>
                                <button class="p-2 text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 rounded-lg transition" title="Assign Reviewers">
                                    <span class="material-symbols-outlined text-[18px]">manage_accounts</span>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- R3: Final Defense -->
                    <tr class="hover:bg-slate-50/50 transition-colors border-b border-transparent">
                        <td class="px-6 py-6">
                            <div class="flex items-start gap-4">
                                <div class="w-10 h-10 rounded-xl bg-blue-50 border border-blue-100 flex flex-col items-center justify-center flex-shrink-0 text-blue-600 shadow-sm">
                                    <span class="font-extrabold text-sm leading-none m-0 p-0 block">R</span>
                                    <span class="font-bold text-[10px] leading-none m-0 p-0 block mt-0.5">3</span>
                                </div>
                                <div class="pt-0.5">
                                    <p class="font-bold text-slate-800 text-[15px] leading-snug">Final Defense</p>
                                    <p class="text-xs text-slate-500 font-medium mt-1 leading-snug tracking-wide">Bảo vệ đồ án cuối kỳ</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-6">
                            <span class="font-extrabold text-slate-800 text-sm">SP25</span>
                        </td>
                        <td class="px-6 py-6">
                            <p class="font-bold text-slate-700 text-[13px] tracking-wide">20/05/2025 - 30/06/2025</p>
                            <p class="text-[9px] text-slate-400 font-extrabold uppercase tracking-widest mt-1.5">41 NGÀY THỰC HIỆN</p>
                        </td>
                        <td class="px-6 py-6">
                            <span class="font-bold text-slate-800 text-sm">15/05/2025</span>
                        </td>
                        <td class="px-6 py-6">
                            <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-50 border border-blue-100 text-blue-600 rounded-full shadow-sm">
                                <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                                <span class="text-[10px] font-extrabold uppercase tracking-widest mt-px">Planned</span>
                            </div>
                        </td>
                        <td class="px-6 py-6 text-center">
                            <div class="flex items-center justify-center gap-1.5">
                                <button class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition" title="Edit Stage">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </button>
                                <button class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition" title="Manage Checklist">
                                    <span class="material-symbols-outlined text-[18px]">fact_check</span>
                                </button>
                                <button class="p-2 text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 rounded-lg transition" title="Assign Reviewers">
                                    <span class="material-symbols-outlined text-[18px]">manage_accounts</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between bg-white text-sm">
            <p class="font-medium text-slate-500">Hiển thị <span class="font-bold text-slate-800">3</span> trong số <span class="font-bold text-slate-800">3</span> vòng review</p>
            <div class="flex items-center gap-2">
                <button class="px-3.5 py-1.5 border border-slate-200 text-slate-500 font-bold rounded-lg hover:bg-slate-50 transition shadow-sm">Trước</button>
                <button class="w-8 h-8 flex items-center justify-center bg-[#1E3A5F] text-white font-bold rounded-lg shadow-sm">1</button>
                <button class="px-3.5 py-1.5 border border-slate-200 text-slate-500 font-bold rounded-lg hover:bg-slate-50 transition shadow-sm">Sau</button>
            </div>
        </div>
    </div>
</div>

@model IEnumerable<GPMS.Application.DTOs.ReviewRoundDto>
@{
    ViewData["Title"] = "Review Rounds";
    Layout = "~/Views/Shared/_HodLayout.cshtml";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950">
    <div class="p-6">
        <div class="max-w-7xl mx-auto space-y-6">
            <!-- Header -->
            <div class="flex items-start justify-between mb-8">
                <div>
                    <nav class="flex items-center gap-2 text-sm mb-4">
                        <a href="/Hod/Dashboard" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200">GPMS</a>
                        <span class="text-slate-400 dark:text-slate-600">/</span>
                        <span class="text-slate-900 dark:text-slate-100 font-medium">Vòng Review</span>
                    </nav>
                    <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Quản lý Vòng Review</h1>
                    <p class="text-slate-600 dark:text-slate-400 mt-2">Thiết lập và theo dõi các giai đoạn đánh giá đề án trong học kỳ.</p>
                </div>
                <a href="/HOD/CreateReviewRound" class="px-6 py-2 bg-[#F37021] text-white rounded-lg hover:bg-[#E55D0D] font-medium flex items-center gap-2 transition">
                    <span class="material-symbols-outlined" style="font-size: 20px;">add</span>
                    Tạo vòng review mới
                </a>
            </div>

            <!-- Review Timeline Visualization -->
            <div class="bg-white dark:bg-slate-900 rounded-xl p-8 shadow-sm border border-slate-200 dark:border-slate-800">
                <div class="flex items-center justify-between">
                    @if (Model != null && Model.Any())
                    {
                        var rounds = Model.OrderBy(r => r.RoundNumber).Take(3).ToList();
                        for (int i = 0; i < rounds.Count; i++)
                        {
                            var r = rounds[i];
                            var statusColorBg = r.Status == GPMS.Domain.Enums.RoundStatus.Ongoing ? "bg-orange-100 dark:bg-orange-900" : (r.Status == GPMS.Domain.Enums.RoundStatus.Completed ? "bg-emerald-100 dark:bg-emerald-900" : "bg-slate-100 dark:bg-slate-800");
                            var statusTextColor = r.Status == GPMS.Domain.Enums.RoundStatus.Ongoing ? "text-orange-800 dark:text-orange-200" : (r.Status == GPMS.Domain.Enums.RoundStatus.Completed ? "text-emerald-800 dark:text-emerald-200" : "text-slate-800 dark:text-slate-200");
                            var iconBg = r.Status == GPMS.Domain.Enums.RoundStatus.Completed ? "bg-emerald-500 text-white" : (r.Status == GPMS.Domain.Enums.RoundStatus.Ongoing ? "bg-[#F37021] text-white" : "bg-slate-300 dark:bg-slate-700 text-slate-600 dark:text-slate-400");
                            var iconName = r.Status == GPMS.Domain.Enums.RoundStatus.Completed ? "check_circle" : (r.Status == GPMS.Domain.Enums.RoundStatus.Ongoing ? "sync" : "schedule");

                            <div class="flex flex-col items-center flex-1">
                                <div class="w-14 h-14 rounded-full @iconBg flex items-center justify-center border-4 border-white dark:border-slate-900 shadow-md">
                                    <span class="material-symbols-outlined" style="font-size: 24px;">@iconName</span>
                                </div>
                                <div class="mt-4 text-center">
                                    <h3 class="font-semibold text-slate-900 dark:text-white">Review @r.RoundNumber</h3>
                                    <span class="inline-block mt-2 px-3 py-1 @statusColorBg @statusTextColor text-xs font-semibold rounded-full">@r.Status</span>
                                    <p class="text-sm text-slate-600 dark:text-slate-400 mt-3">@r.StartDate.ToString("dd/MM") - @r.EndDate.ToString("dd/MM")</p>
                                </div>
                            </div>
                            
                            if (i < rounds.Count - 1)
                            {
                                <!-- Connecting Line -->
                                <div class="flex-1 h-1 bg-slate-300 dark:bg-slate-700 mx-4 mt-8"></div>
                            }
                        }
                    }
                    else
                    {
                        <div class="py-4 text-center text-slate-500 flex-1">
                            Chưa có vòng review nào được thiết lập.
                        </div>
                    }
                </div>
            </div>

            <!-- Review Rounds Table -->
            <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
                <div class="flex items-center justify-between p-6 border-b border-slate-200 dark:border-slate-800">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Danh sách các Vòng Review</h2>
                    <div class="flex items-center gap-3">
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 transform -translate-y-1/2 text-slate-400" style="font-size: 20px;">search</span>
                            <input
                                type="text"
                                placeholder="Tìm kiếm vòng..."
                                class="pl-10 pr-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-[#F37021] focus:border-transparent"
                            />
                        </div>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-slate-50 dark:bg-slate-800">
                            <tr class="border-b border-slate-200 dark:border-slate-700">
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">TÊN VÒNG</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">HỌC KỲ</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">THỜI GIAN (BĐ - KT)</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">DEADLINE</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">TRẠNG THÁI</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    var rowStatusColorBg = item.Status == GPMS.Domain.Enums.RoundStatus.Ongoing ? "bg-orange-100 dark:bg-orange-900" : (item.Status == GPMS.Domain.Enums.RoundStatus.Completed ? "bg-emerald-100 dark:bg-emerald-900" : "bg-slate-100 dark:bg-slate-800");
                                    var rowStatusTextColor = item.Status == GPMS.Domain.Enums.RoundStatus.Ongoing ? "text-orange-800 dark:text-orange-200" : (item.Status == GPMS.Domain.Enums.RoundStatus.Completed ? "text-emerald-800 dark:text-emerald-200" : "text-slate-800 dark:text-slate-200");
                                
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                        <td class="py-4 px-6">
                                            <div class="flex items-center gap-3">
                                                <div class="w-8 h-8 rounded-full bg-orange-100 dark:bg-orange-900 flex items-center justify-center text-orange-600 dark:text-orange-400 font-semibold text-sm">
                                                    R@(item.RoundNumber)
                                                </div>
                                                <div>
                                                    <span class="font-semibold text-slate-900 dark:text-white block">Review @(item.RoundNumber)</span>
                                                    <span class="text-xs text-slate-500">@(item.RoundType)</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="py-4 px-6 text-slate-600 dark:text-slate-400">@item.SemesterCode</td>
                                        <td class="py-4 px-6 text-slate-600 dark:text-slate-400">@item.StartDate.ToString("dd/MM/yyyy") - @item.EndDate.ToString("dd/MM/yyyy")</td>
                                        <td class="py-4 px-6 text-slate-600 dark:text-slate-400">
                                            <span class="px-2 py-1 bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 text-xs font-semibold rounded">@item.SubmissionDeadline.ToString("dd/MM/yyyy HH:mm")</span>
                                        </td>
                                        <td class="py-4 px-6">
                                            <span class="px-3 py-1 @rowStatusColorBg @rowStatusTextColor text-xs font-semibold rounded-full">@item.Status</span>
                                        </td>
                                        <td class="py-4 px-6">
                                            <div class="flex items-center gap-2">
                                                <a href="/HOD/EditReviewRound/@item.ReviewRoundID" class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition inline-block" title="Edit">
                                                    <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                                                </a>
                                                <form asp-action="DeleteReviewRound" method="post" asp-route-id="@item.ReviewRoundID" class="inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vòng này?');">
                                                    <button type="submit" class="p-1 text-slate-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400 transition" title="Delete">
                                                        <span class="material-symbols-outlined" style="font-size: 18px;">delete</span>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="py-10 text-center text-slate-500 font-medium">Bạn chưa tạo vòng review nào trong học kỳ này</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="flex items-center justify-between p-6 border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/50">
                    <p class="text-sm text-slate-600 dark:text-slate-400">Hiển thị @(Model?.Count() ?? 0) vòng review</p>
                    <div class="flex gap-2">
                        <button class="px-3 py-1 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-slate-100 rounded hover:bg-slate-100 dark:hover:bg-slate-700 disabled:opacity-50 transition" disabled>Trước</button>
                        <button class="px-3 py-1 bg-slate-900 dark:bg-slate-700 text-white rounded font-medium">1</button>
                        <button class="px-3 py-1 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-slate-100 rounded hover:bg-slate-100 dark:hover:bg-slate-700 transition">Sau</button>
                    </div>
                </div>
            </div>
        </div>
    </div>


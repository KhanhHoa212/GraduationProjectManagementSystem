@{
    ViewData["Title"] = "Review Rounds";
    Layout = "~/Views/Shared/_HodLayout.cshtml";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950">
    <div class="p-6">
        <div class="max-w-7xl mx-auto space-y-6">
            <!-- Header -->
            <div class="flex items-start justify-between mb-8">
                <div>
                    <nav class="flex items-center gap-2 text-sm mb-4">
                        <a href="/Hod/Dashboard" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200">GPMS</a>
                        <span class="text-slate-400 dark:text-slate-600">/</span>
                        <span class="text-slate-900 dark:text-slate-100 font-medium">Vòng Review</span>
                    </nav>
                    <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Quản lý Vòng Review</h1>
                    <p class="text-slate-600 dark:text-slate-400 mt-2">Thiết lập và theo dõi các giai đoạn đánh giá đề án trong học kỳ.</p>
                </div>
                <a href="/HOD/CreateReviewRound" class="px-6 py-2 bg-[#F37021] text-white rounded-lg hover:bg-[#E55D0D] font-medium flex items-center gap-2 transition">
                    <span class="material-symbols-outlined" style="font-size: 20px;">add</span>
                    Tạo vòng review mới
                </a>
            </div>

            <!-- Review Timeline Visualization -->
            <div class="bg-white dark:bg-slate-900 rounded-xl p-8 shadow-sm border border-slate-200 dark:border-slate-800">
                <div class="flex items-center justify-between">
                    <!-- Round 1 -->
                    <div class="flex flex-col items-center flex-1">
                        <div class="w-14 h-14 rounded-full bg-[#F37021] flex items-center justify-center text-white border-4 border-white dark:border-slate-900 shadow-md">
                            <span class="material-symbols-outlined" style="font-size: 24px;">check_circle</span>
                        </div>
                        <div class="mt-4 text-center">
                            <h3 class="font-semibold text-slate-900 dark:text-white">Vòng 1: Proposal Review</h3>
                            <span class="inline-block mt-2 px-3 py-1 bg-orange-100 dark:bg-orange-900 text-orange-800 dark:text-orange-200 text-xs font-semibold rounded-full">Đang diễn ra</span>
                            <p class="text-sm text-slate-600 dark:text-slate-400 mt-3">10/01 - 25/01</p>
                        </div>
                    </div>

                    <!-- Connecting Line -->
                    <div class="flex-1 h-1 bg-slate-300 dark:bg-slate-700 mx-4 mt-8"></div>

                    <!-- Round 2 -->
                    <div class="flex flex-col items-center flex-1">
                        <div class="w-14 h-14 rounded-full bg-slate-300 dark:bg-slate-700 flex items-center justify-center text-slate-600 dark:text-slate-400 border-4 border-white dark:border-slate-900">
                            <span class="material-symbols-outlined" style="font-size: 24px;">schedule</span>
                        </div>
                        <div class="mt-4 text-center">
                            <h3 class="font-semibold text-slate-900 dark:text-white">Vòng 2: Mid-term Progress</h3>
                            <span class="inline-block mt-2 px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 text-xs font-semibold rounded-full">Dự kiến</span>
                            <p class="text-sm text-slate-600 dark:text-slate-400 mt-3">01/03 - 15/03</p>
                        </div>
                    </div>

                    <!-- Connecting Line -->
                    <div class="flex-1 h-1 bg-slate-300 dark:bg-slate-700 mx-4 mt-8"></div>

                    <!-- Round 3 -->
                    <div class="flex flex-col items-center flex-1">
                        <div class="w-14 h-14 rounded-full bg-slate-300 dark:bg-slate-700 flex items-center justify-center text-slate-600 dark:text-slate-400 border-4 border-white dark:border-slate-900">
                            <span class="material-symbols-outlined" style="font-size: 24px;">calendar_month</span>
                        </div>
                        <div class="mt-4 text-center">
                            <h3 class="font-semibold text-slate-900 dark:text-white">Vòng 3: Final Defence</h3>
                            <span class="inline-block mt-2 px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-800 dark:text-slate-200 text-xs font-semibold rounded-full">Dự kiến</span>
                            <p class="text-sm text-slate-600 dark:text-slate-400 mt-3">20/05 - 30/06</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Review Rounds Table -->
            <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
                <div class="flex items-center justify-between p-6 border-b border-slate-200 dark:border-slate-800">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Danh sách các Vòng Review</h2>
                    <div class="flex items-center gap-3">
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 transform -translate-y-1/2 text-slate-400" style="font-size: 20px;">search</span>
                            <input
                                type="text"
                                placeholder="Tìm kiếm vòng..."
                                class="pl-10 pr-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-[#F37021] focus:border-transparent"
                            />
                        </div>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-slate-50 dark:bg-slate-800">
                            <tr class="border-b border-slate-200 dark:border-slate-700">
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">TÊN VÒNG</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">HỌC KỲ</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">THỜI GIAN (BĐ - KT)</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">DEADLINE</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">TRẠNG THÁI</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                            <!-- Row 1 -->
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-orange-100 dark:bg-orange-900 flex items-center justify-center text-orange-600 dark:text-orange-400 font-semibold text-sm">
                                            R1
                                        </div>
                                        <span class="font-semibold text-slate-900 dark:text-white">Proposal Review</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">SP25</td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">10/01/2025 - 25/01/2025</td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">
                                    <span class="px-2 py-1 bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 text-xs font-semibold rounded">20/01/2025</span>
                                </td>
                                <td class="py-4 px-6">
                                    <span class="px-3 py-1 bg-orange-100 dark:bg-orange-900 text-orange-800 dark:text-orange-200 text-xs font-semibold rounded-full">Đang diễn ra</span>
                                </td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-2">
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition" title="Edit">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                                        </button>
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition" title="View">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">visibility</span>
                                        </button>
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition" title="More">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">more_vert</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>

                            <!-- Row 2 -->
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900 flex items-center justify-center text-blue-600 dark:text-blue-400 font-semibold text-sm">
                                            R2
                                        </div>
                                        <span class="font-semibold text-slate-900 dark:text-white">Mid-term Progress</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">SP25</td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">01/03/2025 - 15/03/2025</td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">
                                    <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 text-xs font-semibold rounded">10/03/2025</span>
                                </td>
                                <td class="py-4 px-6">
                                    <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 text-xs font-semibold rounded-full">Dự kiến</span>
                                </td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-2">
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition" title="Edit">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                                        </button>
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition" title="View">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">visibility</span>
                                        </button>
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition" title="More">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">more_vert</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>

                            <!-- Row 3 -->
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center text-slate-600 dark:text-slate-400 font-semibold text-sm">
                                            R3
                                        </div>
                                        <span class="font-semibold text-slate-900 dark:text-white">Final Defence</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">SP25</td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">20/05/2025 - 30/06/2025</td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">
                                    <span class="px-2 py-1 bg-slate-100 dark:bg-slate-800 text-slate-800 dark:text-slate-200 text-xs font-semibold rounded">15/05/2025</span>
                                </td>
                                <td class="py-4 px-6">
                                    <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-800 dark:text-slate-200 text-xs font-semibold rounded-full">Dự kiến</span>
                                </td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-2">
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition" title="Edit">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                                        </button>
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition" title="View">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">visibility</span>
                                        </button>
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition" title="More">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">more_vert</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="flex items-center justify-between p-6 border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/50">
                    <p class="text-sm text-slate-600 dark:text-slate-400">Hiển thị 3 trong số 3 vòng review</p>
                    <div class="flex gap-2">
                        <button class="px-3 py-1 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-slate-100 rounded hover:bg-slate-100 dark:hover:bg-slate-700 disabled:opacity-50 transition" disabled>Trước</button>
                        <button class="px-3 py-1 bg-slate-900 dark:bg-slate-700 text-white rounded font-medium">1</button>
                        <button class="px-3 py-1 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-slate-100 rounded hover:bg-slate-100 dark:hover:bg-slate-700 transition">Sau</button>
                    </div>
                </div>
            </div>
        </div>
    </div>


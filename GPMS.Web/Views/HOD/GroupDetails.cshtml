@{
    ViewBag.Title = "Group Details";
    ViewBag.CurrentPage = "Groups";
    ViewBag.BreadcrumbSection = "Chi tiết nhóm";
    Layout = "~/Views/Shared/_HODLayout.cshtml";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div>
            <nav class="flex items-center gap-2 text-sm text-slate-500 font-medium mb-4">
                <a href="/HOD/Dashboard" class="hover:text-slate-800 transition-colors no-underline">GPMS</a>
                <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                <a href="/HOD/Groups" class="hover:text-slate-800 transition-colors no-underline">Groups</a>
                <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                <span class="text-slate-800 font-bold">Groups details</span>
            </nav>
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 border border-blue-100">
                    <span class="material-symbols-outlined">group</span>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-800">Group G-042: AI Research</h1>
                    <p class="text-slate-500 text-sm mt-1 flex items-center gap-1.5 font-medium">
                        <span class="material-symbols-outlined text-[16px]">rocket_launch</span>
                        Smart Campus Navigation System
                    </p>
                </div>
            </div>
        </div>
        <div class="flex gap-3 items-end">
            <button class="bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-bold transition shadow-sm">
                Edit Info
            </button>
            <button class="bg-[#1E3A5F] hover:bg-slate-800 text-white flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-bold transition shadow-sm border border-slate-700">
                <span class="material-symbols-outlined text-[18px]">download</span>
                Export Report
            </button>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Left Column -->
        <div class="lg:col-span-2 space-y-6">
            
            <!-- Team Members -->
            <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] p-6">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-slate-400">group</span>
                        <h2 class="text-[15px] font-bold text-slate-800">Team Members</h2>
                    </div>
                    <div class="text-right">
                        <span class="text-[15px] font-bold text-slate-800 block">4</span>
                        <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Students</span>
                    </div>
                </div>
                
                <div class="space-y-4">
                    <!-- Member 1 -->
                    <div class="flex items-center justify-between py-2 border-b border-slate-100 last:border-0">
                        <div class="flex items-center gap-4">
                            <div class="w-11 h-11 rounded-full bg-slate-100 border border-slate-200 overflow-hidden shadow-sm flex items-center justify-center">
                                <span class="text-slate-500 font-bold text-sm">NA</span>
                            </div>
                            <div>
                                <p class="font-bold text-slate-800 text-sm">Nguyen Van A</p>
                                <p class="text-xs text-slate-500 font-medium mt-0.5">MSSV: 20240001</p>
                            </div>
                        </div>
                        <span class="px-2.5 py-1 bg-amber-50 text-amber-700 text-[10px] font-bold uppercase tracking-wider rounded border border-amber-100/50">Leader</span>
                    </div>
                    <!-- Member 2 -->
                    <div class="flex items-center justify-between py-2 border-b border-slate-100 last:border-0">
                        <div class="flex items-center gap-4">
                            <div class="w-11 h-11 rounded-full bg-slate-100 border border-slate-200 overflow-hidden shadow-sm flex items-center justify-center">
                                <span class="text-slate-500 font-bold text-sm">TB</span>
                            </div>
                            <div>
                                <p class="font-bold text-slate-800 text-sm">Tran Thi B</p>
                                <p class="text-xs text-slate-500 font-medium mt-0.5">MSSV: 20240002</p>
                            </div>
                        </div>
                        <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-wider rounded border border-slate-200/50">Member</span>
                    </div>
                    <!-- Member 3 -->
                    <div class="flex items-center justify-between py-2 border-b border-slate-100 last:border-0">
                        <div class="flex items-center gap-4">
                            <div class="w-11 h-11 rounded-full bg-slate-100 border border-slate-200 overflow-hidden shadow-sm flex items-center justify-center">
                                <span class="text-slate-500 font-bold text-sm">LC</span>
                            </div>
                            <div>
                                <p class="font-bold text-slate-800 text-sm">Le Van C</p>
                                <p class="text-xs text-slate-500 font-medium mt-0.5">MSSV: 20240003</p>
                            </div>
                        </div>
                        <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-wider rounded border border-slate-200/50">Member</span>
                    </div>
                </div>
            </div>

            <!-- Assigned Supervisor -->
            <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] p-6">
                <div class="flex items-center gap-2 mb-6">
                    <span class="material-symbols-outlined text-slate-400">assignment_ind</span>
                    <h2 class="text-[15px] font-bold text-slate-800">Assigned Supervisor</h2>
                </div>
                
                <div class="flex items-center gap-5 bg-slate-50 border border-slate-100 rounded-xl p-5">
                    <div class="w-16 h-16 rounded-xl bg-slate-200 flex items-center justify-center shadow-sm overflow-hidden border border-slate-300">
                        <!-- Placeholder for photo -->
                        <span class="material-symbols-outlined text-slate-400 text-3xl">person</span>
                    </div>
                    <div>
                        <p class="font-bold text-slate-800 text-lg">Dr. Pham Minh Hoang</p>
                        <p class="text-xs text-slate-500 font-medium mt-0.5">Senior Lecturer - AI & Data Science</p>
                        <div class="flex items-center gap-4 mt-3">
                            <a href="#" class="inline-flex items-center gap-1.5 text-xs font-bold text-blue-600 hover:text-blue-700 transition">
                                <span class="material-symbols-outlined text-[16px]">mail</span> Contact
                            </a>
                            <a href="#" class="inline-flex items-center gap-1.5 text-xs font-bold text-blue-600 hover:text-blue-700 transition">
                                <span class="material-symbols-outlined text-[16px]">calendar_month</span> Office Hours
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabbed Section -->
            <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] overflow-hidden">
                <!-- Navigation Tabs -->
                <div class="flex gap-8 px-6 pt-4 border-b border-slate-200 bg-slate-50/50">
                    <button class="pb-3 text-blue-600 border-b-2 border-blue-600 font-bold text-sm">Submissions</button>
                    <button class="pb-3 text-slate-500 hover:text-slate-800 font-bold text-sm transition-colors border-b-2 border-transparent">Evaluations</button>
                    <button class="pb-3 text-slate-500 hover:text-slate-800 font-bold text-sm transition-colors border-b-2 border-transparent">Feedback</button>
                    <button class="pb-3 text-slate-500 hover:text-slate-800 font-bold text-sm transition-colors border-b-2 border-transparent">Internal Notes</button>
                </div>

                <!-- Submissions Table -->
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-slate-100 bg-white">
                                <th class="py-4 px-6 text-left text-xs font-bold text-slate-500">Document Name</th>
                                <th class="py-4 px-6 text-left text-xs font-bold text-slate-500">Round</th>
                                <th class="py-4 px-6 text-left text-xs font-bold text-slate-500">Submit Date</th>
                                <th class="py-4 px-6 text-left text-xs font-bold text-slate-500">Status</th>
                                <th class="py-4 px-6 text-center text-xs font-bold text-slate-500">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-red-500">picture_as_pdf</span>
                                        <span class="text-slate-700 font-bold">Thesis_Proposal_G042_vFinal.pdf</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6 text-slate-600 font-medium text-sm">Round 1</td>
                                <td class="py-4 px-6 text-slate-500 font-medium text-sm">Oct 12, 2023</td>
                                <td class="py-4 px-6">
                                    <span class="px-2.5 py-1 bg-emerald-50 text-emerald-700 text-[10px] font-bold uppercase tracking-wider rounded border border-emerald-100">Accepted</span>
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <div class="flex justify-center gap-2">
                                        <button class="text-slate-400 hover:text-blue-600 transition" title="Download">
                                            <span class="material-symbols-outlined text-[20px]">download</span>
                                        </button>
                                        <button class="text-slate-400 hover:text-slate-800 transition" title="View">
                                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-blue-500">description</span>
                                        <span class="text-slate-700 font-bold">Midterm_Progress_Report.docx</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6 text-slate-600 font-medium text-sm">Round 2</td>
                                <td class="py-4 px-6 text-slate-500 font-medium text-sm">Jan 05, 2024</td>
                                <td class="py-4 px-6">
                                    <span class="px-2.5 py-1 text-blue-700 text-[10px] font-bold uppercase tracking-wider">Under Review</span>
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <div class="flex justify-center gap-2">
                                        <button class="text-slate-400 hover:text-blue-600 transition" title="Download">
                                            <span class="material-symbols-outlined text-[20px]">download</span>
                                        </button>
                                        <button class="text-slate-400 hover:text-slate-800 transition" title="View">
                                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Column (Sidebar) -->
        <div class="space-y-6">
            
            <!-- Review Timeline -->
            <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] p-6">
                <div class="flex items-center gap-2 mb-6">
                    <span class="material-symbols-outlined text-slate-400">trending_up</span>
                    <h2 class="text-[15px] font-bold text-slate-800">Review Timeline</h2>
                </div>
                
                <div class="relative pl-3">
                    <!-- Vertical Line -->
                    <div class="absolute left-[17px] top-2 bottom-6 w-0.5 bg-slate-200 z-0"></div>
                    
                    <!-- Round 1 -->
                    <div class="relative z-10 flex gap-4 pb-8">
                        <div class="flex-shrink-0">
                            <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 ring-4 ring-white shadow-sm mt-1 mb-1 relative ml-[1px]"></div>
                        </div>
                        <div>
                            <p class="font-bold text-slate-800 text-sm leading-none pt-1">Round 1: Proposal Review</p>
                            <p class="text-[11px] text-slate-500 font-semibold mt-1">Completed on Oct 15, 2023</p>
                            <span class="inline-block mt-1.5 text-[9px] font-extrabold text-emerald-600 uppercase tracking-widest bg-emerald-50 px-1.5 py-0.5 rounded">APPROVED</span>
                        </div>
                    </div>

                    <!-- Round 2 -->
                    <div class="relative z-10 flex gap-4 pb-8">
                        <div class="flex-shrink-0">
                            <div class="w-3.5 h-3.5 rounded-full bg-white border-2 border-blue-600 flex items-center justify-center ring-4 ring-white shadow-sm mt-0.5 relative -ml-[1px]">
                                <div class="w-1.5 h-1.5 bg-blue-600 rounded-full"></div>
                            </div>
                        </div>
                        <div>
                            <p class="font-bold text-slate-800 text-sm leading-none pt-1">Round 2: Mid-term Progress</p>
                            <p class="text-[11px] text-slate-500 font-semibold mt-1">Due: Jan 20, 2024</p>
                            <span class="inline-block mt-1.5 text-[9px] font-extrabold text-blue-600 uppercase tracking-widest bg-blue-50 px-1.5 py-0.5 rounded">IN PROGRESS</span>
                        </div>
                    </div>

                    <!-- Final Defense -->
                    <div class="relative z-10 flex gap-4">
                        <div class="flex-shrink-0">
                            <div class="w-2.5 h-2.5 rounded-full bg-slate-300 ring-4 ring-white shadow-sm mt-1 mb-1 relative ml-[1px]"></div>
                        </div>
                        <div>
                            <p class="font-bold text-slate-400 text-sm leading-none pt-1">Final Defense</p>
                            <p class="text-[11px] text-slate-400 font-semibold mt-1">Expected: June 2024</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Reviewers Panel -->
            <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] p-6">
                <div class="flex items-center gap-2 mb-6">
                    <span class="material-symbols-outlined text-slate-400">rate_review</span>
                    <h2 class="text-[15px] font-bold text-slate-800">Reviewers Panel</h2>
                </div>
                
                <div class="space-y-3 mb-5">
                    <!-- Reviewer 1 -->
                    <div class="flex items-center justify-between py-2 border-b border-slate-100 pb-3">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center text-slate-500">
                                <span class="material-symbols-outlined text-[18px]">person</span>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-slate-800">Prof. Sarah Jenkins</p>
                                <p class="text-[10px] uppercase tracking-wider font-bold text-slate-400 mt-0.5">REVIEWER 1</p>
                            </div>
                        </div>
                        <div class="w-6 h-6 rounded-full border-2 border-emerald-500 flex items-center justify-center text-emerald-500">
                            <span class="material-symbols-outlined text-[14px]">check</span>
                        </div>
                    </div>
                    
                    <!-- Reviewer 2 -->
                    <div class="flex items-center justify-between py-2 border-b border-slate-100 pb-3">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center text-slate-500">
                                <span class="material-symbols-outlined text-[18px]">person</span>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-slate-800">Dr. Robert Chen</p>
                                <p class="text-[10px] uppercase tracking-wider font-bold text-slate-400 mt-0.5">REVIEWER 2</p>
                            </div>
                        </div>
                        <div class="w-6 h-6 rounded-full border-2 border-slate-300 flex items-center justify-center text-slate-300">
                            <span class="material-symbols-outlined text-[14px]">check</span>
                        </div>
                    </div>
                </div>
                
                <button class="w-full py-2.5 bg-slate-50 border border-slate-200 text-slate-700 hover:bg-slate-100 hover:text-slate-900 rounded-lg font-bold text-xs transition-colors shadow-sm">
                    Assign New Reviewer
                </button>
            </div>
        </div>
    </div>
</div>

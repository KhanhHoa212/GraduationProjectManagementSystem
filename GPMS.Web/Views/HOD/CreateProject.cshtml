@{
    ViewData["Title"] = "Tạo đề tài mới";
    Layout = "_Layout";
}

<div class="space-y-6">
    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-800 mb-2">Tạo đề tài mới</h1>
        <p class="text-slate-500 text-sm">Vui lòng điền đầy đủ thông tin bên dưới để khởi tạo một đề tài nghiên cứu mới.</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] p-8 mb-8">
        <form method="post" action="/HOD/CreateProject">
            @Html.AntiForgeryToken()
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                <!-- Mã đề tài -->
                <div>
                    <label for="projectId" class="block text-sm font-bold text-slate-700 mb-2">
                        Mã đề tài <span class="text-red-500">*</span>
                    </label>
                    <input 
                        type="text" 
                        id="projectId" 
                        name="ProjectCode" 
                        placeholder="VD: CS2024_001" 
                        class="w-full px-4 py-3 border border-slate-200 rounded-lg text-sm text-slate-800 font-medium placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors"
                        required
                    />
                </div>

                <!-- Trạng thái -->
                <div>
                    <label for="status" class="block text-sm font-bold text-slate-700 mb-2">
                        Trạng thái
                    </label>
                    <div class="relative">
                        <select id="status" name="Status" class="w-full px-4 py-3 border border-slate-200 rounded-lg text-sm text-slate-800 font-medium bg-white focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors appearance-none cursor-pointer">
                            <option value="Draft">Bản nháp</option>
                            <option value="Active">Công khai</option>
                            <option value="Completed">Hoàn thành</option>
                        </select>
                        <span class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400 material-symbols-outlined text-sm">expand_more</span>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                <!-- Tên đề tài -->
                <div>
                    <label for="projectName" class="block text-sm font-bold text-slate-700 mb-2">
                        Tên đề tài <span class="text-red-500">*</span>
                    </label>
                    <input 
                        type="text" 
                        id="projectName" 
                        name="ProjectName" 
                        placeholder="Nhập tên đề tài nghiên cứu" 
                        class="w-full px-4 py-3 border border-slate-200 rounded-lg text-sm text-slate-800 font-medium placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors"
                        required
                    />
                </div>

                <!-- Giảng viên hướng dẫn -->
                <div>
                    <label for="supervisor" class="block text-sm font-bold text-slate-700 mb-2">
                        Giảng viên hướng dẫn
                    </label>
                    <div class="relative">
                        <select id="supervisor" name="SupervisorID" class="w-full px-4 py-3 border border-slate-200 rounded-lg text-sm text-slate-800 font-medium bg-white focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors appearance-none cursor-pointer">
                            <option value="">Chọn giảng viên hướng dẫn</option>
                            <option value="0402ae55-aed0-4ff6-8c46-99ca0bd13ed8" selected>TS. Nguyễn Văn A</option>
                            <option value="561cc6c4-b808-4e31-89dc-ea27e289ea6d">ThS. Trần Hoàng B</option>
                        </select>
                        <span class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400 material-symbols-outlined text-sm">expand_more</span>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
                <!-- Học kỳ -->
                <div>
                    <label for="semester" class="block text-sm font-bold text-slate-700 mb-2">
                        Học kỳ
                    </label>
                    <div class="relative">
                        @if (ViewBag.ActiveSemester != null)
                        {
                            <input type="hidden" name="SemesterID" value="@ViewBag.ActiveSemester.SemesterID" />
                            <input type="text" value="@ViewBag.ActiveSemester.SemesterCode (@ViewBag.ActiveSemester.AcademicYear)" readonly class="w-full px-4 py-3 border border-slate-200 rounded-lg text-sm text-slate-500 font-medium bg-slate-50 focus:outline-none cursor-not-allowed" />
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400 material-symbols-outlined text-sm">lock</span>
                        }
                        else
                        {
                            <input type="text" value="Chưa có học kỳ nào đang mở" readonly class="w-full px-4 py-3 border border-red-200 rounded-lg text-sm text-red-500 font-medium bg-red-50 focus:outline-none cursor-not-allowed" />
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-red-400 material-symbols-outlined text-sm">warning</span>
                        }
                    </div>
                </div>

                <!-- Chuyên ngành -->
                <div>
                    <label for="specialization" class="block text-sm font-bold text-slate-700 mb-2">
                        Chuyên ngành
                    </label>
                    <div class="relative">
                        <select id="specialization" name="MajorID" class="w-full px-4 py-3 border border-slate-200 rounded-lg text-sm text-slate-800 font-medium bg-white focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors appearance-none cursor-pointer">
                            <option value="1">Software Engineering (Kỹ thuật phần mềm) - SE</option>
                            <option value="2">Software Testing (Kiểm thử phần mềm) - SS</option>
                        </select>
                        <span class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400 material-symbols-outlined text-sm">expand_more</span>
                    </div>
                </div>

                <!-- Số lượng sinh viên tối đa -->
                <div>
                    <label for="maxStudents" class="block text-sm font-bold text-slate-700 mb-2">
                        Số lượng sinh viên tối đa
                    </label>
                    <input 
                        type="number" 
                        id="maxStudents" 
                        name="MaxStudents" 
                        value="2" 
                        class="w-full px-4 py-3 border border-slate-200 rounded-lg text-sm text-slate-800 font-medium placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors"
                        required
                    />
                </div>
            </div>

            <!-- Mô tả đề tài -->
            <div class="mb-8">
                 <label for="description" class="block text-sm font-bold text-slate-700 mb-2">
                        Mô tả đề tài
                 </label>
                 <textarea id="description" name="Description" rows="5" placeholder="Nhập tóm tắt nội dung nghiên cứu, mục tiêu và yêu cầu đề tài..." class="w-full px-4 py-3 border border-slate-200 rounded-lg text-sm text-slate-800 font-medium placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors resize-none"></textarea>
            </div>

            <!-- Buttons -->
            <div class="flex items-center justify-end gap-3 pt-6 border-t border-slate-100">
                <a href="/HOD/Projects" class="px-6 py-2.5 bg-slate-50 hover:bg-slate-100 text-slate-600 font-bold rounded-lg transition-colors border border-slate-200 text-sm no-underline text-center">
                    Hủy
                </a>
                <button type="submit" class="px-6 py-2.5 bg-[#1E3A5F] hover:bg-slate-800 text-white font-bold rounded-lg transition-colors shadow-sm flex items-center gap-2 text-sm">
                    <span class="material-symbols-outlined text-[18px]">save</span>
                    Lưu đề tài
                </button>
            </div>
        </form>
    </div>

    <!-- Info Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Info Card 1 -->
        <div class="bg-slate-50 border border-slate-200 rounded-xl p-5 flex gap-4 items-start">
            <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center shrink-0 border border-white shadow-sm text-blue-600">
                <span class="material-symbols-outlined text-[16px]">info</span>
            </div>
            <div>
                <h4 class="text-sm font-bold text-slate-800 mb-1">Quy định mã đề tài</h4>
                <p class="text-xs text-slate-500 leading-relaxed font-medium">Mã đề tài cần tuân theo định dạng [Mã Khoa][Năm]_[Số thứ tự].</p>
            </div>
        </div>

        <!-- Info Card 2 -->
        <div class="bg-slate-50 border border-slate-200 rounded-xl p-5 flex gap-4 items-start">
            <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center shrink-0 border border-white shadow-sm text-slate-600">
                <span class="material-symbols-outlined text-[16px]">help</span>
            </div>
            <div>
                <h4 class="text-sm font-bold text-slate-800 mb-1">Hỗ trợ</h4>
                <p class="text-xs text-slate-500 leading-relaxed font-medium">Gặp khó khăn? Liên hệ phòng Quản lý Khoa học để được hỗ trợ.</p>
            </div>
        </div>

        <!-- Info Card 3 -->
        <div class="bg-slate-50 border border-slate-200 rounded-xl p-5 flex gap-4 items-start">
            <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center shrink-0 border border-white shadow-sm text-slate-600">
                <span class="material-symbols-outlined text-[16px]">visibility</span>
            </div>
            <div>
                <h4 class="text-sm font-bold text-slate-800 mb-1">Hiển thị</h4>
                <p class="text-xs text-slate-500 leading-relaxed font-medium">Đề tài sẽ được sinh viên nhìn thấy sau khi Trưởng bộ môn duyệt.</p>
            </div>
        </div>
    </div>
</div>

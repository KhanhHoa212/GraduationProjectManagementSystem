@{
    ViewData["Title"] = "Dashboard";
    Layout = "_HODLayout";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-slate-900">Department Overview</h1>
        <div class="flex gap-2">
            <button class="px-4 py-2 bg-white border border-slate-200 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 shadow-sm transition-all">Export Report</button>
            <a asp-action="Projects" class="px-4 py-2 bg-[#F37021] text-white rounded-lg text-sm font-semibold hover:bg-orange-600 shadow-lg shadow-orange-500/20 no-underline transition-all ring-offset-2 focus:ring-2 focus:ring-orange-500">New Project</a>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <span class="p-2 bg-blue-50 text-blue-600 rounded-lg"><span class="material-symbols-outlined">folder</span></span>
                <span class="text-green-500 text-xs font-bold">+12%</span>
            </div>
            <p class="text-sm font-medium text-slate-500">Total Projects</p>
            <h3 class="text-2xl font-bold text-slate-900 mt-1">48</h3>
        </div>

        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <span class="p-2 bg-orange-50 text-[#F37021] rounded-lg"><span class="material-symbols-outlined">groups</span></span>
            </div>
            <p class="text-sm font-medium text-slate-500">Total Groups</p>
            <h3 class="text-2xl font-bold text-slate-900 mt-1">42</h3>
        </div>

        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <span class="p-2 bg-red-50 text-red-600 rounded-lg"><span class="material-symbols-outlined">person_off</span></span>
                <span class="bg-red-100 text-red-600 text-[10px] font-bold px-2 py-0.5 rounded-full">REQUIRED</span>
            </div>
            <p class="text-sm font-medium text-slate-500">Missing Supervisor</p>
            <h3 class="text-2xl font-bold text-slate-900 mt-1">14</h3>
        </div>

        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <span class="p-2 bg-emerald-50 text-emerald-600 rounded-lg"><span class="material-symbols-outlined">check_circle</span></span>
            </div>
            <p class="text-sm font-medium text-slate-500">Approved Projects</p>
            <h3 class="text-2xl font-bold text-slate-900 mt-1">31</h3>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Project Progress -->
        <div class="lg:col-span-2 bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="p-5 border-b border-slate-100 flex items-center justify-between">
                <h2 class="font-bold text-slate-800">Project Status</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-slate-50 text-slate-500 font-semibold text-xs border-b border-slate-100">
                        <tr>
                            <th class="px-6 py-4">ID</th>
                            <th class="px-6 py-4">Project Name</th>
                            <th class="px-6 py-4">Status</th>
                            <th class="px-6 py-4 text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <tr class="hover:bg-slate-50/50">
                            <td class="px-6 py-4 text-sm font-medium text-slate-400">#GP001</td>
                            <td class="px-6 py-4 text-sm font-bold text-slate-700">Smart Campus IoT System</td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 rounded-full text-[11px] font-bold bg-green-50 text-green-700 border border-green-100">Approved</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a asp-action="ProjectDetails" class="text-[#F37021] font-bold text-xs hover:underline no-underline">View</a>
                            </td>
                        </tr>
                        <tr class="hover:bg-slate-50/50">
                            <td class="px-6 py-4 text-sm font-medium text-slate-400">#GP002</td>
                            <td class="px-6 py-4 text-sm font-bold text-slate-700">E-Learning Gamification</td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 rounded-full text-[11px] font-bold bg-slate-100 text-slate-600 border border-slate-200">Draft</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a asp-action="ProjectDetails" class="text-[#F37021] font-bold text-xs hover:underline no-underline">View</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Activity Feed -->
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
            <h2 class="font-bold text-slate-800 mb-6">Recent Activities</h2>
            <div class="space-y-6">
                <div class="flex gap-4 relative">
                    <div class="absolute left-1.5 top-6 bottom-[-24px] w-px bg-slate-100"></div>
                    <div class="w-3 h-3 rounded-full bg-orange-500 mt-1 shrink-0"></div>
                    <div>
                        <p class="text-sm font-semibold text-slate-700">Supervisor assigned to Group G01</p>
                        <p class="text-xs text-slate-400 mt-1">10 minutes ago</p>
                    </div>
                </div>
                <div class="flex gap-4 relative">
                    <div class="w-3 h-3 rounded-full bg-green-500 mt-1 shrink-0"></div>
                    <div>
                        <p class="text-sm font-semibold text-slate-700">GP-SE-001 Approved by HOD</p>
                        <p class="text-xs text-slate-400 mt-1">1 hour ago</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@model IEnumerable<GPMS.Application.DTOs.ProjectDto>
@using GPMS.Domain.Enums
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_HODLayout";
    var activeSemester = ViewBag.ActiveSemester as GPMS.Application.DTOs.SemesterDto;
    int totalProjects = ViewBag.TotalProjects ?? 0;
    int withGroup = ViewBag.WithGroup ?? 0;
    int missingSupervisor = ViewBag.MissingSupervisor ?? 0;
    int missingMembers = ViewBag.MissingMembers ?? 0;
    int groupPercent = totalProjects > 0 ? (int)((double)withGroup / totalProjects * 100) : 0;
}

<div class="space-y-6">

    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight">Department Overview</h1>
            <p class="text-sm text-slate-500 mt-0.5">
                @(activeSemester != null ? $"{activeSemester.SemesterCode} · {activeSemester.AcademicYear}" : "No active semester")
                &middot; Faculty of Software Engineering
            </p>
        </div>
        <div class="flex gap-2">
            <button class="flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 shadow-sm transition-all">
                <span class="material-symbols-outlined text-[18px]">download</span>
                Export Report
            </button>
        </div>
    </div>

    <!-- KPI CARDS -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-5">

        <!-- Total Projects -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 flex flex-col gap-3 hover:shadow-md transition-shadow">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Total Projects</p>
                    <h3 class="text-3xl font-extrabold text-slate-900 mt-1">@totalProjects</h3>
                </div>
                <span class="size-10 rounded-xl bg-blue-50 flex items-center justify-center">
                    <span class="material-symbols-outlined text-blue-500 text-[20px]">folder_open</span>
                </span>
            </div>
            <div class="w-full bg-slate-100 rounded-full h-1.5">
                <div class="bg-blue-500 h-1.5 rounded-full" style="width: @groupPercent%"></div>
            </div>
            <p class="text-[11px] text-slate-400">@withGroup with assigned group</p>
        </div>

        <!-- Missing Supervisor -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 flex flex-col gap-3 hover:shadow-md transition-shadow">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Missing Supervisor</p>
                    <h3 class="text-3xl font-extrabold text-slate-900 mt-1">@missingSupervisor</h3>
                </div>
                @if (missingSupervisor > 0)
                {
                    <span class="px-2 py-1 bg-red-50 text-red-600 text-[10px] font-bold uppercase rounded-lg border border-red-100">
                        Action Required
                    </span>
                }
                else
                {
                    <span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-[10px] font-bold uppercase rounded-lg border border-emerald-100">
                        All Assigned
                    </span>
                }
            </div>
            <div class="w-full bg-slate-100 rounded-full h-1.5">
                @{ int supervisorPercent = totalProjects > 0 ? (int)((double)(totalProjects - missingSupervisor) / totalProjects * 100) : 100; }
                <div class="bg-orange-500 h-1.5 rounded-full" style="width: @supervisorPercent%"></div>
            </div>
            <p class="text-[11px] text-slate-400">@(totalProjects - missingSupervisor) / @totalProjects supervised</p>
        </div>

        <!-- Missing Members -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 flex flex-col gap-3 hover:shadow-md transition-shadow">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Groups w/o Members</p>
                    <h3 class="text-3xl font-extrabold text-slate-900 mt-1">@missingMembers</h3>
                </div>
                @if (missingMembers > 0)
                {
                    <span class="px-2 py-1 bg-amber-50 text-amber-600 text-[10px] font-bold uppercase rounded-lg border border-amber-100">
                        Critical
                    </span>
                }
            </div>
            <div class="w-full bg-slate-100 rounded-full h-1.5">
                <div class="bg-amber-500 h-1.5 rounded-full" style="width: @(missingMembers > 0 ? 40 : 0)%"></div>
            </div>
            <p class="text-[11px] text-slate-400">Groups registered but empty</p>
        </div>

        <!-- With Groups -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 flex flex-col gap-3 hover:shadow-md transition-shadow">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Projects w/ Group</p>
                    <h3 class="text-3xl font-extrabold text-slate-900 mt-1">@withGroup</h3>
                </div>
                <span class="size-10 rounded-xl bg-emerald-50 flex items-center justify-center">
                    <span class="material-symbols-outlined text-emerald-500 text-[20px]">groups</span>
                </span>
            </div>
            <div class="w-full bg-slate-100 rounded-full h-1.5">
                <div class="bg-emerald-500 h-1.5 rounded-full" style="width: @groupPercent%"></div>
            </div>
            <p class="text-[11px] text-slate-400">@groupPercent% of total projects</p>
        </div>

    </div>

    <!-- BOTTOM: Project Status Table + Activity -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

        <!-- Project Status Table (2/3) -->
        <div class="xl:col-span-2 bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
                <h2 class="text-sm font-bold text-slate-800">Project Status Distribution</h2>
                <a asp-action="Projects" class="text-xs font-semibold text-primary hover:underline no-underline">View All →</a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-slate-50 border-b border-slate-100">
                            <th class="px-6 py-3 text-[11px] font-bold text-slate-500 uppercase tracking-wider">Project</th>
                            <th class="px-6 py-3 text-[11px] font-bold text-slate-500 uppercase tracking-wider">Supervisor</th>
                            <th class="px-6 py-3 text-[11px] font-bold text-slate-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-[11px] font-bold text-slate-500 uppercase tracking-wider text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var project in Model)
                            {
                                var statusColor = project.Status switch
                                {
                                    ProjectStatus.Active => "bg-blue-50 text-blue-600",
                                    ProjectStatus.Completed => "bg-emerald-50 text-emerald-700",
                                    ProjectStatus.Cancelled => "bg-red-50 text-red-600",
                                    _ => "bg-slate-100 text-slate-500"
                                };
                                var dotColor = project.Status switch
                                {
                                    ProjectStatus.Active => "bg-blue-500",
                                    ProjectStatus.Completed => "bg-emerald-500",
                                    ProjectStatus.Cancelled => "bg-red-500",
                                    _ => "bg-slate-400"
                                };
                                <tr class="hover:bg-slate-50/60 transition-colors">
                                    <td class="px-6 py-3.5">
                                        <p class="text-sm font-semibold text-slate-800">@project.ProjectName</p>
                                        <p class="text-[11px] text-slate-400">@project.ProjectCode</p>
                                    </td>
                                    <td class="px-6 py-3.5 text-sm text-slate-600">
                                        @(project.SupervisorName ?? "—")
                                    </td>
                                    <td class="px-6 py-3.5">
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-bold @statusColor">
                                            <span class="size-1.5 rounded-full @dotColor"></span>
                                            @project.Status
                                        </span>
                                    </td>
                                    <td class="px-6 py-3.5 text-right">
                                        <a asp-action="ProjectDetails" asp-route-id="@project.ProjectID"
                                           class="text-xs font-semibold text-primary hover:underline no-underline">View →</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="px-6 py-10 text-center text-sm text-slate-400">No projects found for this semester.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Recent Projects (1/3) -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-sm font-bold text-slate-800">Recent Activities</h2>
                <span class="material-symbols-outlined text-slate-400 text-[18px]">schedule</span>
            </div>
            <div class="space-y-4">
                @if (Model != null && Model.Any())
                {
                    @foreach (var project in Model.Take(5))
                    {
                        var dotColor = project.Status switch
                        {
                            ProjectStatus.Active => "bg-blue-500",
                            ProjectStatus.Completed => "bg-emerald-500",
                            ProjectStatus.Cancelled => "bg-red-500",
                            _ => "bg-slate-300"
                        };
                        <div class="flex gap-3">
                            <div class="flex flex-col items-center">
                                <div class="size-2 rounded-full @dotColor mt-1.5 flex-shrink-0"></div>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-xs font-semibold text-slate-800 truncate">@project.ProjectName</p>
                                <p class="text-[11px] text-slate-400 mt-0.5">
                                    Created @project.CreatedAt.ToString("MMM dd, yyyy")
                                </p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-slate-400 text-center py-4">No recent activity.</p>
                }
            </div>
            <a asp-action="Projects" class="mt-6 block text-center text-xs font-bold text-primary hover:underline no-underline">
                See all projects →
            </a>
        </div>

    </div>
</div>

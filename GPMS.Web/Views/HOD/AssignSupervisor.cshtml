@using GPMS.Application.DTOs
@using GPMS.Web.ViewModels
@model SupervisorAssignmentViewModel
@{
    ViewBag.Title = "Supervisor Assignment";
    ViewBag.CurrentPage = "AssignSupervisor";
    ViewBag.BreadcrumbSection = "Phân công Giảng viên";
    Layout = "_Layout";
    var activeSemester = ViewBag.ActiveSemester as GPMS.Application.DTOs.SemesterDto;
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div>
            <nav class="flex items-center gap-2 text-sm text-slate-500 font-medium mb-4">
                <a href="/HOD/Dashboard" class="hover:text-slate-800 transition-colors no-underline">GPMS</a>
                <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                <span class="text-slate-800 font-bold">Phân công Giảng viên</span>
            </nav>
            <h1 class="text-2xl font-bold text-slate-800">Phân công Giảng viên Hướng dẫn</h1>
            <p class="text-slate-500 text-sm mt-1 font-medium">
                Kết nối nhóm sinh viên với giảng viên hướng dẫn phù hợp.
                @if (activeSemester != null)
                {
                    <span class="text-[#F37021] font-bold">(@activeSemester.SemesterCode)</span>
                }
            </p>
        </div>
    </div>

    <!-- Main 2-Column Grid for Assignment -->
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
        
        <!-- Unassigned Groups Column -->
        <div class="flex flex-col h-full">
            <div class="flex items-center gap-2 mb-6">
                <div class="flex gap-0.5">
                    <span class="w-2 h-2 rounded-full bg-orange-500"></span>
                    <span class="w-2 h-2 rounded-full bg-orange-500"></span>
                    <span class="w-2 h-2 rounded-full bg-orange-500"></span>
                </div>
                <h2 class="text-[15px] font-bold text-slate-800">Nhóm chưa phân công (@Model.UnassignedProjects.Count)</h2>
            </div>

            <!-- Project Filters -->
            <div class="flex flex-col sm:flex-row gap-3 mb-6">
                <div class="relative flex-grow">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                    <input type="text" id="projectSearch" placeholder="Tìm tên hoặc mã nhóm..." 
                           class="w-full pl-10 pr-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:border-[#F37021] focus:ring-1 focus:ring-[#F37021] outline-none transition-all"
                           onkeyup="filterProjects()">
                </div>
                <div class="sm:w-48">
                    <select id="majorFilter" class="w-full px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:border-[#F37021] outline-none transition-all" onchange="filterProjects()">
                        <option value="">Tất cả chuyên ngành</option>
                        @foreach (var major in Model.UnassignedProjects.Select(p => p.MajorName).Distinct().OrderBy(m => m))
                        {
                            <option value="@major">@major</option>
                        }
                    </select>
                </div>
            </div>
            
            <div id="unassignedProjectsContainer" class="space-y-4 max-h-[500px] overflow-y-auto pr-2 custom-main-scroll">
                @if (Model.UnassignedProjects.Any())
                {
                    foreach (var project in Model.UnassignedProjects)
                    {
                        <div class="project-card p-6 bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.02)] min-h-[140px] hover:border-[#F37021] hover:shadow-md transition-all cursor-pointer group" 
                             data-name="@project.ProjectName.ToLower()" 
                             data-code="@project.ProjectCode.ToLower()" 
                             data-major="@project.MajorName"
                             onclick="openLecturerModal('@project.ProjectID', '@project.ProjectCode', '@project.MajorName')">
                            <div class="flex items-center justify-between mb-2">
                                <span class="font-bold text-slate-500 text-xs tracking-wider">@project.ProjectCode</span>
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">@project.MajorName</span>
                            </div>
                            <p class="font-bold text-slate-800 text-lg mb-2 group-hover:text-[#F37021] transition-colors">@project.ProjectName</p>
                            <p class="text-sm font-medium text-slate-500 mb-4">
                                <span class="material-symbols-outlined text-sm align-middle">groups</span>
                                Nhóm: @project.StudentName
                            </p>
                            <div class="flex items-center gap-2">
                                <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-wider rounded border border-slate-200/50">Mới</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="p-12 text-center bg-slate-50 rounded-2xl border-2 border-dashed border-slate-200">
                        <span class="material-symbols-outlined text-4xl text-slate-300 mb-2">check_circle</span>
                        <p class="text-slate-500 font-medium">Tất cả các nhóm đã được phân công!</p>
                    </div>
                }
            </div>
        </div>

        <!-- Available Lecturers Column -->
        <div class="flex flex-col h-full">
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-[#1E3A5F]">person_search</span>
                    <h2 class="text-[15px] font-bold text-slate-800">Giảng viên khả dụng</h2>
                </div>
            </div>

            <!-- Lecturer Filters -->
            <div class="flex flex-col sm:flex-row gap-3 mb-6">
                <div class="relative flex-grow">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                    <input type="text" id="lecturerSearch" placeholder="Tìm tên giảng viên..." 
                           class="w-full pl-10 pr-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:border-[#1E3A5F] focus:ring-1 focus:ring-[#1E3A5F] outline-none transition-all"
                           onkeyup="filterLecturers()">
                </div>
                <div class="sm:w-48">
                    <select id="specialtyFilter" class="w-full px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:border-[#1E3A5F] outline-none transition-all" onchange="filterLecturers()">
                        <option value="">Tất cả chuyên môn</option>
                        @foreach (var specialty in Model.Lecturers.Select(l => l.Specialty).Where(s => !string.IsNullOrEmpty(s)).Distinct().OrderBy(s => s))
                        {
                            <option value="@specialty">@specialty</option>
                        }
                    </select>
                </div>
            </div>
            
            <div id="lecturersContainer" class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-h-[500px] overflow-y-auto pr-2 custom-main-scroll">
                @foreach (var lecturer in Model.Lecturers)
                {
                    var isFull = lecturer.CurrentWorkload >= lecturer.MaxWorkload;
                    var workloadPercent = (lecturer.CurrentWorkload * 100) / lecturer.MaxWorkload;
                    var workloadColor = lecturer.CurrentWorkload >= lecturer.MaxWorkload ? "bg-red-500" : (lecturer.CurrentWorkload >= 4 ? "bg-amber-500" : "bg-[#1E3A5F]");
                    var textColor = lecturer.CurrentWorkload >= lecturer.MaxWorkload ? "text-red-500" : (lecturer.CurrentWorkload >= 4 ? "text-amber-500" : "text-emerald-600");
                    var initials = string.Concat(lecturer.FullName.Split(' ').Select(s => s[0]));

                    <div class="lecturer-card bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.02)] p-5 flex flex-col hover:shadow-md transition-shadow @(isFull ? "opacity-75" : "")"
                         data-name="@lecturer.FullName.ToLower()"
                         data-specialty="@lecturer.Specialty">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center flex-shrink-0 border border-slate-200 overflow-hidden shadow-sm">
                                <span class="text-slate-500 font-bold text-sm">@initials</span>
                            </div>
                            <div>
                                <p class="font-bold text-slate-800 text-sm leading-tight">@lecturer.FullName</p>
                                <p class="text-[11px] font-bold text-slate-500 uppercase tracking-widest mt-1">@lecturer.Level</p>
                                <p class="text-[10px] text-slate-400 mt-0.5 leading-snug">Chuyên môn: @lecturer.Specialty</p>
                            </div>
                        </div>
                        
                        <div class="mb-5 mt-auto">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-[10px] font-extrabold uppercase tracking-wider text-slate-500">TẢI CÔNG VIỆC</span>
                                <span class="text-[10px] font-bold @textColor">@lecturer.CurrentWorkload / @lecturer.MaxWorkload NHÓM</span>
                            </div>
                            <div class="w-full bg-slate-100 rounded-full h-1.5 overflow-hidden">
                                <div class="@workloadColor h-full rounded-full transition-all duration-500" style="width: @workloadPercent%"></div>
                            </div>
                        </div>
                        
                        @if (isFull)
                        {
                            <button disabled class="w-full py-2.5 border border-slate-200 bg-slate-100 text-slate-400 rounded-lg font-bold text-xs cursor-not-allowed">
                                Đã đầy tải
                            </button>
                        }
                        else
                        {
                            <button class="w-full py-2.5 bg-[#1E3A5F] hover:bg-slate-800 text-white rounded-lg font-bold text-xs transition-colors shadow-sm" onclick="openProjectModal('@lecturer.LecturerID', '@lecturer.FullName')">
                                Phân công nhóm
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Assignment Summary Section -->
    <div id="assignment-summary-container" 
         hx-target="#assignment-summary-container" 
         hx-select="#assignment-summary-container" 
         hx-swap="innerHTML show:no-scroll"
         hx-push-url="true">
        <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] overflow-hidden mt-6">
        <div class="p-6 border-b border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white">
            <h2 class="text-lg font-bold text-slate-800">Bảng tổng hợp phân công</h2>
            <div class="px-3 py-1 bg-emerald-50 border border-emerald-100 text-emerald-700 rounded-full shadow-sm">
                <span class="text-xs font-bold uppercase tracking-wider">@Model.AssignedProjects.TotalItems Nhóm đã phân công</span>
            </div>
        </div>

        <!-- Summary Table Filters -->
        <div class="p-4 bg-slate-50/50 border-b border-slate-100">
            <form method="get" action="/HOD/AssignSupervisor" 
                  hx-get="/HOD/AssignSupervisor" 
                  hx-trigger="submit, change from:#summaryLecturerFilter"
                  class="flex flex-col sm:flex-row gap-4">
                
                <input type="hidden" name="semesterId" value="@Model.SelectedSemesterId" />
                
                <div class="relative flex-grow">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                    <input type="text" name="search" value="@Model.CurrentSearch" placeholder="Tìm theo tên đề tài, mã nhóm hoặc giảng viên..." 
                           hx-trigger="keyup changed delay:500ms"
                           class="w-full pl-10 pr-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none transition-all">
                </div>
                <div class="sm:w-64">
                    <select id="summaryLecturerFilter" name="lecturerFilter" class="w-full px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:border-emerald-500 outline-none transition-all">
                        <option value="">Tất cả giảng viên hướng dẫn</option>
                        @foreach (var lecturerName in Model.Lecturers.Select(l => l.FullName).OrderBy(s => s))
                        {
                            <option value="@lecturerName" selected="@(Model.CurrentLecturerFilter == lecturerName ? "selected" : null)">@lecturerName</option>
                        }
                    </select>
                </div>
            </form>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100">
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">MÃ NHÓM</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider w-1/4">TÊN ĐỀ TÀI</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">CHUYÊN NGÀNH</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">GIẢNG VIÊN HƯỚNG DẪN</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">TRẠNG THÁI</th>
                        <th class="py-4 px-6 text-center text-xs font-bold text-slate-500 uppercase tracking-wider">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model.AssignedProjects.Any())
                    {
                        foreach (var project in Model.AssignedProjects)
                        {
                            var initials = string.Concat(project.SupervisorName?.Split(' ').Select(s => s[0]) ?? new[] { '?' });
                            <tr class="summary-row hover:bg-slate-50/50 transition-colors"
                                data-name="@project.ProjectName.ToLower()"
                                data-code="@project.ProjectCode.ToLower()"
                                data-supervisor="@project.SupervisorName">
                                <td class="py-5 px-6 font-bold text-slate-800">@project.ProjectCode</td>
                                <td class="py-5 px-6 font-semibold text-slate-700 leading-snug">@project.ProjectName</td>
                                <td class="py-5 px-6 text-slate-500 font-medium">@project.MajorName</td>
                                <td class="py-5 px-6">
                                    <div class="flex items-center gap-2">
                                        <div class="w-7 h-7 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 font-bold text-[10px]">@initials</div>
                                        <span class="font-bold text-slate-700">@project.SupervisorName</span>
                                    </div>
                                </td>
                                <td class="py-5 px-6">
                                    <span class="px-2.5 py-1 bg-blue-50 text-blue-700 text-[10px] font-bold uppercase tracking-wider rounded border border-blue-100">Đã xác nhận</span>
                                </td>
                                <td class="py-5 px-6 text-center">
                                    <button class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-slate-500 hover:text-[#F37021] hover:bg-orange-50 rounded-lg transition" title="Thay đổi" 
                                            onclick="openLecturerModal('@project.ProjectID', '@project.ProjectCode', '@project.MajorName')">
                                        <span class="material-symbols-outlined text-[16px]">swap_horiz</span>
                                        Đổi GV
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="py-12 text-center text-slate-400 italic">Chưa có nhóm nào được phân công giảng viên.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @await Html.PartialAsync("_Pagination", Model.AssignedProjects)
    </div>

    <!-- Supervisor Assignment Modals (Moved inside container for HTMX syncing) -->
    <!-- Lecturer Selection Modal -->
    <div id="lecturerModal" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-2xl bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-200">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                <div>
                    <h3 class="text-xl font-bold text-slate-800">Chọn giảng viên hướng dẫn</h3>
                    <p class="text-xs text-slate-500 font-medium mt-1">Phân công cho nhóm: <span id="modalProjectCode" class="text-[#F37021] font-bold"></span></p>
                </div>
                <button onclick="closeLecturerModal()" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-white hover:shadow-md text-slate-400 hover:text-slate-600 transition-all">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            <div class="p-6">
                <!-- Search & Filter for Modal -->
                <div class="flex flex-col sm:flex-row gap-4 mb-6">
                    <div class="relative flex-grow">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                        <input type="text" id="modalLecturerSearch" placeholder="Tìm giảng viên..." 
                               class="w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:border-[#F37021] focus:ring-1 focus:ring-[#F37021] outline-none transition-all"
                               onkeyup="filterModalLecturers()">
                    </div>
                    <div class="flex items-center gap-2 px-3 py-2 bg-blue-50/50 rounded-xl border border-blue-100">
                        <input type="checkbox" id="smartMatchToggle" class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500" onchange="filterModalLecturers()">
                        <label for="smartMatchToggle" class="text-xs font-bold text-blue-700 cursor-pointer whitespace-nowrap">Khớp chuyên ngành</label>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-h-[400px] overflow-y-auto pr-2 custom-main-scroll">
                    @foreach (var lecturer in Model.Lecturers)
                    {
                        <div class="modal-lecturer-item p-4 border border-slate-100 rounded-2xl hover:border-[#F37021] hover:bg-orange-50/30 transition-all cursor-pointer group"
                             data-name="@lecturer.FullName.ToLower()"
                             data-specialty="@lecturer.Specialty.ToLower()"
                             onclick="assignLecturerToProject('@lecturer.LecturerID')">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 font-bold group-hover:bg-white group-hover:shadow-sm">
                                    @string.Concat(lecturer.FullName.Split(' ').Select(s => s[0]))
                                </div>
                                <div class="flex-grow min-w-0">
                                    <p class="font-bold text-slate-800 text-sm truncate group-hover:text-[#F37021]">@lecturer.FullName</p>
                                    <div class="flex items-center gap-2 mt-0.5">
                                        <span class="text-[10px] text-slate-500 font-medium">@lecturer.Specialty</span>
                                        <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                                        <span class="text-[10px] text-emerald-600 font-bold">@lecturer.CurrentWorkload/@lecturer.MaxWorkload Nhóm</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            
            <div class="px-8 py-5 border-t border-slate-100 bg-slate-50 flex justify-end">
                <button onclick="closeLecturerModal()" class="px-6 py-2.5 text-xs font-bold text-slate-600 hover:text-slate-800 transition-colors">Hủy</button>
            </div>
        </div>
    </div>

    <!-- Project Selection Modal (When starting from Lecturer) -->
    <div id="projectModal" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-2xl bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-200">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                <div>
                    <h3 class="text-xl font-bold text-slate-800">Chọn nhóm nhận hướng dẫn</h3>
                    <p class="text-xs text-slate-500 font-medium mt-1">Giảng viên: <span id="modalLecturerName" class="text-[#F37021] font-bold"></span></p>
                </div>
                <button onclick="closeProjectModal()" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-white hover:shadow-md text-slate-400 hover:text-slate-600 transition-all">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            <div class="p-6">
                <!-- Search for Projects -->
                <div class="relative mb-6">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                    <input type="text" id="modalProjectSearch" placeholder="Tìm mã nhóm hoặc tên đề tài..." 
                           class="w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:border-[#F37021] focus:ring-1 focus:ring-[#F37021] outline-none transition-all"
                           onkeyup="filterModalProjects()">
                </div>

                <div class="space-y-3 max-h-[400px] overflow-y-auto pr-2 custom-main-scroll">
                    @if (Model.UnassignedProjects.Any())
                    {
                        foreach (var project in Model.UnassignedProjects)
                        {
                            <div class="modal-project-item p-4 border border-slate-100 rounded-2xl hover:border-[#F37021] hover:bg-orange-50/30 transition-all cursor-pointer group"
                                 data-name="@project.ProjectName.ToLower()"
                                 data-code="@project.ProjectCode.ToLower()"
                                 onclick="assignLecturerToProjectForProject('@project.ProjectID')">
                                <div class="flex items-center justify-between gap-4">
                                    <div class="flex-grow min-w-0">
                                        <p class="text-[10px] font-bold text-slate-400 mb-1">@project.ProjectCode</p>
                                        <p class="font-bold text-slate-800 text-sm truncate group-hover:text-[#F37021]">@project.ProjectName</p>
                                        <p class="text-[10px] text-slate-500 mt-1">@project.StudentName</p>
                                    </div>
                                    <div class="shrink-0 flex items-center gap-2">
                                        <span class="px-2 py-0.5 bg-slate-100 text-slate-500 text-[10px] font-bold rounded">@project.MajorName</span>
                                        <span class="material-symbols-outlined text-slate-300 group-hover:text-[#F37021] transition-colors">add_circle</span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-center py-8 text-slate-400 italic">Không có nhóm nào chưa phân công.</p>
                    }
                </div>
            </div>
            <div class="px-8 py-5 border-t border-slate-100 bg-slate-50 flex justify-end">
                <button onclick="closeProjectModal()" class="px-6 py-2.5 text-xs font-bold text-slate-600 hover:text-slate-800 transition-colors">Hủy</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let selectedProjectId = null;
        let selectedLecturerId = null;

        function closeLecturerModal() {
            document.getElementById('lecturerModal').classList.add('hidden');
            selectedProjectId = null;
        }

        function openProjectModal(lecturerId, lecturerName) {
            selectedLecturerId = lecturerId;
            document.getElementById('modalLecturerName').innerText = lecturerName;
            document.getElementById('modalProjectSearch').value = '';
            filterModalProjects();
            document.getElementById('projectModal').classList.remove('hidden');
        }

        function closeProjectModal() {
            document.getElementById('projectModal').classList.add('hidden');
            selectedLecturerId = null;
        }

        function assignLecturerToProject(lecturerId) {
            submitAssignment(selectedProjectId, lecturerId);
        }

        function assignLecturerToProjectForProject(projectId) {
            submitAssignment(projectId, selectedLecturerId);
        }

        async function submitAssignment(projectId, lecturerId) {
            try {
                const response = await fetch('/HOD/ReassignSupervisor', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        ProjectID: parseInt(projectId),
                        LecturerID: lecturerId
                    })
                });

                const result = await response.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert(result.message || 'Có lỗi xảy ra khi phân công.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Có lỗi xảy ra kết nối với hệ thống.');
            }
        }

        // --- Search and Filtering Logic ---

        function filterProjects() {
            const searchText = document.getElementById('projectSearch').value.toLowerCase();
            const majorFilter = document.getElementById('majorFilter').value;
            const projectCards = document.querySelectorAll('.project-card');

            projectCards.forEach(card => {
                const name = card.getAttribute('data-name');
                const code = card.getAttribute('data-code');
                const major = card.getAttribute('data-major');

                const matchesSearch = name.includes(searchText) || code.includes(searchText);
                const matchesMajor = majorFilter === "" || major === majorFilter;

                if (matchesSearch && matchesMajor) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });
        }

        function filterLecturers() {
            const searchText = document.getElementById('lecturerSearch').value.toLowerCase();
            const specialtyFilter = document.getElementById('specialtyFilter').value;
            const lecturerCards = document.querySelectorAll('.lecturer-card');

            lecturerCards.forEach(card => {
                const name = card.getAttribute('data-name');
                const specialty = card.getAttribute('data-specialty');

                const matchesSearch = name.includes(searchText);
                const matchesSpecialty = specialtyFilter === "" || specialty === specialtyFilter;

                if (matchesSearch && matchesSpecialty) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });
        }

        let currentProjectMajor = null;
        function openLecturerModal(projectId, projectCode, majorName) {
            selectedProjectId = projectId;
            currentProjectMajor = majorName;
            document.getElementById('modalProjectCode').innerText = projectCode;
            document.getElementById('modalLecturerSearch').value = '';
            document.getElementById('smartMatchToggle').checked = false;
            filterModalLecturers();
            document.getElementById('lecturerModal').classList.remove('hidden');
        }

        function filterModalLecturers() {
            const searchText = document.getElementById('modalLecturerSearch').value.toLowerCase();
            const smartMatch = document.getElementById('smartMatchToggle').checked;
            const modalLecturers = document.querySelectorAll('.modal-lecturer-item');

            modalLecturers.forEach(item => {
                const name = item.getAttribute('data-name');
                const specialty = item.getAttribute('data-specialty');

                const matchesSearch = name.includes(searchText) || specialty?.toLowerCase().includes(searchText);
                const matchesSmart = !smartMatch || (currentProjectMajor && specialty?.toLowerCase().includes(currentProjectMajor.toLowerCase()));

                if (matchesSearch && matchesSmart) {
                    item.classList.remove('hidden');
                } else {
                    item.classList.add('hidden');
                }
            });
        }

        function filterModalProjects() {
            const searchText = document.getElementById('modalProjectSearch').value.toLowerCase();
            const modalProjects = document.querySelectorAll('.modal-project-item');

            modalProjects.forEach(item => {
                const name = item.getAttribute('data-name');
                const code = item.getAttribute('data-code');

                const matchesSearch = name.includes(searchText) || code.includes(searchText);

                if (matchesSearch) {
                    item.classList.remove('hidden');
                } else {
                    item.classList.add('hidden');
                }
            });
        }
    </script>
}

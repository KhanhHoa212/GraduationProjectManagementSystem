@{
    ViewData["Title"] = "Supervisor Assignment";
    Layout = "_HODLayout";
}

<div class="max-w-4xl mx-auto space-y-8 animate-in fade-in duration-500 pb-12">
    <div class="flex flex-col items-center text-center space-y-4">
        <h1 class="text-3xl font-bold text-slate-800 tracking-tight uppercase tracking-widest">Supervisor Pairings</h1>
        <p class="text-slate-400 text-xs font-bold uppercase tracking-[2px] mt-2 italic px-12 italic border-b border-slate-100 pb-4">Associate mentors with active research groups for SP25</p>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-10">
        <form class="space-y-10">
            <div class="grid grid-cols-2 gap-10">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-3 px-1">Target Group ID <span class="text-red-500">*</span></label>
                    <select class="w-full border border-slate-200 bg-slate-50 rounded-xl px-4 py-3 text-sm font-bold text-slate-700 focus:border-[#F37021] transition-all appearance-none cursor-pointer">
                        <option>Select Case...</option>
                        <option>G02 (Project: GP-SE-002)</option>
                        <option>G04 (Project: None Assigned)</option>
                    </select>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-3 px-1">Lead Supervisor <span class="text-red-500">*</span></label>
                    <select class="w-full border border-slate-200 bg-slate-50 rounded-xl px-4 py-3 text-sm font-bold text-slate-700 focus:border-[#F37021] transition-all appearance-none cursor-pointer">
                        <option>Select Mentor...</option>
                        <option>Nguyễn Thế Hoàng (Current Load: 75%)</option>
                        <option disabled class="text-red-400">Trần Văn Tú (FULL - 100%)</option>
                    </select>
                    <p class="mt-3 text-[10px] font-bold text-[#F37021] uppercase tracking-widest">Rule: Max 4 Groups per Sector</p>
                </div>
            </div>

            <div class="p-8 bg-slate-50/50 rounded-xl border border-dashed border-slate-200 flex flex-col gap-6">
                <div class="flex items-center justify-between">
                    <h4 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Workload analytics</h4>
                </div>
                
                <div class="grid grid-cols-3 gap-6">
                    <div class="bg-white p-4 rounded-xl border border-slate-100 shadow-sm flex flex-col gap-3 group translate transition-all hover:-translate-y-1 hover:shadow-lg">
                        <p class="text-[9px] font-bold text-slate-700 uppercase tracking-[2px]">DR. HOÀNG</p>
                        <div class="h-1.5 w-full bg-slate-50 rounded-full overflow-hidden">
                            <div class="h-full bg-green-500 w-[75%] rounded-full shadow-inner ring-4 ring-green-100/30"></div>
                        </div>
                        <p class="text-[10px] text-right font-bold text-green-600 uppercase">3 / 4 Slots</p>
                    </div>

                    <div class="bg-red-50 p-4 rounded-xl border border-red-100 shadow-sm flex flex-col gap-3 group translate transition-all hover:-translate-y-1">
                        <p class="text-[9px] font-bold text-red-500 uppercase tracking-[2px]">DR. TÚ</p>
                        <div class="h-1.5 w-full bg-white rounded-full overflow-hidden">
                            <div class="h-full bg-red-500 w-full rounded-full shadow-lg ring-4 ring-red-100/50"></div>
                        </div>
                        <p class="text-[10px] text-right font-bold text-red-600 uppercase tracking-widest font-black">FULL CAPACITY (4/4)</p>
                    </div>

                    <div class="bg-white p-4 rounded-xl border border-slate-100 shadow-sm flex flex-col gap-3 group translate transition-all hover:-translate-y-1 hover:shadow-lg">
                        <p class="text-[9px] font-bold text-slate-700 uppercase tracking-[2px]">M.S TRUNG</p>
                        <div class="h-1.5 w-full bg-slate-50 rounded-full overflow-hidden">
                            <div class="h-full bg-[#F37021] w-[50%] rounded-full shadow-inner ring-4 ring-orange-100/30"></div>
                        </div>
                        <p class="text-[10px] text-right font-bold text-[#F37021] uppercase">2 / 4 Slots</p>
                    </div>
                </div>
            </div>

            <div class="flex justify-center pt-6">
                <button class="px-24 py-4 bg-[#F37021] text-white font-bold rounded-xl shadow-[0_10px_30px_-10px_rgba(243,112,33,0.3)] hover:shadow-orange-500/50 hover:bg-orange-600 transition-all uppercase tracking-[2px] text-xs">AUTHORIZED ASSIGNMENT</button>
            </div>
        </form>
    </div>
</div>

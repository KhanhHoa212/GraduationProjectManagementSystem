@model GPMS.Web.ViewModels.HODReportViewModel
@{
    ViewData["Title"] = "Reports";
    Layout = "_Layout";
    
    // Helper values
    var totalProjects = Model.TotalProjects > 0 ? Model.TotalProjects : 1; // avoid division by zero
    var draftPct = (int)Math.Round((double)Model.DraftProjects / totalProjects * 100);
    var activePct = (int)Math.Round((double)Model.ActiveProjects / totalProjects * 100);
    var completedPct = (int)Math.Round((double)Model.CompletedProjects / totalProjects * 100);
    var cancelledPct = (int)Math.Round((double)Model.CancelledProjects / totalProjects * 100);
    var maxMajor = Model.MajorDistribution.Any() ? Model.MajorDistribution.Max(m => m.ProjectCount) : 1;
}

@section Styles {
    <style>
        @@media print {
            /* Ẩn sidebar, header của layout */
            aside, header, nav, .print\:hidden { display: none !important; }
            
            /* Reset layout để full trang */
            main.ml-64, main {
                margin: 0 !important;
                padding: 0 !important;
                width: 100% !important;
                max-width: 100% !important;
            }

            /* Giữ nguyên màu sắc và dark mode styles khi in */
            body {
                background: white !important;
                color: black !important;
            }

            * {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
                page-break-inside: avoid;
            }

            /* Giảm bớt shadow và format lại charts */
            .shadow-sm, .shadow-md, .shadow-lg { box-shadow: none !important; border: 1px solid #e2e8f0 !important; }
        }
    </style>
}


<div class="space-y-8" id="reportContent">
    <!-- ===== HEADER ===== -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl lg:text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Báo cáo tổng quan</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary-500 text-base">calendar_today</span>
                Kỳ hiển thị: <span class="font-bold text-primary-600">@Model.SemesterCode — @Model.AcademicYear</span>
            </p>
        </div>

        <!-- Tiện ích (Filter + Print) -->
        <div class="flex flex-col sm:flex-row items-center gap-3 print:hidden">
            <form method="get" asp-action="Reports" id="filterForm" class="w-full sm:w-auto">
                <select name="semesterId" class="w-full sm:w-48 px-4 py-2 border border-slate-200 dark:border-dark-700 bg-white dark:bg-dark-800 rounded-xl focus:ring-2 focus:ring-primary-500" onchange="document.getElementById('filterForm').submit()">
                    <option value="-1">✅ Tất cả các kỳ</option>
                    @if (ViewBag.Semesters != null)
                    {
                        foreach (var sem in ViewBag.Semesters)
                        {
                            var isSelected = ViewBag.SelectedSemesterId == sem.SemesterID;
                            if (isSelected)
                            {
                                <option value="@sem.SemesterID" selected>@sem.SemesterCode (@sem.AcademicYear)</option>
                            }
                            else
                            {
                                <option value="@sem.SemesterID">@sem.SemesterCode (@sem.AcademicYear)</option>
                            }
                        }
                    }
                </select>
            </form>

            <button type="button" onclick="window.print()" class="w-full sm:w-auto flex justify-center items-center gap-2 bg-slate-900 dark:bg-primary-600 text-white px-5 py-2 rounded-xl hover:bg-slate-800 dark:hover:bg-primary-700 transition-colors shadow-sm">
                <span class="material-symbols-outlined text-sm">print</span>
                <span class="font-semibold text-sm">Xuất PDF</span>
            </button>
        </div>
    </div>

    <!-- ===== KPI CARDS ===== -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
        <!-- Total Projects -->
        <div class="relative overflow-hidden bg-white dark:bg-dark-800 rounded-2xl p-5 shadow-sm border border-slate-100 dark:border-dark-700 group hover:shadow-lg hover:border-primary-200 transition-all duration-300">
            <div class="absolute -top-4 -right-4 w-20 h-20 bg-primary-500/5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
            <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 bg-primary-500/10 rounded-xl flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary-500 text-[22px]">account_tree</span>
                </div>
            </div>
            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Đề tài</p>
            <p class="text-3xl font-black text-slate-900 dark:text-white mt-1">@Model.TotalProjects</p>
        </div>

        <!-- Total Groups -->
        <div class="relative overflow-hidden bg-white dark:bg-dark-800 rounded-2xl p-5 shadow-sm border border-slate-100 dark:border-dark-700 group hover:shadow-lg hover:border-blue-200 transition-all duration-300">
            <div class="absolute -top-4 -right-4 w-20 h-20 bg-blue-500/5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
            <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 bg-blue-500/10 rounded-xl flex items-center justify-center">
                    <span class="material-symbols-outlined text-blue-500 text-[22px]">groups</span>
                </div>
            </div>
            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Nhóm</p>
            <p class="text-3xl font-black text-slate-900 dark:text-white mt-1">@Model.TotalGroups</p>
        </div>

        <!-- Total Students -->
        <div class="relative overflow-hidden bg-white dark:bg-dark-800 rounded-2xl p-5 shadow-sm border border-slate-100 dark:border-dark-700 group hover:shadow-lg hover:border-emerald-200 transition-all duration-300">
            <div class="absolute -top-4 -right-4 w-20 h-20 bg-emerald-500/5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
            <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 bg-emerald-500/10 rounded-xl flex items-center justify-center">
                    <span class="material-symbols-outlined text-emerald-500 text-[22px]">school</span>
                </div>
            </div>
            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Sinh viên</p>
            <p class="text-3xl font-black text-slate-900 dark:text-white mt-1">@Model.TotalStudents</p>
        </div>

        <!-- Total Supervisors -->
        <div class="relative overflow-hidden bg-white dark:bg-dark-800 rounded-2xl p-5 shadow-sm border border-slate-100 dark:border-dark-700 group hover:shadow-lg hover:border-violet-200 transition-all duration-300">
            <div class="absolute -top-4 -right-4 w-20 h-20 bg-violet-500/5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
            <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 bg-violet-500/10 rounded-xl flex items-center justify-center">
                    <span class="material-symbols-outlined text-violet-500 text-[22px]">person_search</span>
                </div>
            </div>
            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">GVHD</p>
            <p class="text-3xl font-black text-slate-900 dark:text-white mt-1">@Model.TotalSupervisors</p>
        </div>
    </div>

    <!-- ===== ROW 2: PROJECT STATUS + MAJOR DISTRIBUTION ===== -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
        <!-- Project Status Distribution (3/5) -->
        <div class="lg:col-span-3 bg-white dark:bg-dark-800 rounded-2xl p-6 shadow-sm border border-slate-100 dark:border-dark-700">
            <h2 class="text-base font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary-500 text-lg">donut_small</span>
                Trạng thái Đề tài
            </h2>

            <div class="flex flex-col md:flex-row items-center gap-8">
                <!-- Donut Chart -->
                <div class="relative w-48 h-48 shrink-0">
                    @{
                        // SVG donut chart calculations
                        double circumference = 2 * Math.PI * 45;
                        double draftArc = circumference * draftPct / 100;
                        double activeArc = circumference * activePct / 100;
                        double completedArc = circumference * completedPct / 100;
                        double cancelledArc = circumference * cancelledPct / 100;
                        double offset1 = 0;
                        double offset2 = -draftArc;
                        double offset3 = -(draftArc + activeArc);
                        double offset4 = -(draftArc + activeArc + completedArc);
                    }
                    <svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120">
                        @if(draftPct > 0)
                        {
                            <circle cx="60" cy="60" r="45" fill="none" stroke="#94A3B8" stroke-width="14"
                                    stroke-dasharray="@draftArc.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) @circumference.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                    stroke-dashoffset="@offset1.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                    stroke-linecap="round" class="transition-all duration-700"></circle>
                        }
                        @if(activePct > 0)
                        {
                            <circle cx="60" cy="60" r="45" fill="none" stroke="#F37021" stroke-width="14"
                                    stroke-dasharray="@activeArc.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) @circumference.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                    stroke-dashoffset="@offset2.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                    stroke-linecap="round" class="transition-all duration-700"></circle>
                        }
                        @if(completedPct > 0)
                        {
                            <circle cx="60" cy="60" r="45" fill="none" stroke="#10B981" stroke-width="14"
                                    stroke-dasharray="@completedArc.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) @circumference.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                    stroke-dashoffset="@offset3.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                    stroke-linecap="round" class="transition-all duration-700"></circle>
                        }
                        @if(cancelledPct > 0)
                        {
                            <circle cx="60" cy="60" r="45" fill="none" stroke="#EF4444" stroke-width="14"
                                    stroke-dasharray="@cancelledArc.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) @circumference.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                    stroke-dashoffset="@offset4.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                    stroke-linecap="round" class="transition-all duration-700"></circle>
                        }
                    </svg>
                    <div class="absolute inset-0 flex items-center justify-center">
                        <div class="text-center">
                            <p class="text-3xl font-black text-slate-900 dark:text-white">@Model.TotalProjects</p>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Tổng</p>
                        </div>
                    </div>
                </div>

                <!-- Legend -->
                <div class="grid grid-cols-2 gap-x-8 gap-y-4 flex-1">
                    <div class="flex items-center gap-3">
                        <div class="w-3 h-3 rounded-full bg-slate-400 shrink-0"></div>
                        <div>
                            <p class="text-sm font-semibold text-slate-700 dark:text-white">Draft</p>
                            <p class="text-xs text-slate-400">@Model.DraftProjects đề tài (@draftPct%)</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-3 h-3 rounded-full bg-[#F37021] shrink-0"></div>
                        <div>
                            <p class="text-sm font-semibold text-slate-700 dark:text-white">Active</p>
                            <p class="text-xs text-slate-400">@Model.ActiveProjects đề tài (@activePct%)</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-3 h-3 rounded-full bg-emerald-500 shrink-0"></div>
                        <div>
                            <p class="text-sm font-semibold text-slate-700 dark:text-white">Completed</p>
                            <p class="text-xs text-slate-400">@Model.CompletedProjects đề tài (@completedPct%)</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-3 h-3 rounded-full bg-red-500 shrink-0"></div>
                        <div>
                            <p class="text-sm font-semibold text-slate-700 dark:text-white">Cancelled</p>
                            <p class="text-xs text-slate-400">@Model.CancelledProjects đề tài (@cancelledPct%)</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Major Distribution (2/5) -->
        <div class="lg:col-span-2 bg-white dark:bg-dark-800 rounded-2xl p-6 shadow-sm border border-slate-100 dark:border-dark-700">
            <h2 class="text-base font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-blue-500 text-lg">domain</span>
                Phân bố Chuyên ngành
            </h2>

            @if (Model.MajorDistribution.Any())
            {
                <div class="space-y-4">
                    @{ var majorColors = new[] { "bg-primary-500", "bg-blue-500", "bg-emerald-500", "bg-violet-500", "bg-amber-500" }; var i = 0; }
                    @foreach (var major in Model.MajorDistribution)
                    {
                        var pct = (int)Math.Round((double)major.ProjectCount / totalProjects * 100);
                        var color = majorColors[i % majorColors.Length];
                        <div>
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm font-semibold text-slate-700 dark:text-white">@major.MajorName</span>
                                <span class="text-xs font-bold text-slate-500">@major.ProjectCount đề tài · @pct%</span>
                            </div>
                            <div class="h-3 bg-slate-100 dark:bg-dark-700 rounded-full overflow-hidden">
                                <div class="h-full @color rounded-full transition-all duration-700" style="width: @pct%"></div>
                            </div>
                        </div>
                        i++;
                    }
                </div>
            }
            else
            {
                <div class="flex flex-col items-center justify-center h-32 text-slate-400">
                    <span class="material-symbols-outlined text-3xl mb-2">info</span>
                    <p class="text-sm">Chưa có dữ liệu</p>
                </div>
            }
        </div>
    </div>

    <!-- ===== ROW 3: SUBMISSION STATS + MENTOR DECISIONS ===== -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Submission Stats per Round -->
        <div class="bg-white dark:bg-dark-800 rounded-2xl p-6 shadow-sm border border-slate-100 dark:border-dark-700">
            <h2 class="text-base font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-emerald-500 text-lg">upload_file</span>
                Tình hình nộp bài theo vòng Review
            </h2>

            @if (Model.RoundSubmissionStats.Any())
            {
                <div class="space-y-5">
                    @foreach (var round in Model.RoundSubmissionStats)
                    {
                        var total = round.OnTimeCount + round.LateCount + round.NotSubmittedCount;
                        total = total > 0 ? total : 1;
                        var onTimePct = (int)Math.Round((double)round.OnTimeCount / total * 100);
                        var latePct = (int)Math.Round((double)round.LateCount / total * 100);
                        var notSubPct = (int)Math.Round((double)round.NotSubmittedCount / total * 100);

                        <div>
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm font-bold text-slate-700 dark:text-white">Review @round.RoundNumber</span>
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">@total bài</span>
                            </div>
                            <!-- Stacked bar -->
                            <div class="flex h-4 rounded-full overflow-hidden bg-slate-100 dark:bg-dark-700 gap-px">
                                @if (onTimePct > 0)
                                {
                                    <div class="bg-emerald-500 transition-all duration-500" style="width: @onTimePct%" title="Đúng hạn: @round.OnTimeCount"></div>
                                }
                                @if (latePct > 0)
                                {
                                    <div class="bg-amber-500 transition-all duration-500" style="width: @latePct%" title="Trễ hạn: @round.LateCount"></div>
                                }
                                @if (notSubPct > 0)
                                {
                                    <div class="bg-slate-300 dark:bg-dark-600 transition-all duration-500" style="width: @notSubPct%" title="Chưa nộp: @round.NotSubmittedCount"></div>
                                }
                            </div>
                            <div class="flex items-center gap-4 mt-1.5">
                                <span class="text-[10px] text-emerald-600 font-bold">✓ @round.OnTimeCount đúng hạn</span>
                                <span class="text-[10px] text-amber-600 font-bold">⏱ @round.LateCount trễ</span>
                                <span class="text-[10px] text-slate-400 font-bold">○ @round.NotSubmittedCount chưa nộp</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="flex flex-col items-center justify-center h-32 text-slate-400">
                    <span class="material-symbols-outlined text-3xl mb-2">event_busy</span>
                    <p class="text-sm">Chưa có vòng review nào</p>
                </div>
            }
        </div>

        <!-- Mentor Decision Progress per Round -->
        <div class="bg-white dark:bg-dark-800 rounded-2xl p-6 shadow-sm border border-slate-100 dark:border-dark-700">
            <h2 class="text-base font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-violet-500 text-lg">how_to_reg</span>
                Quyết định GVHD (Mentor Gate)
            </h2>

            @if (Model.RoundMentorStats.Any())
            {
                <div class="space-y-5">
                    @foreach (var round in Model.RoundMentorStats)
                    {
                        var totalDecisions = round.AcceptedCount + round.RejectedCount + round.PendingCount + round.StoppedCount;
                        totalDecisions = totalDecisions > 0 ? totalDecisions : 1;

                        <div>
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm font-bold text-slate-700 dark:text-white">Review @round.RoundNumber</span>
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">@totalDecisions nhóm</span>
                            </div>
                            <div class="grid grid-cols-4 gap-2">
                                <div class="text-center bg-emerald-50 dark:bg-emerald-500/10 rounded-xl py-2.5 px-1">
                                    <p class="text-lg font-black text-emerald-600">@round.AcceptedCount</p>
                                    <p class="text-[9px] font-bold text-emerald-500 uppercase tracking-wider">Accepted</p>
                                </div>
                                <div class="text-center bg-red-50 dark:bg-red-500/10 rounded-xl py-2.5 px-1">
                                    <p class="text-lg font-black text-red-600">@round.RejectedCount</p>
                                    <p class="text-[9px] font-bold text-red-500 uppercase tracking-wider">Rejected</p>
                                </div>
                                <div class="text-center bg-amber-50 dark:bg-amber-500/10 rounded-xl py-2.5 px-1">
                                    <p class="text-lg font-black text-amber-600">@round.PendingCount</p>
                                    <p class="text-[9px] font-bold text-amber-500 uppercase tracking-wider">Pending</p>
                                </div>
                                <div class="text-center bg-slate-50 dark:bg-dark-700 rounded-xl py-2.5 px-1">
                                    <p class="text-lg font-black text-slate-500">@round.StoppedCount</p>
                                    <p class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Stopped</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="flex flex-col items-center justify-center h-32 text-slate-400">
                    <span class="material-symbols-outlined text-3xl mb-2">pending_actions</span>
                    <p class="text-sm">Chưa có dữ liệu đánh giá</p>
                </div>
            }
        </div>
    </div>

    <!-- ===== ROW 4: SUPERVISOR WORKLOAD TABLE ===== -->
    <div class="bg-white dark:bg-dark-800 rounded-2xl shadow-sm border border-slate-100 dark:border-dark-700 overflow-hidden">
        <div class="p-6 border-b border-slate-100 dark:border-dark-700 flex items-center justify-between">
            <h2 class="text-base font-bold text-slate-900 dark:text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-primary-500 text-lg">supervisor_account</span>
                Khối lượng Giảng viên Hướng dẫn
            </h2>
            <span class="text-xs font-bold text-slate-400 px-3 py-1 bg-slate-50 dark:bg-dark-700 rounded-full">@Model.SupervisorWorkloads.Count GVHD</span>
        </div>

        @if (Model.SupervisorWorkloads.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-slate-50/80 dark:bg-dark-700/50">
                        <tr>
                            <th class="text-left py-3 px-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">#</th>
                            <th class="text-left py-3 px-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Giảng viên</th>
                            <th class="text-center py-3 px-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Đề tài</th>
                            <th class="text-center py-3 px-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Nhóm</th>
                            <th class="text-center py-3 px-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Sinh viên</th>
                            <th class="text-left py-3 px-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Tải trọng</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-dark-700">
                        @{ var idx = 0; var maxProjects = Model.SupervisorWorkloads.Max(s => s.ProjectCount); maxProjects = maxProjects > 0 ? maxProjects : 1; }
                        @foreach (var sup in Model.SupervisorWorkloads)
                        {
                            idx++;
                            var loadPct = (int)Math.Round((double)sup.ProjectCount / maxProjects * 100);
                            var barColor = loadPct >= 80 ? "bg-red-500" : loadPct >= 50 ? "bg-amber-500" : "bg-emerald-500";

                            <tr class="hover:bg-slate-50/80 dark:hover:bg-dark-700/30 transition-colors">
                                <td class="py-4 px-6 text-xs font-bold text-slate-300">@idx</td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 bg-gradient-to-br from-primary-400 to-primary-600 rounded-full flex items-center justify-center text-white text-xs font-bold shadow-sm">
                                            @sup.LecturerName.Substring(0, 1).ToUpper()
                                        </div>
                                        <span class="font-semibold text-slate-700 dark:text-white">@sup.LecturerName</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-primary-50 dark:bg-primary-500/10 text-primary-600 font-bold text-sm">@sup.ProjectCount</span>
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-500/10 text-blue-600 font-bold text-sm">@sup.GroupCount</span>
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 font-bold text-sm">@sup.StudentCount</span>
                                </td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-3">
                                        <div class="h-2 bg-slate-100 dark:bg-dark-700 rounded-full flex-1" style="min-width: 80px;">
                                            <div class="h-full @barColor rounded-full transition-all duration-500" style="width: @loadPct%"></div>
                                        </div>
                                        <span class="text-xs font-bold text-slate-500 w-8 text-right">@loadPct%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="flex flex-col items-center justify-center py-12 text-slate-400">
                <span class="material-symbols-outlined text-4xl mb-3">person_off</span>
                <p class="text-sm font-medium">Chưa có giảng viên nào được phân công</p>
            </div>
        }
    </div>
</div>

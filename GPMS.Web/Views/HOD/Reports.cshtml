@{
    ViewData["Title"] = "Reports";
    Layout = "~/Views/Shared/_HodLayout.cshtml";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950">
    <div class="p-6">
        <div class="max-w-7xl mx-auto space-y-6">
            <!-- Header -->
            <div class="flex items-start justify-between mb-8">
                <div>
                    <nav class="flex items-center gap-2 text-sm mb-4">
                        <a href="/Hod/Dashboard" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200">GPMS</a>
                        <span class="text-slate-400 dark:text-slate-600">/</span>
                        <span class="text-slate-900 dark:text-slate-100 font-medium">Reports</span>
                    </nav>
                    <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Báo cáo thống kê</h1>
                    <p class="text-slate-600 dark:text-slate-400 mt-2">Thống kê tổng hợp về dữ liệu và thống kê liên quan</p>
                </div>
                <div class="flex gap-3">
                    <button class="px-4 py-2 bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 font-medium flex items-center gap-2 transition">
                        <span class="material-symbols-outlined" style="font-size: 20px;">picture_as_pdf</span>
                        Xuất PDF
                    </button>
                    <button class="px-4 py-2 bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 font-medium flex items-center gap-2 transition">
                        <span class="material-symbols-outlined" style="font-size: 20px;">table_chart</span>
                        Xuất Excel
                    </button>
                </div>
            </div>

            <!-- KPI Cards -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <!-- Total Groups -->
                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                    <div class="flex items-start justify-between mb-4">
                        <div>
                            <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Tổng số nhóm</p>
                            <h3 class="text-3xl font-bold text-slate-900 dark:text-white mt-1">142</h3>
                        </div>
                        <span class="text-green-600 dark:text-green-400 text-sm font-medium px-2 py-1 bg-green-100 dark:bg-green-900 rounded">+2.5%</span>
                    </div>
                    <div class="h-1 bg-green-500 rounded-full w-full"></div>
                </div>

                <!-- Completion Rate -->
                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                    <div class="flex items-start justify-between mb-4">
                        <div>
                            <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Tỉ lệ hoàn thành</p>
                            <h3 class="text-3xl font-bold text-slate-900 dark:text-white mt-1">88%</h3>
                        </div>
                        <span class="text-[#F37021] dark:text-orange-400 text-sm font-medium px-2 py-1 bg-orange-100 dark:bg-orange-900 rounded">+1.2%</span>
                    </div>
                    <div class="h-1 bg-[#F37021] rounded-full w-88" style="width: 88%;"></div>
                </div>

                <!-- Average Score -->
                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                    <div class="flex items-start justify-between mb-4">
                        <div>
                            <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Điểm trung bình</p>
                            <h3 class="text-3xl font-bold text-slate-900 dark:text-white mt-1">7.8</h3>
                        </div>
                        <span class="text-emerald-600 dark:text-emerald-400 text-sm font-medium px-2 py-1 bg-emerald-100 dark:bg-emerald-900 rounded">+0.3</span>
                    </div>
                    <div class="h-1 bg-emerald-500 rounded-full w-full"></div>
                </div>

                <!-- Pass Rate -->
                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                    <div class="flex items-start justify-between mb-4">
                        <div>
                            <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Tỉ lệ thông qua</p>
                            <h3 class="text-3xl font-bold text-slate-900 dark:text-white mt-1">94.5%</h3>
                        </div>
                        <span class="text-blue-600 dark:text-blue-400 text-sm font-medium px-2 py-1 bg-blue-100 dark:bg-blue-900 rounded">-3.4%</span>
                    </div>
                    <div class="h-1 bg-blue-500 rounded-full" style="width: 94.5%;"></div>
                </div>
            </div>

            <!-- Charts Row 1 -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Average Score by Review Rounds -->
                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-6">Điểm trung bình theo các vòng Review</h2>
                    <div class="flex items-end justify-around h-64">
                        <!-- Bar 1 -->
                        <div class="flex flex-col items-center">
                            <div class="w-12 bg-gradient-to-t from-[#F37021] to-orange-400 rounded-t-lg" style="height: 85%;"></div>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white mt-4">8.5</p>
                            <p class="text-xs text-slate-600 dark:text-slate-400 mt-1">Review 1</p>
                        </div>

                        <!-- Bar 2 -->
                        <div class="flex flex-col items-center">
                            <div class="w-12 bg-gradient-to-t from-blue-500 to-blue-400 rounded-t-lg" style="height: 72%;"></div>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white mt-4">7.2</p>
                            <p class="text-xs text-slate-600 dark:text-slate-400 mt-1">Review 2</p>
                        </div>

                        <!-- Bar 3 -->
                        <div class="flex flex-col items-center">
                            <div class="w-12 bg-gradient-to-t from-green-500 to-green-400 rounded-t-lg" style="height: 78%;"></div>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white mt-4">7.8</p>
                            <p class="text-xs text-slate-600 dark:text-slate-400 mt-1">Review 3</p>
                        </div>

                        <!-- Bar 4 -->
                        <div class="flex flex-col items-center">
                            <div class="w-12 bg-gradient-to-t from-purple-500 to-purple-400 rounded-t-lg" style="height: 85%;"></div>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white mt-4">8.5</p>
                            <p class="text-xs text-slate-600 dark:text-slate-400 mt-1">Final Defence</p>
                        </div>
                    </div>
                </div>

                <!-- Group Status Distribution -->
                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-6">Trạng thái nhóm đó ơn</h2>
                    <div class="flex items-center justify-center gap-8">
                        <!-- Donut Chart -->
                        <div class="relative w-48 h-48">
                            <svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120">
                                <!-- Completed (60%) -->
                                <circle cx="60" cy="60" r="45" fill="none" stroke="#10b981" stroke-width="12" stroke-dasharray="169.6 283" stroke-linecap="round"></circle>
                                <!-- Active (30%) -->
                                <circle cx="60" cy="60" r="45" fill="none" stroke="#F37021" stroke-width="12" stroke-dasharray="84.8 283" stroke-linecap="round" style="stroke-dashoffset: -169.6;"></circle>
                                <!-- Draft (10%) -->
                                <circle cx="60" cy="60" r="45" fill="none" stroke="#cbd5e1" stroke-width="12" stroke-dasharray="28.3 283" stroke-linecap="round" style="stroke-dashoffset: -254.4;"></circle>
                            </svg>
                            <div class="absolute inset-0 flex items-center justify-center">
                                <div class="text-center">
                                    <p class="text-3xl font-bold text-slate-900 dark:text-white">142</p>
                                    <p class="text-xs text-slate-600 dark:text-slate-400">Tổng nhóm</p>
                                </div>
                            </div>
                        </div>

                        <!-- Legend -->
                        <div class="space-y-4">
                            <div class="flex items-center gap-3">
                                <div class="w-3 h-3 rounded-full bg-emerald-500"></div>
                                <div>
                                    <p class="text-sm font-medium text-slate-900 dark:text-white">Completed</p>
                                    <p class="text-xs text-slate-600 dark:text-slate-400">85 nhóm (60%)</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-3 h-3 rounded-full bg-[#F37021]"></div>
                                <div>
                                    <p class="text-sm font-medium text-slate-900 dark:text-white">Active</p>
                                    <p class="text-xs text-slate-600 dark:text-slate-400">42 nhóm (30%)</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-3 h-3 rounded-full bg-slate-300 dark:bg-slate-600"></div>
                                <div>
                                    <p class="text-sm font-medium text-slate-900 dark:text-white">Draft</p>
                                    <p class="text-xs text-slate-600 dark:text-slate-400">15 nhóm (10%)</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Charts Row 2 -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Submission Timeliness -->
                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-6">Tỉ lệ nộp bài Đúng hạn vs Trễ hạn</h2>
                    <div class="space-y-4">
                        <div>
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm font-medium text-slate-900 dark:text-white">Đúng hạn</span>
                                <span class="text-sm font-semibold text-slate-900 dark:text-white">74%</span>
                            </div>
                            <div class="h-2 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
                                <div class="h-full bg-emerald-500" style="width: 74%;"></div>
                            </div>
                        </div>

                        <div>
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm font-medium text-slate-900 dark:text-white">Trễ hạn</span>
                                <span class="text-sm font-semibold text-slate-900 dark:text-white">18%</span>
                            </div>
                            <div class="h-2 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
                                <div class="h-full bg-red-500" style="width: 18%;"></div>
                            </div>
                        </div>

                        <div>
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm font-medium text-slate-900 dark:text-white">Chưa nộp</span>
                                <span class="text-sm font-semibold text-slate-900 dark:text-white">8%</span>
                            </div>
                            <div class="h-2 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
                                <div class="h-full bg-slate-400" style="width: 8%;"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Submission Distribution by Round -->
                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-6">Phân bố nộp bài theo vòng Review</h2>
                    <div class="space-y-4">
                        <div class="flex items-end justify-around h-40">
                            <div class="flex flex-col items-center">
                                <div class="w-10 bg-blue-500 rounded-t" style="height: 85%;"></div>
                                <p class="text-xs font-semibold text-slate-900 dark:text-white mt-2">Review 1</p>
                                <p class="text-xs text-slate-600 dark:text-slate-400">121</p>
                            </div>
                            <div class="flex flex-col items-center">
                                <div class="w-10 bg-blue-500 rounded-t" style="height: 92%;"></div>
                                <p class="text-xs font-semibold text-slate-900 dark:text-white mt-2">Review 2</p>
                                <p class="text-xs text-slate-600 dark:text-slate-400">131</p>
                            </div>
                            <div class="flex flex-col items-center">
                                <div class="w-10 bg-blue-500 rounded-t" style="height: 78%;"></div>
                                <p class="text-xs font-semibold text-slate-900 dark:text-white mt-2">Review 3</p>
                                <p class="text-xs text-slate-600 dark:text-slate-400">111</p>
                            </div>
                            <div class="flex flex-col items-center">
                                <div class="w-10 bg-slate-400 rounded-t" style="height: 45%;"></div>
                                <p class="text-xs font-semibold text-slate-900 dark:text-white mt-2">Final</p>
                                <p class="text-xs text-slate-600 dark:text-slate-400">64</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Workload Tables Row -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Reviewer Workload -->
                <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
                    <div class="p-6 border-b border-slate-200 dark:border-slate-800">
                        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Khối lượng công việc Reviewer</h2>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead class="bg-slate-50 dark:bg-slate-800">
                                <tr>
                                    <th class="text-left py-3 px-6 font-semibold text-slate-700 dark:text-slate-300">GIẢNG VIÊN</th>
                                    <th class="text-left py-3 px-6 font-semibold text-slate-700 dark:text-slate-300">NHÓM REVIEW</th>
                                    <th class="text-left py-3 px-6 font-semibold text-slate-700 dark:text-slate-300">TẢI TRONG (%)</th>
                                    <th class="text-left py-3 px-6 font-semibold text-slate-700 dark:text-slate-300">ĐÁNH GIÁ</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
                                    <td class="py-4 px-6 text-slate-900 dark:text-white font-medium">Nguyễn Văn Thành</td>
                                    <td class="py-4 px-6 text-slate-600 dark:text-slate-400">12</td>
                                    <td class="py-4 px-6">
                                        <div class="flex items-center gap-2">
                                            <div class="h-2 bg-slate-200 dark:bg-slate-700 rounded-full flex-1" style="min-width: 60px;">
                                                <div class="h-full bg-blue-500 rounded-full" style="width: 80%;"></div>
                                            </div>
                                            <span class="text-xs font-medium text-slate-900 dark:text-white">80%</span>
                                        </div>
                                    </td>
                                    <td class="py-4 px-6 text-slate-900 dark:text-white font-medium">4.8</td>
                                </tr>
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
                                    <td class="py-4 px-6 text-slate-900 dark:text-white font-medium">Lê Thị Hoa</td>
                                    <td class="py-4 px-6 text-slate-600 dark:text-slate-400">10</td>
                                    <td class="py-4 px-6">
                                        <div class="flex items-center gap-2">
                                            <div class="h-2 bg-slate-200 dark:bg-slate-700 rounded-full flex-1" style="min-width: 60px;">
                                                <div class="h-full bg-blue-500 rounded-full" style="width: 85%;"></div>
                                            </div>
                                            <span class="text-xs font-medium text-slate-900 dark:text-white">85%</span>
                                        </div>
                                    </td>
                                    <td class="py-4 px-6 text-slate-900 dark:text-white font-medium">4.1</td>
                                </tr>
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
                                    <td class="py-4 px-6 text-slate-900 dark:text-white font-medium">Trần Anh Quân</td>
                                    <td class="py-4 px-6 text-slate-600 dark:text-slate-400">15</td>
                                    <td class="py-4 px-6">
                                        <div class="flex items-center gap-2">
                                            <div class="h-2 bg-slate-200 dark:bg-slate-700 rounded-full flex-1" style="min-width: 60px;">
                                                <div class="h-full bg-red-500 rounded-full" style="width: 100%;"></div>
                                            </div>
                                            <span class="text-xs font-medium text-slate-900 dark:text-white">100%</span>
                                        </div>
                                    </td>
                                    <td class="py-4 px-6 text-slate-900 dark:text-white font-medium">4.2</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Supervisor Workload -->
                <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
                    <div class="p-6 border-b border-slate-200 dark:border-slate-800">
                        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Khối lượng công việc Giảng viên hướng dẫn</h2>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead class="bg-slate-50 dark:bg-slate-800">
                                <tr>
                                    <th class="text-left py-3 px-6 font-semibold text-slate-700 dark:text-slate-300">GIẢNG VIÊN</th>
                                    <th class="text-left py-3 px-6 font-semibold text-slate-700 dark:text-slate-300">NHÓM HƯỚNG DẪN</th>
                                    <th class="text-left py-3 px-6 font-semibold text-slate-700 dark:text-slate-300">DUNG HẠN (%)</th>
                                    <th class="text-left py-3 px-6 font-semibold text-slate-700 dark:text-slate-300">ĐIỂM TB NHÓM</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
                                    <td class="py-4 px-6 text-slate-900 dark:text-white font-medium">Vũ Minh Tuấn</td>
                                    <td class="py-4 px-6 text-slate-600 dark:text-slate-400">8</td>
                                    <td class="py-4 px-6">
                                        <div class="flex items-center gap-2">
                                            <div class="h-2 bg-slate-200 dark:bg-slate-700 rounded-full flex-1" style="min-width: 60px;">
                                                <div class="h-full bg-emerald-500 rounded-full" style="width: 96%;"></div>
                                            </div>
                                            <span class="text-xs font-medium text-slate-900 dark:text-white">96%</span>
                                        </div>
                                    </td>
                                    <td class="py-4 px-6 text-slate-900 dark:text-white font-medium">8.4</td>
                                </tr>
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
                                    <td class="py-4 px-6 text-slate-900 dark:text-white font-medium">Phạm Ngọc Lân</td>
                                    <td class="py-4 px-6 text-slate-600 dark:text-slate-400">6</td>
                                    <td class="py-4 px-6">
                                        <div class="flex items-center gap-2">
                                            <div class="h-2 bg-slate-200 dark:bg-slate-700 rounded-full flex-1" style="min-width: 60px;">
                                                <div class="h-full bg-emerald-500 rounded-full" style="width: 92%;"></div>
                                            </div>
                                            <span class="text-xs font-medium text-slate-900 dark:text-white">92%</span>
                                        </div>
                                    </td>
                                    <td class="py-4 px-6 text-slate-900 dark:text-white font-medium">7.9</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

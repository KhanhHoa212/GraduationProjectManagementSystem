@using GPMS.Application.DTOs
@model IEnumerable<ProjectImportPreviewDto>
@{
    ViewData["Title"] = "Xem trước Import Đề tài";
    Layout = "_Layout";
    var validCount = Model.Count(m => m.IsValid);
    var invalidCount = Model.Count(m => !m.IsValid);
}

<div class="space-y-6 pb-12">
    <!-- Header with Stats -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Kiểm tra dữ liệu Import</h1>
            <p class="text-slate-500 text-sm mt-1">Vui lòng rà soát kỹ các thông tin trước khi xác nhận lưu vào hệ thống.</p>
        </div>
        <div class="flex items-center gap-4">
            <div class="px-4 py-2 bg-emerald-50 border border-emerald-100 rounded-lg shadow-sm">
                <span class="block text-[10px] font-bold text-emerald-600 uppercase tracking-widest leading-tight">HỢP LỆ</span>
                <span class="text-xl font-black text-emerald-700">@validCount</span>
            </div>
            <div class="px-4 py-2 bg-red-50 border border-red-100 rounded-lg shadow-sm">
                <span class="block text-[10px] font-bold text-red-600 uppercase tracking-widest leading-tight">LỖI</span>
                <span class="text-xl font-black text-red-700">@invalidCount</span>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-2xl border border-slate-200 p-16 text-center shadow-sm">
            <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6">
                <span class="material-symbols-outlined text-5xl text-slate-200">folder_off</span>
            </div>
            <h3 class="text-xl font-bold text-slate-800">Không tìm thấy dữ liệu hợp lệ</h3>
            <p class="text-slate-500 text-sm max-w-sm mx-auto mt-2 leading-relaxed">File Excel của bạn có vẻ trống hoặc không đúng định dạng mẫu của hệ thống.</p>
            <div class="mt-8 flex justify-center gap-3">
                <a href="/HOD/Projects" class="px-8 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-xl font-bold transition no-underline flex items-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                    Quay lại danh sách
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Preview Table -->
        <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden animate-in fade-in slide-in-from-bottom duration-500">
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50/50 border-b border-slate-200">
                            <th class="px-6 py-4 font-bold text-slate-500 text-[10px] uppercase tracking-widest w-12 text-center">Dòng</th>
                            <th class="px-6 py-4 font-bold text-slate-500 text-[10px] uppercase tracking-widest">Thông tin đề tài</th>
                            <th class="px-6 py-4 font-bold text-slate-500 text-[10px] uppercase tracking-widest w-1/4">Mentor & Chuyên ngành</th>
                            <th class="px-6 py-4 font-bold text-slate-500 text-[10px] uppercase tracking-widest w-1/4">Thành viên (MSSV)</th>
                            <th class="px-6 py-4 font-bold text-slate-500 text-[10px] uppercase tracking-widest">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.IsValid ? "hover:bg-emerald-50/30" : "bg-red-50/20") transition-colors group">
                                <td class="px-6 py-5 text-center text-slate-400 font-mono text-xs">@item.RowIndex</td>
                                <td class="px-6 py-5">
                                    <div class="flex items-center gap-2 mb-1.5">
                                        <span class="px-1.5 py-0.5 bg-slate-100 text-slate-500 text-[10px] font-black rounded uppercase tracking-tighter">CODE</span>
                                        <span class="text-[11px] font-bold text-slate-600 uppercase tracking-widest">@item.Data.ProjectCode</span>
                                    </div>
                                    <div class="font-bold text-slate-800 leading-tight group-hover:text-[#1E3A5F] transition-colors">@item.Data.ProjectName</div>
                                    @if (!string.IsNullOrEmpty(item.Data.Description))
                                    {
                                        <p class="text-[11px] text-slate-400 mt-2 line-clamp-2 italic" title="@item.Data.Description">@item.Data.Description</p>
                                    }
                                </td>
                                <td class="px-6 py-5">
                                    <div class="space-y-2">
                                        <div class="flex items-center gap-2">
                                            <div class="w-6 h-6 rounded-full bg-blue-50 flex items-center justify-center">
                                                <span class="material-symbols-outlined text-[14px] text-blue-600">person</span>
                                            </div>
                                            <span class="text-slate-700 font-bold text-xs truncate max-w-[150px]" title="@item.Data.SupervisorEmail">@item.Data.SupervisorEmail</span>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <div class="w-6 h-6 rounded-full bg-slate-50 flex items-center justify-center">
                                                <span class="material-symbols-outlined text-[14px] text-slate-400">school</span>
                                            </div>
                                            <span class="text-slate-500 text-[11px] font-medium">@item.Data.MajorName</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    <div class="flex flex-wrap gap-1.5">
                                        @foreach (var mssv in item.Data.StudentEmails)
                                        {
                                            <span class="px-2 py-1 bg-white border border-slate-200 rounded-md text-[10px] font-black text-slate-600 shadow-sm border-b-2 border-b-slate-300">@mssv</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    @if (item.IsValid)
                                    {
                                        <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-100/50 text-emerald-700 rounded-full text-[10px] font-black uppercase tracking-wider">
                                            <span class="material-symbols-outlined text-[16px]">check_circle</span>
                                            Sẵn sàng
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="space-y-1.5">
                                            @foreach (var error in item.Errors)
                                            {
                                                <div class="flex items-start gap-1.5 text-red-600 text-[11px] font-bold leading-tight">
                                                    <span class="material-symbols-outlined text-[16px] mt-0 text-red-500">error</span>
                                                    <span>@error</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <!-- Footer Actions -->
            <div class="px-8 py-6 bg-slate-50/80 border-t border-slate-200 flex flex-col sm:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-2 text-slate-500 text-xs font-semibold">
                    <span class="material-symbols-outlined text-[18px]">info</span>
                    <span>Hệ thống chỉ xử lý những dòng có trạng thái <span class="text-emerald-700 font-black tracking-tighter uppercase px-1.5 py-0.5 bg-emerald-100 rounded">Sẵn sàng</span></span>
                </div>
                <div class="flex items-center gap-4">
                    <a href="/HOD/Projects" class="px-6 py-2.5 text-sm font-bold text-slate-600 hover:text-slate-900 transition no-underline">Quay lại sửa file</a>
                    
                    @if (validCount > 0)
                    {
                        <form asp-action="ConfirmProjectImport" asp-controller="HOD" method="post" id="confirmImportForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="importDataJson" id="importDataJson" value='@System.Text.Json.JsonSerializer.Serialize(Model.Where(m => m.IsValid).Select(m => m.Data))' />
                            <button type="submit" class="px-10 py-3 bg-[#F37021] hover:bg-orange-600 text-white rounded-xl text-sm font-black shadow-lg shadow-orange-500/20 transition-all transform active:scale-95 flex items-center gap-3">
                                <span class="material-symbols-outlined">save</span>
                                XÁC NHẬN LƯU @validCount ĐỀ TÀI
                            </button>
                        </form>
                    }
                    else
                    {
                        <button disabled class="px-10 py-3 bg-slate-200 text-slate-400 rounded-xl text-sm font-black cursor-not-allowed flex items-center gap-3 border border-slate-300">
                             <span class="material-symbols-outlined">block</span>
                             CHƯA CÓ DỮ LIỆU HỢP LỆ
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.getElementById('confirmImportForm')?.addEventListener('submit', function(e) {
            const btn = this.querySelector('button');
            const originalContent = btn.innerHTML;
            
            // Visual feedback
            btn.disabled = true;
            btn.classList.add('opacity-80', 'cursor-not-allowed');
            btn.innerHTML = `
                <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                ĐANG XỬ LÝ DỮ LIỆU...
            `;
        });
    </script>
}

@using GPMS.Application.DTOs
@model ChecklistDto
@{
    ViewData["Title"] = "Checklist Configuration";
    Layout = "~/Views/Shared/_HodLayout.cshtml";
    var activeSemester = ViewBag.ActiveSemester as SemesterDto;
    var reviewRounds = ViewBag.ReviewRounds as List<ReviewRoundDto> ?? new List<ReviewRoundDto>();
    var selectedRoundId = (int?)ViewBag.SelectedRoundId;
}

<div class="min-h-screen bg-slate-50">
    <div class="p-6">
        <div class="max-w-7xl mx-auto space-y-6">
            <!-- Header -->
            <div class="flex flex-col md:flex-row md:items-start justify-between gap-4 mb-8">
                <div>
                    <nav class="flex items-center gap-2 text-sm mb-4">
                        <a href="/Hod/Dashboard" class="text-slate-600 hover:text-[#F37021] transition-colors">GPMS</a>
                        <span class="text-slate-400">/</span>
                        <span class="text-slate-900 font-medium">Checklist</span>
                    </nav>
                    <h1 class="text-3xl font-bold text-slate-900">Checklist Configuration</h1>
                    <p class="text-slate-600 mt-2">
                        Define qualitative assessment criteria and rubrics
                        @if (activeSemester != null)
                        {
                            <span class="text-[#F37021] font-bold">(@activeSemester.SemesterCode)</span>
                        }
                    </p>
                </div>
                <div class="flex flex-wrap gap-3">
                    <button onclick="saveChecklist()" class="px-6 py-2.5 bg-[#1E3A5F] text-white rounded-xl hover:bg-slate-800 font-bold flex items-center gap-2 transition-all shadow-lg shadow-blue-900/10">
                        <span class="material-symbols-outlined" style="font-size: 20px;">save</span>
                        Save Configuration
                    </button>
                </div>
            </div>

            <!-- Round Selector & Information -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Select Round -->
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200">
                    <h2 class="text-sm font-bold text-slate-900 uppercase tracking-widest mb-4">Select Review Round</h2>
                    <div class="space-y-2">
                        @foreach (var round in reviewRounds)
                        {
                            <a href="/HOD/Checklists?roundId=@round.ReviewRoundID" 
                               class="flex items-center justify-between p-4 rounded-xl border transition-all @(selectedRoundId == round.ReviewRoundID ? "bg-orange-50 border-[#F37021] text-[#F37021] font-bold" : "bg-slate-50 border-slate-100 text-slate-600 hover:border-slate-300 hover:bg-white")">
                                <div class="flex items-center gap-3">
                                    <span class="material-symbols-outlined text-xl">@(round.RoundType == GPMS.Domain.Enums.RoundType.Online ? "language" : "groups")</span>
                                    <span>Round @round.RoundNumber: @round.RoundType</span>
                                </div>
                                <span class="material-symbols-outlined text-sm">@(selectedRoundId == round.ReviewRoundID ? "check_circle" : "chevron_right")</span>
                            </a>
                        }
                    </div>
                </div>

                <!-- Info Card -->
                <div class="lg:col-span-2 bg-white rounded-2xl p-6 shadow-sm border border-slate-200">
                    <h2 class="text-sm font-bold text-slate-900 uppercase tracking-widest mb-6">Checklist Details</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <p class="text-[10px] font-extrabold text-slate-500 uppercase tracking-wider">Linked Review Round</p>
                            @{
                                var selectedRound = reviewRounds.FirstOrDefault(r => r.ReviewRoundID == selectedRoundId);
                            }
                            <p class="text-lg font-bold text-slate-900 mt-2 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[#F37021]">task_alt</span>
                                @(selectedRound != null ? $"Round {selectedRound.RoundNumber} - {selectedRound.RoundType}" : "Select a round")
                            </p>
                        </div>
                        <div>
                            <p class="text-[10px] font-extrabold text-slate-500 uppercase tracking-wider">Configuration Summary</p>
                            <div class="mt-4 flex items-center gap-6">
                                <div>
                                    <span class="block text-2xl font-black text-slate-800" id="summaryItemCount">@Model.Items.Count</span>
                                    <span class="text-[10px] font-bold text-slate-400 uppercase">Total Items</span>
                                </div>
                                <div class="w-px h-8 bg-slate-100"></div>
                                <div>
                                    <span class="block text-2xl font-black text-[#F37021]" id="summaryYesNoCount">@Model.Items.Count(i => i.ItemType == "YesNo")</span>
                                    <span class="text-[10px] font-bold text-slate-400 uppercase">Yes/No Items</span>
                                </div>
                                <div class="w-px h-8 bg-slate-100"></div>
                                <div>
                                    <span class="block text-2xl font-black text-emerald-600" id="summaryRubricCount">@Model.Items.Count(i => i.ItemType == "Rubric")</span>
                                    <span class="text-[10px] font-bold text-slate-400 uppercase">Rubric Items</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Criteria Table Card -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="flex items-center justify-between p-6 border-b border-slate-100">
                    <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                        <span class="material-symbols-outlined text-slate-400">format_list_bulleted</span>
                        Assessment Criteria
                    </h2>
                    <button onclick="openAddCriteriaModal()" class="px-5 py-2 text-[#F37021] bg-orange-50 hover:bg-orange-100 rounded-xl font-bold text-sm flex items-center gap-2 transition-all">
                        <span class="material-symbols-outlined" style="font-size: 20px;">add_circle</span>
                        Add Item
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left" id="criteriaTable">
                        <thead>
                            <tr class="bg-slate-50/50 border-b border-slate-100">
                                <th class="py-4 px-6 text-[11px] font-extrabold text-slate-500 uppercase tracking-wider w-12">#</th>
                                <th class="py-4 px-6 text-[11px] font-extrabold text-slate-500 uppercase tracking-wider w-32">CODE</th>
                                <th class="py-4 px-6 text-[11px] font-extrabold text-slate-500 uppercase tracking-wider">TITLE / SECTION</th>
                                <th class="py-4 px-6 text-[11px] font-extrabold text-slate-500 uppercase tracking-wider w-1/3">CONTENT</th>
                                <th class="py-4 px-6 text-[11px] font-extrabold text-slate-500 uppercase tracking-wider text-center w-28">TYPE</th>
                                <th class="py-4 px-6 text-[11px] font-extrabold text-slate-500 uppercase tracking-wider text-center w-32">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100" id="criteriaList">
                            @for (int i = 0; i < Model.Items.Count; i++)
                            {
                                var item = Model.Items[i];
                                <tr class="criteria-row hover:bg-slate-50/50 transition-colors" data-id="@item.ItemID">
                                    <td class="py-4 px-6 font-bold text-slate-400">@(i + 1)</td>
                                    <td class="py-4 px-6">
                                        <span class="px-2.5 py-1 bg-slate-100 text-slate-700 rounded-lg font-bold text-[10px] tracking-wider border border-slate-200">@item.ItemCode</span>
                                    </td>
                                    <td class="py-4 px-6">
                                        <div class="font-bold text-slate-800">@item.ItemName</div>
                                        <div class="text-[10px] text-slate-400 font-bold uppercase mt-0.5">@item.Section</div>
                                    </td>
                                    <td class="py-4 px-6 text-slate-600">@item.ItemContent</td>
                                    <td class="py-4 px-6 text-center">
                                        <span class="px-2 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider @(item.ItemType == "Rubric" ? "bg-purple-100 text-purple-700 border border-purple-200" : "bg-blue-100 text-blue-700 border border-blue-200")">
                                            @item.ItemType
                                        </span>
                                    </td>
                                    <td class="py-4 px-6 text-center">
                                        <div class="flex items-center justify-center gap-1">
                                            <button onclick="editCriteriaByIndex(@i)" class="p-2 text-slate-400 hover:text-[#1E3A5F] hover:bg-slate-100 rounded-lg transition-all" title="Edit">
                                                <span class="material-symbols-outlined text-[20px]">edit_note</span>
                                            </button>
                                            <button onclick="removeCriteriaByIndex(@i)" class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all" title="Delete">
                                                <span class="material-symbols-outlined text-[20px]">delete</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Criteria Modal -->
<div id="criteriaModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-200">
        <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
            <div>
                <h3 id="modalTitle" class="text-xl font-bold text-slate-800">Assessment Item</h3>
                <p class="text-xs text-slate-500 font-medium mt-1">Define requirement details</p>
            </div>
            <button onclick="closeModal()" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-white hover:shadow-md transition-all text-slate-400 hover:text-slate-600">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-8 space-y-5">
            <input type="hidden" id="editItemId" value="-1">
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-1">
                    <label class="block text-[10px] font-extrabold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Item Code</label>
                    <input type="text" id="itemCode" placeholder="e.g. R1-01" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold focus:bg-white focus:border-[#F37021] outline-none transition-all">
                </div>
                <div class="col-span-1">
                    <label class="block text-[10px] font-extrabold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Type</label>
                    <select id="itemType" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold focus:bg-white focus:border-[#F37021] outline-none transition-all">
                        <option value="YesNo">Yes/No/NA</option>
                        <option value="Rubric">Rubric (R3)</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-[10px] font-extrabold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Item Name</label>
                <input type="text" id="itemName" placeholder="e.g. Final Presentation" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold focus:bg-white focus:border-[#F37021] outline-none transition-all">
            </div>
            <div>
                <label class="block text-[10px] font-extrabold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Section / Group</label>
                <input type="text" id="section" placeholder="e.g. Documentation" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold focus:bg-white focus:border-[#F37021] outline-none transition-all">
            </div>
            <div>
                <label class="block text-[10px] font-extrabold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Evaluation Content / Question</label>
                <textarea id="itemContent" rows="3" placeholder="Enter evaluation details..." class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium focus:bg-white focus:border-[#F37021] outline-none transition-all resize-none"></textarea>
            </div>
        </div>
        <div class="px-8 py-5 border-t border-slate-100 bg-slate-50 flex justify-end gap-3">
            <button onclick="closeModal()" class="px-6 py-2.5 text-xs font-extrabold text-slate-500 hover:text-slate-700 uppercase tracking-widest">Cancel</button>
            <button onclick="applyCriteriaChanges()" class="px-6 py-2.5 bg-[#F37021] text-white rounded-xl font-bold text-xs shadow-lg hover:bg-[#e66010] transition-all uppercase tracking-widest">Apply Changes</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let items = @Html.Raw(Json.Serialize(Model.Items));
        let selectedRoundId = @(selectedRoundId ?? 0);

        function updateSummary() {
            const count = items.length;
            const yesNoCount = items.filter(i => i.itemType === 'YesNo').length;
            const rubricCount = items.filter(i => i.itemType === 'Rubric').length;

            document.getElementById('summaryItemCount').innerText = count;
            document.getElementById('summaryYesNoCount').innerText = yesNoCount;
            document.getElementById('summaryRubricCount').innerText = rubricCount;
        }

        function renderRows() {
            const list = document.getElementById('criteriaList');
            list.innerHTML = '';
            
            items.forEach((item, index) => {
                const tr = document.createElement('tr');
                tr.className = 'criteria-row hover:bg-slate-50/50 transition-colors';
                tr.setAttribute('data-id', item.itemID);
                
                const typeClass = item.itemType === 'Rubric' 
                    ? 'bg-purple-100 text-purple-700 border border-purple-200' 
                    : 'bg-blue-100 text-blue-700 border border-blue-200';

                tr.innerHTML = `
                    <td class="py-4 px-6 font-bold text-slate-400">${index + 1}</td>
                    <td class="py-4 px-6">
                        <span class="px-2.5 py-1 bg-slate-100 text-slate-700 rounded-lg font-bold text-[10px] tracking-wider border border-slate-200">${item.itemCode || ''}</span>
                    </td>
                    <td class="py-4 px-6">
                        <div class="font-bold text-slate-800">${item.itemName || 'Untitled'}</div>
                        <div class="text-[10px] text-slate-400 font-bold uppercase mt-0.5">${item.section || 'General'}</div>
                    </td>
                    <td class="py-4 px-6 text-slate-600 font-medium text-xs leading-relaxed">${item.itemContent}</td>
                    <td class="py-4 px-6 text-center">
                        <span class="px-2 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider ${typeClass}">
                            ${item.itemType}
                        </span>
                    </td>
                    <td class="py-4 px-6 text-center">
                        <div class="flex items-center justify-center gap-1">
                            <button onclick="editCriteriaByIndex(${index})" class="p-2 text-slate-400 hover:text-[#1E3A5F] hover:bg-slate-100 rounded-lg transition-all" title="Edit">
                                <span class="material-symbols-outlined text-[20px]">edit_note</span>
                            </button>
                            <button onclick="removeCriteriaByIndex(${index})" class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all" title="Delete">
                                <span class="material-symbols-outlined text-[20px]">delete</span>
                            </button>
                        </div>
                    </td>
                `;
                list.appendChild(tr);
            });
            updateSummary();
        }

        function openAddCriteriaModal() {
            document.getElementById('modalTitle').innerText = 'Add New Item';
            document.getElementById('editItemId').value = '-1';
            document.getElementById('itemCode').value = '';
            document.getElementById('itemName').value = '';
            document.getElementById('section').value = '';
            document.getElementById('itemType').value = 'YesNo';
            document.getElementById('itemContent').value = '';
            document.getElementById('criteriaModal').classList.remove('hidden');
        }

        function editCriteriaByIndex(index) {
            const item = items[index];
            document.getElementById('modalTitle').innerText = 'Edit Assessment Item';
            document.getElementById('editItemId').value = index;
            document.getElementById('itemCode').value = item.itemCode || '';
            document.getElementById('itemName').value = item.itemName || '';
            document.getElementById('section').value = item.section || '';
            document.getElementById('itemType').value = item.itemType || 'YesNo';
            document.getElementById('itemContent').value = item.itemContent || '';
            document.getElementById('criteriaModal').classList.remove('hidden');
        }

        function applyCriteriaChanges() {
            const index = parseInt(document.getElementById('editItemId').value);
            const code = document.getElementById('itemCode').value;
            const name = document.getElementById('itemName').value;
            const sect = document.getElementById('section').value;
            const type = document.getElementById('itemType').value;
            const content = document.getElementById('itemContent').value;

            if (!code || !content) {
                alert('Please fill in both code and content.');
                return;
            }

            const itemData = {
                itemCode: code,
                itemName: name,
                section: sect,
                itemType: type,
                itemContent: content
            };

            if (index === -1) {
                itemData.itemID = 0;
                itemData.orderIndex = items.length + 1;
                items.push(itemData);
            } else {
                items[index] = { ...items[index], ...itemData };
            }

            renderRows();
            closeModal();
        }

        function removeCriteriaByIndex(index) {
            if (confirm('Are you sure you want to remove this assessment item?')) {
                items.splice(index, 1);
                items.forEach((item, idx) => item.orderIndex = idx + 1);
                renderRows();
            }
        }

        function closeModal() {
            document.getElementById('criteriaModal').classList.add('hidden');
        }

        async function saveChecklist() {
            if (selectedRoundId === 0) {
                alert('Please select a review round first.');
                return;
            }

            const data = {
                reviewRoundID: selectedRoundId,
                title: "Assessment Checklist",
                description: "Evaluation criteria for project review",
                items: items.map(i => ({
                    itemID: i.itemID,
                    itemCode: i.itemCode,
                    itemName: i.itemName,
                    section: i.section,
                    itemType: i.itemType,
                    itemContent: i.itemContent,
                    orderIndex: i.orderIndex
                }))
            };

            try {
                const response = await fetch('/HOD/SaveChecklist', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                if (result.success) {
                    alert('Checklist configuration saved successfully!');
                    location.reload();
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (error) {
                console.error('Error saving checklist:', error);
                alert('Connection error. Please try again.');
            }
        }

        // Initialize
        if (items.length > 0) updateSummary();
    </script>
}

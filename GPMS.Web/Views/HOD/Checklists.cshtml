@{
    ViewData["Title"] = "Checklist Configuration";
    Layout = "~/Views/Shared/_HodLayout.cshtml";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950">
    <div class="p-6">
        <div class="max-w-7xl mx-auto space-y-6">
            <!-- Header -->
            <div class="flex items-start justify-between mb-8">
                <div>
                    <nav class="flex items-center gap-2 text-sm mb-4">
                        <a href="/Hod/Dashboard" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200">GPMS</a>
                        <span class="text-slate-400 dark:text-slate-600">/</span>
                        <span class="text-slate-900 dark:text-slate-100 font-medium">Checklist</span>
                    </nav>
                    <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Checklist Configuration</h1>
                    <p class="text-slate-600 dark:text-slate-400 mt-2">Define assessment criteria and weights for quality assurance</p>
                </div>
                <div class="flex gap-3">
                    <button class="px-6 py-2 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 font-medium flex items-center gap-2 transition">
                        <span class="material-symbols-outlined" style="font-size: 20px;">download</span>
                        Export PDF
                    </button>
                    <button class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium flex items-center gap-2 transition">
                        <span class="material-symbols-outlined" style="font-size: 20px;">save</span>
                        Save Configuration
                    </button>
                </div>
            </div>

            <!-- Checklist Information Card -->
            <div class="bg-white dark:bg-slate-900 rounded-xl p-8 shadow-sm border border-slate-200 dark:border-slate-800">
                <div class="flex items-start gap-6">
                    <div class="flex-1">
                        <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-6">Checklist Information</h2>
                        <div class="grid grid-cols-3 gap-6">
                            <div>
                                <p class="text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wide">Checklist Title</p>
                                <p class="text-base font-semibold text-slate-900 dark:text-white mt-2">Technical Quality Assessment v2.0</p>
                                <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Last updated: Oct 12, 2023</p>
                            </div>
                            <div>
                                <p class="text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wide">Linked Review Round</p>
                                <div class="mt-2 space-y-2">
                                    <p class="text-base font-semibold text-slate-900 dark:text-white flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[#F37021]" style="font-size: 18px;">check_circle</span>
                                        Q4 Technical Review 2023
                                    </p>
                                    <p class="text-sm text-slate-600 dark:text-slate-400">Status: Active</p>
                                </div>
                            </div>
                            <div>
                                <p class="text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wide">Description</p>
                                <p class="text-sm text-slate-600 dark:text-slate-400 mt-2">Standard criteria for reviewing software architecture, code quality, security protocols, and performance metrics across all enterprise applications.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Criteria Table Card -->
            <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
                <div class="flex items-center justify-between p-6 border-b border-slate-200 dark:border-slate-800">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white flex items-center gap-2">
                        <span class="material-symbols-outlined" style="font-size: 24px;">table_chart</span>
                        Criteria Table
                    </h2>
                    <button class="px-4 py-2 text-[#F37021] hover:bg-orange-50 dark:hover:bg-orange-900/20 rounded-lg font-medium flex items-center gap-2 transition">
                        <span class="material-symbols-outlined" style="font-size: 20px;">add_circle</span>
                        Add Criteria
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-slate-50 dark:bg-slate-800">
                            <tr class="border-b border-slate-200 dark:border-slate-700">
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300 w-12">STT</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300 w-24">CODE</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">CRITERIA CONTENT</th>
                                <th class="text-center py-4 px-6 font-semibold text-slate-700 dark:text-slate-300 w-24">MAX SCORE</th>
                                <th class="text-center py-4 px-6 font-semibold text-slate-700 dark:text-slate-300 w-24">WEIGHT (%)</th>
                                <th class="text-center py-4 px-6 font-semibold text-slate-700 dark:text-slate-300 w-24">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                            <!-- Row 1 -->
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="py-4 px-6 text-slate-500 dark:text-slate-400">01</td>
                                <td class="py-4 px-6">
                                    <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded font-semibold text-xs">ARCH-01</span>
                                </td>
                                <td class="py-4 px-6 text-slate-900 dark:text-white">Architecture Complienance: Code follows the defined hierarchal architecture and layer separation rules.</td>
                                <td class="py-4 px-6 text-center text-slate-900 dark:text-white font-semibold">10.0</td>
                                <td class="py-4 px-6 text-center text-slate-900 dark:text-white font-semibold">25</td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center justify-center gap-2">
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                                        </button>
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400 transition">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>

                            <!-- Row 2 -->
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="py-4 px-6 text-slate-500 dark:text-slate-400">02</td>
                                <td class="py-4 px-6">
                                    <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded font-semibold text-xs">CODE-02</span>
                                </td>
                                <td class="py-4 px-6 text-slate-900 dark:text-white">Clean Code Standards: Proper naming conventions, method length limits, and documentation.</td>
                                <td class="py-4 px-6 text-center text-slate-900 dark:text-white font-semibold">10.0</td>
                                <td class="py-4 px-6 text-center text-slate-900 dark:text-white font-semibold">20</td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center justify-center gap-2">
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                                        </button>
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400 transition">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>

                            <!-- Row 3 -->
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="py-4 px-6 text-slate-500 dark:text-slate-400">03</td>
                                <td class="py-4 px-6">
                                    <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded font-semibold text-xs">SEC-01</span>
                                </td>
                                <td class="py-4 px-6 text-slate-900 dark:text-white">Security: Input validation, proper authentication checks, and no hardcoded credentials.</td>
                                <td class="py-4 px-6 text-center text-slate-900 dark:text-white font-semibold">10.0</td>
                                <td class="py-4 px-6 text-center text-slate-900 dark:text-white font-semibold">30</td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center justify-center gap-2">
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                                        </button>
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400 transition">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>

                            <!-- Row 4 -->
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="py-4 px-6 text-slate-500 dark:text-slate-400">04</td>
                                <td class="py-4 px-6">
                                    <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded font-semibold text-xs">PERF-04</span>
                                </td>
                                <td class="py-4 px-6 text-slate-900 dark:text-white">Performance: Database query optimization and efficient resource utilization.</td>
                                <td class="py-4 px-6 text-center text-slate-900 dark:text-white font-semibold">10.0</td>
                                <td class="py-4 px-6 text-center text-slate-900 dark:text-white font-semibold">15</td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center justify-center gap-2">
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                                        </button>
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400 transition">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>

                            <!-- Row 5 -->
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="py-4 px-6 text-slate-500 dark:text-slate-400">05</td>
                                <td class="py-4 px-6">
                                    <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded font-semibold text-xs">TEST-01</span>
                                </td>
                                <td class="py-4 px-6 text-slate-900 dark:text-white">Unit Testing: Coverage is > 80% and includes edge cases for new logic.</td>
                                <td class="py-4 px-6 text-center text-slate-900 dark:text-white font-semibold">10.0</td>
                                <td class="py-4 px-6 text-center text-slate-900 dark:text-white font-semibold">10</td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center justify-center gap-2">
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">edit</span>
                                        </button>
                                        <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400 transition">
                                            <span class="material-symbols-outlined" style="font-size: 18px;">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Total Score Configuration -->
                <div class="flex items-center justify-between p-6 bg-slate-50 dark:bg-slate-800 border-t border-slate-200 dark:border-slate-700">
                    <p class="text-sm font-semibold text-slate-700 dark:text-slate-300 uppercase tracking-wide">Total Score Configuration</p>
                    <div class="flex items-center gap-4">
                        <span class="text-2xl font-bold text-slate-900 dark:text-white">50.0</span>
                        <div class="w-16 h-16 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-lg shadow-md">
                            100
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pro Tip Card -->
            <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl p-6 flex items-start gap-4">
                <span class="material-symbols-outlined text-blue-600 dark:text-blue-400 flex-shrink-0 mt-1" style="font-size: 24px;">info</span>
                <div>
                    <p class="text-sm font-semibold text-blue-900 dark:text-blue-200">
                        Pro Tip: Ensure that the total weight across all criteria adds up to exactly 100% for accurate scoring calculations in the review round.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

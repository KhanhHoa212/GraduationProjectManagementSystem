@using GPMS.Application.DTOs
@using GPMS.Domain.Enums
@model IEnumerable<ChecklistDto>
@{
    ViewData["Title"] = "Cấu hình Checklist";
    Layout = "_HODLayout";
    var rounds = ViewBag.ReviewRounds as IEnumerable<ReviewRoundDto> ?? new List<ReviewRoundDto>();
    var checklists = ViewBag.Checklists as IEnumerable<ChecklistDto> ?? new List<ChecklistDto>();
    var activeSemester = ViewBag.ActiveSemester as SemesterDto;
    var semesters = ViewBag.Semesters as IEnumerable<SemesterDto> ?? new List<SemesterDto>();
}

<div class="p-6">
    <div class="flex justify-between items-start mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Cấu hình Checklist</h1>
            <p class="text-gray-500">Quản lý tiêu chí đánh giá cho từng vòng review trong học kỳ @activeSemester?.SemesterCode</p>
        </div>
        <div class="flex gap-3">
            <button onclick="openCopyModal()" class="px-4 py-2 border border-orange-500 text-orange-500 rounded-lg hover:bg-orange-50 transition-colors flex items-center gap-2">
                <i class="ri-file-copy-line"></i>
                Copy từ kỳ trước
            </button>
            <a href="/HOD/ReviewRounds" class="px-4 py-2 bg-orange-500 text-white rounded-lg hover:bg-orange-600 transition-colors flex items-center gap-2">
                <i class="ri-add-line"></i>
                Quản lý Vòng Review
            </a>
        </div>
    </div>

    <!-- Tabs Header -->
    <div class="border-b border-gray-200 mb-8">
        <div class="flex gap-8">
            @foreach (var round in rounds.OrderBy(r => r.RoundNumber))
            {
                var isRubric = round.RoundNumber == 3;
                <button onclick="switchTab(@round.RoundNumber)" 
                        id="tab-btn-@round.RoundNumber"
                        class="tab-btn pb-4 px-2 text-sm font-medium transition-all relative @(round.RoundNumber == 1 ? "text-indigo-600 border-b-2 border-indigo-600" : "text-gray-500 hover:text-gray-700")">
                    <span class="flex items-center gap-2">
                        Review @round.RoundNumber
                        <span class="px-2 py-0.5 rounded-full text-[10px] @(isRubric ? "bg-purple-100 text-purple-600" : "bg-blue-100 text-blue-600")">
                            @(isRubric ? "⭐ Rubric" : "Yes/No")
                        </span>
                    </span>
                </button>
            }
        </div>
    </div>

    <!-- Tab Contents -->
    <div id="tab-contents">
        @foreach (var round in rounds.OrderBy(r => r.RoundNumber))
        {
            var checklist = checklists.FirstOrDefault(c => c.ReviewRoundID == round.ReviewRoundID);
            var isRubric = round.RoundNumber == 3;

            <div id="content-@round.RoundNumber" class="tab-content @(round.RoundNumber != 1 ? "hidden" : "") animate-fadeIn">
                <!-- Summary & Actions -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6 flex justify-between items-center">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600">
                            <i class="ri-folder-info-line text-2xl"></i>
                        </div>
                        <div>
                            <h2 class="text-lg font-bold text-gray-800">@(checklist?.Title ?? $"Review {round.RoundNumber} Checklist")</h2>
                            <p class="text-sm text-gray-500">@round.StartDate.ToString("dd/MM/yyyy") – @round.EndDate.ToString("dd/MM/yyyy")</p>
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <a href="/HOD/EditChecklist/@round.ReviewRoundID" class="px-4 py-2 border border-blue-600 text-blue-600 rounded-lg font-medium text-sm hover:bg-blue-50 transition-colors flex items-center gap-2">
                             <i class="ri-edit-line"></i> Chỉnh sửa cấu trúc
                        </a>
                    </div>
                </div>

                @if (checklist == null || !checklist.Items.Any())
                {
                    <div class="bg-white rounded-2xl border-2 border-dashed border-gray-100 p-12 flex flex-col items-center text-center">
                        <div class="w-16 h-16 bg-orange-50 rounded-full flex items-center justify-center text-orange-500 mb-4">
                            <i class="ri-error-warning-line text-3xl"></i>
                        </div>
                        <h3 class="text-lg font-bold text-gray-800 mb-2">Chưa có nội dung cho vòng review này</h3>
                        <p class="text-gray-500 max-w-sm mb-6">Vui lòng cấu hình bộ tiêu chí đánh giá để Reviewer có thể bắt đầu chấm bài.</p>
                        <a href="/HOD/EditChecklist/@round.ReviewRoundID" class="px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-bold transition-all">
                            + Thiết lập ngay
                        </a>
                    </div>
                }
                else
                {
                    if (isRubric)
                    {
                        <!-- Rubric Scale Info -->
                        <div class="bg-indigo-900 text-white rounded-xl p-6 mb-6 shadow-sm">
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                                <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-green-500"></span> <span class="text-xs font-bold">Excellent: 8-10</span></div>
                                <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-blue-500"></span> <span class="text-xs font-bold">Good: 6-8</span></div>
                                <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-yellow-400"></span> <span class="text-xs font-bold">Acceptable: 4-6</span></div>
                                <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-red-500"></span> <span class="text-xs font-bold">Fail: 0-4</span></div>
                            </div>
                        </div>

                        <!-- Rubric Items by Section -->
                        @foreach (var group in checklist.Items.GroupBy(i => i.Section ?? "General").OrderBy(g => g.Key))
                        {
                            <div class="mb-6">
                                <h3 class="text-xs font-black text-indigo-600 uppercase tracking-widest mb-4 flex items-center gap-2">
                                    <i class="ri-bookmark-3-line"></i> @group.Key
                                    <span class="h-px bg-indigo-100 flex-grow"></span>
                                </h3>
                                <div class="grid gap-4">
                                    @foreach (var item in group.OrderBy(i => i.OrderIndex))
                                    {
                                        <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden group">
                                            <div class="p-4 bg-gray-50/50 border-b border-gray-100 flex justify-between items-center">
                                                <div class="flex items-center gap-2">
                                                    <span class="text-[10px] font-bold text-gray-400">@item.ItemCode</span>
                                                    <h4 class="font-bold text-gray-700">@item.ItemName</h4>
                                                </div>
                                                <button onclick="toggleRubric('@item.ItemID')" class="text-xs text-indigo-600 font-bold hover:underline">Chi tiết Rubric</button>
                                            </div>
                                            <div class="p-4">
                                                <p class="text-sm text-gray-600 leading-relaxed mb-3">@item.ItemContent</p>
                                                <div id="rubric-@item.ItemID" class="hidden grid grid-cols-1 md:grid-cols-4 gap-2 animate-fadeIn">
                                                    @foreach (var level in new[] { "Excellent", "Good", "Acceptable", "Fail" })
                                                    {
                                                        var rb = item.Rubrics.FirstOrDefault(r => r.GradeLevel == level);
                                                        <div class="p-2 rounded bg-gray-50 border border-gray-100 italic text-[10px] text-gray-500">
                                                            <div class="font-bold uppercase text-gray-400 mb-1">@level</div>
                                                            @rb?.Description
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <!-- Yes/No Items by Section -->
                        <div class="space-y-4">
                            @foreach (var group in checklist.Items.GroupBy(i => i.Section ?? "General").OrderBy(g => g.Key))
                            {
                                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                                    <div class="p-4 bg-gray-50/50 flex justify-between items-center">
                                        <h3 class="font-bold text-gray-700">@group.Key</h3>
                                        <span class="text-[10px] bg-gray-200 text-gray-500 px-2 py-0.5 rounded-full font-bold">@group.Count() TIÊU CHÍ</span>
                                    </div>
                                    <div class="divide-y border-t border-gray-50">
                                        @foreach (var item in group.OrderBy(i => i.OrderIndex))
                                        {
                                            <div class="p-4 flex gap-4 items-start group">
                                                <div class="text-[10px] font-mono font-bold text-gray-300 group-hover:text-blue-500 pt-1">@item.ItemCode</div>
                                                <p class="text-sm text-gray-600 flex-grow leading-relaxed">@item.ItemContent</p>
                                                <div class="flex gap-1 pt-1 opacity-40">
                                                    <span class="w-5 h-5 rounded border bg-gray-50 flex items-center justify-center text-[9px] font-bold text-gray-400">Y</span>
                                                    <span class="w-5 h-5 rounded border bg-gray-50 flex items-center justify-center text-[9px] font-bold text-gray-400">N</span>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

<!-- Copy Modal -->
<div id="copyModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md overflow-hidden">
        <div class="p-4 border-b flex justify-between items-center bg-gray-50">
            <h3 class="font-bold text-gray-800 flex items-center gap-2">
                <i class="ri-file-copy-line text-orange-500"></i>
                Copy Checklist từ kỳ học khác
            </h3>
            <button onclick="closeCopyModal()" class="text-gray-400 hover:text-gray-600"><i class="ri-close-line text-xl"></i></button>
        </div>
        <div class="p-6">
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Chọn kỳ học nguồn:</label>
                <select id="sourceSemester" class="w-full border-gray-300 rounded-lg shadow-sm focus:border-orange-500 focus:ring-orange-500">
                    @foreach (var sem in semesters.Where(s => s.SemesterID != activeSemester?.SemesterID))
                    {
                        <option value="@sem.SemesterID">@sem.SemesterCode (@sem.AcademicYear)</option>
                    }
                </select>
            </div>
            
            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Chọn vòng review để copy:</label>
                <div class="space-y-2">
                    <label class="flex items-center gap-2 p-2 hover:bg-gray-50 rounded cursor-pointer">
                        <input type="checkbox" name="roundNum" value="1" checked class="rounded text-orange-500 focus:ring-orange-500">
                        <span class="text-sm text-gray-700">Review 1 Checklist</span>
                    </label>
                    <label class="flex items-center gap-2 p-2 hover:bg-gray-50 rounded cursor-pointer">
                        <input type="checkbox" name="roundNum" value="2" checked class="rounded text-orange-500 focus:ring-orange-500">
                        <span class="text-sm text-gray-700">Review 2 Checklist</span>
                    </label>
                    <label class="flex items-center gap-2 p-2 hover:bg-gray-50 rounded cursor-pointer">
                        <input type="checkbox" name="roundNum" value="3" checked class="rounded text-orange-500 focus:ring-orange-500">
                        <span class="text-sm text-gray-700">Review 3 Final Checklist</span>
                    </label>
                </div>
            </div>

            <div class="bg-orange-50 p-3 rounded-lg flex items-start gap-2 mb-6">
                <i class="ri-error-warning-line text-orange-500 mt-0.5"></i>
                <p class="text-xs text-orange-700">
                    Lưu ý: Thao tác này sẽ ghi đè checklist hiện tại của kỳ học @activeSemester?.SemesterCode nếu đã tồn tại.
                </p>
            </div>

            <div class="flex justify-end gap-3">
                <button onclick="closeCopyModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg">Hủy</button>
                <button onclick="executeCopy()" class="px-6 py-2 bg-orange-500 text-white rounded-lg hover:bg-orange-600 font-medium">📋 Copy và áp dụng</button>
            </div>
        </div>
    </div>
</div>

<script>
    function switchTab(roundNum) {
        // Toggle Buttons
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('text-indigo-600', 'border-b-2', 'border-indigo-600');
            btn.classList.add('text-gray-500');
        });
        const activeBtn = document.getElementById('tab-btn-' + roundNum);
        activeBtn.classList.remove('text-gray-500');
        activeBtn.classList.add('text-indigo-600', 'border-b-2', 'border-indigo-600');

        // Toggle Contents
        document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
        document.getElementById('content-' + roundNum).classList.remove('hidden');
    }

    function toggleDropdown(roundNum) {
        const dropdown = document.getElementById('dropdown-' + roundNum);
        const allDropdowns = document.querySelectorAll('.dropdown-menu');
        
        // Close others
        allDropdowns.forEach(d => {
            if (d.id !== 'dropdown-' + roundNum) d.classList.add('hidden');
        });

        dropdown.classList.toggle('hidden');
    }

    // Close dropdowns on outside click
    window.addEventListener('click', function(e) {
        if (!e.target.closest('.dropdown-container')) {
            document.querySelectorAll('.dropdown-menu').forEach(d => d.classList.add('hidden'));
        }
    });

    function openCopyModal() {
        document.getElementById('copyModal').classList.remove('hidden');
        document.getElementById('copyModal').classList.add('flex');
    }

    function closeCopyModal() {
        document.getElementById('copyModal').classList.add('hidden');
        document.getElementById('copyModal').classList.remove('flex');
    }

    function toggleRubric(itemId) {
        const el = document.getElementById('rubric-' + itemId);
        el.classList.toggle('hidden');
    }

    async function executeCopy() {
        const fromSemesterId = parseInt(document.getElementById('sourceSemester').value);
        const roundNums = Array.from(document.querySelectorAll('input[name="roundNum"]:checked')).map(cb => parseInt(cb.value));
        
        if (roundNums.length === 0) {
            alert('Vui lòng chọn ít nhất một vòng review.');
            return;
        }

        const data = {
            fromSemesterId: fromSemesterId,
            toSemesterId: @(activeSemester?.SemesterID ?? 0),
            roundNumbers: roundNums
        };

        try {
            const response = await fetch('/HOD/CopyChecklists', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await response.json();
            if (result.success) {
                location.reload();
            } else {
                alert(result.message);
            }
        } catch (err) {
            alert('Đã có lỗi xảy ra.');
        }
    }
</script>

<style>
    .animate-fadeIn {
        animation: fadeIn 0.4s ease-out;
    }
    .animate-scaleIn {
        animation: scaleIn 0.2s ease-out;
        transform-origin: top right;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@keyframes scaleIn {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }
</style>

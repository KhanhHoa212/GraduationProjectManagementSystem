@{
    ViewData["Title"] = "Checklist Configuration";
    Layout = "~/Views/Shared/_HodLayout.cshtml";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950">
    <div class="p-6">
        <div class="max-w-7xl mx-auto space-y-6">
            <!-- Header -->
            <div class="flex items-start justify-between mb-8">
                <div>
                    <nav class="flex items-center gap-2 text-sm mb-4">
                        <a href="/Hod/Dashboard" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 no-underline">GPMS</a>
                        <span class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
                        <span class="text-slate-900 dark:text-slate-100 font-bold">Cấu hình Checklist</span>
                    </nav>
                    <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Cấu hình Checklist</h1>
                    <p class="text-slate-600 dark:text-slate-400 mt-2 font-medium">Quản lý tiêu chí đánh giá cho từng vòng review</p>
                </div>
                <button class="px-6 py-2.5 bg-[#F37021] text-white rounded-xl hover:bg-[#E55D0D] font-bold shadow-lg shadow-orange-500/20 flex items-center gap-2 transition-all active:scale-95">
                    <span class="material-symbols-outlined" style="font-size: 20px;">add</span>
                    Tạo checklist mới
                </button>
            </div>

            <!-- Tab Navigation -->
            <div class="border-b border-slate-200 dark:border-slate-800">
                <div class="flex gap-1">
                    <!-- Review 1 Tab -->
                    <button class="review-tab px-6 py-4 text-slate-500 dark:text-slate-400 border-b-2 border-transparent hover:text-slate-900 dark:hover:text-slate-200 transition-all font-bold" data-tab="review1">
                        <div class="flex flex-col items-center">
                            <span class="text-[15px]">Review 1</span>
                            <span class="text-[10px] font-extrabold uppercase tracking-widest opacity-60">Yes/No</span>
                        </div>
                    </button>
                    
                    <!-- Review 2 Tab -->
                    <button class="review-tab px-6 py-4 text-slate-500 dark:text-slate-400 border-b-2 border-transparent hover:text-slate-900 dark:hover:text-slate-200 transition-all font-bold" data-tab="review2">
                        <div class="flex flex-col items-center">
                            <span class="text-[15px]">Review 2</span>
                            <span class="text-[10px] font-extrabold uppercase tracking-widest opacity-60">Yes/No</span>
                        </div>
                    </button>
                    
                    <!-- Review 3 Tab -->
                    <button class="review-tab px-6 py-4 text-slate-500 dark:text-slate-400 border-b-2 border-transparent hover:text-slate-900 dark:hover:text-slate-200 transition-all font-bold active" data-tab="review3">
                        <div class="flex flex-col items-center">
                            <div class="flex items-center gap-1">
                                <span class="text-[15px]">Review 3</span>
                                <span class="material-symbols-outlined text-amber-500 text-sm">star</span>
                            </div>
                            <span class="text-[10px] font-extrabold uppercase tracking-widest opacity-60">Rubric Based</span>
                        </div>
                    </button>
                </div>
            </div>

            <!-- TAB CONTENT -->

            <!-- REVIEW 1 TAB (Yes/No Checklist) -->
            <div id="review1" class="tab-content hidden space-y-6 animate-in fade-in slide-in-from-bottom-2 duration-300">
                <!-- Checklist Info Card -->
                <div class="bg-white dark:bg-slate-900 rounded-2xl p-8 border border-slate-200 dark:border-slate-800 shadow-[0_8px_30px_rgb(0,0,0,0.04)]">
                    <div class="flex items-start justify-between">
                        <div class="flex gap-5">
                            <div class="w-14 h-14 rounded-2xl bg-orange-50 dark:bg-orange-950/30 flex items-center justify-center text-[#F37021] border border-orange-100 dark:border-orange-900/50">
                                <span class="material-symbols-outlined text-3xl">fact_check</span>
                            </div>
                            <div>
                                <h2 class="text-xl font-bold text-slate-900 dark:text-white">FPTU SE Capstone Project – Review 1 Checklist</h2>
                                <div class="flex flex-wrap items-center gap-4 mt-3">
                                    <span class="flex items-center gap-1.5 text-sm font-bold text-slate-500 dark:text-slate-400">
                                        <span class="material-symbols-outlined text-base">style</span>
                                        Dạng đánh giá: Yes / No / N/A
                                    </span>
                                    <span class="w-1 h-1 rounded-full bg-slate-300 dark:bg-slate-700"></span>
                                    <span class="flex items-center gap-1.5 text-sm font-bold text-[#F37021]">
                                        <span class="material-symbols-outlined text-base">event_available</span>
                                        Áp dụng: Round 1 · SP26 – 2025-2026
                                    </span>
                                </div>
                            </div>
                        </div>
                        <button class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
                            <span class="material-symbols-outlined">edit</span>
                        </button>
                    </div>
                </div>

                <!-- Sections -->
                <div class="space-y-4">
                    <!-- Section P1 -->
                    <div class="section-card bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm transition-all">
                        <div class="section-header p-6 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800/50 flex items-center justify-between transition">
                            <div class="flex items-center gap-4">
                                <span class="material-symbols-outlined toggle-icon text-slate-400 transition-transform">expand_more</span>
                                <div class="w-10 h-10 rounded-xl bg-slate-900 dark:bg-slate-700 text-white flex items-center justify-center font-bold text-sm">P1</div>
                                <div>
                                    <span class="font-bold text-slate-900 dark:text-white text-lg">Coverage of Objectives</span>
                                    <span class="text-xs font-bold text-slate-400 ml-2 uppercase tracking-tighter">(4 câu hỏi)</span>
                                </div>
                            </div>
                        </div>
                        <div class="section-content">
                            <div class="p-6 pt-0 space-y-3 border-t border-slate-100 dark:border-slate-800/50">
                                <!-- Question rows -->
                                <div class="flex items-start gap-4 p-4 hover:bg-slate-50 dark:hover:bg-slate-800/30 rounded-xl transition-colors group">
                                    <div class="mt-1 text-slate-300 dark:text-slate-700 cursor-move opacity-0 group-hover:opacity-100 transition-opacity">
                                        <span class="material-symbols-outlined">drag_indicator</span>
                                    </div>
                                    <div class="flex-1">
                                        <p class="text-slate-800 dark:text-slate-200 font-bold">Is problem to solve stated clearly?</p>
                                    </div>
                                    <span class="px-2.5 py-1 bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 text-[10px] font-extrabold uppercase tracking-wider rounded border border-red-100 dark:border-red-900/50">Mandatory</span>
                                    <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button class="p-2 text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
                                            <span class="material-symbols-outlined text-[20px]">edit</span>
                                        </button>
                                        <button class="p-2 text-slate-400 hover:text-red-500 transition-colors">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                    </div>
                                </div>

                                <div class="flex items-start gap-4 p-4 hover:bg-slate-50 dark:hover:bg-slate-800/30 rounded-xl transition-colors group border-t border-slate-50 dark:border-slate-800/50">
                                    <div class="mt-1 text-slate-300 dark:text-slate-700 cursor-move opacity-0 group-hover:opacity-100 transition-opacity">
                                        <span class="material-symbols-outlined">drag_indicator</span>
                                    </div>
                                    <div class="flex-1">
                                        <p class="text-slate-800 dark:text-slate-200 font-bold">Is a functional overview of the system provided?</p>
                                    </div>
                                    <span class="text-slate-300 dark:text-slate-700 text-xs">—</span>
                                    <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button class="p-2 text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
                                            <span class="material-symbols-outlined text-[20px]">edit</span>
                                        </button>
                                        <button class="p-2 text-slate-400 hover:text-red-500 transition-colors">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                    </div>
                                </div>

                                <div class="flex items-start gap-4 p-4 hover:bg-slate-50 dark:hover:bg-slate-800/30 rounded-xl transition-colors group border-t border-slate-50 dark:border-slate-800/50">
                                    <div class="mt-1 text-slate-300 dark:text-slate-700 cursor-move opacity-0 group-hover:opacity-100 transition-opacity">
                                        <span class="material-symbols-outlined">drag_indicator</span>
                                    </div>
                                    <div class="flex-1">
                                        <p class="text-slate-800 dark:text-slate-200 font-bold">If assumptions that affect implementation have been made, are they stated?</p>
                                    </div>
                                    <span class="text-slate-300 dark:text-slate-700 text-xs">—</span>
                                    <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button class="p-2 text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
                                            <span class="material-symbols-outlined text-[20px]">edit</span>
                                        </button>
                                        <button class="p-2 text-slate-400 hover:text-red-500 transition-colors">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                    </div>
                                </div>

                                <div class="flex items-start gap-4 p-4 hover:bg-slate-50 dark:hover:bg-slate-800/30 rounded-xl transition-colors group border-t border-slate-50 dark:border-slate-800/50">
                                    <div class="mt-1 text-slate-300 dark:text-slate-700 cursor-move opacity-0 group-hover:opacity-100 transition-opacity">
                                        <span class="material-symbols-outlined">drag_indicator</span>
                                    </div>
                                    <div class="flex-1">
                                        <p class="text-slate-800 dark:text-slate-200 font-bold">Is size of system (Usecase Points) large enough for members?</p>
                                    </div>
                                    <span class="px-2.5 py-1 bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 text-[10px] font-extrabold uppercase tracking-wider rounded border border-red-100 dark:border-red-900/50">Mandatory</span>
                                    <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button class="p-2 text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
                                            <span class="material-symbols-outlined text-[20px]">edit</span>
                                        </button>
                                        <button class="p-2 text-slate-400 hover:text-red-500 transition-colors">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                    </div>
                                </div>

                                <!-- Add Question Button -->
                                <button class="w-full py-3 mt-4 text-center text-slate-500 dark:text-slate-400 hover:text-[#F37021] dark:hover:text-orange-400 font-bold text-xs uppercase tracking-wider transition-all border border-dashed border-slate-200 dark:border-slate-800 rounded-xl hover:bg-orange-50/50 dark:hover:bg-orange-900/10">
                                    <span class="material-symbols-outlined text-base align-middle mr-1">add_circle</span>
                                    Thêm câu hỏi
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Section P2 -->
                    <div class="section-card bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
                        <div class="section-header p-6 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800/50 flex items-center justify-between transition">
                            <div class="flex items-center gap-4">
                                <span class="material-symbols-outlined toggle-icon text-slate-400">chevron_right</span>
                                <div class="w-10 h-10 rounded-xl bg-slate-900 dark:bg-slate-700 text-white flex items-center justify-center font-bold text-sm">P2</div>
                                <div>
                                    <span class="font-bold text-slate-900 dark:text-white text-lg">Practical applicability</span>
                                    <span class="text-xs font-bold text-slate-400 ml-2 uppercase tracking-tighter">(2 câu hỏi)</span>
                                </div>
                            </div>
                        </div>
                        <div class="section-content hidden">
                            <!-- Content for P2 -->
                        </div>
                    </div>

                    <!-- Add Section Button -->
                    <button class="w-full py-5 text-center text-[#F37021] hover:bg-orange-50 dark:hover:bg-orange-900/10 font-bold uppercase tracking-widest text-xs border-2 border-dashed border-orange-200 dark:border-orange-900/40 rounded-2xl transition-all hover:border-[#F37021]">
                        <span class="material-symbols-outlined text-xl align-middle mr-2">playlist_add</span>
                        Thêm Section Mới
                    </button>
                </div>
            </div>

            <!-- REVIEW 2 TAB -->
            <div id="review2" class="tab-content hidden space-y-6 animate-in fade-in slide-in-from-bottom-2 duration-300">
                <div class="bg-white dark:bg-slate-900 rounded-2xl p-8 border border-slate-200 dark:border-slate-800 shadow-[0_8px_30px_rgb(0,0,0,0.04)] text-center py-20">
                    <span class="material-symbols-outlined text-6xl text-slate-200 dark:text-slate-800 mb-4">settings_suggest</span>
                    <h3 class="text-xl font-bold text-slate-800 dark:text-slate-200">Đang cập nhật Review 2</h3>
                    <p class="text-slate-500 dark:text-slate-400 mt-2">Nội dung checklist cho Round 2 đang được biên soạn.</p>
                </div>
            </div>

            <!-- REVIEW 3 TAB (Rubric Checklist) -->
            <div id="review3" class="tab-content space-y-6 animate-in fade-in slide-in-from-bottom-2 duration-300">
                <!-- Checklist Info + Grade Scale -->
                <div class="bg-white dark:bg-slate-900 rounded-2xl p-8 border border-slate-200 dark:border-slate-800 shadow-[0_8px_30px_rgb(0,0,0,0.04)]">
                    <div class="flex items-start justify-between mb-8">
                        <div class="flex gap-5">
                            <div class="w-14 h-14 rounded-2xl bg-amber-50 dark:bg-amber-950/30 flex items-center justify-center text-amber-500 border border-amber-100 dark:border-amber-900/50">
                                <span class="material-symbols-outlined text-3xl">emoji_events</span>
                            </div>
                            <div>
                                <h2 class="text-xl font-bold text-slate-900 dark:text-white">FPTU SE Capstone Project – Review 3 Final Checklist</h2>
                                <div class="flex flex-wrap items-center gap-4 mt-3">
                                    <span class="flex items-center gap-1.5 text-sm font-bold text-slate-500 dark:text-slate-400">
                                        <span class="material-symbols-outlined text-base">analytics</span>
                                        Dạng đánh giá: Rubric (Grade Level)
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Grade Scale -->
                    <div>
                        <p class="text-[10px] font-extrabold text-slate-400 uppercase tracking-[0.2em] mb-4">Thang điểm đánh giá</p>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                            <div class="p-5 bg-emerald-50/50 dark:bg-emerald-950/20 rounded-2xl border border-emerald-100 dark:border-emerald-800/50 text-center group hover:shadow-md transition-all">
                                <span class="text-2xl mb-2 block">🟢</span>
                                <p class="font-bold text-emerald-700 dark:text-emerald-400">Excellent</p>
                                <p class="text-sm font-extrabold text-emerald-800 dark:text-emerald-300 mt-1">8.0 – 10.0</p>
                            </div>
                            <div class="p-5 bg-blue-50/50 dark:bg-blue-950/20 rounded-2xl border border-blue-100 dark:border-blue-800/50 text-center group hover:shadow-md transition-all">
                                <span class="text-2xl mb-2 block">🔵</span>
                                <p class="font-bold text-blue-700 dark:text-blue-400">Good</p>
                                <p class="text-sm font-extrabold text-blue-800 dark:text-blue-300 mt-1">6.5 – 8.0</p>
                            </div>
                            <div class="p-5 bg-yellow-50/50 dark:bg-yellow-950/20 rounded-2xl border border-yellow-100 dark:border-yellow-800/50 text-center group hover:shadow-md transition-all">
                                <span class="text-2xl mb-2 block">🟡</span>
                                <p class="font-bold text-yellow-700 dark:text-yellow-400">Acceptable</p>
                                <p class="text-sm font-extrabold text-yellow-800 dark:text-yellow-300 mt-1">4.0 – 6.5</p>
                            </div>
                            <div class="p-5 bg-red-50/50 dark:bg-red-950/20 rounded-2xl border border-red-100 dark:border-red-800/50 text-center group hover:shadow-md transition-all">
                                <span class="text-2xl mb-2 block">🔴</span>
                                <p class="font-bold text-red-700 dark:text-red-400">Fail</p>
                                <p class="text-sm font-extrabold text-red-800 dark:text-red-300 mt-1">0.0 – 4.0</p>
                            </div>
                        </div>
                        <div class="mt-4 flex items-center gap-2 text-xs font-bold text-slate-400">
                            <span class="material-symbols-outlined text-base">info</span>
                            + N/A: Tiêu chí không áp dụng cho nhóm dự án này
                        </div>
                    </div>
                </div>

                <!-- Criteria Sections -->
                <div class="space-y-4">
                    <!-- Product Section -->
                    <div class="rubric-section bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
                        <div class="section-header p-6 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800/50 flex items-center justify-between transition">
                            <div class="flex items-center gap-4">
                                <span class="material-symbols-outlined toggle-icon text-slate-400">expand_more</span>
                                <span class="text-2xl">📦</span>
                                <div>
                                    <span class="font-bold text-slate-900 dark:text-white text-lg">Product</span>
                                    <span class="text-xs font-bold text-slate-400 ml-2 uppercase tracking-tighter">(8 tiêu chí)</span>
                                </div>
                            </div>
                        </div>
                        <div class="section-content">
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm">
                                    <thead class="bg-slate-50 dark:bg-slate-800/50 border-t border-b border-slate-100 dark:border-slate-800">
                                        <tr>
                                            <th class="py-4 px-6 text-left text-[10px] font-extrabold text-slate-400 uppercase tracking-widest">Mã</th>
                                            <th class="py-4 px-6 text-left text-[10px] font-extrabold text-slate-400 uppercase tracking-widest">Tên tiêu chí</th>
                                            <th class="py-4 px-6 text-left text-[10px] font-extrabold text-slate-400 uppercase tracking-widest">Mô tả đánh giá</th>
                                            <th class="py-4 px-6 text-right text-[10px] font-extrabold text-slate-400 uppercase tracking-widest">Thao tác</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-50 dark:divide-slate-800/50">
                                        <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors">
                                            <td class="py-5 px-6">
                                                <span class="px-2.5 py-1 bg-slate-900 dark:bg-slate-700 text-white text-[10px] font-extrabold rounded">P1</span>
                                            </td>
                                            <td class="py-5 px-6">
                                                <p class="font-bold text-slate-800 dark:text-white">Scope: Coverage of Objectives</p>
                                            </td>
                                            <td class="py-5 px-6">
                                                <div class="text-slate-500 dark:text-slate-400 text-xs space-y-1">
                                                    <p class="flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-slate-300"></span> Problem to solve (innovation, creative…)</p>
                                                    <p class="flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-slate-300"></span> Size of system, data complexity...</p>
                                                </div>
                                            </td>
                                            <td class="py-5 px-6 text-right">
                                                <div class="flex items-center justify-end gap-1">
                                                    <button class="w-9 h-9 flex items-center justify-center rounded-lg text-slate-400 hover:bg-white dark:hover:bg-slate-800 hover:text-[#1E3A5F] hover:shadow-sm transition-all" title="Xem chi tiết" onclick="openDetailModal()">
                                                        <span class="material-symbols-outlined text-xl">visibility</span>
                                                    </button>
                                                    <button class="w-9 h-9 flex items-center justify-center rounded-lg text-slate-400 hover:bg-white dark:hover:bg-slate-800 hover:text-[#F37021] hover:shadow-sm transition-all" title="Chỉnh sửa">
                                                        <span class="material-symbols-outlined text-xl">edit</span>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        <!-- Repeat for P2 -->
                                        <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors border-t border-slate-50 dark:border-slate-800/50">
                                            <td class="py-5 px-6">
                                                <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-[10px] font-extrabold rounded">P2</span>
                                            </td>
                                            <td class="py-5 px-6">
                                                <p class="font-bold text-slate-800 dark:text-white">Practical applicability</p>
                                            </td>
                                            <td class="py-5 px-6">
                                                <div class="text-slate-500 dark:text-slate-400 text-xs space-y-1">
                                                    <p class="flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-slate-300"></span> Deployed in production mode…</p>
                                                    <p class="flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-slate-300"></span> Have real users/customers…</p>
                                                </div>
                                            </td>
                                            <td class="py-5 px-6 text-right">
                                                <div class="flex items-center justify-end gap-1">
                                                    <button class="w-9 h-9 flex items-center justify-center rounded-lg text-slate-400 hover:bg-white dark:hover:bg-slate-800 hover:text-[#1E3A5F] hover:shadow-sm transition-all" title="Xem chi tiết">
                                                        <span class="material-symbols-outlined text-xl">visibility</span>
                                                    </button>
                                                    <button class="w-9 h-9 flex items-center justify-center rounded-lg text-slate-400 hover:bg-white dark:hover:bg-slate-800 hover:text-[#F37021] hover:shadow-sm transition-all" title="Chỉnh sửa">
                                                        <span class="material-symbols-outlined text-xl">edit</span>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- AI Optional Section -->
                    <div class="rubric-section bg-gradient-to-r from-white to-orange-50/30 dark:from-slate-900 dark:to-orange-950/10 rounded-2xl border-2 border-orange-100 dark:border-orange-900/30 overflow-hidden shadow-sm">
                        <div class="section-header p-6 cursor-pointer hover:bg-orange-50/50 dark:hover:bg-orange-950/20 flex items-center justify-between transition">
                            <div class="flex items-center gap-4">
                                <span class="material-symbols-outlined toggle-icon text-orange-400">chevron_right</span>
                                <span class="text-2xl">🤖</span>

@{
    ViewData["Title"] = "Reviewer Assignment";
    Layout = "~/Views/Shared/_HodLayout.cshtml";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950">
    <div class="p-6">
        <div class="max-w-7xl mx-auto space-y-6">
            <!-- Header with User Info -->
            <div class="flex items-start justify-between mb-8">
                <div class="flex items-center gap-4">
                    <div class="w-16 h-16 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center text-white text-xl font-bold">
                        AN
                    </div>
                    <div>
                        <nav class="flex items-center gap-2 text-sm mb-2">
                            <a href="/Hod/Dashboard" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200">GPMS</a>
                            <span class="text-slate-400 dark:text-slate-600">/</span>
                            <span class="text-slate-900 dark:text-slate-100 font-medium">Reviewer Assign</span>
                        </nav>
                        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Dr. Alex Nguyen</h1>
                        <p class="text-sm text-slate-600 dark:text-slate-400">Head of Department</p>
                    </div>
                </div>
            </div>

            <!-- Page Title and Description -->
            <div class="mb-8">
                <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Phân công Reviewer</h2>
                <p class="text-slate-600 dark:text-slate-400">Tự động hóa thủ tục phân công giảng viên phản biện cho các giai đoạn báo cáo</p>
            </div>

            <!-- Tabs Navigation -->
            <div class="border-b border-slate-200 dark:border-slate-800">
                <div class="flex gap-8">
                    <button class="pb-4 px-1 border-b-2 border-[#F37021] text-[#F37021] font-semibold">
                        Tổng quan phân công
                    </button>
                    <button class="pb-4 px-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 font-medium">
                        Constraint Rules
                    </button>
                </div>
            </div>

            <!-- Statistics Cards -->
            <div class="grid grid-cols-4 gap-6 mt-8">
                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wide">Tổng số nhóm</p>
                            <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">42</p>
                        </div>
                        <div class="w-12 h-12 rounded-lg bg-blue-100 dark:bg-blue-900 flex items-center justify-center">
                            <span class="material-symbols-outlined text-blue-600 dark:text-blue-400" style="font-size: 24px;">groups</span>
                        </div>
                    </div>
                </div>

                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wide">Đã phân công</p>
                            <p class="text-3xl font-bold text-green-600 dark:text-green-400 mt-2">35</p>
                        </div>
                        <div class="w-12 h-12 rounded-lg bg-green-100 dark:bg-green-900 flex items-center justify-center">
                            <span class="material-symbols-outlined text-green-600 dark:text-green-400" style="font-size: 24px;">check_circle</span>
                        </div>
                    </div>
                </div>

                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wide">Chưa phân công</p>
                            <p class="text-3xl font-bold text-[#F37021] mt-2">07</p>
                        </div>
                        <div class="w-12 h-12 rounded-lg bg-orange-100 dark:bg-orange-900 flex items-center justify-center">
                            <span class="material-symbols-outlined text-[#F37021]" style="font-size: 24px;">schedule</span>
                        </div>
                    </div>
                </div>

                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                    <div>
                        <p class="text-xs font-semibold text-slate-600 dark:text-slate-400 uppercase tracking-wide">Tiến độ</p>
                        <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">83%</p>
                        <div class="w-full bg-slate-200 dark:bg-slate-700 rounded-full h-2 mt-4">
                            <div class="bg-blue-600 h-2 rounded-full" style="width: 83%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Assignment Table Section -->
            <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden mt-8">
                <div class="flex items-center justify-between p-6 border-b border-slate-200 dark:border-slate-800">
                    <div class="flex-1 flex items-center gap-4">
                        <div class="flex-1">
                            <select class="w-full px-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#F37021]">
                                <option>Round 1: Proposal Review (Vòng 5)</option>
                                <option>Round 2: Mid-term Progress</option>
                                <option>Round 3: Final Defence</option>
                            </select>
                        </div>
                        <div class="flex-1 relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 transform -translate-y-1/2 text-slate-400" style="font-size: 20px;">search</span>
                            <input
                                type="text"
                                placeholder="Nhập mã nhóm, tên đề tài..."
                                class="w-full pl-10 pr-4 py-2 border border-slate-300 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-[#F37021]"
                            />
                        </div>
                        <button class="px-4 py-2 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition">
                            <span class="material-symbols-outlined" style="font-size: 20px;">tune</span>
                        </button>
                        <button class="px-4 py-2 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition">
                            <span class="material-symbols-outlined" style="font-size: 20px;">download</span>
                        </button>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-slate-50 dark:bg-slate-800">
                            <tr class="border-b border-slate-200 dark:border-slate-700">
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">MÃ NHÓM</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">ĐỀ TÀI</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">GVHD</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">REVIEWER ĐƯỢC GIAO</th>
                                <th class="text-left py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">TRẠNG THÁI</th>
                                <th class="text-center py-4 px-6 font-semibold text-slate-700 dark:text-slate-300">THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                            <!-- Row 1 -->
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="py-4 px-6">
                                    <span class="font-semibold text-slate-900 dark:text-white">G12_SEP</span>
                                </td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">Hệ thống quản lý chuỗi ứng nặng sâu</td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-2">
                                        <div class="w-8 h-8 rounded-full bg-slate-300 dark:bg-slate-700"></div>
                                        <span class="text-sm text-slate-900 dark:text-white">Nguyễn Văn A</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-2">
                                        <div class="w-6 h-6 rounded-full bg-gradient-to-br from-slate-400 to-slate-600"></div>
                                        <span class="text-sm text-slate-900 dark:text-white">TS. Lê Thị B</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6">
                                    <span class="inline-flex items-center gap-1 px-3 py-1 bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 text-xs font-semibold rounded-full">
                                        <span class="material-symbols-outlined" style="font-size: 14px;">check_circle</span>
                                        Đã gán
                                    </span>
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition">
                                        <span class="material-symbols-outlined" style="font-size: 18px;">more_vert</span>
                                    </button>
                                </td>
                            </tr>

                            <!-- Row 2 -->
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="py-4 px-6">
                                    <span class="font-semibold text-slate-900 dark:text-white">G08_IOT</span>
                                </td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">Ứng dụng AI trong giám sát an ninh nhà thông minh</td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-2">
                                        <div class="w-8 h-8 rounded-full bg-slate-300 dark:bg-slate-700"></div>
                                        <span class="text-sm text-slate-900 dark:text-white">TS. Trần Minh C</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-2">
                                        <div class="w-6 h-6 rounded-full bg-gradient-to-br from-green-400 to-green-600"></div>
                                        <span class="text-sm text-slate-900 dark:text-white">TS. Đỗ Hoàng D</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6">
                                    <span class="inline-flex items-center gap-1 px-3 py-1 bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 text-xs font-semibold rounded-full">
                                        <span class="material-symbols-outlined" style="font-size: 14px;">check_circle</span>
                                        Đã gán
                                    </span>
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition">
                                        <span class="material-symbols-outlined" style="font-size: 18px;">more_vert</span>
                                    </button>
                                </td>
                            </tr>

                            <!-- Row 3 -->
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="py-4 px-6">
                                    <span class="font-semibold text-slate-900 dark:text-white">G24_WEB</span>
                                </td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">Nền tảng thương mại điện tử tích hợp Blockchain...</td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-2">
                                        <div class="w-8 h-8 rounded-full bg-slate-300 dark:bg-slate-700"></div>
                                        <span class="text-sm text-slate-900 dark:text-white">TS. Phạm Xuân E</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6">
                                    <span class="text-sm text-slate-600 dark:text-slate-400">Chưa phân công</span>
                                </td>
                                <td class="py-4 px-6">
                                    <span class="inline-flex items-center gap-1 px-3 py-1 bg-yellow-100 dark:bg-yellow-900 text-yellow-800 dark:text-yellow-200 text-xs font-semibold rounded-full">
                                        <span class="material-symbols-outlined" style="font-size: 14px;">schedule</span>
                                        Chờ xử lý
                                    </span>
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <button class="px-3 py-1 bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold rounded transition">
                                        Gán reviewer
                                    </button>
                                </td>
                            </tr>

                            <!-- Row 4 -->
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition">
                                <td class="py-4 px-6">
                                    <span class="font-semibold text-slate-900 dark:text-white">G15_APP</span>
                                </td>
                                <td class="py-4 px-6 text-slate-600 dark:text-slate-400">Giải pháp Booking đa nền tảng cho lịch hẹn...</td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-2">
                                        <div class="w-8 h-8 rounded-full bg-slate-300 dark:bg-slate-700"></div>
                                        <span class="text-sm text-slate-900 dark:text-white">ThS. Võ Quang F</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-2">
                                        <div class="w-6 h-6 rounded-full bg-gradient-to-br from-orange-400 to-orange-600"></div>
                                        <span class="text-sm text-slate-900 dark:text-white">TS. Nguyễn Văn A</span>
                                    </div>
                                </td>
                                <td class="py-4 px-6">
                                    <span class="inline-flex items-center gap-1 px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 text-xs font-semibold rounded-full">
                                        <span class="material-symbols-outlined" style="font-size: 14px;">assignment</span>
                                        Đang review
                                    </span>
                                </td>
                                <td class="py-4 px-6 text-center">
                                    <button class="p-1 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition">
                                        <span class="material-symbols-outlined" style="font-size: 18px;">more_vert</span>
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="flex items-center justify-between p-6 border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/50">
                    <p class="text-sm text-slate-600 dark:text-slate-400">Hiển thị 1-4 trong số 42 nhóm</p>
                    <div class="flex gap-2">
                        <button class="px-3 py-1 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-slate-100 rounded hover:bg-slate-100 dark:hover:bg-slate-700 transition" disabled>Trước</button>
                        <button class="px-3 py-1 bg-slate-900 dark:bg-slate-700 text-white rounded font-medium">1</button>
                        <button class="px-3 py-1 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-slate-100 rounded hover:bg-slate-100 dark:hover:bg-slate-700 transition">2</button>
                        <button class="px-3 py-1 border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-slate-100 rounded hover:bg-slate-100 dark:hover:bg-slate-700 transition">Sau</button>
                    </div>
                </div>
            </div>

            <!-- Constraint Rules Section -->
            <div class="mt-12 mb-8">
                <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-[#F37021]" style="font-size: 24px;">rule</span>
                    Constraint Rules (Quy tắc ràng buộc hệ thống)
                </h3>

                <div class="grid grid-cols-4 gap-6">
                    <!-- Rule 1: Conflict of Interest -->
                    <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-red-100 dark:bg-red-900 mb-4">
                            <span class="material-symbols-outlined text-red-600 dark:text-red-400" style="font-size: 24px;">block</span>
                        </div>
                        <h4 class="font-semibold text-slate-900 dark:text-white mb-2">Conflict of Interest</h4>
                        <p class="text-sm text-slate-600 dark:text-slate-400">Reviewers cannot evaluate projects of students they teach or have taught recently.</p>
                    </div>

                    <!-- Rule 2: Consistency -->
                    <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-blue-100 dark:bg-blue-900 mb-4">
                            <span class="material-symbols-outlined text-blue-600 dark:text-blue-400" style="font-size: 24px;">sync</span>
                        </div>
                        <h4 class="font-semibold text-slate-900 dark:text-white mb-2">Consistency</h4>
                        <p class="text-sm text-slate-600 dark:text-slate-400">The same reviewer must evaluate a project through all review phases for continuity.</p>
                    </div>

                    <!-- Rule 3: Expertise Matching -->
                    <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-green-100 dark:bg-green-900 mb-4">
                            <span class="material-symbols-outlined text-green-600 dark:text-green-400" style="font-size: 24px;">verified</span>
                        </div>
                        <h4 class="font-semibold text-slate-900 dark:text-white mb-2">Expertise Matching</h4>
                        <p class="text-sm text-slate-600 dark:text-slate-400">Reviewers are matched with projects matching their areas of expertise and specialization.</p>
                    </div>

                    <!-- Rule 4: Workload Balance -->
                    <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-purple-100 dark:bg-purple-900 mb-4">
                            <span class="material-symbols-outlined text-purple-600 dark:text-purple-400" style="font-size: 24px;">balance</span>
                        </div>
                        <h4 class="font-semibold text-slate-900 dark:text-white mb-2">Workload Balance</h4>
                        <p class="text-sm text-slate-600 dark:text-slate-400">Reviewer workload is balanced by distributing projects as evenly as possible among all qualified reviewers.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@using GPMS.Application.DTOs
@using GPMS.Domain.Enums
@model ReviewerAssignmentDto
@{
    ViewBag.Title = "Reviewer Assignment";
    ViewBag.CurrentPage = "AssignReviewer";
    ViewBag.BreadcrumbSection = "Reviewer Assignment";
    Layout = "_Layout";
    var activeSemester = ViewBag.ActiveSemester as GPMS.Application.DTOs.SemesterDto;
}

<div class="space-y-6">
    <!-- Header Section -->
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div>
            <nav class="flex items-center gap-2 text-sm text-slate-500 font-medium mb-4">
                <a href="/HOD/Dashboard" class="hover:text-slate-800 transition-colors no-underline">GPMS</a>
                <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                <span class="text-slate-800 font-bold">Reviewer Assignment</span>
            </nav>
            <h1 class="text-2xl font-bold text-slate-800">Assign Reviewers to Projects</h1>
            <p class="text-slate-500 text-sm mt-1 font-medium">
                Manage and assign reviewers for project groups by review rounds.
                @if (activeSemester != null)
                {
                    <span class="text-[#F37021] font-bold">(@activeSemester.SemesterCode)</span>
                }
            </p>
        </div>

        <!-- Round Selection -->
        <div class="flex items-center gap-3 bg-white p-1 rounded-xl border border-slate-200 shadow-sm self-start">
            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest ml-3 mr-1">Select Round:</span>
            @foreach (var round in Model.AllRounds.Where(r => r.RoundNumber <= 2))
            {
                <a href="/HOD/AssignReviewer?roundId=@round.ReviewRoundID" 
                   class="px-5 py-2 rounded-lg text-sm font-bold transition-all no-underline @(Model.ReviewRoundID == round.ReviewRoundID ? "bg-[#F37021] text-white shadow-lg shadow-orange-500/20" : "text-slate-500 hover:bg-slate-50")">
                    Round @round.RoundNumber
                </a>
            }
        </div>
    </div>

    <!-- Main 2-Column Grid for Assignment -->
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
        
        <!-- Unassigned Groups Column -->
        <div class="flex flex-col h-full">
            <div class="flex items-center gap-2 mb-6">
                <div class="flex gap-0.5">
                    <span class="w-2 h-2 rounded-full bg-orange-500"></span>
                </div>
                <h2 class="text-[15px] font-bold text-slate-800">Unassigned Groups (@Model.UnassignedGroups.Count)</h2>
            </div>

            <!-- Project Filters -->
            <div class="flex flex-col sm:flex-row gap-3 mb-6">
                <div class="relative flex-grow">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                    <input type="text" id="groupSearch" placeholder="Search by name or code..." 
                           class="w-full pl-10 pr-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:border-[#F37021] focus:ring-1 focus:ring-[#F37021] outline-none transition-all"
                           onkeyup="filterGroups()">
                </div>
                <div class="sm:w-48">
                    <select id="majorFilter" class="w-full px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:border-[#F37021] outline-none transition-all" onchange="filterGroups()">
                        <option value="">All Specialties</option>
                        @foreach (var major in Model.UnassignedGroups.Select(p => p.MajorName).Distinct().OrderBy(m => m))
                        {
                            <option value="@major">@major</option>
                        }
                    </select>
                </div>
            </div>
            
            <div id="unassignedGroupsContainer" class="space-y-4 max-h-[500px] overflow-y-auto pr-2 custom-main-scroll">
                @if (Model.UnassignedGroups.Any())
                {
                    foreach (var group in Model.UnassignedGroups)
                    {
                        <div class="group-card p-6 bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.02)] min-h-[140px] hover:border-[#F37021] hover:shadow-md transition-all cursor-pointer group" 
                             data-name="@group.GroupName.ToLower()" 
                             data-code="@group.ProjectCode.ToLower()" 
                             data-major="@group.MajorName"
                             onclick='openReviewerModal("@group.GroupID", "@group.ProjectCode", "@group.MajorName", "@group.GroupName", @Json.Serialize(group.Reviewers), @Json.Serialize(group.MentorIDs))'>
                            <div class="flex items-center justify-between mb-2">
                                <span class="font-bold text-slate-500 text-xs tracking-wider">@group.ProjectCode</span>
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">@group.MajorName</span>
                            </div>
                            <p class="font-bold text-slate-800 text-lg mb-1 group-hover:text-[#F37021] transition-colors leading-tight">@group.GroupName</p>
                            <p class="text-xs text-slate-500 font-medium mb-3 italic">@group.ProjectName</p>
                            <div class="flex items-center justify-between mt-auto">
                                <div class="flex items-center gap-1.5 text-[11px] font-bold text-slate-400 uppercase tracking-wider">
                                    <span class="material-symbols-outlined text-[16px]">person</span>
                                    Mentor: @group.SupervisorName
                                </div>
                                <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-wider rounded border border-slate-200/50">Unassigned</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="p-12 text-center bg-slate-50 rounded-2xl border-2 border-dashed border-slate-200">
                        <span class="material-symbols-outlined text-4xl text-slate-300 mb-2">check_circle</span>
                        <p class="text-slate-500 font-medium">Tất cả các nhóm đã được phân công phản biện!</p>
                    </div>
                }
            </div>
        </div>

        <!-- Available Lecturers Column -->
        <div class="flex flex-col h-full">
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-[#1E3A5F]">person_search</span>
                    <h2 class="text-[15px] font-bold text-slate-800">Available Lecturers</h2>
                </div>
            </div>

            <!-- Lecturer Filters -->
            <div class="flex flex-col sm:flex-row gap-3 mb-6">
                <div class="relative flex-grow">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                    <input type="text" id="lecturerSearch" placeholder="Search by name..." 
                           class="w-full pl-10 pr-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:border-[#1E3A5F] focus:ring-1 focus:ring-[#1E3A5F] outline-none transition-all"
                           onkeyup="filterLecturers()">
                </div>
            </div>
            
            <div id="lecturersContainer" class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-h-[500px] overflow-y-auto pr-2 custom-main-scroll">
                @foreach (var lecturer in Model.Lecturers)
                {
                    var isFull = lecturer.CurrentWorkload >= lecturer.MaxWorkload;
                    var workloadPercent = (lecturer.CurrentWorkload * 100) / lecturer.MaxWorkload;
                    var workloadColor = lecturer.CurrentWorkload >= lecturer.MaxWorkload ? "bg-red-500" : (lecturer.CurrentWorkload >= 10 ? "bg-amber-500" : "bg-[#1E3A5F]");
                    var textColor = lecturer.CurrentWorkload >= lecturer.MaxWorkload ? "text-red-500" : (lecturer.CurrentWorkload >= 10 ? "text-amber-500" : "text-emerald-600");
                    var initials = lecturer.FullName.Contains(" ") ? string.Concat(lecturer.FullName.Split(' ').Select(s => s[0])) : lecturer.FullName.Substring(0, 1);

                    <div class="lecturer-card bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.02)] p-5 flex flex-col hover:shadow-md transition-shadow @(isFull ? "opacity-75" : "")"
                         data-name="@lecturer.FullName.ToLower()"
                         data-specialty="@lecturer.Specialty">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center flex-shrink-0 border border-slate-200 overflow-hidden shadow-sm">
                                <span class="text-slate-500 font-bold text-sm">@initials</span>
                            </div>
                            <div>
                                <p class="font-bold text-slate-800 text-sm leading-tight">@lecturer.FullName</p>
                                <p class="text-[11px] font-bold text-slate-500 uppercase tracking-widest mt-1">@lecturer.Level</p>
                                <p class="text-[10px] text-slate-400 mt-0.5 leading-snug">Expertise: @lecturer.Specialty</p>
                            </div>
                        </div>
                        
                        <div class="mb-5 mt-auto">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-[10px] font-extrabold uppercase tracking-wider text-slate-500">Review Workload</span>
                                <span class="text-[10px] font-bold @textColor">@lecturer.CurrentWorkload / @lecturer.MaxWorkload GROUPS</span>
                            </div>
                            <div class="w-full bg-slate-100 rounded-full h-1.5 overflow-hidden">
                                <div class="@workloadColor h-full rounded-full transition-all duration-500" style="width: @workloadPercent%"></div>
                            </div>
                        </div>
                        
                        <button class="w-full py-2.5 bg-[#1E3A5F] hover:bg-slate-800 text-white rounded-lg font-bold text-xs transition-colors shadow-sm" onclick="openProjectModal('@lecturer.LecturerID', '@lecturer.FullName')">
                            View & Assign
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Assignment Summary Section -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] overflow-hidden mt-6">
        <div class="p-6 border-b border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white">
            <h2 class="text-lg font-bold text-slate-800">Assignment Summary - Round @(Model.AllRounds.FirstOrDefault(r => r.ReviewRoundID == Model.ReviewRoundID)?.RoundNumber ?? 0)</h2>
            <div class="px-3 py-1 bg-emerald-50 border border-emerald-100 text-emerald-700 rounded-full shadow-sm">
                <span class="text-xs font-bold uppercase tracking-wider">@Model.AssignedGroups.Count Groups Assigned</span>
            </div>
        </div>

        <!-- Summary Table Filters -->
        <div class="p-4 bg-slate-50/50 border-b border-slate-100 flex flex-col sm:flex-row gap-4">
            <div class="relative flex-grow">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                <input type="text" id="summarySearch" placeholder="Search by name, code or reviewer..." 
                       class="w-full pl-10 pr-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none transition-all"
                       onkeyup="filterSummaryTable()">
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100">
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">GROUP CODE</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider w-1/4">GROUP NAME / TOPIC</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">MENTOR</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">REVIEWER</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">STATUS</th>
                        <th class="py-4 px-6 text-center text-xs font-bold text-slate-500 uppercase tracking-wider">ACTIONS</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model.AssignedGroups.Any())
                    {
                        foreach (var group in Model.AssignedGroups)
                        {
                            <tr class="summary-row hover:bg-slate-50/50 transition-colors"
                                data-name="@group.GroupName.ToLower()"
                                data-code="@group.ProjectCode.ToLower()">
                                <td class="py-5 px-6 font-bold text-slate-800">@group.ProjectCode</td>
                                <td class="py-5 px-6">
                                    <div class="font-bold text-slate-800 leading-snug">@group.GroupName</div>
                                    <div class="text-[10px] text-slate-400 mt-1 italic line-clamp-1">@group.ProjectName</div>
                                </td>
                                <td class="py-5 px-6">
                                    <span class="text-slate-600 font-medium">@group.SupervisorName</span>
                                </td>
                                <td class="py-5 px-6">
                                    <div class="space-y-1.5">
                                        @foreach(var rev in group.Reviewers) {
                                            <div class="flex items-center gap-2">
                                                <div class="flex items-center gap-1 px-2 py-0.5 bg-green-50 text-green-700 rounded text-[10px] font-bold border border-green-100">
                                                    @rev.ReviewerName (@rev.Role.ToString())
                                                    <button onclick="removeReviewerAction(@Model.ReviewRoundID, @group.GroupID, '@rev.ReviewerID')" class="hover:text-red-500 ml-1">
                                                        <span class="material-symbols-outlined text-[12px]">close</span>
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                        @if(!group.Reviewers.Any()){
                                            <span class="text-slate-400 italic text-[11px]">Unassigned</span>
                                        }
                                    </div>
                                </td>
                                <td class="py-5 px-6">
                                    <span class="px-2.5 py-1 bg-blue-50 text-blue-700 text-[10px] font-bold uppercase tracking-wider rounded border border-blue-100">Assigned</span>
                                </td>
                                <td class="py-5 px-6 text-center">
                                    <button class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-[#F37021] hover:bg-orange-50 rounded-lg transition" title="Modify" 
                                            onclick='openReviewerModal("@group.GroupID", "@group.ProjectCode", "@group.MajorName", "@group.GroupName", @Json.Serialize(group.Reviewers), @Json.Serialize(group.MentorIDs))'>
                                        <span class="material-symbols-outlined text-[16px]">person_add</span>
                                        Edit
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="py-12 text-center text-slate-400 italic">No groups have been assigned reviewers yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Reviewer Selection Modal -->
<div id="reviewerModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-2xl bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-200">
        <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
            <div>
                <h3 class="text-xl font-bold text-slate-800">Assign Reviewers</h3>
                <p class="text-xs text-slate-500 font-medium mt-1">Assigning to: <span id="modalGroupName" class="text-[#F37021] font-bold"></span> (<span id="modalProjectCode" class="font-bold"></span>)</p>
            </div>
            <button onclick="closeReviewerModal()" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-white hover:shadow-md transition-all text-slate-400 hover:text-slate-600">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        
        <div class="p-8">
            <div class="mb-6">
                <label class="text-xs font-bold text-slate-400 uppercase tracking-widest block mb-3">Selected Reviewers</label>
                <div id="selectedReviewersList" class="flex flex-wrap gap-2 min-h-[40px] p-3 bg-slate-50 rounded-2xl border border-slate-200 border-dashed">
                    <!-- Dynamic chips -->
                </div>
            </div>

            <div>
                <label class="text-xs font-bold text-slate-400 uppercase tracking-widest block mb-3">List of Available Lecturers</label>
                <div class="relative mb-4">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                    <input type="text" id="modalLecturerSearch" placeholder="Search by name or specialty..." 
                           class="w-full pl-10 pr-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm focus:border-[#F37021] outline-none transition-all"
                           onkeyup="filterModalLecturers()">
                </div>
                
                <div id="modalLecturerList" class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-h-[300px] overflow-y-auto custom-main-scroll pr-2">
                    @foreach (var lecturer in Model.Lecturers)
                    {
                        <div class="modal-lecturer-item p-3 border border-slate-100 rounded-2xl flex items-center justify-between group hover:border-[#F37021] bg-white cursor-pointer transition-all"
                             data-id="@lecturer.LecturerID"
                             data-name="@lecturer.FullName"
                             data-specialty="@lecturer.Specialty"
                             onclick="toggleReviewerSelection('@lecturer.LecturerID', '@lecturer.FullName')">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 font-bold text-[10px] border border-slate-200">
                                    @lecturer.FullName.Substring(0, 1)
                                </div>
                                <div>
                                    <p class="font-bold text-slate-800 text-xs">@lecturer.FullName</p>
                                    <p class="text-[9px] text-slate-500">Load: @lecturer.CurrentWorkload/@lecturer.MaxWorkload</p>
                                </div>
                            </div>
                            <span class="add-icon material-symbols-outlined text-[#F37021] opacity-30 group-hover:opacity-100">add_circle</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="px-8 py-5 border-t border-slate-100 bg-slate-50 flex justify-between items-center">
            <div class="flex items-center gap-2">
                @if (Model.IsFinalRound) {
                    <select id="reviewerRoleSelect" class="bg-white border border-slate-200 rounded-lg px-3 py-2 text-xs font-bold outline-none focus:ring-2 focus:ring-orange-500/20 transition-all">
                        @foreach (var role in Enum.GetValues(typeof(CommitteeRole))) {
                            <option value="@role">Role: @role</option>
                        }
                    </select>
                } else {
                    <input type="hidden" id="reviewerRoleSelect" value="Reviewer" />
                    <div class="px-3 py-1.5 bg-slate-100 text-slate-500 rounded-lg text-xs font-bold border border-slate-200">
                        Vai trò: Phản biện (Cố định)
                    </div>
                }
            </div>
            <div class="flex items-center gap-3">
                <button onclick="closeReviewerModal()" class="px-6 py-2.5 text-xs font-bold text-slate-600 hover:text-slate-800 transition-colors">Cancel</button>
                <button onclick="saveAssignmentAction()" class="px-8 py-2.5 bg-[#F37021] text-white font-bold rounded-xl shadow-lg shadow-orange-500/20 hover:scale-[1.02] active:scale-[0.98] transition-all">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Project Modal (For Lecturer -> Projects view) -->
<div id="projectModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-2xl bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-200">
        <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
            <div>
                <h3 class="text-xl font-bold text-slate-800">Select Project Group</h3>
                <p class="text-xs text-slate-500 font-medium mt-1">Lecturer: <span id="modalLecturerTitle" class="text-[#1E3A5F] font-bold"></span></p>
            </div>
            <button onclick="closeProjectModal()" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-white hover:shadow-md transition-all text-slate-400 hover:text-slate-600">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-8">
            <div class="relative mb-6">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                <input type="text" id="modalGroupSearch" placeholder="Search by name or project code..." 
                       class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-xl text-sm focus:border-[#F37021] outline-none transition-all"
                       onkeyup="filterModalGroups()">
            </div>
            <div id="modalGroupList" class="space-y-3 max-h-[400px] overflow-y-auto custom-main-scroll pr-2">
                @foreach (var group in Model.UnassignedGroups)
                {
                    <div class="modal-group-item p-4 border border-slate-100 rounded-2xl flex items-center justify-between group hover:border-[#F37021] bg-white cursor-pointer transition-all"
                         data-name="@group.GroupName.ToLower()"
                         data-code="@group.ProjectCode.ToLower()"
                         onclick="quickAssignLecturerToGroup('@group.GroupID', '@group.GroupName')">
                        <div>
                            <div class="flex items-center gap-2 mb-1">
                                <span class="text-[10px] font-bold text-slate-500 tracking-wider">@group.ProjectCode</span>
                                <span class="px-1.5 py-0.5 bg-slate-100 text-[9px] font-bold text-slate-400 uppercase rounded">@group.MajorName</span>
                            </div>
                            <p class="font-bold text-slate-800 text-sm group-hover:text-[#F37021]">@group.GroupName</p>
                        </div>
                        <span class="material-symbols-outlined text-[#F37021] opacity-0 group-hover:opacity-100">add_circle</span>
                    </div>
                }
            </div>
        </div>
        <div class="px-8 py-5 border-t border-slate-100 bg-slate-50 flex justify-end">
            <button onclick="closeProjectModal()" class="px-6 py-2.5 text-xs font-bold text-slate-600 hover:text-slate-800 transition-colors">Cancel</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentGroupId = null;
        let selectedReviewers = [];
        let currentLecturerId = null;
        const currentRoundId = @Model.ReviewRoundID;

        // --- Core Assignment Logic ---

        let currentMentorIds = [];

        function openReviewerModal(groupId, code, major, groupName, existingReviewers = [], mentorIds = []) {
            currentGroupId = groupId;
            currentMentorIds = mentorIds || [];
            document.getElementById('modalProjectCode').innerText = code;
            document.getElementById('modalGroupName').innerText = groupName;
            
            // Map existing reviewers if any
            selectedReviewers = existingReviewers.map(r => ({
                id: r.ReviewerID || r.reviewerID,
                name: r.ReviewerName || r.reviewerName
            }));

            renderSelectedChips();
            filterModalLecturers(); // Apply mentor filtering
            document.getElementById('reviewerModal').classList.remove('hidden');
        }

        function closeReviewerModal() {
            document.getElementById('reviewerModal').classList.add('hidden');
            selectedReviewers = [];
        }

        function toggleReviewerSelection(id, name) {
            const index = selectedReviewers.findIndex(r => r.id === id);
            if (index === -1) {
                selectedReviewers.push({ id, name });
            } else {
                selectedReviewers.splice(index, 1);
            }
            renderSelectedChips();
        }

        function renderSelectedChips() {
            const container = document.getElementById('selectedReviewersList');
            container.innerHTML = '';
            
            if (selectedReviewers.length === 0) {
                container.innerHTML = '<span class="text-slate-300 text-xs italic">No lecturers selected</span>';
                return;
            }

            selectedReviewers.forEach(rev => {
                const chip = document.createElement('div');
                chip.className = 'flex items-center gap-1.5 px-3 py-1.5 bg-[#F37021]/10 text-[#F37021] rounded-full text-[11px] font-bold border border-[#F37021]/20';
                chip.innerHTML = `
                    ${rev.name}
                    <button onclick="toggleReviewerSelection('${rev.id}', '${rev.name}')" class="hover:text-red-500 flex items-center">
                        <span class="material-symbols-outlined text-[14px]">close</span>
                    </button>
                `;
                container.appendChild(chip);
            });
        }

        async function saveAssignmentAction() {
            if (selectedReviewers.length === 0) {
                alert('Please select at least one reviewer.');
                return;
            }

            const role = document.getElementById('reviewerRoleSelect').value;
            const data = {
                ReviewRoundID: currentRoundId,
                GroupID: parseInt(currentGroupId),
                Assignments: selectedReviewers.map(r => ({
                    LecturerID: r.id,
                    Role: role
                }))
            };

            try {
                const response = await fetch('/HOD/ReassignReviewer', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const res = await response.json();
                if (res.success) window.location.reload();
                else alert(res.message);
            } catch(err) {
                console.error(err);
                alert('Connection error.');
            }
        }

        async function removeReviewerAction(roundId, groupId, lecturerId) {
            if (!confirm('Are you sure you want to remove this reviewer?')) return;
            try {
                const res = await fetch('/HOD/RemoveReviewer', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ReviewRoundID: roundId, GroupID: groupId, LecturerID: lecturerId })
                });
                const data = await res.json();
                if (data.success) window.location.reload();
                else alert(data.message);
            } catch(err) { console.error(err); }
        }

        // --- UI Modal Handlers ---

        function openProjectModal(lecturerId, lecturerName) {
            currentLecturerId = lecturerId;
            document.getElementById('modalLecturerTitle').innerText = lecturerName;
            document.getElementById('projectModal').classList.remove('hidden');
        }

        function closeProjectModal() {
            document.getElementById('projectModal').classList.add('hidden');
            currentLecturerId = null;
        }

        async function quickAssignLecturerToGroup(groupId, groupName) {
            currentGroupId = groupId;
            selectedReviewers = [{ id: currentLecturerId, name: document.getElementById('modalLecturerTitle').innerText }];
            await saveAssignmentAction();
        }

        // --- Filtering Logic ---

        function filterGroups() {
            const search = document.getElementById('groupSearch').value.toLowerCase();
            const major = document.getElementById('majorFilter').value;
            document.querySelectorAll('.group-card').forEach(card => {
                const name = card.dataset.name;
                const code = card.dataset.code;
                const cardMajor = card.dataset.major;
                const show = (name.includes(search) || code.includes(search)) && (major === "" || cardMajor === major);
                card.style.display = show ? 'block' : 'none';
            });
        }

        function filterLecturers() {
            const search = document.getElementById('lecturerSearch').value.toLowerCase();
            document.querySelectorAll('.lecturer-card').forEach(card => {
                const name = card.dataset.name;
                card.style.display = name.includes(search) ? 'block' : 'none';
            });
        }

        function filterSummaryTable() {
            const search = document.getElementById('summarySearch').value.toLowerCase();
            document.querySelectorAll('.summary-row').forEach(row => {
                const name = row.dataset.name;
                const code = row.dataset.code;
                row.style.display = (name.includes(search) || code.includes(search)) ? '' : 'none';
            });
        }

        function filterModalLecturers() {
            const searchTerm = document.getElementById('modalLecturerSearch').value.toLowerCase();
            const items = document.querySelectorAll('.modal-lecturer-item');
            
            items.forEach(item => {
                const id = item.dataset.id;
                const name = item.dataset.name.toLowerCase();
                const specialty = item.dataset.specialty.toLowerCase();
                
                // Block if it's a mentor for the current group
                if (currentMentorIds.includes(id)) {
                    item.style.display = 'none';
                    return;
                }

                if (name.includes(searchTerm) || specialty.includes(searchTerm)) {
                    item.style.display = 'flex';
                } else {
                    item.style.display = 'none';
                }
            });
        }

        function filterModalGroups() {
            const search = document.getElementById('modalGroupSearch').value.toLowerCase();
            document.querySelectorAll('.modal-group-item').forEach(item => {
                const name = item.dataset.name;
                const code = item.dataset.code;
                item.style.display = (name.includes(search) || code.includes(search)) ? 'flex' : 'none';
            });
        }
    </script>
}

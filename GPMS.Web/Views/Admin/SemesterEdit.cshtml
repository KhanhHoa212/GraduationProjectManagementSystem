@model GPMS.Web.ViewModels.EditSemesterViewModel
@{
    ViewData["Title"] = "Edit Semester";
    ViewData["BreadcrumbTitle"] = "Edit Semester";
    Layout = "_AdminLayout";
}

<div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center gap-3 mb-1">
            <a asp-action="SemesterIndex" class="p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-colors no-underline">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            </a>
            <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight">Edit Semester: @Model.SemesterCode</h1>
        </div>
        <p class="text-slate-500 text-sm ml-11">Update the details for this academic term.</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-xl overflow-hidden">
        <div class="p-8">
            <form asp-action="SemesterEdit" method="post" class="space-y-6">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="SemesterID" />
                <div asp-validation-summary="ModelOnly" class="p-4 text-sm text-red-700 bg-red-50 border border-red-200 rounded-xl"></div>

                <div>
                    <label asp-for="SemesterCode" class="block text-sm font-bold text-slate-700 mb-2">Semester Code</label>
                    <input asp-for="SemesterCode" 
                           class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" />
                    <span asp-validation-for="SemesterCode" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="AcademicYear" class="block text-sm font-bold text-slate-700 mb-2">Academic Year</label>
                    <input asp-for="AcademicYear" 
                           class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" />
                    <span asp-validation-for="AcademicYear" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="StartDate" class="block text-sm font-bold text-slate-700 mb-2">Start Date</label>
                        <input asp-for="StartDate" type="date" id="StartDate"
                               class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" />
                        <span asp-validation-for="StartDate" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="EndDate" class="block text-sm font-bold text-slate-700 mb-2">End Date</label>
                        <input asp-for="EndDate" type="date" id="EndDate"
                               class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" />
                        <span asp-validation-for="EndDate" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="Status" class="block text-sm font-bold text-slate-700 mb-2">Status (Auto-calculated)</label>
                    <select id="StatusDisplay" class="w-full px-4 py-3 bg-slate-100 border border-slate-200 rounded-xl focus:ring-0 outline-none transition-all appearance-none cursor-not-allowed"
                            asp-items="Html.GetEnumSelectList<GPMS.Domain.Enums.SemesterStatus>()" disabled>
                    </select>
                    <input type="hidden" asp-for="Status" id="StatusHidden" />
                    <p class="text-[11px] text-slate-400 mt-1.5 font-medium">Status is automatically determined based on the current date relative to the Start and End dates.</p>
                </div>

                <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
                    <a asp-action="SemesterIndex" class="px-6 py-3 text-sm font-bold text-slate-600 hover:bg-slate-50 rounded-xl transition-all no-underline">Cancel</a>
                    <button type="submit" class="px-8 py-3 bg-primary hover:bg-orange-600 text-white text-sm font-bold rounded-xl shadow-lg shadow-primary/30 transition-all">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const startDateInput = document.getElementById('StartDate');
            const endDateInput = document.getElementById('EndDate');
            const statusSelect = document.getElementById('StatusDisplay');
            const hiddenStatus = document.getElementById('StatusHidden');

            function updateStatus() {
                const startStr = startDateInput.value;
                const endStr = endDateInput.value;
                
                if (!startStr || !endStr) return;

                const start = new Date(startStr);
                const end = new Date(endStr);
                const today = new Date();
                today.setHours(0, 0, 0, 0);

                let status = '1'; // Active
                if (today < start) {
                    status = '0'; // Upcoming
                } else if (today > end) {
                    status = '2'; // Closed
                }
                
                statusSelect.value = status;
                if (hiddenStatus) hiddenStatus.value = status;

                // Duration hint
                const startMonths = start.getFullYear() * 12 + start.getMonth();
                const endMonths = end.getFullYear() * 12 + end.getMonth();
                const monthDiff = endMonths - startMonths;
                
                const existingHint = document.getElementById('duration-hint');
                if (existingHint) existingHint.remove();

                const hint = document.createElement('p');
                hint.id = 'duration-hint';
                hint.className = 'text-[11px] mt-1 font-medium';
                
                if (monthDiff < 3 || monthDiff > 4) {
                    hint.textContent = `Current duration: ~${monthDiff} months (Must be 3-4 months)`;
                    hint.className += ' text-red-500';
                } else {
                    hint.textContent = `Current duration: ~${monthDiff} months (Valid range)`;
                    hint.className += ' text-green-600';
                }
                endDateInput.parentNode.appendChild(hint);
            }

            startDateInput.addEventListener('change', updateStatus);
            endDateInput.addEventListener('change', updateStatus);

            // Initial run
            if (startDateInput.value && endDateInput.value) {
                updateStatus();
            }
        });
    </script>
}

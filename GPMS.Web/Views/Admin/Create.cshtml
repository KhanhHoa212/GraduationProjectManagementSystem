@model GPMS.Web.ViewModels.EditUserViewModel
@{
    ViewData["Title"] = "Create User";
    ViewData["BreadcrumbTitle"] = "Create User";
    Layout = "_AdminLayout";
}

<div class="max-w-3xl mx-auto">
    <!-- Page Header -->
    <div class="mb-8">
        <div class="flex items-center gap-3 mb-1">
            <a asp-action="Index" class="p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-colors no-underline">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            </a>
            <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight">Create New User</h1>
        </div>
        <p class="text-slate-500 text-sm ml-11">Add a new user to the system with specific roles and permissions.</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <!-- Card Header -->
        <div class="px-8 py-5 border-b border-slate-100 bg-slate-50/50">
            <div class="flex items-center gap-3">
                <div class="size-10 rounded-xl bg-green-100 flex items-center justify-center text-green-600">
                    <span class="material-symbols-outlined">person_add</span>
                </div>
                <div>
                    <p class="text-sm font-bold text-slate-900">New User Account</p>
                    <p class="text-xs text-slate-500">Fill in all required fields marked with *</p>
                </div>
            </div>
        </div>

        <div class="p-8">
            <form asp-action="Create" method="post" class="space-y-6">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="p-4 text-sm text-red-700 bg-red-50 border border-red-200 rounded-xl" role="alert"></div>

                <!-- User ID -->
                <div>
                    <label asp-for="UserID" class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Student / User ID <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="UserID"
                           class="block w-full px-4 py-2.5 border border-slate-200 rounded-xl bg-slate-50 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all text-sm"
                           placeholder="e.g. DE000001" />
                    <span asp-validation-for="UserID" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Full Name -->
                <div>
                    <label asp-for="FullName" class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Full Name <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="FullName"
                           class="block w-full px-4 py-2.5 border border-slate-200 rounded-xl bg-slate-50 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all text-sm"
                           placeholder="e.g. Nguyen Van A" />
                    <span asp-validation-for="FullName" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Email & Phone -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label asp-for="Email" class="block text-sm font-semibold text-slate-700 mb-1.5">
                            Email Address <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[18px]">mail</span>
                            <input asp-for="Email"
                                   class="block w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-xl bg-slate-50 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all text-sm"
                                   placeholder="example@fpt.edu.vn" />
                        </div>
                        <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Phone" class="block text-sm font-semibold text-slate-700 mb-1.5">
                            Phone Number
                        </label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[18px]">phone</span>
                            <input asp-for="Phone"
                                   class="block w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-xl bg-slate-50 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all text-sm"
                                   placeholder="e.g. 0901234567" />
                        </div>
                        <span asp-validation-for="Phone" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                </div>

                <!-- Account Status -->
                <div>
                    <label asp-for="Status" class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Account Status <span class="text-red-500">*</span>
                    </label>
                    <select asp-for="Status"
                            class="block w-full px-4 py-2.5 border border-slate-200 rounded-xl bg-slate-50 text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all text-sm"
                            asp-items="Html.GetEnumSelectList<GPMS.Domain.Enums.UserStatus>()">
                    </select>
                    <span asp-validation-for="Status" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Roles Section -->
                <div class="p-5 bg-slate-50 rounded-xl border border-slate-200">
                    <div class="flex items-center gap-2 mb-4">
                        <span class="material-symbols-outlined text-slate-600 text-[18px]">admin_panel_settings</span>
                        <label class="text-sm font-bold text-slate-900 uppercase tracking-wider">Roles &amp; Permissions</label>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <!-- Student -->
                        <label class="relative flex items-center gap-3 p-4 rounded-xl border-2 border-slate-200 bg-white hover:border-primary/50 transition-all cursor-pointer has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                            <input type="radio" asp-for="Role" value="Student" class="size-4 text-primary border-slate-300 focus:ring-primary/20" />
                            <div>
                                <span class="block text-sm font-semibold text-slate-700">Student</span>
                                <span class="block text-xs text-slate-400">Basic access</span>
                            </div>
                        </label>

                        <!-- Lecturer -->
                        <label class="relative flex items-center gap-3 p-4 rounded-xl border-2 border-slate-200 bg-white hover:border-primary/50 transition-all cursor-pointer has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                            <input type="radio" asp-for="Role" value="Lecturer" class="size-4 text-primary border-slate-300 focus:ring-primary/20" />
                            <div>
                                <span class="block text-sm font-semibold text-slate-700">Lecturer</span>
                                <span class="block text-xs text-slate-400">Supervisor access</span>
                            </div>
                        </label>

                        <!-- HeadOfDept -->
                        <label class="relative flex items-center gap-3 p-4 rounded-xl border-2 border-slate-200 bg-white hover:border-primary/50 transition-all cursor-pointer has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                            <input type="radio" asp-for="Role" value="HeadOfDept" class="size-4 text-primary border-slate-300 focus:ring-primary/20" />
                            <div>
                                <span class="block text-sm font-semibold text-slate-700">Head of Dept</span>
                                <span class="block text-xs text-slate-400">Department management</span>
                            </div>
                        </label>

                        <!-- Admin (locked) -->
                        <label class="relative flex items-center gap-3 p-4 rounded-xl border-2 border-slate-200 bg-slate-100 opacity-60 cursor-not-allowed">
                            <input type="radio" asp-for="Role" value="Admin" disabled class="size-4 text-slate-300 border-slate-300" />
                            <div>
                                <span class="block text-sm font-semibold text-slate-500">Administrator</span>
                                <span class="block text-[10px] text-orange-500 font-bold uppercase">System Protected</span>
                            </div>
                        </label>
                    </div>
                    <span asp-validation-for="Role" class="text-xs text-red-500 mt-2 block"></span>
                </div>

                <!-- Form Actions -->
                <div class="flex items-center justify-between pt-2">
                    <a asp-action="Index" class="flex items-center gap-2 text-slate-500 hover:text-slate-800 font-semibold text-sm transition-colors no-underline">
                        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                        Cancel
                    </a>
                    <button type="submit"
                            class="flex items-center gap-2 rounded-xl bg-primary hover:bg-orange-600 text-white px-8 py-2.5 text-sm font-bold transition-all shadow-lg shadow-primary/25">
                        <span class="material-symbols-outlined text-[18px]">person_add</span>
                        Create User
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const userIdInput = document.querySelector('input[name="UserID"]');
            const validationSpan = document.querySelector('span[data-valmsg-for="UserID"]');
            const roleRadios = document.querySelectorAll('input[name="Role"]');

            function validateUserID() {
                if (!userIdInput) return;
                
                let value = userIdInput.value;
                let selectedRole = document.querySelector('input[name="Role"]:checked')?.value;
                
                // Auto-capitalize
                let upperValue = value.toUpperCase();
                if (value !== upperValue) {
                    userIdInput.value = upperValue;
                    value = upperValue;
                }

                // Count leading letters
                let letterCount = 0;
                while (letterCount < value.length && /[a-zA-Z]/.test(value[letterCount])) {
                    letterCount++;
                }

                if (letterCount >= 3 && selectedRole !== "HeadOfDept") {
                    validationSpan.textContent = "chỉ HOD được sử dụng ID 3 kí tự";
                    validationSpan.classList.remove('field-validation-valid');
                    validationSpan.classList.add('field-validation-error');
                } else {
                    // If it was our custom message, clear it. 
                    if (validationSpan && validationSpan.textContent === "chỉ HOD được sử dụng ID 3 kí tự") {
                        validationSpan.textContent = "";
                    }
                }
            }

            if (userIdInput) {
                userIdInput.addEventListener('input', validateUserID);
            }

            roleRadios.forEach(radio => {
                radio.addEventListener('change', validateUserID);
            });
        });
    </script>
}

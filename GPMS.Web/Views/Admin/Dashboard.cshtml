@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<div class="max-w-7xl mx-auto">
    <!-- Header Section -->
    <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
        <div>
            <h2 class="text-2xl font-black tracking-tight text-slate-900">System Overview</h2>
            <p class="text-slate-500 text-sm">Real-time performance metrics for Graduation Project Management System</p>
        </div>
        <div class="flex gap-3">
            <a asp-action="Create" asp-controller="Admin" class="flex items-center gap-2 bg-primary text-white px-4 py-2 rounded-lg font-semibold hover:bg-orange-600 transition-all shadow-sm no-underline">
                <span class="material-symbols-outlined text-sm">add</span>
                Add New User
            </a>
            <button class="flex items-center gap-2 bg-white border border-slate-200 px-4 py-2 rounded-lg font-semibold hover:bg-slate-50 transition-all shadow-sm">
                <span class="material-symbols-outlined text-sm">download</span>
                Export Report
            </button>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
        <!-- Users KPI -->
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
            <div class="flex items-center justify-between mb-4">
                <span class="p-2 bg-blue-100 text-blue-600 rounded-lg material-symbols-outlined">groups</span>
                <span class="text-green-500 text-xs font-bold bg-green-50 px-2 py-1 rounded">+12%</span>
            </div>
            <p class="text-sm text-slate-500 font-medium">Total Active Users</p>
            <p class="text-3xl font-black mt-1">14,250</p>
            <div class="mt-4 flex gap-1 overflow-hidden h-1.5">
                <div class="w-[70%] bg-blue-500 rounded-full" title="Students"></div>
                <div class="w-[20%] bg-orange-500 rounded-full" title="Lecturers"></div>
                <div class="w-[10%] bg-slate-400 rounded-full" title="Admins"></div>
            </div>
            <div class="mt-2 flex justify-between text-[10px] uppercase font-bold text-slate-400">
                <span>Stud: 12k</span>
                <span>Lect: 2k</span>
                <span>Adm: 250</span>
            </div>
        </div>

        <!-- System Health -->
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
            <div class="flex items-center justify-between mb-4">
                <span class="p-2 bg-green-100 text-green-600 rounded-lg material-symbols-outlined">bolt</span>
                <span class="text-slate-500 text-xs font-bold bg-slate-50 px-2 py-1 rounded">Stable</span>
            </div>
            <p class="text-sm text-slate-500 font-medium">System Health</p>
            <p class="text-3xl font-black mt-1">99.98%</p>
            <p class="text-xs text-slate-400 mt-2 flex items-center gap-1">
                <span class="w-2 h-2 bg-green-500 rounded-full"></span> 
                All services operational
            </p>
        </div>

        <!-- Active Projects -->
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
            <div class="flex items-center justify-between mb-4">
                <span class="p-2 bg-primary/10 text-primary rounded-lg material-symbols-outlined">assignment</span>
                <span class="text-primary text-xs font-bold bg-primary/5 px-2 py-1 rounded">+8%</span>
            </div>
            <p class="text-sm text-slate-500 font-medium">Active Projects</p>
            <p class="text-3xl font-black mt-1">2,430</p>
            <p class="text-xs text-slate-400 mt-2 italic">Running in SP25 semester</p>
        </div>

        <!-- Alerts -->
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
            <div class="flex items-center justify-between mb-4">
                <span class="p-2 bg-red-100 text-red-600 rounded-lg material-symbols-outlined">warning</span>
                <span class="text-red-500 text-xs font-bold bg-red-50 px-2 py-1 rounded">Urgent</span>
            </div>
            <p class="text-sm text-slate-500 font-medium">Pending Alerts</p>
            <p class="text-3xl font-black mt-1">12</p>
            <p class="text-xs text-slate-400 mt-2 underline cursor-pointer">View support queue</p>
        </div>
    </div>

    <!-- Middle Section: Activity & Quick Actions -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
        <!-- Chart Section -->
        <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <div class="flex items-center justify-between mb-6">
                <h3 class="font-bold text-lg text-slate-800">User Login Activity</h3>
                <select class="text-sm bg-slate-50 border-slate-200 rounded-lg px-3 py-1.5 focus:ring-primary/30 outline-none">
                    <option>Last 30 Days</option>
                    <option>Last 7 Days</option>
                </select>
            </div>
            <div class="h-64 relative">
                <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 400 150">
                    <defs>
                        <linearGradient id="chartGradient" x1="0" x2="0" y1="0" y2="1">
                            <stop offset="0%" stop-color="#F27123" stop-opacity="0.3"></stop>
                            <stop offset="100%" stop-color="#F27123" stop-opacity="0"></stop>
                        </linearGradient>
                    </defs>
                    <path d="M0,120 Q20,110 40,115 T80,100 T120,80 T160,95 T200,60 T240,75 T280,45 T320,50 T360,30 T400,20 V150 H0 Z" fill="url(#chartGradient)"></path>
                    <path d="M0,120 Q20,110 40,115 T80,100 T120,80 T160,95 T200,60 T240,75 T280,45 T320,50 T360,30 T400,20" fill="none" stroke="#F27123" stroke-width="3"></path>
                </svg>
                <div class="absolute bottom-0 left-0 w-full flex justify-between text-[10px] text-slate-400 pt-4 font-bold border-t border-slate-100">
                    <span>DAY 1</span>
                    <span>DAY 10</span>
                    <span>DAY 20</span>
                    <span>DAY 30</span>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <h3 class="font-bold text-lg mb-6 text-slate-800">Quick Actions</h3>
            <div class="space-y-4">
                <a asp-action="Create" asp-controller="Admin" class="w-full flex items-center justify-between p-4 bg-slate-50 hover:bg-primary/5 hover:text-primary rounded-xl border border-transparent hover:border-primary/20 transition-all group no-underline">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-slate-400 group-hover:text-primary">person_add</span>
                        <span class="font-semibold text-sm text-slate-700 group-hover:text-primary">Add New User</span>
                    </div>
                    <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">chevron_right</span>
                </a>
                <button class="w-full flex items-center justify-between p-4 bg-slate-50 hover:bg-primary/5 hover:text-primary rounded-xl border border-transparent hover:border-primary/20 transition-all group text-left">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-slate-400 group-hover:text-primary">cloud_download</span>
                        <span class="font-semibold text-sm text-slate-700 group-hover:text-primary">Export Report</span>
                    </div>
                    <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">chevron_right</span>
                </button>
                <div class="pt-4 mt-4 border-t border-slate-100">
                    <p class="text-xs font-bold text-slate-400 uppercase mb-4 tracking-wider">Support Shortlinks</p>
                    <div class="grid grid-cols-3 gap-2">
                        <div class="text-center py-2 bg-slate-50 rounded-lg text-xs font-bold text-slate-600 hover:bg-slate-100 cursor-pointer transition-colors">Docs</div>
                        <div class="text-center py-2 bg-slate-50 rounded-lg text-xs font-bold text-slate-600 hover:bg-slate-100 cursor-pointer transition-colors">Help</div>
                        <div class="text-center py-2 bg-slate-50 rounded-lg text-xs font-bold text-slate-600 hover:bg-slate-100 cursor-pointer transition-colors">Status</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Logs Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/30">
            <h3 class="font-bold text-lg text-slate-800">Recent System Logs</h3>
            <button class="text-primary text-sm font-bold hover:underline">View All Logs</button>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-slate-50 text-slate-400 text-[10px] font-bold uppercase tracking-wider">
                    <tr>
                        <th class="px-6 py-4">Admin Action</th>
                        <th class="px-6 py-4">User Target</th>
                        <th class="px-6 py-4">Timestamp</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Reference</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-blue-500 bg-blue-50 p-1.5 rounded-lg text-sm">person_add</span>
                                <span class="text-sm font-medium text-slate-700">New student account created</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm font-bold text-slate-900">DE170042 - Nguyen Van A</td>
                        <td class="px-6 py-4 text-sm text-slate-500">2 minutes ago</td>
                        <td class="px-6 py-4">
                            <span class="px-2.5 py-1 rounded-full text-[10px] font-bold bg-green-100 text-green-700 uppercase">Success</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <span class="text-slate-400 text-xs font-mono">#LOG-82910</span>
                        </td>
                    </tr>
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-orange-500 bg-orange-50 p-1.5 rounded-lg text-sm">update</span>
                                <span class="text-sm font-medium text-slate-700">Semester SP25 dates updated</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm font-bold text-slate-900">System / Semester Config</td>
                        <td class="px-6 py-4 text-sm text-slate-500">45 minutes ago</td>
                        <td class="px-6 py-4">
                            <span class="px-2.5 py-1 rounded-full text-[10px] font-bold bg-green-100 text-green-700 uppercase">Success</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <span class="text-slate-400 text-xs font-mono">#LOG-82909</span>
                        </td>
                    </tr>
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-red-500 bg-red-50 p-1.5 rounded-lg text-sm">shield</span>
                                <span class="text-sm font-medium text-slate-700">Failed login attempt detected</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm font-bold text-slate-900">Lecturer - 14.23.112.5</td>
                        <td class="px-6 py-4 text-sm text-slate-500">1 hour ago</td>
                        <td class="px-6 py-4">
                            <span class="px-2.5 py-1 rounded-full text-[10px] font-bold bg-red-100 text-red-700 uppercase">Blocked</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <span class="text-slate-400 text-xs font-mono">#LOG-82908</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

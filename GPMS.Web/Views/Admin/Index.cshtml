@model IEnumerable<GPMS.Web.ViewModels.UserViewModel>
@{
    ViewData["Title"] = "User Management";
    ViewData["BreadcrumbTitle"] = "User Management";
    Layout = "_AdminLayout";
}

<div class="max-w-7xl mx-auto">
    <!-- Page Header -->
    <div class="flex flex-wrap justify-between items-start gap-6 mb-8">
        <div>
            <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight">User Management</h1>
            <p class="text-slate-500 text-sm mt-1">Manage access, roles, and status for students, lecturers, and staff.</p>
        </div>
        <a asp-action="Create"
           class="flex items-center gap-2 rounded-xl bg-primary hover:bg-orange-600 text-white px-5 py-2.5 text-sm font-bold transition-all shadow-lg shadow-primary/25 no-underline">
            <span class="material-symbols-outlined text-[18px]">add</span>
            <span>Add New User</span>
        </a>
    </div>

    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl flex items-center gap-3">
            <span class="material-symbols-outlined text-green-500">check_circle</span>
            <p class="text-sm text-green-700 font-medium">@TempData["SuccessMessage"]</p>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl flex items-center gap-3">
            <span class="material-symbols-outlined text-red-500">error</span>
            <p class="text-sm text-red-700 font-medium">@TempData["ErrorMessage"]</p>
        </div>
    }

    <!-- Filters & Search Bar -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 mb-5">
        <div class="flex flex-col md:flex-row gap-3 items-center">
            <!-- Search -->
            <div class="relative flex-1 w-full">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[18px]">search</span>
                <input type="text"
                       placeholder="Search by name, email, or ID..."
                       class="w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all" />
            </div>
            <!-- Role Filter -->
            <div class="flex items-center gap-2">
                <select class="px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary pr-8">
                    <option>All Roles</option>
                    <option>Admin</option>
                    <option>Lecturer</option>
                    <option>Student</option>
                </select>
                <select class="px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary pr-8">
                    <option>All Status</option>
                    <option>Active</option>
                    <option>Inactive</option>
                </select>
                <button class="flex items-center gap-2 px-4 py-2.5 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-orange-600 transition-all">
                    <span class="material-symbols-outlined text-[16px]">tune</span>
                    Apply
                </button>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200">
                        <th class="py-3.5 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">
                            <input type="checkbox" class="rounded border-slate-300" />
                        </th>
                        <th class="py-3.5 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">User</th>
                        <th class="py-3.5 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">Email Address</th>
                        <th class="py-3.5 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">Role</th>
                        <th class="py-3.5 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider">SSO Status</th>
                        <th class="py-3.5 px-6 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var user in Model)
                    {
                        var isAdmin = user.Roles.Contains("Admin");
                        <tr class="group hover:bg-slate-50/70 transition-colors">
                            <td class="py-4 px-6">
                                <input type="checkbox" class="rounded border-slate-300" />
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-3">
                                    <div class="size-9 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold text-sm flex-shrink-0 group-hover:bg-primary group-hover:text-white transition-all">
                                        @user.FullName.Substring(0, Math.Min(2, user.FullName.Length)).ToUpper()
                                    </div>
                                    <div>
                                        <p class="text-sm font-semibold text-slate-900">@user.FullName</p>
                                        <p class="text-xs text-slate-400">ID: @user.UserID</p>
                                    </div>
                                </div>
                            </td>
                            <td class="py-4 px-6 text-sm text-slate-600">@user.Email</td>
                            <td class="py-4 px-6">
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var role in user.Roles)
                                    {
                                        var roleClass = role switch
                                        {
                                            "Admin" => "bg-orange-100 text-orange-700 border border-orange-200",
                                            "Lecturer" => "bg-purple-100 text-purple-700 border border-purple-200",
                                            "Student" => "bg-blue-100 text-blue-700 border border-blue-200",
                                            _ => "bg-slate-100 text-slate-600 border border-slate-200"
                                        };
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold @roleClass">
                                            @role
                                        </span>
                                    }
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-2">
                                    <div class="size-2 rounded-full @(user.Status == GPMS.Domain.Enums.UserStatus.Active ? "bg-green-500" : "bg-slate-300")"></div>
                                    <span class="text-sm @(user.Status == GPMS.Domain.Enums.UserStatus.Active ? "text-green-600 font-medium" : "text-slate-400")">
                                        @user.Status
                                    </span>
                                </div>
                            </td>
                            <td class="py-4 px-6 text-right">
                                <div class="flex items-center justify-end gap-1">
                                    <a asp-action="Edit" asp-route-id="@user.UserID"
                                       class="p-2 text-slate-400 hover:text-secondary hover:bg-secondary/10 transition-colors rounded-lg no-underline" title="Edit User">
                                        <span class="material-symbols-outlined text-[18px]">edit</span>
                                    </a>

                                    @if (!isAdmin)
                                    {
                                        <form asp-action="ToggleStatus" asp-route-id="@user.UserID" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="p-2 text-slate-400 hover:text-red-500 transition-colors rounded-lg hover:bg-red-50"
                                                    title="@(user.Status == GPMS.Domain.Enums.UserStatus.Active ? "Deactivate" : "Activate")">
                                                <span class="material-symbols-outlined text-[18px]">
                                                    @(user.Status == GPMS.Domain.Enums.UserStatus.Active ? "block" : "check_circle")
                                                </span>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="p-2 text-slate-300 cursor-not-allowed" disabled title="Admin cannot be deactivated">
                                            <span class="material-symbols-outlined text-[18px]">shield</span>
                                        </button>
                                    }

                                    <button class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors rounded-lg">
                                        <span class="material-symbols-outlined text-[18px]">more_vert</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex items-center justify-between">
            <span class="text-sm text-slate-500">
                Showing <span class="font-semibold text-slate-900">1</span> to
                <span class="font-semibold text-slate-900">@Model.Count()</span> of
                <span class="font-semibold text-slate-900">@Model.Count()</span> results
            </span>
            <div class="flex items-center gap-2">
                <button class="px-3 py-1.5 bg-white border border-slate-200 rounded-lg text-sm font-medium text-slate-400 cursor-not-allowed">
                    &larr; Previous
                </button>
                <button class="px-3 py-1.5 bg-white border border-slate-200 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-50 transition-colors">
                    Next &rarr;
                </button>
            </div>
        </div>
    </div>
</div>

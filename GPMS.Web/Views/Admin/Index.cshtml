@model IEnumerable<GPMS.Web.ViewModels.UserViewModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="px-4 sm:px-10 py-8">
    <!-- Breadcrumbs -->
    <div class="flex flex-wrap gap-2 py-2 mb-6 items-center">
        <a class="text-[#4c669a] dark:text-gray-400 hover:text-primary text-sm font-medium no-underline" asp-controller="Home" asp-action="Index">Home</a>
        <span class="material-symbols-outlined text-[#4c669a] dark:text-gray-500 text-sm">chevron_right</span>
        <span class="text-[#0d121b] dark:text-white text-sm font-medium">User Management</span>
    </div>

    <!-- Page Heading & Primary Action -->
    <div class="flex flex-wrap justify-between items-end gap-6 mb-8">
        <div class="flex flex-col gap-2">
            <h1 class="text-[#0d121b] dark:text-white text-3xl font-bold leading-tight tracking-tight">User Management</h1>
            <p class="text-[#4c669a] dark:text-gray-400 text-base font-normal">Manage access, roles, and status for students, lecturers, and staff.</p>
        </div>
        <a asp-action="Create" class="flex items-center justify-center gap-2 rounded-lg bg-primary hover:bg-[#d95d12] text-white h-10 px-5 text-sm font-bold transition-all shadow-sm no-underline">
            <span class="material-symbols-outlined text-[20px]">add</span>
            <span>Add New User</span>
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg flex items-start gap-3">
            <span class="material-symbols-outlined text-green-500 text-xl">check_circle</span>
            <p class="text-sm text-green-700 font-medium">@TempData["SuccessMessage"]</p>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg flex items-start gap-3">
            <span class="material-symbols-outlined text-red-500 text-xl">error</span>
            <p class="text-sm text-red-700 font-medium">@TempData["ErrorMessage"]</p>
        </div>
    }

    <!-- Data Table -->
    <div class="bg-white dark:bg-[#1a2230] rounded-xl shadow-sm border border-[#e7ebf3] dark:border-gray-800 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-[#f8f9fc] dark:bg-gray-800/50 border-b border-[#e7ebf3] dark:border-gray-700">
                        <th class="py-4 px-6 text-xs font-semibold uppercase tracking-wider text-[#4c669a] dark:text-gray-400">User</th>
                        <th class="py-4 px-6 text-xs font-semibold uppercase tracking-wider text-[#4c669a] dark:text-gray-400">Email Address</th>
                        <th class="py-4 px-6 text-xs font-semibold uppercase tracking-wider text-[#4c669a] dark:text-gray-400">Role</th>
                        <th class="py-4 px-6 text-xs font-semibold uppercase tracking-wider text-[#4c669a] dark:text-gray-400">Status</th>
                        <th class="py-4 px-6 text-xs font-semibold uppercase tracking-wider text-[#4c669a] dark:text-gray-400 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#e7ebf3] dark:divide-gray-700">
                    @foreach (var user in Model)
                    {
                        var isAdmin = user.Roles.Contains("Admin");
                        <tr class="group hover:bg-[#f8f9fc] dark:hover:bg-gray-800/30 transition-colors">
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-3">
                                    <div class="size-9 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold text-sm shadow-sm group-hover:bg-primary group-hover:text-white transition-all">
                                        @user.FullName.Substring(0, Math.Min(2, user.FullName.Length)).ToUpper()
                                    </div>
                                    <div>
                                        <p class="text-sm font-semibold text-[#0d121b] dark:text-white">@user.FullName</p>
                                        <p class="text-xs text-[#4c669a] dark:text-gray-500">ID: @user.UserID</p>
                                    </div>
                                </div>
                            </td>
                            <td class="py-4 px-6 text-sm text-[#0d121b] dark:text-gray-300">@user.Email</td>
                            <td class="py-4 px-6">
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var role in user.Roles)
                                    {
                                        var roleClass = role switch {
                                            "Admin" => "bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300",
                                            "Lecturer" => "bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300",
                                            "Student" => "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300",
                                            _ => "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300"
                                        };
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @roleClass">
                                            @role
                                        </span>
                                    }
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-2">
                                    <div class="size-2 rounded-full @(user.Status == GPMS.Domain.Enums.UserStatus.Active ? "bg-green-500" : "bg-gray-400")"></div>
                                    <span class="text-sm @(user.Status == GPMS.Domain.Enums.UserStatus.Active ? "text-green-600 font-medium" : "text-[#4c669a] dark:text-gray-500")">
                                        @user.Status
                                    </span>
                                </div>
                            </td>
                            <td class="py-4 px-6 text-right">
                                <div class="flex items-center justify-end gap-1">
                                    <a asp-action="Edit" asp-route-id="@user.UserID" class="p-2 text-[#4c669a] hover:text-primary dark:text-gray-400 dark:hover:text-white transition-colors rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700" title="Edit">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </a>
                                    
                                    @if (!isAdmin)
                                    {
                                        <form asp-action="ToggleStatus" asp-route-id="@user.UserID" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="p-2 text-[#4c669a] hover:text-red-500 dark:text-gray-400 transition-colors rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20" 
                                                    title="@(user.Status == GPMS.Domain.Enums.UserStatus.Active ? "Deactivate" : "Activate")">
                                                <span class="material-symbols-outlined text-[20px]">
                                                    @(user.Status == GPMS.Domain.Enums.UserStatus.Active ? "block" : "check_circle")
                                                </span>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="p-2 text-gray-300 dark:text-gray-600 cursor-not-allowed" disabled title="Admin cannot be deactivated">
                                            <span class="material-symbols-outlined text-[20px]">shield</span>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

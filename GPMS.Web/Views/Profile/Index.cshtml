@model GPMS.Web.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="max-w-4xl mx-auto py-10 px-4">
    <!-- Breadcrumb -->
    <nav class="flex mb-8 text-sm font-medium text-slate-400" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li class="inline-flex items-center">
                <a asp-controller="Home" asp-action="Index" class="hover:text-primary transition-colors no-underline flex items-center">
                    <span class="material-symbols-outlined text-sm mr-2">home</span>
                    Home
                </a>
            </li>
            <li>
                <div class="flex items-center">
                    <span class="material-symbols-outlined text-sm mx-1">chevron_right</span>
                    <span class="text-slate-600 font-bold ml-1 md:ml-2">Profile</span>
                </div>
            </li>
        </ol>
    </nav>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 p-4 bg-green-50 border-l-4 border-green-500 rounded-r-lg flex items-center justify-between shadow-sm animate-in fade-in slide-in-from-top duration-300">
            <div class="flex items-center">
                <span class="material-symbols-outlined text-green-600 mr-3">check_circle</span>
                <p class="text-green-800 font-medium">@TempData["SuccessMessage"]</p>
            </div>
            <button type="button" class="text-green-600 hover:text-green-800" onclick="this.parentElement.remove()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
    }

    <div class="bg-white rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden">
        <!-- Header/Cover -->
        <div class="h-32 bg-gradient-to-r from-primary to-orange-400 relative"></div>
        
        <div class="px-8 pb-8 relative">
            <!-- Profile Picture -->
            <div class="absolute -top-16 left-8">
                <div class="size-32 rounded-3xl border-4 border-white shadow-lg overflow-hidden bg-slate-100 flex items-center justify-center">
                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img src="@Model.AvatarUrl" alt="@Model.FullName" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-6xl text-slate-300">person</span>
                    }
                </div>
            </div>

            <!-- Profile Info Header -->
            <div class="pt-20 flex flex-wrap items-end justify-between gap-6">
                <div>
                    <h1 class="text-3xl font-black text-slate-900 tracking-tight">@Model.FullName</h1>
                    <div class="flex flex-wrap gap-2 mt-2">
                        @foreach (var role in Model.Roles)
                        {
                            <span class="px-3 py-1 bg-primary/10 text-primary text-xs font-bold rounded-full uppercase tracking-wider">@role</span>
                        }
                    </div>
                </div>
                <div class="flex gap-3">
                    <a asp-action="Edit" class="flex items-center gap-2 bg-primary text-black px-6 py-2.5 rounded-xl font-bold hover:bg-orange-600 transition-all shadow-md shadow-orange-200 no-underline">
                        <span class="material-symbols-outlined text-lg">edit</span>
                        Edit Profile
                    </a>
                </div>
            </div>

            <hr class="my-8 border-slate-100" />

            <!-- Details Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-6">
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">User Identification</p>
                        <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl border border-slate-100">
                            <span class="material-symbols-outlined text-slate-400">id_card</span>
                            <span class="text-slate-800 font-bold">@Model.UserID</span>
                        </div>
                    </div>

                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Email Address</p>
                        <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl border border-slate-100">
                            <span class="material-symbols-outlined text-slate-400">mail</span>
                            <span class="text-slate-700">@(Model.Email ?? "Not provided")</span>
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Phone Number</p>
                        <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl border border-slate-100">
                            <span class="material-symbols-outlined text-slate-400">call</span>
                            <span class="text-slate-700">@(Model.Phone ?? "Not provided")</span>
                        </div>
                    </div>

                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Account Status</p>
                        <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl border border-slate-100">
                            <span class="material-symbols-outlined text-green-500">check_circle</span>
                            <span class="text-green-700 font-bold">Active</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
